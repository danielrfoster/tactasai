---
import BaseLayout from "../layouts/BaseLayout.astro";
import HomePage from "../components/HomePage.astro";
import { getOrganization, getSiteUrl } from "../lib/site";

const siteUrl = getSiteUrl();
const title = "Tactas AI - AI Workflow Automation with Operational Control";
const description =
  "Tactas AI helps businesses build, monitor, and manage AI agents that run internal workflows, connect with business systems, track actions, explain decisions, and fit real operations.";
const organization = getOrganization();

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": `${siteUrl}/#website`,
      name: "Tactas AI",
      url: siteUrl,
      description:
        "AI workflow automation with full operational control for internal business processes, system integration, agent monitoring, and implementation support.",
      publisher: { "@id": `${siteUrl}/#organization` },
      inLanguage: "en-US",
    },
    organization,
    {
      "@type": "ProfessionalService",
      "@id": `${siteUrl}/#service`,
      name: "Tactas AI",
      url: siteUrl,
      description:
        "AI workflow automation, agent setup, workflow configuration, system integration, data preparation, monitoring, and operational support for business teams.",
      serviceType: [
        "AI workflow automation",
        "AI agent implementation",
        "Business system integration",
        "Workflow monitoring",
        "Operational AI support",
      ],
      areaServed: "Worldwide",
      provider: { "@id": `${siteUrl}/#organization` },
    },
  ],
};
---

<BaseLayout
  title={title}
  description={description}
  canonical="/"
  keywords={[
    "AI workflow automation",
    "AI agents for business operations",
    "business operations automation",
    "AI agent monitoring",
    "custom AI agents",
    "workflow automation support",
    "AI system integration",
    "operational control layer",
    "workflow automation for businesses",
  ]}
  openGraph={{
    title,
    description,
    type: "website",
    locale: "en_US",
    images: [
      {
        url: "/ef4e97cc-14e2-4157-a55f-42bfa62ad8a3.png",
        width: 1200,
        height: 630,
        alt: "Tactas AI - AI workflow automation with operational control",
      },
    ],
  }}
  twitter={{
    card: "summary_large_image",
    title,
    description,
    images: ["/ef4e97cc-14e2-4157-a55f-42bfa62ad8a3.png"],
  }}
  jsonLd={jsonLd}
>
  <HomePage siteUrl={siteUrl} currentPath="/" />
</BaseLayout>
