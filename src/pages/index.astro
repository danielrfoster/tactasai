---
import BaseLayout from "../layouts/BaseLayout.astro";
import HomePage from "../components/HomePage.astro";
import { getOrganization, getSiteUrl } from "../lib/site";

const siteUrl = getSiteUrl();
const title = "Tactas AI - Managed Agent Systems for Business Operations";
const description =
  "Tactas AI deploys managed AI agents that learn how your business works, turn company knowledge into action, improve work performance, and automate business tasks.";
const organization = getOrganization();

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": `${siteUrl}/#website`,
      name: "Tactas AI",
      url: siteUrl,
      description:
        "Managed AI agents for business operations that turn company knowledge, business context, and connected tools into outputs, updates, and automated actions.",
      publisher: { "@id": `${siteUrl}/#organization` },
      inLanguage: "en-US",
    },
    organization,
    {
      "@type": "ProfessionalService",
      "@id": `${siteUrl}/#service`,
      name: "Tactas AI",
      url: siteUrl,
      description:
        "Managed agent systems for business operations, business task automation, company knowledge automation, connected business tools, and AI operating layers for work performance.",
      serviceType: [
        "Managed agent systems",
        "Managed AI agents",
        "AI agents for business operations",
        "Business task automation",
        "Company knowledge automation",
        "AI operating layer",
        "Connected business tools",
        "Work performance support",
        "Automated business tasks",
        "Business context automation",
      ],
      areaServed: "Worldwide",
      provider: { "@id": `${siteUrl}/#organization` },
    },
  ],
};
---

<BaseLayout
  title={title}
  description={description}
  canonical="/"
  currentPath="/"
  navbarTheme="light"
  navbarCtaLabel="Task review"
  keywords={[
    "managed agent systems",
    "managed AI agents",
    "AI agents for business operations",
    "business task automation",
    "automated business tasks",
    "company knowledge automation",
    "company knowledge into action",
    "AI operating layer",
    "connected business tools",
    "business operations automation",
    "work performance AI",
    "AI task automation",
    "business context automation",
    "AI agents for work productivity",
    "AI agents that automate business tasks",
    "business productivity automation",
    "AI agents for company knowledge",
    "business tools AI automation",
    "managed AI agent systems",
    "AI automation for business tasks",
  ]}
  openGraph={{
    title,
    description,
    type: "website",
    locale: "en_US",
    images: [
      {
        url: "/ef4e97cc-14e2-4157-a55f-42bfa62ad8a3.png",
        width: 1200,
        height: 630,
        alt: "Tactas AI - Managed AI agents for business task automation",
      },
    ],
  }}
  twitter={{
    card: "summary_large_image",
    title,
    description,
    images: ["/ef4e97cc-14e2-4157-a55f-42bfa62ad8a3.png"],
  }}
  jsonLd={jsonLd}
>
  <HomePage siteUrl={siteUrl} currentPath="/" />
</BaseLayout>
