---
import BaseLayout from "../layouts/BaseLayout.astro";
import HomePage from "../components/HomePage.astro";
import { getOrganization, getSiteUrl } from "../lib/site";

const siteUrl = getSiteUrl();
const title = "Tactas AI - Managed Agent Systems for Business Operations";
const description =
  "Tactas AI helps businesses delegate repetitive support, admin, and back-office work to AI operators from request to resolution.";
const organization = getOrganization();

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": `${siteUrl}/#website`,
      name: "Tactas AI",
      url: siteUrl,
      description:
        "AI operators for repetitive support, admin, finance, and back-office work with system integration, approvals, decision visibility, monitoring, and implementation support.",
      publisher: { "@id": `${siteUrl}/#organization` },
      inLanguage: "en-US",
    },
    organization,
    {
      "@type": "ProfessionalService",
      "@id": `${siteUrl}/#service`,
      name: "Tactas AI",
      url: siteUrl,
      description:
        "AI operator setup, workflow configuration, system integration, data preparation, action logging, decision explanation, monitoring, and operational support for business operations teams.",
      serviceType: [
        "AI operator implementation",
        "AI operators for business operations",
        "Delegated AI work",
        "AI workflow automation",
        "AI operator implementation",
        "AI customer support automation",
        "AI back-office automation",
        "Business system integration",
        "AI operator monitoring",
        "Decision visibility",
        "Operational AI support",
      ],
      areaServed: "Worldwide",
      provider: { "@id": `${siteUrl}/#organization` },
    },
  ],
};
---

<BaseLayout
  title={title}
  description={description}
  canonical="/"
  currentPath="/"
  navbarTheme="light"
  navbarCtaLabel="Operator review"
  keywords={[
    "AI operators",
    "AI operators for business operations",
    "delegate work to AI",
    "delegated AI work",
    "AI workflow automation",
    "AI operator workflow automation",
    "AI operators that complete workflows",
    "business operations automation",
    "AI operations automation",
    "AI customer support automation",
    "AI back-office automation",
    "AI admin workflow automation",
    "AI operator monitoring",
    "AI operator control layer",
    "custom AI operators",
    "AI operator implementation",
    "workflow automation support",
    "AI system integration",
    "operational control layer",
    "workflow automation for businesses",
  ]}
  openGraph={{
    title,
    description,
    type: "website",
    locale: "en_US",
    images: [
      {
        url: "/ef4e97cc-14e2-4157-a55f-42bfa62ad8a3.png",
        width: 1200,
        height: 630,
        alt: "Tactas AI - AI operators for business operations",
      },
    ],
  }}
  twitter={{
    card: "summary_large_image",
    title,
    description,
    images: ["/ef4e97cc-14e2-4157-a55f-42bfa62ad8a3.png"],
  }}
  jsonLd={jsonLd}
>
  <HomePage siteUrl={siteUrl} currentPath="/" />
</BaseLayout>
