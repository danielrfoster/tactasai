---
import BaseLayout from "../layouts/BaseLayout.astro";
import HomePage from "../components/HomePage.astro";
import { getOrganization, getSiteUrl } from "../lib/site";

const siteUrl = getSiteUrl();
const title = "TactasAI - AI Agents Built for the Way Your Business Works";
const description =
  "TactasAI deploys managed AI agents that learn your company context, work with your team, and turn business knowledge into useful outputs and action.";
const organization = getOrganization();

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": `${siteUrl}/#website`,
      name: "Tactas AI",
      url: siteUrl,
      description:
        "Managed AI agents that learn company context, work with teams, and turn business knowledge into useful outputs and action.",
      publisher: { "@id": `${siteUrl}/#organization` },
      inLanguage: "en-US",
    },
    organization,
    {
      "@type": "ProfessionalService",
      "@id": `${siteUrl}/#service`,
      name: "Tactas AI",
      url: siteUrl,
      description:
        "Managed agent systems for business operations, business task automation, company knowledge automation, connected business tools, and AI operating layers for work performance.",
      serviceType: [
        "Managed agent systems",
        "Managed AI agents",
        "AI agents for business operations",
        "Business task automation",
        "Company knowledge automation",
        "AI operating layer",
        "Connected business tools",
        "Work performance support",
        "Automated business tasks",
        "Business context automation",
      ],
      areaServed: "Worldwide",
      provider: { "@id": `${siteUrl}/#organization` },
    },
  ],
};
---

<BaseLayout
  title={title}
  description={description}
  canonical="/"
  currentPath="/"
  navbarTheme="light"
  navbarCtaLabel="Book a review"
  keywords={[
    "managed agent systems",
    "managed AI agents",
    "AI agents for business operations",
    "business task automation",
    "automated business tasks",
    "company knowledge automation",
    "company knowledge into action",
    "AI operating layer",
    "connected business tools",
    "business operations automation",
    "work performance AI",
    "AI task automation",
    "business context automation",
    "AI agents for work productivity",
    "AI agents that automate business tasks",
    "business productivity automation",
    "AI agents for company knowledge",
    "business tools AI automation",
    "managed AI agent systems",
    "AI automation for business tasks",
  ]}
  openGraph={{
    title,
    description,
    type: "website",
    locale: "en_US",
    images: [
      {
        url: "/tactas-ai-managed-agent-systems-og.jpg",
        width: 1734,
        height: 907,
        alt: "Tactas AI - Managed AI agents for business task automation",
      },
    ],
  }}
  twitter={{
    card: "summary_large_image",
    title,
    description,
    images: ["/tactas-ai-managed-agent-systems-og.jpg"],
  }}
  jsonLd={jsonLd}
>
  <HomePage siteUrl={siteUrl} currentPath="/" />
</BaseLayout>
