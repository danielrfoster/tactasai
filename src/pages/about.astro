---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getBrandEmail, getOrganization, getSiteUrl } from "../lib/site";

const siteUrl = getSiteUrl();
const brandEmail = getBrandEmail();
const organization = getOrganization();
const updatedAt = "May 7, 2026";

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "AboutPage",
      "@id": `${siteUrl}/about#aboutpage`,
      name: "About Tactas AI",
      url: `${siteUrl}/about`,
      isPartOf: { "@id": `${siteUrl}/#website` },
      about: { "@id": `${siteUrl}/#organization` },
    },
    organization,
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Home", item: `${siteUrl}/` },
        { "@type": "ListItem", position: 2, name: "About", item: `${siteUrl}/about` },
      ],
    },
  ],
};
---

<BaseLayout
  title="About Tactas AI"
  description="Learn about Tactas AI, our mission, operating model, and the principles behind supervised multi-agent systems for business workflows."
  canonical="/about"
  jsonLd={jsonLd}
>
  <main class="min-h-screen bg-[#0b1220] py-20 text-[#f8fafc]">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-[#06B6D4]">About</p>
      <h1 class="mt-3 text-3xl font-bold tracking-tight text-[#f8fafc] sm:text-4xl">About Tactas AI</h1>
      <p class="mt-3 text-sm text-[#94a3b8]">Last updated: {updatedAt}</p>

      <div class="mt-10 space-y-8 text-sm leading-relaxed text-[#94a3b8]">
        <section>
          <h2 class="text-lg font-semibold text-[#f8fafc]">Who we are</h2>
          <p class="mt-2">
            Tactas AI is an operations-focused AI studio. We design and deploy supervised multi-agent systems that help
            teams execute repetitive workflows with consistent quality, clear approvals, and full traceability.
          </p>
        </section>

        <section>
          <h2 class="text-lg font-semibold text-[#f8fafc]">What we build</h2>
          <p class="mt-2">
            We build company-specific systems that connect to your existing tools, enforce your SOPs and guardrails,
            and route sensitive decisions to humans when judgment is required.
          </p>
        </section>

        <section>
          <h2 class="text-lg font-semibold text-[#f8fafc]">How we operate</h2>
          <ul class="mt-3 list-disc space-y-2 pl-5">
            <li>Workflow-first design: map real operational steps before automation.</li>
            <li>Approval-aware execution: high-impact actions always respect escalation paths.</li>
            <li>Audit-ready delivery: every action is logged for review and compliance.</li>
            <li>Human-in-the-loop by default: exceptions are escalated with context.</li>
          </ul>
        </section>

        <section>
          <h2 class="text-lg font-semibold text-[#f8fafc]">Who we work with</h2>
          <p class="mt-2">
            We support teams in support operations, SaaS operations, finance operations, and back-office workflows where
            repetitive tasks and cross-tool coordination create execution bottlenecks.
          </p>
        </section>

        <section>
          <h2 class="text-lg font-semibold text-[#f8fafc]">Contact</h2>
          <p class="mt-2">
            To discuss your workflow, send details to <a class="text-[#06B6D4] hover:text-[#22D3EE]" href={`mailto:${brandEmail}`}>{brandEmail}</a>
            {" "}or go back to the <a class="text-[#06B6D4] hover:text-[#22D3EE]" href="/#contact">contact section</a>.
          </p>
        </section>
      </div>

      <div class="mt-12 border-t border-[#1e293b] pt-6 text-xs text-[#64748b]">
        <a href="/" class="transition hover:text-[#cbd5e1]">Back to home</a>
      </div>
    </div>
  </main>
</BaseLayout>
