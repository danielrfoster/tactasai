---
import { ArrowRight, BrainCircuit, Check, Network, Sparkles } from "@lucide/astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getBrandEmail, getOrganization, getSiteUrl } from "../lib/site";

const siteUrl = getSiteUrl();
const brandEmail = getBrandEmail();
const organization = getOrganization();
const updatedAt = "May 28, 2026";

const principles = [
  ["Company knowledge into action", "AI should not stop at search. It should help prepare answers, outputs, updates, next steps, and automated actions."],
  ["Managed agents for real work", "Agents need business context, connected tools, clear task patterns, and ongoing improvement."],
  ["Start with one task", "The best deployment begins with a repeated business task where the output is clear and measurable."],
];

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "AboutPage",
      "@id": `${siteUrl}/about#aboutpage`,
      name: "About Tactas AI",
      url: `${siteUrl}/about`,
      isPartOf: { "@id": `${siteUrl}/#website` },
      about: { "@id": `${siteUrl}/#organization` },
    },
    organization,
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Home", item: `${siteUrl}/` },
        { "@type": "ListItem", position: 2, name: "About", item: `${siteUrl}/about` },
      ],
    },
  ],
};
---

<BaseLayout
  title="About Tactas AI"
  description="Learn how TactasAI deploys managed AI agents that learn company context, work with teams, and turn business knowledge into useful outputs and action."
  canonical="/about"
  currentPath="/about"
  navbarTheme="light"
  navbarCtaLabel="Book a review"
  jsonLd={jsonLd}
>
  <main class="min-h-screen bg-tactas-bg text-tactas-ink">
    <section class="relative overflow-hidden border-b border-tactas-line bg-tactas-bg">
      <div class="pointer-events-none absolute inset-x-0 top-0 h-px tactas-gradient-rule"></div>
      <div class="mx-auto grid w-full max-w-[1240px] items-center gap-10 px-5 py-16 sm:px-8 lg:grid-cols-[0.92fr_1.08fr] lg:px-10 lg:py-20">
        <div>
          <div class="mb-8 inline-flex items-center rounded-full bg-tactas-accent px-4 py-2 text-[14px] font-medium text-white shadow-[0_14px_32px_-24px_rgba(6,174,234,0.9)]">
            About Tactas AI
          </div>
          <h1 class="max-w-[820px] text-[clamp(3.4rem,8vw,6.4rem)] font-semibold leading-[0.94] tracking-normal text-tactas-ink-strong">
            Managed AI agents for business operations.
          </h1>
          <p class="mt-7 max-w-[44rem] text-[18px] leading-relaxed text-tactas-ink-strong/78">
            TactasAI deploys managed AI agents that learn company context, work with teams, and turn business knowledge into useful outputs and action across daily operations.
          </p>
          <p class="mt-4 text-sm text-tactas-muted-soft">Last updated: {updatedAt}</p>
        </div>

        <div class="border border-tactas-line bg-white p-6 shadow-[0_34px_100px_-72px_rgba(7,50,74,0.42)]">
          <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-tactas-muted-soft">Operating model</p>
          <div class="mt-6 grid gap-3">
            {[
              ["Learn", "Understand business context"],
              ["Use", "Apply company knowledge"],
              ["Prepare", "Create action-ready work"],
              ["Automate", "Move repeated tasks forward"],
            ].map(([label, body]) => (
              <div class="flex items-center gap-3 border border-tactas-line-soft bg-tactas-bg p-4">
                <span class="flex h-9 w-9 items-center justify-center rounded-[8px] border border-tactas-accent-line bg-tactas-accent-soft text-tactas-accent-strong">
                  <Sparkles class="h-4 w-4" stroke-width={1.9} />
                </span>
                <div>
                  <p class="text-[14px] font-semibold text-tactas-ink-strong">{label}</p>
                  <p class="mt-1 text-[13px] text-tactas-muted-soft">{body}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="border-b border-tactas-line bg-tactas-bg">
      <div class="mx-auto grid w-full max-w-[1240px] gap-10 px-5 py-16 sm:px-8 lg:grid-cols-[0.7fr_1.3fr] lg:px-10 lg:py-20">
        <div>
          <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-tactas-accent-strong">Principles</p>
          <h2 class="mt-4 text-[clamp(2.3rem,4vw,4rem)] font-semibold leading-tight tracking-normal text-tactas-ink-strong">
            Built around work, not AI theater.
          </h2>
        </div>
        <div class="grid gap-4">
          {principles.map(([title, body], index) => {
            const icons = [BrainCircuit, Network, Check];
            const Icon = icons[index] || Sparkles;
            return (
              <article class="border border-tactas-line bg-white p-6 shadow-[0_20px_60px_-54px_rgba(7,50,74,0.25)]">
                <Icon class="h-5 w-5 text-tactas-accent" stroke-width={1.9} />
                <h3 class="mt-5 text-[22px] font-semibold tracking-normal text-tactas-ink-strong">{title}</h3>
                <p class="mt-3 text-[15px] leading-relaxed text-tactas-muted">{body}</p>
              </article>
            );
          })}
        </div>
      </div>
    </section>

    <section class="bg-tactas-bg">
      <div class="tactas-container py-16 lg:py-20">
        <div class="grid gap-8 border border-tactas-line bg-white p-7 shadow-[0_34px_100px_-72px_rgba(7,50,74,0.42)] sm:p-9 lg:grid-cols-[1fr_320px] lg:items-center">
          <div>
            <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-tactas-accent-strong">Contact</p>
            <h2 class="mt-4 text-[clamp(2rem,4vw,3.6rem)] font-semibold leading-tight tracking-normal text-tactas-ink-strong">
              Start with one business task.
            </h2>
            <p class="mt-4 max-w-[42rem] text-[16px] leading-relaxed text-tactas-muted">
              Tell us about repeated work, company knowledge, and the tools involved. We will help map the first useful managed agent.
            </p>
          </div>
          <a href={`mailto:${brandEmail}`} class="inline-flex h-12 items-center justify-center rounded-[8px] bg-tactas-primary px-6 text-[14px] font-semibold text-white transition hover:bg-tactas-accent">
            Email Tactas
            <ArrowRight class="ml-2 h-4 w-4" stroke-width={2} />
          </a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
