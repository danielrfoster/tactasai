---
import { ArrowLeft, ArrowRight, CalendarDays, Check, Clock, Link2, Share2 } from "@lucide/astro";
import CTASection from "../../components/CTASection.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { blogPosts, getBlogPostBySlug } from "../../lib/blog";
import { getOrganization, getSiteUrl } from "../../lib/site";

export function getStaticPaths() {
  return blogPosts.map((post) => ({
    params: { slug: post.slug },
    props: { slug: post.slug },
  }));
}

interface Props {
  slug: string;
}

const { slug } = Astro.props;
const post = getBlogPostBySlug(slug);

if (!post) {
  throw new Error(`Blog post not found: ${slug}`);
}

const siteUrl = getSiteUrl();
const organization = getOrganization();
const pageUrl = `${siteUrl}/blog/${post.slug}`;
const formattedDate = new Date(`${post.publishedAt}T00:00:00`).toLocaleDateString("en-US", {
  month: "long",
  day: "numeric",
  year: "numeric",
});

const relatedPosts = blogPosts.filter((item) => item.slug !== post.slug).slice(0, 2);

const slugify = (text: string) =>
  text
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/(^-|-$)/g, "");

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    organization,
    {
      "@type": "BlogPosting",
      "@id": `${pageUrl}#blogposting`,
      headline: post.title,
      description: post.description,
      datePublished: post.publishedAt,
      dateModified: post.publishedAt,
      url: pageUrl,
      inLanguage: "en-US",
      author: { "@id": `${siteUrl}/#organization` },
      publisher: { "@id": `${siteUrl}/#organization` },
      mainEntityOfPage: { "@id": `${pageUrl}#webpage` },
      keywords: post.keywords,
    },
    {
      "@type": "WebPage",
      "@id": `${pageUrl}#webpage`,
      name: post.title,
      url: pageUrl,
      description: post.description,
      isPartOf: { "@id": `${siteUrl}/#website` },
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Home", item: `${siteUrl}/` },
        { "@type": "ListItem", position: 2, name: "Blog", item: `${siteUrl}/blog` },
        { "@type": "ListItem", position: 3, name: post.title, item: pageUrl },
      ],
    },
  ],
};
---

<BaseLayout
  title={`${post.title} | Tactas AI Blog`}
  description={post.description}
  canonical={`/blog/${post.slug}`}
  currentPath={`/blog/${post.slug}`}
  navbarTheme="light"
  navbarCtaLabel="Book a review"
  keywords={post.keywords}
  openGraph={{
    title: `${post.title} | Tactas AI Blog`,
    description: post.description,
    url: pageUrl,
    type: "article",
    images: [
      {
        url: "/tactas-ai-managed-agent-systems-og.jpg",
        width: 1734,
        height: 907,
        alt: post.title,
      },
    ],
  }}
  twitter={{ card: "summary_large_image", title: post.title, description: post.description, images: ["/tactas-ai-managed-agent-systems-og.jpg"] }}
  jsonLd={jsonLd}
>
  <div class="fixed left-0 right-0 top-0 z-[100] h-1 bg-transparent">
    <div id="reading-progress" class="h-full w-0 bg-[#0891B2] transition-all duration-75"></div>
  </div>

  <main class="min-h-screen bg-[#F7F8FA] text-[#111827] selection:bg-[#BAE6FD] selection:text-[#0F172A]">
    <article>
      <header class="border-b border-[#D8E1EA] bg-white">
        <div class="mx-auto w-full max-w-[1040px] px-5 py-14 sm:px-8 lg:px-10 lg:py-20 reveal">
          <a href="/blog" class="inline-flex items-center gap-2 text-[14px] font-semibold text-[#475569] transition hover:text-[#07324A]">
            <ArrowLeft class="h-4 w-4" stroke-width={2} />
            Back to blog
          </a>

          <div class="mt-10">
            <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.22em] text-[#0891B2]">{post.category}</p>
            <h1 class="mt-5 max-w-[920px] text-[clamp(2.2rem,5.2vw,4.5rem)] font-semibold leading-[1.04] tracking-normal text-[#07324A]">
              {post.title}
            </h1>
            <p class="mt-6 max-w-[760px] text-[18px] leading-relaxed text-[#475569] sm:text-[20px]">
              {post.summary}
            </p>
          </div>

          <div class="mt-10 flex flex-wrap items-center gap-x-5 gap-y-3 border-t border-[#E2E8F0] pt-6 text-[14px] text-[#64748B]">
            <span class="font-semibold text-[#07324A]">Tactas AI Editorial</span>
            <span class="hidden h-1 w-1 rounded-full bg-[#CBD5E1] sm:block" aria-hidden="true"></span>
            <span class="inline-flex items-center gap-1.5">
              <CalendarDays class="h-4 w-4" />
              {formattedDate}
            </span>
            <span class="hidden h-1 w-1 rounded-full bg-[#CBD5E1] sm:block" aria-hidden="true"></span>
            <span class="inline-flex items-center gap-1.5">
              <Clock class="h-4 w-4" />
              {post.readTime}
            </span>
          </div>
        </div>
      </header>

      <div class="mx-auto grid w-full max-w-[1120px] gap-10 px-5 py-12 sm:px-8 lg:grid-cols-[240px_minmax(0,760px)] lg:px-10 lg:py-16">
        <aside class="hidden lg:block">
          <div class="sticky top-28 space-y-8">
            <nav class="border-l border-[#D8E1EA] pl-5 reveal" data-delay="1" aria-label="Article outline">
              <p class="mb-4 text-[12px] font-semibold uppercase tracking-[0.16em] text-[#64748B]">In this article</p>
              <div class="space-y-3">
                {post.sections.map((section) => {
                  const sectionId = slugify(section.heading);
                  return (
                    <a
                      href={`#${sectionId}`}
                      data-toc-link={sectionId}
                      class="block text-[13px] font-medium leading-relaxed text-[#64748B] transition hover:text-[#07324A]"
                    >
                      {section.heading}
                    </a>
                  );
                })}
              </div>
            </nav>

            <div class="border-l border-[#D8E1EA] pl-5 reveal" data-delay="2">
              <p class="mb-4 inline-flex items-center gap-2 text-[12px] font-semibold uppercase tracking-[0.16em] text-[#64748B]">
                <Share2 class="h-3.5 w-3.5" />
                Share
              </p>
              <div class="flex items-center gap-2">
                <button
                  type="button"
                  id="share-linkedin"
                  data-share-url={pageUrl}
                  class="flex h-9 w-9 items-center justify-center border border-[#D8E1EA] bg-white text-[#475569] transition hover:border-[#94A3B8] hover:text-[#07324A]"
                  title="Share on LinkedIn"
                >
                  <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path fill-rule="evenodd" d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" clip-rule="evenodd"></path>
                  </svg>
                </button>
                <button
                  type="button"
                  id="copy-link"
                  data-copy-url={pageUrl}
                  class="relative flex h-9 w-9 items-center justify-center border border-[#D8E1EA] bg-white text-[#475569] transition hover:border-[#94A3B8] hover:text-[#07324A]"
                  title="Copy link"
                >
                  <Link2 id="copy-icon" class="h-4 w-4" />
                  <Check id="check-icon" class="absolute hidden h-4 w-4 text-[#059669]" />
                </button>
              </div>
              <p id="copy-toast" class="mt-3 hidden text-[12px] font-semibold text-[#059669]">Copied</p>
            </div>
          </div>
        </aside>

        <div class="min-w-0 reveal" data-delay="1">
          <details class="mb-10 border border-[#D8E1EA] bg-white p-5 lg:hidden">
            <summary class="cursor-pointer text-[14px] font-semibold text-[#07324A]">Article outline</summary>
            <nav class="mt-4 space-y-3 border-l border-[#D8E1EA] pl-4" aria-label="Mobile outline">
              {post.sections.map((section) => (
                <a href={`#${slugify(section.heading)}`} class="block text-[14px] font-medium text-[#64748B] hover:text-[#07324A]">
                  {section.heading}
                </a>
              ))}
            </nav>
          </details>

          <div class="space-y-12">
            {post.sections.map((section, sectionIdx) => {
              const sectionId = slugify(section.heading);
              return (
                <section id={sectionId} data-article-section={sectionId} class="scroll-mt-28">
                  <h2 class="border-b border-[#D8E1EA] pb-4 text-[28px] font-semibold leading-tight tracking-normal text-[#07324A] sm:text-[34px]">
                    {section.heading}
                  </h2>
                  <div class="mt-6 space-y-6">
                    {section.body.map((paragraph, paraIdx) => {
                      const isKeyPoint = sectionIdx === 1 && paraIdx === 0;

                      if (isKeyPoint) {
                        return (
                          <aside class="border-l-4 border-[#0891B2] bg-white px-6 py-5 shadow-[0_18px_55px_-48px_rgba(7,50,74,0.45)]">
                            <p class="text-[17px] font-medium leading-relaxed text-[#07324A]">{paragraph}</p>
                          </aside>
                        );
                      }

                      return <p class="text-[17px] leading-[1.85] text-[#334155]">{paragraph}</p>;
                    })}
                  </div>
                </section>
              );
            })}
          </div>

          <CTASection
            contained={false}
            sectionClass="mt-16"
            cardClass="border-[#D8E1EA] bg-white p-7 shadow-[0_24px_70px_-58px_rgba(7,50,74,0.42)] sm:p-9"
            eyebrow="Task review"
            title="Map one business task into managed AI automation."
            description="Share a repeated task, the knowledge behind it, and the tools where work happens. Tactas AI can help turn that task into action-ready agent work."
            descriptionClass="mt-4 max-w-[42rem] text-[16px] leading-relaxed text-[#475569]"
            primaryLabel="Request task review"
            primaryHref="/contact"
            primaryClass="inline-flex h-12 items-center justify-center bg-[#07324A] px-6 text-[14px] font-semibold text-white transition hover:bg-[#075985]"
            showPrimaryArrow
          />
        </div>
      </div>
    </article>

    <section class="border-t border-[#D8E1EA] bg-white py-14">
      <div class="mx-auto w-full max-w-[1040px] px-5 sm:px-8 lg:px-10 reveal">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
          <div>
            <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.24em] text-[#0891B2]">Related reads</p>
            <h2 class="mt-3 text-[30px] font-semibold leading-tight tracking-normal text-[#07324A] sm:text-[38px]">Continue reading</h2>
          </div>
          <a href="/blog" class="inline-flex h-11 items-center justify-center border border-[#D8E1EA] px-5 text-[14px] font-semibold text-[#07324A] transition hover:border-[#94A3B8]">
            View all
          </a>
        </div>

        <div class="mt-8 grid gap-5 sm:grid-cols-2">
          {relatedPosts.map((item) => (
            <a href={`/blog/${item.slug}`} class="group flex min-h-[260px] flex-col justify-between border border-[#D8E1EA] bg-white p-7 transition hover:border-[#A7B4C4]">
              <div>
                <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.2em] text-[#64748B]">{item.category}</p>
                <h3 class="mt-4 text-[23px] font-semibold leading-tight tracking-normal text-[#07324A] transition group-hover:text-[#075985]">{item.title}</h3>
                <p class="mt-4 text-[15px] leading-relaxed text-[#475569]">{item.summary}</p>
              </div>
              <span class="mt-8 inline-flex items-center text-[14px] font-semibold text-[#07324A] transition group-hover:text-[#075985]">
                Read article
                <ArrowRight class="ml-2 h-4 w-4 transition group-hover:translate-x-1" stroke-width={2} />
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<script is:inline>
  function initBlogDetail() {
    const progressBar = document.getElementById("reading-progress");
    const tocLinks = document.querySelectorAll("[data-toc-link]");
    const sections = document.querySelectorAll("[data-article-section]");
    const btnLinkedin = document.getElementById("share-linkedin");
    const btnCopy = document.getElementById("copy-link");
    const toast = document.getElementById("copy-toast");
    const copyIcon = document.getElementById("copy-icon");
    const checkIcon = document.getElementById("check-icon");

    function handleScroll() {
      const winScroll = document.documentElement.scrollTop || document.body.scrollTop;
      const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
      const scrolled = height > 0 ? (winScroll / height) * 100 : 0;
      if (progressBar) progressBar.style.width = scrolled + "%";

      let currentSectionId = "";
      const scrollPosition = window.scrollY + 180;

      sections.forEach((section) => {
        const top = section.offsetTop;
        const bottom = top + section.offsetHeight;
        if (scrollPosition >= top && scrollPosition < bottom) {
          currentSectionId = section.getAttribute("data-article-section") || "";
        }
      });

      tocLinks.forEach((link) => {
        const isActive = link.getAttribute("data-toc-link") === currentSectionId;
        link.classList.toggle("text-[#07324A]", isActive);
        link.classList.toggle("font-semibold", isActive);
        link.classList.toggle("text-[#64748B]", !isActive);
      });
    }

    if (btnLinkedin) {
      btnLinkedin.addEventListener("click", () => {
        const url = btnLinkedin.getAttribute("data-share-url");
        window.open(`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(url)}`, "_blank", "noopener,noreferrer");
      });
    }

    if (btnCopy && toast) {
      btnCopy.addEventListener("click", () => {
        const url = btnCopy.getAttribute("data-copy-url") || window.location.href;
        navigator.clipboard.writeText(url).then(() => {
          toast.classList.remove("hidden");
          copyIcon?.classList.add("hidden");
          checkIcon?.classList.remove("hidden");

          setTimeout(() => {
            toast.classList.add("hidden");
            checkIcon?.classList.add("hidden");
            copyIcon?.classList.remove("hidden");
          }, 1800);
        });
      });
    }

    window.addEventListener("scroll", handleScroll);
    handleScroll();

    tocLinks.forEach((link) => {
      link.addEventListener("click", (event) => {
        event.preventDefault();
        const targetId = link.getAttribute("href");
        const target = targetId ? document.querySelector(targetId) : null;
        if (target) {
          window.scrollTo({ top: target.offsetTop - 110, behavior: "smooth" });
        }
      });
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initBlogDetail);
  } else {
    initBlogDetail();
  }

  document.addEventListener("astro:after-swap", initBlogDetail);
</script>
