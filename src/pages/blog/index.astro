---
import { ArrowRight, CalendarDays, Clock } from "@lucide/astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { blogPosts } from "../../lib/blog";
import { getOrganization, getSiteUrl } from "../../lib/site";

const siteUrl = getSiteUrl();
const pageUrl = `${siteUrl}/blog`;
const organization = getOrganization();
const title = "Tactas AI Blog | Managed AI Agents for Business Operations";
const description =
  "Read practical guides on managed AI agents, business task automation, company knowledge, connected tools, and turning context into action-ready work.";

const categories = ["All", ...new Set(blogPosts.map((post) => post.category))];
const featuredPost = blogPosts[0];
const latestPosts = blogPosts.slice(1);

const formatDate = (date: string) =>
  new Date(`${date}T00:00:00`).toLocaleDateString("en-US", {
    month: "long",
    day: "numeric",
    year: "numeric",
  });

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    organization,
    {
      "@type": "Blog",
      "@id": `${pageUrl}#blog`,
      name: "Tactas AI Blog",
      url: pageUrl,
      description,
      publisher: { "@id": `${siteUrl}/#organization` },
      inLanguage: "en-US",
      blogPost: blogPosts.map((post) => ({
        "@type": "BlogPosting",
        headline: post.title,
        description: post.description,
        datePublished: post.publishedAt,
        dateModified: post.publishedAt,
        url: `${pageUrl}/${post.slug}`,
        author: { "@id": `${siteUrl}/#organization` },
        publisher: { "@id": `${siteUrl}/#organization` },
      })),
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Home", item: `${siteUrl}/` },
        { "@type": "ListItem", position: 2, name: "Blog", item: pageUrl },
      ],
    },
  ],
};
---

<BaseLayout
  title={title}
  description={description}
  canonical="/blog"
  currentPath="/blog"
  navbarTheme="light"
  navbarCtaLabel="Book a review"
  keywords={[
    "managed AI agents blog",
    "business task automation",
    "company knowledge automation",
    "AI agents for business operations",
    "connected business tools",
    "work performance AI",
  ]}
  openGraph={{
    title,
    description,
    url: pageUrl,
    type: "website",
    images: [
      {
        url: "/tactas-ai-managed-agent-systems-og.jpg",
        width: 1734,
        height: 907,
        alt: "Tactas AI blog about managed AI agents for business operations",
      },
    ],
  }}
  twitter={{ card: "summary_large_image", title, description, images: ["/tactas-ai-managed-agent-systems-og.jpg"] }}
  jsonLd={jsonLd}
>
  <main class="min-h-screen bg-[#F7F8FA] text-[#111827] selection:bg-[#BAE6FD] selection:text-[#0F172A]">
    <section class="border-b border-[#D8E1EA] bg-white">
      <div class="mx-auto grid w-full max-w-[1240px] gap-10 px-5 py-16 sm:px-8 lg:grid-cols-[minmax(0,760px)_320px] lg:px-10 lg:py-20">
        <div class="reveal">
          <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.24em] text-[#0891B2]">Tactas AI Blog</p>
          <h1 class="mt-5 max-w-[760px] text-[clamp(2.4rem,6vw,4.6rem)] font-semibold leading-[1.03] tracking-normal text-[#07324A]">
            Practical thinking for AI operations.
          </h1>
          <p class="mt-6 max-w-[680px] text-[18px] leading-relaxed text-[#475569]">
            Guides for teams turning company knowledge, repeated tasks, and connected tools into managed AI agent workflows.
          </p>
        </div>

        <aside class="border-t border-[#D8E1EA] pt-6 lg:border-l lg:border-t-0 lg:pl-8 lg:pt-2 reveal" data-delay="1">
          <p class="text-[13px] font-semibold uppercase tracking-[0.16em] text-[#64748B]">Editorial focus</p>
          <dl class="mt-5 space-y-5">
            <div>
              <dt class="text-[13px] font-semibold text-[#07324A]">Operating context</dt>
              <dd class="mt-1 text-[14px] leading-relaxed text-[#64748B]">How agents use business knowledge before taking action.</dd>
            </div>
            <div>
              <dt class="text-[13px] font-semibold text-[#07324A]">Workflow selection</dt>
              <dd class="mt-1 text-[14px] leading-relaxed text-[#64748B]">How to choose tasks with clear inputs, outputs, and ownership.</dd>
            </div>
            <div>
              <dt class="text-[13px] font-semibold text-[#07324A]">Managed deployment</dt>
              <dd class="mt-1 text-[14px] leading-relaxed text-[#64748B]">How to make automation reliable inside real business systems.</dd>
            </div>
          </dl>
        </aside>
      </div>
    </section>

    <section class="border-b border-[#D8E1EA] bg-[#F7F8FA]">
      <div class="mx-auto w-full max-w-[1240px] px-5 py-5 sm:px-8 lg:px-10">
        <nav class="flex gap-2 overflow-x-auto pb-1 scrollbar-none" aria-label="Blog categories">
          {categories.map((category) => (
            <button
              type="button"
              data-category-btn={category}
              data-active={category === "All" ? "true" : "false"}
              class="category-btn shrink-0 border border-[#D8E1EA] bg-white px-4 py-2 text-[13px] font-semibold text-[#334155] transition hover:border-[#94A3B8] hover:text-[#07324A] data-[active=true]:border-[#07324A] data-[active=true]:bg-[#07324A] data-[active=true]:text-white"
            >
              {category}
            </button>
          ))}
        </nav>
      </div>
    </section>

    <section class="mx-auto w-full max-w-[1240px] px-5 py-12 sm:px-8 lg:px-10 lg:py-16">
      <article data-post-card data-post-category={featuredPost.category} class="reveal">
        <a
          href={`/blog/${featuredPost.slug}`}
          class="group grid overflow-hidden border border-[#D8E1EA] bg-white shadow-[0_24px_70px_-58px_rgba(7,50,74,0.4)] transition hover:border-[#A7B4C4] lg:grid-cols-[0.88fr_1.12fr]"
        >
          <div class="relative min-h-[260px] border-b border-[#D8E1EA] bg-[#F8FAFC] lg:min-h-[460px] lg:border-b-0 lg:border-r">
            <img
              src="/tactas-ai-managed-agent-systems-og.jpg"
              alt="Tactas AI managed agent systems"
              class="h-full w-full object-cover"
              loading="eager"
              decoding="async"
            />
          </div>

          <div class="flex min-h-[420px] flex-col justify-between p-7 sm:p-9 lg:p-11">
            <div>
              <p class="text-[12px] font-semibold uppercase tracking-[0.18em] text-[#0891B2]">Featured article</p>
              <div class="mt-6 flex flex-wrap items-center gap-x-4 gap-y-2 text-[13px] font-medium text-[#64748B]">
                <span class="inline-flex items-center gap-1.5">
                  <CalendarDays class="h-4 w-4 text-[#64748B]" />
                  {formatDate(featuredPost.publishedAt)}
                </span>
                <span class="h-1 w-1 rounded-full bg-[#CBD5E1]" aria-hidden="true"></span>
                <span class="inline-flex items-center gap-1.5">
                  <Clock class="h-4 w-4 text-[#64748B]" />
                  {featuredPost.readTime}
                </span>
              </div>
              <p class="mt-8 font-mono text-[11px] font-semibold uppercase tracking-[0.2em] text-[#64748B]">
                {featuredPost.category}
              </p>
              <h2 class="mt-4 max-w-[720px] text-[clamp(2rem,4vw,3.3rem)] font-semibold leading-[1.06] tracking-normal text-[#07324A] transition group-hover:text-[#075985]">
                {featuredPost.title}
              </h2>
              <p class="mt-5 max-w-[640px] text-[17px] leading-relaxed text-[#475569]">{featuredPost.summary}</p>
            </div>

            <div class="mt-10 flex items-center justify-between border-t border-[#E2E8F0] pt-6">
              <span class="text-[13px] font-semibold text-[#64748B]">Tactas AI Editorial</span>
              <span class="inline-flex items-center text-[14px] font-semibold text-[#07324A] transition group-hover:text-[#075985]">
                Read article
                <ArrowRight class="ml-2 h-4 w-4 transition group-hover:translate-x-1" stroke-width={2} />
              </span>
            </div>
          </div>
        </a>
      </article>

      <div class="mt-16 flex flex-col gap-3 border-t border-[#D8E1EA] pt-10 sm:flex-row sm:items-end sm:justify-between reveal">
        <div>
          <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.24em] text-[#0891B2]">Latest analysis</p>
          <h2 class="mt-3 text-[32px] font-semibold leading-tight tracking-normal text-[#07324A] sm:text-[42px]">More from Tactas AI</h2>
        </div>
        <a href="/contact" class="inline-flex h-11 items-center justify-center border border-[#D8E1EA] bg-white px-5 text-[14px] font-semibold text-[#07324A] transition hover:border-[#94A3B8]">
          Request a topic
        </a>
      </div>

      <div class="mt-8 grid gap-5 lg:grid-cols-2">
        {latestPosts.map((post, idx) => (
          <article data-post-card data-post-category={post.category} class="reveal" data-delay={String(idx + 1)}>
            <a
              href={`/blog/${post.slug}`}
              class="group flex h-full min-h-[320px] flex-col justify-between border border-[#D8E1EA] bg-white p-7 transition hover:border-[#A7B4C4] sm:p-8"
            >
              <div>
                <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-[13px] font-medium text-[#64748B]">
                  <span>{formatDate(post.publishedAt)}</span>
                  <span class="h-1 w-1 rounded-full bg-[#CBD5E1]" aria-hidden="true"></span>
                  <span>{post.readTime}</span>
                </div>
                <p class="mt-7 font-mono text-[11px] font-semibold uppercase tracking-[0.2em] text-[#64748B]">{post.category}</p>
                <h3 class="mt-4 text-[26px] font-semibold leading-tight tracking-normal text-[#07324A] transition group-hover:text-[#075985]">
                  {post.title}
                </h3>
                <p class="mt-4 text-[15.5px] leading-relaxed text-[#475569]">{post.summary}</p>
              </div>
              <span class="mt-10 inline-flex items-center text-[14px] font-semibold text-[#07324A] transition group-hover:text-[#075985]">
                Read article
                <ArrowRight class="ml-2 h-4 w-4 transition group-hover:translate-x-1" stroke-width={2} />
              </span>
            </a>
          </article>
        ))}
      </div>
    </section>

    <section class="border-y border-[#D8E1EA] bg-white">
      <div class="mx-auto grid w-full max-w-[1240px] gap-6 px-5 py-12 sm:px-8 lg:grid-cols-[1fr_auto] lg:items-center lg:px-10">
        <div>
          <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.24em] text-[#0891B2]">Task review</p>
          <h2 class="mt-3 max-w-[720px] text-[30px] font-semibold leading-tight tracking-normal text-[#07324A] sm:text-[40px]">
            Need help choosing the first workflow?
          </h2>
          <p class="mt-4 max-w-[640px] text-[16px] leading-relaxed text-[#475569]">
            Share a repeated business task and the systems behind it. Tactas AI can map the context, outputs, and automation path.
          </p>
        </div>
        <a href="/contact" class="inline-flex h-12 items-center justify-center bg-[#07324A] px-6 text-[14px] font-semibold text-white transition hover:bg-[#075985]">
          Request task review
          <ArrowRight class="ml-2 h-4 w-4" stroke-width={2} />
        </a>
      </div>
    </section>
  </main>
</BaseLayout>

<script is:inline>
  function initFilters() {
    const buttons = document.querySelectorAll("[data-category-btn]");
    const posts = document.querySelectorAll("[data-post-card]");

    if (buttons.length === 0 || posts.length === 0) return;

    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const category = btn.getAttribute("data-category-btn");

        buttons.forEach((button) => button.setAttribute("data-active", "false"));
        btn.setAttribute("data-active", "true");

        posts.forEach((post) => {
          const postCategory = post.getAttribute("data-post-category");
          post.classList.toggle("hidden", category !== "All" && postCategory !== category);
        });
      });
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initFilters);
  } else {
    initFilters();
  }

  document.addEventListener("astro:after-swap", initFilters);
</script>

<style>
  .scrollbar-none::-webkit-scrollbar {
    display: none;
  }

  .scrollbar-none {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
