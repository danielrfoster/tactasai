---
import { ArrowRight, CalendarDays, Clock } from "@lucide/astro";
import BlogNavbar from "../../components/BlogNavbar.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { blogPosts } from "../../lib/blog";
import { getOrganization, getSiteUrl } from "../../lib/site";

const siteUrl = getSiteUrl();
const pageUrl = `${siteUrl}/blog`;
const organization = getOrganization();
const title = "Tactas AI Blog | Managed AI Agents for Business Operations";
const description =
  "Read practical guides on managed AI agents, business task automation, company knowledge, connected tools, and turning context into action-ready work.";

const categories = ["All", ...new Set(blogPosts.map((post) => post.category))];
const featuredPost = blogPosts[0];
const latestPosts = blogPosts.slice(1);
const defaultPostImage = {
  src: "/tactas-ai-managed-agent-systems-og.jpg",
  width: 1734,
  height: 907,
  alt: "Tactas AI managed agent systems",
};
const featuredImage = featuredPost.image ?? defaultPostImage;

const formatDate = (date: string) =>
  new Date(`${date}T00:00:00`).toLocaleDateString("en-US", {
    month: "long",
    day: "numeric",
    year: "numeric",
  });

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    organization,
    {
      "@type": "Blog",
      "@id": `${pageUrl}#blog`,
      name: "Tactas AI Blog",
      url: pageUrl,
      description,
      publisher: { "@id": `${siteUrl}/#organization` },
      inLanguage: "en-US",
      blogPost: blogPosts.map((post) => ({
        "@type": "BlogPosting",
        headline: post.title,
        description: post.description,
        datePublished: post.publishedAt,
        dateModified: post.publishedAt,
        url: `${pageUrl}/${post.slug}`,
        image: `${siteUrl}${post.image?.src ?? defaultPostImage.src}`,
        author: { "@id": `${siteUrl}/#organization` },
        publisher: { "@id": `${siteUrl}/#organization` },
      })),
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Home", item: `${siteUrl}/` },
        { "@type": "ListItem", position: 2, name: "Blog", item: pageUrl },
      ],
    },
  ],
};
---

<BaseLayout
  title={title}
  description={description}
  canonical="/blog"
  currentPath="/blog"
  showNavbar={false}
  keywords={[
    "managed AI agents blog",
    "business task automation",
    "company knowledge automation",
    "AI agents for business operations",
    "connected business tools",
    "work performance AI",
  ]}
  openGraph={{
    title,
    description,
    url: pageUrl,
    type: "website",
    images: [
      {
        url: "/tactas-ai-managed-agent-systems-og.jpg",
        width: 1734,
        height: 907,
        alt: "Tactas AI blog about managed AI agents for business operations",
      },
    ],
  }}
  twitter={{ card: "summary_large_image", title, description, images: ["/tactas-ai-managed-agent-systems-og.jpg"] }}
  jsonLd={jsonLd}
>
  <BlogNavbar currentPath="/blog" />
  <main class="min-h-screen bg-tactas-bg text-tactas-ink selection:bg-tactas-accent-line selection:text-tactas-ink">
    <section class="border-b border-tactas-line bg-white">
      <div class="tactas-container py-10 lg:py-12">
        <div class="reveal">
          <p class="max-w-[760px] text-[16px] leading-relaxed text-tactas-muted sm:text-[18px]">
            Explore expert insights and actionable strategies for navigating the evolving landscape of enterprise AI.
          </p>
        </div>
      </div>
    </section>

    <section class="tactas-container py-8 lg:py-10">
      <article class="reveal">
        <a
          href={`/blog/${featuredPost.slug}`}
          class="group grid overflow-hidden border border-tactas-line bg-white shadow-[0_24px_70px_-58px_rgba(7,17,31,0.4)] transition hover:border-tactas-line-strong lg:grid-cols-[minmax(0,1.08fr)_minmax(360px,0.92fr)]"
        >
          <div class="relative flex min-h-[260px] items-center justify-center border-b border-tactas-line bg-tactas-bg-soft p-4 sm:p-5 lg:min-h-[390px] lg:border-b-0 lg:border-r lg:p-6">
            <img
              src={featuredImage.src}
              alt={featuredImage.alt}
              class="aspect-[1672/900] h-auto w-full object-contain"
              loading="eager"
              decoding="async"
            />
          </div>

          <div class="flex flex-col justify-between p-7 sm:p-8 lg:p-9">
            <div class="min-w-0">
              <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-[13px] font-medium text-tactas-muted-soft">
                <span class="font-semibold uppercase tracking-[0.16em] text-tactas-accent-strong">Featured article</span>
                <span class="h-1 w-1 rounded-full bg-tactas-line-strong" aria-hidden="true"></span>
                <span class="inline-flex items-center gap-1.5">
                  <CalendarDays class="h-4 w-4 text-tactas-muted-soft" />
                  {formatDate(featuredPost.publishedAt)}
                </span>
                <span class="h-1 w-1 rounded-full bg-tactas-line-strong" aria-hidden="true"></span>
                <span class="inline-flex items-center gap-1.5">
                  <Clock class="h-4 w-4 text-tactas-muted-soft" />
                  {featuredPost.readTime}
                </span>
              </div>
              <p class="mt-6 font-mono text-[11px] font-semibold uppercase tracking-[0.2em] text-tactas-muted-soft">
                {featuredPost.category}
              </p>
              <h2 class="mt-4 text-[clamp(1.8rem,3.2vw,2.75rem)] font-semibold leading-[1.08] tracking-normal text-tactas-ink-strong transition group-hover:text-tactas-accent-strong">
                {featuredPost.title}
              </h2>
            </div>

            <div class="mt-8 flex items-center justify-between border-t border-tactas-line-soft pt-6">
              <span class="text-[13px] font-semibold text-tactas-muted-soft">tactas team</span>
              <span class="inline-flex items-center text-[14px] font-semibold text-tactas-ink-strong transition group-hover:text-tactas-accent-strong">
                Read article
                <ArrowRight class="ml-2 h-4 w-4 transition group-hover:translate-x-1" stroke-width={2} />
              </span>
            </div>
          </div>
        </a>
      </article>
    </section>

    <section class="border-y border-tactas-line bg-tactas-bg">
      <div class="tactas-container py-5">
        <nav class="flex gap-2 overflow-x-auto pb-1 scrollbar-none" aria-label="Blog categories">
          {categories.map((category) => (
            <button
              type="button"
              data-category-btn={category}
              data-active={category === "All" ? "true" : "false"}
              class="category-btn shrink-0 border border-tactas-line bg-white px-4 py-2 text-[13px] font-semibold text-tactas-muted transition hover:border-tactas-line-strong hover:text-tactas-ink-strong data-[active=true]:border-tactas-night-strong data-[active=true]:bg-tactas-night-strong data-[active=true]:text-white"
            >
              {category}
            </button>
          ))}
        </nav>
      </div>
    </section>

    <section class="tactas-container py-12 lg:py-16">
      <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between reveal">
        <div>
          <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.24em] text-tactas-accent-strong">Latest analysis</p>
          <h2 class="mt-3 text-[32px] font-semibold leading-tight tracking-normal text-tactas-ink-strong sm:text-[42px]">More from Tactas AI</h2>
        </div>
        <a href="/contact" class="inline-flex h-11 items-center justify-center border border-tactas-line bg-white px-5 text-[14px] font-semibold text-tactas-ink-strong transition hover:border-tactas-line-strong">
          Request a topic
        </a>
      </div>

      <div class="mt-8 grid gap-5 lg:grid-cols-2">
        {latestPosts.map((post, idx) => (
          <article data-post-card data-post-category={post.category} class="reveal" data-delay={String(idx + 1)}>
            <a
              href={`/blog/${post.slug}`}
              class="group flex h-full min-h-[260px] flex-col justify-between border border-tactas-line bg-white p-7 transition hover:border-tactas-line-strong sm:p-8"
            >
              <div>
                <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-[13px] font-medium text-tactas-muted-soft">
                  <span>{formatDate(post.publishedAt)}</span>
                  <span class="h-1 w-1 rounded-full bg-tactas-line-strong" aria-hidden="true"></span>
                  <span>{post.readTime}</span>
                </div>
                <p class="mt-7 font-mono text-[11px] font-semibold uppercase tracking-[0.2em] text-tactas-muted-soft">{post.category}</p>
                <h3 class="mt-4 text-[26px] font-semibold leading-tight tracking-normal text-tactas-ink-strong transition group-hover:text-tactas-accent-strong">
                  {post.title}
                </h3>
              </div>
              <span class="mt-8 inline-flex items-center text-[14px] font-semibold text-tactas-ink-strong transition group-hover:text-tactas-accent-strong">
                Read article
                <ArrowRight class="ml-2 h-4 w-4 transition group-hover:translate-x-1" stroke-width={2} />
              </span>
            </a>
          </article>
        ))}
      </div>
    </section>

    <section class="border-y border-tactas-line bg-white">
      <div class="mx-auto grid w-full max-w-[1240px] gap-6 px-5 py-12 sm:px-8 lg:grid-cols-[1fr_auto] lg:items-center lg:px-10">
        <div>
          <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.24em] text-tactas-accent-strong">Task review</p>
          <h2 class="mt-3 max-w-[720px] text-[30px] font-semibold leading-tight tracking-normal text-tactas-ink-strong sm:text-[40px]">
            Need help choosing the first workflow?
          </h2>
          <p class="mt-4 max-w-[640px] text-[16px] leading-relaxed text-tactas-muted">
            Share a repeated business task and the systems behind it. Tactas AI can map the context, outputs, and automation path.
          </p>
        </div>
        <a href="/contact" class="inline-flex h-12 items-center justify-center bg-tactas-night-strong px-6 text-[14px] font-semibold text-white transition hover:bg-tactas-accent-strong">
          Request task review
          <ArrowRight class="ml-2 h-4 w-4" stroke-width={2} />
        </a>
      </div>
    </section>
  </main>
</BaseLayout>

<script is:inline>
  function initFilters() {
    const buttons = document.querySelectorAll("[data-category-btn]");
    const posts = document.querySelectorAll("[data-post-card]");

    if (buttons.length === 0 || posts.length === 0) return;

    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const category = btn.getAttribute("data-category-btn");

        buttons.forEach((button) => button.setAttribute("data-active", "false"));
        btn.setAttribute("data-active", "true");

        posts.forEach((post) => {
          const postCategory = post.getAttribute("data-post-category");
          post.classList.toggle("hidden", category !== "All" && postCategory !== category);
        });
      });
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initFilters);
  } else {
    initFilters();
  }

  document.addEventListener("astro:after-swap", initFilters);
</script>
