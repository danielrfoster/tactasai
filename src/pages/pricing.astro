---
import { ArrowRight, Bot, BrainCircuit, Check, Mail, Network, ShieldCheck, Zap } from "@lucide/astro";
import CTASection from "../components/CTASection.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getBrandEmail, getOrganization, getSiteUrl } from "../lib/site";

const siteUrl = getSiteUrl();
const brandEmail = getBrandEmail();
const organization = getOrganization();
const pageUrl = `${siteUrl}/pricing`;

const title = "Managed AI Agent Pricing for Business Operations | Tactas AI";
const description =
  "Explore Tactas AI pricing for managed agent setup, company knowledge layers, connected tools, monthly usage quota, and ongoing managed operation.";

const buildPlans = [
  {
    id: "managed-agent-launch",
    name: "Ignition",
    eyebrow: "Single workflow build",
    summary: "One-time implementation for the first production workflow: company knowledge, agent behavior, and connected actions configured for your business.",
    price: "$3,500",
    suffix: "setup",
    cta: "Scope build",
    href: "/contact",
    includedLabel: "Implementation work:",
    points: [
      "Define the workflow, inputs, outputs, and success criteria",
      "Prepare and index the required company knowledge",
      "Configure agent behavior, retrieval, and connected tool actions",
      "Test with real examples and operational edge cases",
      "Launch with monitoring and an improvement backlog",
    ],
    icon: Bot,
  },
  {
    id: "agent-expansion",
    name: "Forge",
    eyebrow: "Expansion build",
    summary: "Add a new workflow, output, data source, or connected business action on top of an existing Tactas system.",
    price: "$8,000",
    suffix: "setup",
    cta: "Scope expansion",
    href: "/contact",
    includedLabel: "Expansion work:",
    points: [
      "Extend indexed context or add new source systems",
      "Add workflow variants, outputs, and automation actions",
      "Connect additional business tools or records",
      "Tune retrieval, routing, review points, and quality checks",
    ],
    icon: Zap,
  },
  {
    id: "operating-layer",
    name: "Grid",
    eyebrow: "Operating layer rollout",
    summary: "A larger implementation program for teams that need several workflows, shared context, and connected actions across systems.",
    price: "From $25,000",
    suffix: "setup",
    cta: "Scope program",
    href: "/contact",
    includedLabel: "Program work:",
    points: [
      "Architect shared context across teams, knowledge sources, and tools",
      "Configure multiple agent workflows under one operating layer",
      "Integrate core business systems and permission boundaries",
      "Define rollout, monitoring, ownership, and improvement cadence",
    ],
    icon: Network,
  },
];

const ongoingPlans = [
  {
    id: "core-quota",
    name: "Signal",
    eyebrow: "1x operating quota",
    summary: "For launched agent systems with steady monthly usage.",
    price: "$499",
    suffix: "/mo",
    quota: "1x operating quota",
    cta: "Start Signal",
    href: "/contact",
    includedLabel: "Includes:",
    points: [
      "1x monthly operating quota",
      "1x model/runtime quota",
      "1x indexed company context capacity",
      "1x retrieval and monitoring volume",
      "1x connected tool action allowance",
      "Standard improvement allocation",
    ],
    icon: BrainCircuit,
  },
  {
    id: "growth-quota",
    name: "Vector",
    eyebrow: "10x Signal quota",
    summary: "For teams using managed agents in daily operations.",
    price: "$1,999",
    suffix: "/mo",
    quota: "10x Signal quota",
    cta: "Start Vector",
    href: "/contact",
    popular: true,
    includedLabel: "Includes:",
    points: [
      "10x Signal operating quota",
      "10x model/runtime quota",
      "10x indexed company context capacity",
      "10x retrieval and monitoring volume",
      "10x connected tool action allowance",
      "Higher improvement allocation",
    ],
    icon: Zap,
  },
  {
    id: "scale-quota",
    name: "Atlas",
    eyebrow: "Unmetered standard quota",
    summary: "For high-volume operations that need broad operating capacity across most supported models, large indexed context, retrieval-heavy workflows, monitoring, and connected business actions.",
    price: "From $7,500",
    suffix: "/mo",
    quota: "Unmetered standard quota",
    cta: "Talk to sales",
    href: "/contact",
    includedLabel: "Includes:",
    points: [
      "Unmetered standard operating quota for most supported models",
      "Premium / high-cost model quota up to 12x Vector",
      "Custom indexed context capacity",
      "Custom retrieval and monitoring volume",
      "Custom connected tool action allowance",
      "Custom improvement allocation",
    ],
    icon: ShieldCheck,
  },
];

const pricingSections = [
  {
    id: "build-packages",
    eyebrow: "Setup and build",
    title: "One-time build work before monthly usage.",
    summary: "Tactas requires implementation work before the monthly quota starts: workflow mapping, company data preparation, tool connections, agent configuration, testing, and launch.",
    priceLabel: "One-time fee",
    plans: buildPlans,
  },
  {
    id: "ongoing-fees",
    eyebrow: "Monthly usage",
    title: "Monthly Operating Quota",
    summary: "All monthly plans run on the same managed agent system. Plans do not unlock or remove core features. They define monthly operating capacity: model/runtime usage, indexed context capacity, retrieval volume, connected tool actions, monitoring volume, and improvement allocation.",
    priceLabel: "Monthly plan",
    note: "Subject to fair use, agreed operating scope, system safety limits, and premium model quota.",
    plans: ongoingPlans,
  },
];

const plans = [...buildPlans, ...ongoingPlans];

const securityItems = [
  ["Setup scope", "Pay for the data preparation, tool connections, and workflow configuration the system needs."],
  ["Usage quota", "Choose a monthly plan around agent usage, model/runtime resources, context, and tool actions."],
  ["Managed operation", "Keep monitoring, support, and improvement cycles aligned with production usage."],
  ["Expansion path", "Start with one operational workflow and expand once the system pattern is proven."],
];

const faqs = [
  [
    "How do I start?",
    "Start by booking a review. We map the repeated work, company knowledge, tools involved, and the output an AI agent should prepare before scoping the paid build.",
  ],
  [
    "What does pricing depend on?",
    "Setup pricing depends on workflow complexity, company knowledge sources, connected tools, automation steps, and launch requirements. Monthly pricing depends on the operating quota required for model/runtime usage, indexed context, retrieval, monitoring, connected tool actions, and improvement allocation.",
  ],
  [
    "How do monthly plans work?",
    "Monthly plans run on the same managed agent system. They do not unlock or remove core features; they define operating capacity. Signal is the base quota, Vector is 10x Signal, and Atlas provides broader standard operating capacity with agreed scope and premium model limits.",
  ],
  [
    "Do we need all company data connected first?",
    "No. A good first launch uses the minimum knowledge and tools required for one useful business task, then expands as the pattern proves value.",
  ],
  [
    "Can Tactas update tools automatically?",
    "Yes. Agents can prepare or apply updates in connected tools based on the permissions and automation scope chosen for the task.",
  ],
  [
    "Is the knowledge layer separate from task automation?",
    "It is a supporting capability. Company knowledge gives managed AI agents the context they need to answer, summarize, prepare outputs, and automate work.",
  ],
  [
    "Can we expand beyond the first task?",
    "Yes. Once one workflow works, Tactas can reuse the knowledge layer, connected tools, and agent patterns across adjacent operational workflows.",
  ],
];

const offerCatalog = {
  "@type": "OfferCatalog",
  name: "Tactas AI pricing model",
  itemListElement: plans.map((plan) => ({
    "@type": "Offer",
    name: `${plan.name} plan`,
    category: plan.eyebrow,
    url: `${pageUrl}#${plan.id}`,
    priceSpecification: {
      "@type": "PriceSpecification",
      priceCurrency: "USD",
      description: `${plan.price} ${plan.suffix}`.trim(),
    },
    itemOffered: {
      "@type": "Service",
      name: `${plan.name} managed AI agent plan`,
      description: plan.summary,
      provider: { "@id": `${siteUrl}/#organization` },
    },
  })),
};

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    organization,
    {
      "@type": "WebPage",
      "@id": `${pageUrl}#webpage`,
      name: title,
      url: pageUrl,
      description,
      isPartOf: { "@id": `${siteUrl}/#website` },
      about: { "@id": `${siteUrl}/#organization` },
      mainEntity: { "@id": `${pageUrl}#service` },
      inLanguage: "en-US",
    },
    {
      "@type": "Service",
      "@id": `${pageUrl}#service`,
      name: "Managed AI agent pricing",
      description,
      serviceType: "Managed AI agents for business task automation",
      areaServed: "Worldwide",
      provider: { "@id": `${siteUrl}/#organization` },
      hasOfferCatalog: offerCatalog,
    },
    {
      "@type": "FAQPage",
      "@id": `${pageUrl}#faq`,
      mainEntity: faqs.map(([question, answer]) => ({
        "@type": "Question",
        name: question,
        acceptedAnswer: { "@type": "Answer", text: answer },
      })),
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Home", item: `${siteUrl}/` },
        { "@type": "ListItem", position: 2, name: "Pricing", item: pageUrl },
      ],
    },
  ],
};
---

<BaseLayout
  title={title}
  description={description}
  canonical="/pricing"
  currentPath="/pricing"
  navbarTheme="light"
  navbarCtaLabel="Book a review"
  navbarCtaHref="/contact"
  keywords={[
    "managed AI agent pricing",
    "business task automation pricing",
    "managed AI agents for business operations",
    "company knowledge automation pricing",
    "connected business tools AI",
    "AI task automation for business teams",
  ]}
  openGraph={{
    title,
    description,
    url: pageUrl,
    type: "website",
    images: [
      {
        url: "/tactas-ai-managed-agent-systems-og.jpg",
        width: 1734,
        height: 907,
        alt: "Tactas AI managed agent pricing",
      },
    ],
  }}
  twitter={{
    card: "summary_large_image",
    title,
    description,
    images: ["/tactas-ai-managed-agent-systems-og.jpg"],
  }}
  jsonLd={jsonLd}
>
  <div class="min-h-screen bg-[#F6F8FB] text-[#0F172A]">
    <main>
      <section class="relative overflow-hidden border-b border-[#D8E1EA] bg-[#F6F8FB]">
        <div class="pointer-events-none absolute inset-x-0 top-0 h-px bg-[linear-gradient(90deg,transparent,#06B6D4_24%,#D7A22A_72%,transparent)]"></div>
        <div class="mx-auto w-full max-w-[1240px] px-5 py-16 sm:px-8 lg:px-10 lg:py-20">
          <div>
            <h1 class="max-w-[820px] text-[clamp(3.4rem,8vw,6.4rem)] font-semibold leading-[0.94] tracking-normal text-[#07324A]">
              Pricing for managed agent systems at work.
            </h1>
            <p class="mt-7 max-w-[44rem] text-[18px] leading-relaxed text-[#07324A]/78">
              Pricing has two parts: setup for the agent system, data, workflow, and tool connections, then a monthly plan for usage quota, resources, monitoring, and improvement.
            </p>
            <div class="mt-9 flex flex-col gap-3 sm:flex-row sm:items-center">
              <a href="/contact" class="inline-flex h-12 items-center justify-center rounded-[8px] bg-[#2F66FF] px-6 text-[14px] font-semibold text-white shadow-[0_16px_34px_-24px_rgba(47,102,255,0.85)] transition hover:bg-[#0EA5E9]">
                Book a review
              </a>
              <a href="#plans" class="inline-flex h-12 items-center justify-center rounded-[8px] border border-[#D9CFAE] bg-white/60 px-6 text-[14px] font-semibold text-[#07324A] transition hover:border-[#2F66FF] hover:text-[#2F66FF]">
                See pricing model
              </a>
            </div>
          </div>
        </div>
      </section>

      <section id="plans" class="border-b border-[#D8E1EA] bg-[#F6F8FB]">
        <div class="mx-auto grid w-full max-w-[1240px] gap-16 px-5 py-14 sm:px-8 lg:px-10 lg:py-20">
          {pricingSections.map((section) => (
            <div id={section.id} class="scroll-mt-24">
              <div class="max-w-[760px]">
                <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-[#0891B2]">{section.eyebrow}</p>
                <h2 class="mt-4 text-[38px] font-semibold leading-[1.02] tracking-normal text-[#07324A] sm:text-[54px]">
                  {section.title}
                </h2>
                <p class="mt-4 text-[16px] leading-relaxed text-[#475569] sm:text-[17px]">{section.summary}</p>
              </div>

              <div class="mt-8 grid gap-4 lg:grid-cols-3">
                {section.plans.map((plan) => {
                  const Icon = plan.icon;
                  return (
                    <article
                      id={plan.id}
                      class:list={[
                        "flex min-h-[520px] flex-col border bg-white p-6 shadow-[0_24px_70px_-62px_rgba(7,50,74,0.3)]",
                        plan.popular ? "border-[#06B6D4] ring-1 ring-[#06B6D4]/25" : "border-[#D8E1EA]",
                      ]}
                    >
                      <div class="flex items-start justify-between gap-3">
                        <span class="flex h-11 w-11 items-center justify-center rounded-[8px] border border-[#BAE6FD] bg-[#E6FBFF] text-[#0E7490]">
                          <Icon class="h-5 w-5" stroke-width={1.9} />
                        </span>
                        {plan.popular ? (
                          <span class="rounded-full border border-[#A7F3D0] bg-[#ECFDF5] px-2.5 py-1 text-[10px] font-semibold uppercase tracking-[0.12em] text-[#047857]">
                            Recommended
                          </span>
                        ) : null}
                      </div>

                      <p class="mt-8 text-[13px] font-medium text-[#64748B]">{plan.eyebrow}</p>
                      <h3 class="mt-2 text-[30px] font-semibold tracking-normal text-[#07324A]">{plan.name}</h3>
                      <p class="mt-2 min-h-[72px] text-[14px] leading-relaxed text-[#475569]">{plan.summary}</p>

                      <div class="mt-7 border border-[#D8E1EA] bg-[#F6F8FB] p-4">
                        <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-[#64748B]">{plan.priceLabel ?? section.priceLabel}</p>
                        <div class="mt-2 flex flex-wrap items-baseline gap-x-2 gap-y-1">
                          <p class="text-[32px] font-semibold leading-none tracking-normal text-[#07324A]">{plan.price}</p>
                          <p class="text-[13px] text-[#64748B]">{plan.suffix}</p>
                        </div>
                        {plan.quota ? <p class="mt-2 text-[13px] font-semibold text-[#0891B2]">{plan.quota}</p> : null}
                      </div>

                      <a
                        href={plan.href}
                        class:list={[
                          "mt-7 inline-flex h-11 items-center justify-center rounded-[8px] px-4 text-[14px] font-semibold transition",
                          plan.popular
                            ? "bg-[#2F66FF] text-white hover:bg-[#0EA5E9]"
                            : "border border-[#D9CFAE] bg-white text-[#07324A] hover:border-[#2F66FF] hover:text-[#2F66FF]",
                        ]}
                      >
                        {plan.cta}
                      </a>

                      <div class="mt-7 border-t border-[#D8E1EA] pt-5">
                        <p class="text-[13px] font-semibold text-[#07324A]">{plan.includedLabel}</p>
                        <ul class="mt-4 grid gap-3">
                          {plan.points.map((point) => (
                            <li class="flex gap-2.5 text-[13px] leading-relaxed text-[#334155]">
                              <Check class="mt-0.5 h-4 w-4 shrink-0 text-[#06B6D4]" stroke-width={2.4} />
                              <span>{point}</span>
                            </li>
                          ))}
                        </ul>
                      </div>
                    </article>
                  );
                })}
              </div>
              {section.note ? <p class="mt-5 max-w-[58rem] text-[13px] leading-relaxed text-[#64748B]">{section.note}</p> : null}
            </div>
          ))}
        </div>
      </section>

      <section class="border-b border-[#D8E1EA] bg-[#F6F8FB]">
        <div class="mx-auto grid w-full max-w-[1240px] gap-10 px-5 py-16 sm:px-8 lg:grid-cols-[0.9fr_1.1fr] lg:px-10 lg:py-20">
          <div>
            <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-[#0891B2]">How pricing scales</p>
            <h2 class="mt-4 max-w-[720px] text-[42px] font-semibold leading-[1.02] tracking-normal text-[#07324A] sm:text-[58px]">
              Pay for setup complexity first, then the monthly quota the system actually uses.
            </h2>
            <p class="mt-5 max-w-[36rem] text-[17px] leading-relaxed text-[#475569]">
              Tactas can start with one operational workflow, then scale the same knowledge layer and connected tools into more work. Higher model/runtime usage, larger indexed context, heavier retrieval, and more tool actions move the monthly quota up.
            </p>
          </div>

          <div class="grid gap-4 sm:grid-cols-2">
            {securityItems.map(([label, body], index) => (
              <article class="border border-[#D8E1EA] bg-white p-5 shadow-[0_20px_60px_-54px_rgba(7,50,74,0.25)]">
                <div class="flex h-11 w-11 items-center justify-center rounded-[8px] border border-[#BAE6FD] bg-[#E6FBFF] text-[#0E7490]">
                  {index % 2 === 0 ? <ShieldCheck class="h-5 w-5" stroke-width={1.9} /> : <Zap class="h-5 w-5" stroke-width={1.9} />}
                </div>
                <h3 class="mt-5 text-[20px] font-semibold tracking-normal text-[#07324A]">{label}</h3>
                <p class="mt-2 text-[14px] leading-relaxed text-[#475569]">{body}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="border-b border-[#D8E1EA] bg-[#F6F8FB]">
        <div class="mx-auto w-full max-w-[1020px] px-5 py-16 sm:px-8 lg:px-10 lg:py-20">
          <div class="text-center">
            <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-[#0891B2]">FAQ</p>
            <h2 class="mt-4 text-[42px] font-semibold leading-[1.02] tracking-normal text-[#07324A] sm:text-[58px]">
              Frequently asked questions.
            </h2>
          </div>
          <div class="mt-10 divide-y divide-[#D8E1EA] border-y border-[#D8E1EA]">
            {faqs.map(([question, answer]) => (
              <details class="group py-6">
                <summary class="flex cursor-pointer list-none items-center justify-between gap-5 text-[18px] font-semibold text-[#07324A]">
                  {question}
                  <ArrowRight class="h-4 w-4 shrink-0 text-[#06B6D4] transition group-open:rotate-90" stroke-width={2} />
                </summary>
                <p class="mt-3 max-w-[48rem] text-[15px] leading-relaxed text-[#475569]">{answer}</p>
              </details>
            ))}
          </div>
        </div>
      </section>

      <CTASection
        eyebrow="Task review"
        title="Map one business task before you commit to a build."
        description="Share the repeated work, knowledge sources, current tools, and output you want an agent to prepare."
      >
        <div slot="aside" class="border border-[#D8E1EA] bg-[#F6F8FB] p-5">
          <div class="flex items-start gap-3">
            <Mail class="mt-1 h-5 w-5 shrink-0 text-[#06B6D4]" stroke-width={1.9} />
            <div>
              <h3 class="text-[18px] font-semibold tracking-normal text-[#07324A]">Prefer email?</h3>
              <p class="mt-2 text-[14px] leading-relaxed text-[#475569]">
                Send the business context to <a href={`mailto:${brandEmail}`} class="text-[#0891B2] hover:text-[#07324A]">{brandEmail}</a>.
              </p>
            </div>
          </div>
          <a href="/contact" class="mt-6 inline-flex h-11 w-full items-center justify-center rounded-[8px] bg-[#2F66FF] px-4 text-[14px] font-semibold text-white transition hover:bg-[#0EA5E9]">
            Book a review
            <ArrowRight class="ml-2 h-4 w-4" stroke-width={2} />
          </a>
        </div>
      </CTASection>
    </main>
  </div>
</BaseLayout>
