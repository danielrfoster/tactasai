---
import { ArrowRight, Bot, BrainCircuit, Check, Mail, Network, ShieldCheck, Zap } from "@lucide/astro";
import CTASection from "../components/CTASection.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getBrandEmail, getOrganization, getSiteUrl } from "../lib/site";

const siteUrl = getSiteUrl();
const brandEmail = getBrandEmail();
const organization = getOrganization();
const pageUrl = `${siteUrl}/pricing`;

const title = "Managed AI Agent Pricing for Business Operations | Tactas AI";
const description =
  "Explore Tactas AI pricing for managed agent setup, company knowledge layers, connected tools, monthly usage quota, and ongoing managed operation.";

const buildPlans = [
  {
    id: "managed-agent-launch",
    name: "Ignition",
    eyebrow: "Single workflow build",
    summary: "One-time implementation for the first production workflow: company knowledge, agent behavior, and connected actions configured for your business.",
    price: "$3,500",
    suffix: "setup",
    cta: "Scope build",
    href: "/contact",
    includedLabel: "Implementation work:",
    points: [
      "Define the workflow, inputs, outputs, and success criteria",
      "Prepare and index the required company knowledge",
      "Configure agent behavior, retrieval, and connected tool actions",
      "Test with real examples and operational edge cases",
      "Launch with monitoring and an improvement backlog",
    ],
    icon: Bot,
  },
  {
    id: "agent-expansion",
    name: "Forge",
    eyebrow: "Expansion build",
    summary: "Add a new workflow, output, data source, or connected business action on top of an existing Tactas system.",
    price: "$8,000",
    suffix: "setup",
    cta: "Scope expansion",
    href: "/contact",
    includedLabel: "Expansion work:",
    points: [
      "Extend indexed context or add new source systems",
      "Add workflow variants, outputs, and automation actions",
      "Connect additional business tools or records",
      "Tune retrieval, routing, review points, and quality checks",
    ],
    icon: Zap,
    popular: true,
  },
  {
    id: "operating-layer",
    name: "Grid",
    eyebrow: "Operating layer rollout",
    summary: "A larger implementation program for teams that need several workflows, shared context, and connected actions across systems.",
    price: "From $25,000",
    suffix: "setup",
    cta: "Scope program",
    href: "/contact",
    includedLabel: "Program work:",
    points: [
      "Architect shared context across teams, knowledge sources, and tools",
      "Configure multiple agent workflows under one operating layer",
      "Integrate core business systems and permission boundaries",
      "Define rollout, monitoring, ownership, and improvement cadence",
    ],
    icon: Network,
  },
];

const ongoingPlans = [
  {
    id: "core-quota",
    name: "Signal",
    eyebrow: "1x operating quota",
    summary: "For launched agent systems with steady monthly usage.",
    price: "$499",
    suffix: "/mo",
    quota: "1x operating quota",
    cta: "Start Signal",
    href: "/contact",
    includedLabel: "Includes:",
    points: [
      "1x monthly operating quota",
      "1x model/runtime quota",
      "1x indexed company context capacity",
      "1x retrieval and monitoring volume",
      "1x connected tool action allowance",
      "Standard improvement allocation",
    ],
    icon: BrainCircuit,
  },
  {
    id: "growth-quota",
    name: "Vector",
    eyebrow: "10x Signal quota",
    summary: "For teams using managed agents in daily operations.",
    price: "$1,999",
    suffix: "/mo",
    quota: "10x Signal quota",
    cta: "Start Vector",
    href: "/contact",
    popular: true,
    includedLabel: "Includes:",
    points: [
      "10x Signal operating quota",
      "10x model/runtime quota",
      "10x indexed company context capacity",
      "10x retrieval and monitoring volume",
      "10x connected tool action allowance",
      "Higher improvement allocation",
    ],
    icon: Zap,
  },
  {
    id: "scale-quota",
    name: "Atlas",
    eyebrow: "Unmetered standard quota",
    summary: "For high-volume operations that need broad operating capacity across most supported models, large indexed context, retrieval-heavy workflows, monitoring, and connected business actions.",
    price: "From $7,500",
    suffix: "/mo",
    quota: "Unmetered standard quota",
    cta: "Talk to sales",
    href: "/contact",
    includedLabel: "Includes:",
    points: [
      "Unmetered standard operating quota for most supported models",
      "Premium / high-cost model quota up to 12x Vector",
      "Custom indexed context capacity",
      "Custom retrieval and monitoring volume",
      "Custom connected tool action allowance",
      "Custom improvement allocation",
    ],
    icon: ShieldCheck,
  },
];

const pricingSections = [
  {
    id: "build-packages",
    eyebrow: "Setup and build",
    phaseIndex: "01",
    phaseTitle: "Setup & Implementation",
    title: "AI agent design",
    priceLabel: "One-time fee",
    plans: buildPlans,
    themeColor: "text-tactas-accent-strong bg-tactas-accent-soft border-tactas-accent/20",
  },
  {
    id: "ongoing-fees",
    eyebrow: "Monthly usage",
    phaseIndex: "02",
    phaseTitle: "Monthly Operating Quota",
    title: "Monthly Operating Quota",
    priceLabel: "Monthly plan",
    note: "Subject to fair use, agreed operating scope, system safety limits, and premium model quota.",
    plans: ongoingPlans,
    themeColor: "text-tactas-warning-strong bg-tactas-warning-soft border-tactas-warning-line/30",
  },
];

const plans = [...buildPlans, ...ongoingPlans];

const faqs = [
  [
    "How do I start?",
    "Start by booking a review. We map the repeated work, company knowledge, tools involved, and the output an AI agent should prepare before scoping the paid build.",
  ],
  [
    "What does pricing depend on?",
    "Setup pricing depends on workflow complexity, company knowledge sources, connected tools, automation steps, and launch requirements. Monthly pricing depends on the operating quota required for model/runtime usage, indexed context, retrieval, monitoring, connected tool actions, and improvement allocation.",
  ],
  [
    "How do monthly plans work?",
    "Monthly plans run on the same managed agent system. They do not unlock or remove core features; they define operating capacity. Signal is the base quota, Vector is 10x Signal, and Atlas provides broader standard operating capacity with agreed scope and premium model limits.",
  ],
  [
    "Do we need all company data connected first?",
    "No. A good first launch uses the minimum knowledge and tools required for one useful business task, then expands as the pattern proves value.",
  ],
  [
    "Can Tactas update tools automatically?",
    "Yes. Agents can prepare or apply updates in connected tools based on the permissions and automation scope chosen for the task.",
  ],
  [
    "Is the knowledge layer separate from task automation?",
    "It is a supporting capability. Company knowledge gives managed AI agents the context they need to answer, summarize, prepare outputs, and automate work.",
  ],
  [
    "Can we expand beyond the first task?",
    "Yes. Once one workflow works, Tactas can reuse the knowledge layer, connected tools, and agent patterns across adjacent operational workflows.",
  ],
];

const offerCatalog = {
  "@type": "OfferCatalog",
  name: "Tactas AI pricing model",
  itemListElement: plans.map((plan) => ({
    "@type": "Offer",
    name: `${plan.name} plan`,
    category: plan.eyebrow,
    url: `${pageUrl}#${plan.id}`,
    priceSpecification: {
      "@type": "PriceSpecification",
      priceCurrency: "USD",
      description: `${plan.price} ${plan.suffix}`.trim(),
    },
    itemOffered: {
      "@type": "Service",
      name: `${plan.name} managed AI agent plan`,
      description: plan.summary,
      provider: { "@id": `${siteUrl}/#organization` },
    },
  })),
};

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    organization,
    {
      "@type": "WebPage",
      "@id": `${pageUrl}#webpage`,
      name: title,
      url: pageUrl,
      description,
      isPartOf: { "@id": `${siteUrl}/#website` },
      about: { "@id": `${siteUrl}/#organization` },
      mainEntity: { "@id": `${pageUrl}#service` },
      inLanguage: "en-US",
    },
    {
      "@type": "Service",
      "@id": `${pageUrl}#service`,
      name: "Managed AI agent pricing",
      description,
      serviceType: "Managed AI agents for business task automation",
      areaServed: "Worldwide",
      provider: { "@id": `${siteUrl}/#organization` },
      hasOfferCatalog: offerCatalog,
    },
    {
      "@type": "FAQPage",
      "@id": `${pageUrl}#faq`,
      mainEntity: faqs.map(([question, answer]) => ({
        "@type": "Question",
        name: question,
        acceptedAnswer: { "@type": "Answer", text: answer },
      })),
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Home", item: `${siteUrl}/` },
        { "@type": "ListItem", position: 2, name: "Pricing", item: pageUrl },
      ],
    },
  ],
};
---

<BaseLayout
  title={title}
  description={description}
  canonical="/pricing"
  currentPath="/pricing"
  navbarTheme="light"
  navbarCtaLabel="Book a review"
  navbarCtaHref="/contact"
  keywords={[
    "managed AI agent pricing",
    "business task automation pricing",
    "managed AI agents for business operations",
    "company knowledge automation pricing",
    "connected business tools AI",
    "AI task automation for business teams",
  ]}
  openGraph={{
    title,
    description,
    url: pageUrl,
    type: "website",
    images: [
      {
        url: "/tactas-ai-managed-agent-systems-og.jpg",
        width: 1734,
        height: 907,
        alt: "Tactas AI managed agent pricing",
      },
    ],
  }}
  twitter={{
    card: "summary_large_image",
    title,
    description,
    images: ["/tactas-ai-managed-agent-systems-og.jpg"],
  }}
  jsonLd={jsonLd}
>
  <div class="tactas-pricing-style min-h-screen bg-tactas-bg text-tactas-ink selection:bg-tactas-accent/18">
    <main>
      <section class="tactas-pricing-hero border-b border-tactas-line-strong bg-tactas-bg">
        <div class="tactas-container flex min-h-[560px] items-center justify-center py-20 sm:py-24 lg:min-h-[640px] lg:py-24">
          <div class="mx-auto max-w-[1020px] text-center">
            <div class="mx-auto mb-8 inline-flex min-h-12 items-center justify-center rounded-full border border-tactas-accent-line/70 bg-tactas-night-strong px-5 text-[13px] font-extrabold leading-none text-white shadow-[0_22px_60px_-30px_rgba(6,174,234,0.95)] sm:min-h-[54px] sm:px-6 sm:text-[16px]">
              Managed AI agent pricing
            </div>
            <h1 class="mx-auto max-w-[960px] text-[52px] font-semibold leading-[0.94] tracking-normal text-tactas-ink-strong sm:text-[74px] lg:text-[92px]">
              Pricing built around <span class="block text-tactas-warm">real workflows.</span>
            </h1>
          </div>
        </div>
      </section>

      <section id="plans" class="border-b border-tactas-line bg-tactas-bg">
        <div class="tactas-container py-16 lg:py-20">
        <div class="space-y-14">
          {pricingSections.map((section) => (
            <div id={section.id} class="scroll-mt-24 reveal">
              <div class="grid gap-5 border-b border-tactas-line pb-6 lg:grid-cols-[0.72fr_1.28fr] lg:items-end">
                <div>
                  <span class:list={["flex h-7 w-7 items-center justify-center rounded-full text-[11px] font-mono font-bold border", section.themeColor]}>
                    {section.phaseIndex}
                  </span>
                  <p class:list={["mt-4 font-mono text-[11px] font-semibold uppercase tracking-[0.24em]", section.phaseIndex === "01" ? "text-tactas-accent-strong" : "text-tactas-warning-strong"]}>
                    Stage {section.phaseIndex} / {section.phaseTitle}
                  </p>
                </div>
                <div>
                  <h2 class="max-w-[760px] text-[36px] font-semibold leading-[1.04] tracking-normal text-tactas-ink-strong sm:text-[48px]">
                    {section.title}
                  </h2>
                  {section.summary && (
                    <p class="mt-4 max-w-[720px] text-[15.5px] leading-relaxed text-tactas-muted">
                      {section.summary}
                    </p>
                  )}
                </div>
              </div>

              <div class="mt-8 grid gap-5 lg:grid-cols-3">
                {section.plans.map((plan) => {
                  const Icon = plan.icon;
                  return (
                    <article
                      id={plan.id}
                      class:list={[
                        "relative flex min-h-[520px] flex-col justify-between overflow-hidden border bg-white p-6 transition duration-300 hover:-translate-y-0.5",
                        plan.popular
                          ? "border-tactas-accent-line bg-white shadow-[0_34px_100px_-68px_rgba(7,50,74,0.38)] ring-1 ring-tactas-accent/15"
                          : "border-tactas-line shadow-[0_24px_70px_-58px_rgba(7,50,74,0.36)] hover:border-tactas-accent/50"
                      ]}
                    >
                      <div>
                        <div class="flex items-start justify-between gap-3">
                          <span class="flex h-11 w-11 items-center justify-center rounded-[8px] border border-tactas-accent-line bg-tactas-accent-soft text-tactas-accent-strong">
                            <Icon class="h-5.5 w-5.5" stroke-width={1.9} />
                          </span>
                          {plan.popular && (
                            <span class="rounded-full border border-tactas-success-line bg-tactas-success-soft px-3 py-1.5 text-[10px] font-semibold uppercase tracking-[0.14em] text-tactas-success-strong">
                              Recommended
                            </span>
                          )}
                        </div>

                        <p class="mt-7 font-mono text-[10.5px] font-semibold uppercase tracking-[0.22em] text-tactas-accent-strong">{plan.eyebrow}</p>
                        <h3 class="mt-3 text-[26px] font-semibold tracking-normal text-tactas-ink-strong">{plan.name}</h3>
                        <p class="mt-3 text-[14.5px] leading-relaxed text-tactas-muted">{plan.summary}</p>

                        <div class="mt-6 border border-tactas-line-soft bg-tactas-bg p-5">
                          <p class="font-mono text-[9px] uppercase tracking-[0.16em] text-tactas-muted-soft">{plan.priceLabel ?? section.priceLabel}</p>
                          <div class="mt-2 flex flex-wrap items-baseline gap-x-2 gap-y-1">
                            <p class="text-[34px] font-semibold leading-none tracking-normal text-tactas-ink-strong sm:text-[38px]">{plan.price}</p>
                            <p class="text-[13.5px] font-medium text-tactas-muted-soft">{plan.suffix}</p>
                          </div>
                          {plan.quota && (
                            <div class="mt-3 inline-flex items-center gap-1 rounded-full border border-tactas-accent-line bg-tactas-accent-soft px-3 py-1 text-[11px] font-semibold text-tactas-accent-strong">
                              {plan.quota}
                            </div>
                          )}
                        </div>
                      </div>

                      <div class="flex flex-col">
                        <a
                          href={plan.href}
                          class:list={[
                            "mt-7 w-full",
                            plan.popular ? "tactas-button-primary" : "tactas-button-secondary"
                          ]}
                        >
                          {plan.cta}
                        </a>

                        <div class="mt-8 border-t border-tactas-line-soft pt-6">
                          <p class="text-[13.5px] font-semibold text-tactas-ink-strong">{plan.includedLabel}</p>
                          <ul class="mt-4 space-y-3.5">
                            {plan.points.map((point) => (
                              <li class="flex items-start gap-3 text-[13px] leading-relaxed text-tactas-muted">
                                <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full border border-tactas-success-line bg-tactas-success-soft text-tactas-success-strong">
                                  <Check class="h-3 w-3" stroke-width={3} />
                                </span>
                                <span>{point}</span>
                              </li>
                            ))}
                          </ul>
                        </div>
                      </div>
                    </article>
                  );
                })}
              </div>
              
              {section.note && (
                <div class="mt-6 flex max-w-[850px] items-start gap-2 border-l border-tactas-line pl-3 text-[13px] leading-relaxed text-tactas-muted-soft">
                  <span class="text-tactas-accent">Note</span>
                  <p>{section.note}</p>
                </div>
              )}
            </div>
          ))}
        </div>
        </div>
      </section>

      <section class="border-b border-tactas-line bg-tactas-bg">
        <div class="tactas-container-narrow py-16 lg:py-20 reveal">
        <div class="max-w-[700px]">
          <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-tactas-accent-strong">FAQ</p>
          <h2 class="mt-4 text-[36px] font-semibold leading-[1.04] tracking-normal text-tactas-ink-strong sm:text-[48px]">
            Frequently Asked Questions
          </h2>
          <p class="mt-4 text-[15.5px] leading-relaxed text-tactas-muted">
            Have questions about how setup packaging, monthly quotas, and context indexing work? Find answers here.
          </p>
        </div>

        <div class="mt-10 space-y-3">
          {faqs.map(([question, answer]) => (
            <details class="group overflow-hidden border border-tactas-line bg-white transition-all duration-300 [&[open]]:border-tactas-accent-line [&[open]]:bg-white">
              <summary class="flex cursor-pointer list-none items-center justify-between gap-5 p-5 text-[16px] font-semibold text-tactas-ink-strong outline-none select-none sm:text-[17px]">
                {question}
                <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full border border-tactas-line bg-tactas-bg text-tactas-accent transition group-open:rotate-90 group-open:border-tactas-accent-line">
                  <ArrowRight class="h-3.5 w-3.5" stroke-width={2.2} />
                </span>
              </summary>
              <div class="max-w-[800px] border-t border-tactas-line-soft px-5 pb-5 pt-4">
                <p class="text-[14.5px] leading-relaxed text-tactas-muted sm:text-[15.5px]">{answer}</p>
              </div>
            </details>
          ))}
        </div>
        </div>
      </section>

      <CTASection
        eyebrow="Task review"
        title="Map one business task before you commit to a build."
        description="Share the repeated work, knowledge sources, current tools, and output you want an agent to prepare."
      >
        <div slot="aside" class="tactas-surface-soft p-6">
          <div class="flex items-start gap-4">
            <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-[8px] border border-tactas-accent-line bg-tactas-accent-soft text-tactas-accent-strong">
              <Mail class="h-5 w-5" stroke-width={1.9} />
            </span>
            <div>
              <h3 class="text-[18px] font-semibold tracking-normal text-tactas-ink-strong">Prefer email?</h3>
              <p class="mt-2 text-[14px] leading-relaxed text-tactas-muted">
                Send the details behind your task to <a href={`mailto:${brandEmail}`} class="text-tactas-accent-strong font-semibold hover:text-tactas-ink-strong">{brandEmail}</a>.
              </p>
            </div>
          </div>
          <a href="/contact" class="tactas-button-primary mt-6 w-full">
            Book a review
            <ArrowRight class="ml-2 h-4 w-4" stroke-width={2} />
          </a>
        </div>
      </CTASection>
    </main>
  </div>

  <style is:global>
    .tactas-pricing-style {
      position: relative;
      isolation: isolate;
      overflow: hidden;
      background: var(--bg);
    }

    .tactas-pricing-style::before {
      content: "";
      position: fixed;
      inset: 0;
      z-index: 9999;
      pointer-events: none;
      opacity: 0.018;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
    }

    .tactas-pricing-style main > section {
      position: relative;
      isolation: isolate;
    }

    .tactas-pricing-hero {
      overflow: hidden;
    }

    .tactas-pricing-hero::before,
    .tactas-pricing-hero::after {
      content: "";
      position: absolute;
      z-index: -1;
      pointer-events: none;
      border-radius: 999px;
      filter: blur(64px);
    }

    .tactas-pricing-hero::before {
      top: 7%;
      left: 50%;
      width: min(820px, 86vw);
      height: 360px;
      transform: translateX(-50%);
      background: rgba(103, 232, 249, 0.16);
    }

    .tactas-pricing-hero::after {
      right: -18%;
      bottom: 3%;
      width: min(520px, 68vw);
      height: 260px;
      background: rgba(215, 162, 42, 0.14);
    }

    .tactas-pricing-proof,
    .tactas-pricing-style article,
    .tactas-pricing-style details,
    .tactas-pricing-style [class*="border"][class*="bg-white"] {
      border-radius: 18px !important;
    }

    .tactas-pricing-style a,
    .tactas-pricing-style article,
    .tactas-pricing-style details {
      transition-timing-function: cubic-bezier(0.22, 1, 0.36, 1);
    }
  </style>
</BaseLayout>
