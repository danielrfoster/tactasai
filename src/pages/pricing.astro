---
import { ArrowRight, Bot, BrainCircuit, Check, Mail, Network, ShieldCheck, Zap, Sparkles } from "@lucide/astro";
import CTASection from "../components/CTASection.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getBrandEmail, getOrganization, getSiteUrl } from "../lib/site";

const siteUrl = getSiteUrl();
const brandEmail = getBrandEmail();
const organization = getOrganization();
const pageUrl = `${siteUrl}/pricing`;

const title = "Managed AI Agent Pricing for Business Operations | Tactas AI";
const description =
  "Explore Tactas AI pricing for managed agent setup, company knowledge layers, connected tools, monthly usage quota, and ongoing managed operation.";

const buildPlans = [
  {
    id: "managed-agent-launch",
    name: "Ignition",
    eyebrow: "Single workflow build",
    summary: "One-time implementation for the first production workflow: company knowledge, agent behavior, and connected actions configured for your business.",
    price: "$3,500",
    suffix: "setup",
    cta: "Scope build",
    href: "/contact",
    includedLabel: "Implementation work:",
    points: [
      "Define the workflow, inputs, outputs, and success criteria",
      "Prepare and index the required company knowledge",
      "Configure agent behavior, retrieval, and connected tool actions",
      "Test with real examples and operational edge cases",
      "Launch with monitoring and an improvement backlog",
    ],
    icon: Bot,
  },
  {
    id: "agent-expansion",
    name: "Forge",
    eyebrow: "Expansion build",
    summary: "Add a new workflow, output, data source, or connected business action on top of an existing Tactas system.",
    price: "$8,000",
    suffix: "setup",
    cta: "Scope expansion",
    href: "/contact",
    includedLabel: "Expansion work:",
    points: [
      "Extend indexed context or add new source systems",
      "Add workflow variants, outputs, and automation actions",
      "Connect additional business tools or records",
      "Tune retrieval, routing, review points, and quality checks",
    ],
    icon: Zap,
    popular: true,
  },
  {
    id: "operating-layer",
    name: "Grid",
    eyebrow: "Operating layer rollout",
    summary: "A larger implementation program for teams that need several workflows, shared context, and connected actions across systems.",
    price: "From $25,000",
    suffix: "setup",
    cta: "Scope program",
    href: "/contact",
    includedLabel: "Program work:",
    points: [
      "Architect shared context across teams, knowledge sources, and tools",
      "Configure multiple agent workflows under one operating layer",
      "Integrate core business systems and permission boundaries",
      "Define rollout, monitoring, ownership, and improvement cadence",
    ],
    icon: Network,
  },
];

const ongoingPlans = [
  {
    id: "core-quota",
    name: "Signal",
    eyebrow: "1x operating quota",
    summary: "For launched agent systems with steady monthly usage.",
    price: "$499",
    suffix: "/mo",
    quota: "1x operating quota",
    cta: "Start Signal",
    href: "/contact",
    includedLabel: "Includes:",
    points: [
      "1x monthly operating quota",
      "1x model/runtime quota",
      "1x indexed company context capacity",
      "1x retrieval and monitoring volume",
      "1x connected tool action allowance",
      "Standard improvement allocation",
    ],
    icon: BrainCircuit,
  },
  {
    id: "growth-quota",
    name: "Vector",
    eyebrow: "10x Signal quota",
    summary: "For teams using managed agents in daily operations.",
    price: "$1,999",
    suffix: "/mo",
    quota: "10x Signal quota",
    cta: "Start Vector",
    href: "/contact",
    popular: true,
    includedLabel: "Includes:",
    points: [
      "10x Signal operating quota",
      "10x model/runtime quota",
      "10x indexed company context capacity",
      "10x retrieval and monitoring volume",
      "10x connected tool action allowance",
      "Higher improvement allocation",
    ],
    icon: Zap,
  },
  {
    id: "scale-quota",
    name: "Atlas",
    eyebrow: "Unmetered standard quota",
    summary: "For high-volume operations that need broad operating capacity across most supported models, large indexed context, retrieval-heavy workflows, monitoring, and connected business actions.",
    price: "From $7,500",
    suffix: "/mo",
    quota: "Unmetered standard quota",
    cta: "Talk to sales",
    href: "/contact",
    includedLabel: "Includes:",
    points: [
      "Unmetered standard operating quota for most supported models",
      "Premium / high-cost model quota up to 12x Vector",
      "Custom indexed context capacity",
      "Custom retrieval and monitoring volume",
      "Custom connected tool action allowance",
      "Custom improvement allocation",
    ],
    icon: ShieldCheck,
  },
];

const pricingSections = [
  {
    id: "build-packages",
    eyebrow: "Setup and build",
    phaseIndex: "01",
    phaseTitle: "Setup & Implementation",
    title: "One-time build work before monthly usage.",
    summary: "Tactas requires implementation work before the monthly quota starts: workflow mapping, company data preparation, tool connections, agent configuration, testing, and launch.",
    priceLabel: "One-time fee",
    plans: buildPlans,
    themeColor: "text-[#0891B2] bg-[#E6FBFF] border-[#06B6D4]/20",
  },
  {
    id: "ongoing-fees",
    eyebrow: "Monthly usage",
    phaseIndex: "02",
    phaseTitle: "Monthly Operating Quota",
    title: "Monthly Operating Quota",
    summary: "All monthly plans run on the same managed agent system. Plans do not unlock or remove core features. They define monthly operating capacity: model/runtime usage, indexed context capacity, retrieval volume, connected tool actions, monitoring volume, and improvement allocation.",
    priceLabel: "Monthly plan",
    note: "Subject to fair use, agreed operating scope, system safety limits, and premium model quota.",
    plans: ongoingPlans,
    themeColor: "text-[#B45309] bg-[#FEF3C7] border-[#FDE68A]/30",
  },
];

const plans = [...buildPlans, ...ongoingPlans];

const securityItems = [
  {
    label: "Setup scope",
    body: "Pay for the data preparation, tool connections, and workflow configuration the system needs.",
    icon: ShieldCheck,
  },
  {
    label: "Usage quota",
    body: "Choose a monthly plan around agent usage, model/runtime resources, context, and tool actions.",
    icon: Zap,
  },
  {
    label: "Managed operation",
    body: "Keep monitoring, support, and improvement cycles aligned with production usage.",
    icon: ShieldCheck,
  },
  {
    label: "Expansion path",
    body: "Start with one operational workflow and expand once the system pattern is proven.",
    icon: Zap,
  },
];

const faqs = [
  [
    "How do I start?",
    "Start by booking a review. We map the repeated work, company knowledge, tools involved, and the output an AI agent should prepare before scoping the paid build.",
  ],
  [
    "What does pricing depend on?",
    "Setup pricing depends on workflow complexity, company knowledge sources, connected tools, automation steps, and launch requirements. Monthly pricing depends on the operating quota required for model/runtime usage, indexed context, retrieval, monitoring, connected tool actions, and improvement allocation.",
  ],
  [
    "How do monthly plans work?",
    "Monthly plans run on the same managed agent system. They do not unlock or remove core features; they define operating capacity. Signal is the base quota, Vector is 10x Signal, and Atlas provides broader standard operating capacity with agreed scope and premium model limits.",
  ],
  [
    "Do we need all company data connected first?",
    "No. A good first launch uses the minimum knowledge and tools required for one useful business task, then expands as the pattern proves value.",
  ],
  [
    "Can Tactas update tools automatically?",
    "Yes. Agents can prepare or apply updates in connected tools based on the permissions and automation scope chosen for the task.",
  ],
  [
    "Is the knowledge layer separate from task automation?",
    "It is a supporting capability. Company knowledge gives managed AI agents the context they need to answer, summarize, prepare outputs, and automate work.",
  ],
  [
    "Can we expand beyond the first task?",
    "Yes. Once one workflow works, Tactas can reuse the knowledge layer, connected tools, and agent patterns across adjacent operational workflows.",
  ],
];

const offerCatalog = {
  "@type": "OfferCatalog",
  name: "Tactas AI pricing model",
  itemListElement: plans.map((plan) => ({
    "@type": "Offer",
    name: `${plan.name} plan`,
    category: plan.eyebrow,
    url: `${pageUrl}#${plan.id}`,
    priceSpecification: {
      "@type": "PriceSpecification",
      priceCurrency: "USD",
      description: `${plan.price} ${plan.suffix}`.trim(),
    },
    itemOffered: {
      "@type": "Service",
      name: `${plan.name} managed AI agent plan`,
      description: plan.summary,
      provider: { "@id": `${siteUrl}/#organization` },
    },
  })),
};

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    organization,
    {
      "@type": "WebPage",
      "@id": `${pageUrl}#webpage`,
      name: title,
      url: pageUrl,
      description,
      isPartOf: { "@id": `${siteUrl}/#website` },
      about: { "@id": `${siteUrl}/#organization` },
      mainEntity: { "@id": `${pageUrl}#service` },
      inLanguage: "en-US",
    },
    {
      "@type": "Service",
      "@id": `${pageUrl}#service`,
      name: "Managed AI agent pricing",
      description,
      serviceType: "Managed AI agents for business task automation",
      areaServed: "Worldwide",
      provider: { "@id": `${siteUrl}/#organization` },
      hasOfferCatalog: offerCatalog,
    },
    {
      "@type": "FAQPage",
      "@id": `${pageUrl}#faq`,
      mainEntity: faqs.map(([question, answer]) => ({
        "@type": "Question",
        name: question,
        acceptedAnswer: { "@type": "Answer", text: answer },
      })),
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Home", item: `${siteUrl}/` },
        { "@type": "ListItem", position: 2, name: "Pricing", item: pageUrl },
      ],
    },
  ],
};
---

<BaseLayout
  title={title}
  description={description}
  canonical="/pricing"
  currentPath="/pricing"
  navbarTheme="light"
  navbarCtaLabel="Book a review"
  navbarCtaHref="/contact"
  keywords={[
    "managed AI agent pricing",
    "business task automation pricing",
    "managed AI agents for business operations",
    "company knowledge automation pricing",
    "connected business tools AI",
    "AI task automation for business teams",
  ]}
  openGraph={{
    title,
    description,
    url: pageUrl,
    type: "website",
    images: [
      {
        url: "/tactas-ai-managed-agent-systems-og.jpg",
        width: 1734,
        height: 907,
        alt: "Tactas AI managed agent pricing",
      },
    ],
  }}
  twitter={{
    card: "summary_large_image",
    title,
    description,
    images: ["/tactas-ai-managed-agent-systems-og.jpg"],
  }}
  jsonLd={jsonLd}
>
  <div class="relative min-h-screen bg-[#F6F8FB] text-[#07324A] selection:bg-[#06B6D4]/18 overflow-hidden">
    <!-- Decorative premium background mesh gradients & grids -->
    <div class="pointer-events-none absolute left-0 right-0 top-0 -z-10 h-[650px] overflow-hidden">
      <div class="absolute -left-48 -top-48 h-[450px] w-[450px] rounded-full bg-[#06B6D4]/9 blur-[120px]"></div>
      <div class="absolute right-10 top-32 h-[450px] w-[450px] rounded-full bg-[#2F66FF]/6 blur-[120px]"></div>
      <div class="absolute inset-0 opacity-[0.03] [background-image:linear-gradient(to_right,#07324A_1px,transparent_1px),linear-gradient(to_bottom,#07324A_1px,transparent_1px)] [background-size:56px_56px]"></div>
    </div>

    <main>
      <!-- Hero Section -->
      <section class="relative border-b border-black/[0.06] bg-[#F6F8FB]/30 backdrop-blur-[2px]">
        <div class="mx-auto w-full max-w-[1240px] px-5 py-20 sm:px-8 lg:px-10 lg:py-26 reveal">
          <div class="max-w-[850px]">
            <div class="inline-flex items-center gap-2 rounded-full border border-[#06B6D4]/20 bg-[#E6FBFF]/80 px-3.5 py-1.5 text-[11px] font-mono font-semibold uppercase tracking-[0.18em] text-[#0891B2] shadow-xs">
              <Sparkles class="h-3.5 w-3.5" stroke-width={2} />
              Transparent Pricing
            </div>
            <h1 class="mt-6 text-[clamp(2.6rem,6.8vw,5rem)] font-extrabold leading-[1.04] tracking-tight text-[#07324A]">
              Pricing for managed <span class="text-[#06B6D4]">agent systems</span> at work
            </h1>
            <p class="mt-6 max-w-[700px] text-[18px] sm:text-[20px] leading-relaxed text-[#475569]">
              Tactas pricing matches your deployment growth. Pay a one-time build setup for workflow configuration and tool connectivity, followed by a flexible monthly capacity plan.
            </p>
            <div class="mt-10 flex flex-col gap-3 sm:flex-row sm:items-center">
              <a href="/contact" class="inline-flex h-12 items-center justify-center rounded-lg bg-[#06B6D4] px-6 text-[14.5px] font-semibold text-white shadow-[0_10px_25px_-10px_rgba(6,182,212,0.5)] transition hover:bg-[#0891B2] active:scale-98 cursor-pointer">
                Book a Review
              </a>
              <a href="#plans" class="inline-flex h-12 items-center justify-center rounded-lg border border-black/10 bg-white/70 px-6 text-[14.5px] font-semibold text-[#07324A] shadow-xs transition hover:border-[#06B6D4]/40 hover:text-[#0891B2] hover:bg-white active:scale-98">
                Explore Packages
              </a>
            </div>
          </div>
        </div>
      </section>

      <!-- Plans Grid Section with Step Timeline headers -->
      <section id="plans" class="mx-auto w-full max-w-[1240px] px-5 py-16 sm:px-8 lg:px-10 lg:py-24">
        <div class="space-y-24">
          {pricingSections.map((section) => (
            <div id={section.id} class="scroll-mt-24 reveal">
              <!-- Styled Stage/Timeline Header -->
              <div class="max-w-[800px] border-b border-black/[0.05] pb-6">
                <div class="flex items-center gap-3">
                  <span class:list={["flex h-7 w-7 items-center justify-center rounded-full text-[11px] font-mono font-bold border", section.themeColor]}>
                    {section.phaseIndex}
                  </span>
                  <span class:list={["font-mono text-[10px] uppercase tracking-[0.24em] font-bold", section.phaseIndex === "01" ? "text-[#0891B2]" : "text-[#B45309]"]}>
                    STAGE {section.phaseIndex}: {section.phaseTitle}
                  </span>
                </div>
                <h2 class="mt-4 text-[32px] sm:text-[44px] font-extrabold leading-tight tracking-tight text-[#07324A]">
                  {section.title}
                </h2>
                <p class="mt-4 text-[16px] sm:text-[17.5px] leading-relaxed text-[#475569]">
                  {section.summary}
                </p>
              </div>

              <!-- High-Contrast 3-Column Plan Cards -->
              <div class="mt-10 grid gap-8 lg:grid-cols-3">
                {section.plans.map((plan) => {
                  const Icon = plan.icon;
                  return (
                    <article
                      id={plan.id}
                      class:list={[
                        "relative flex flex-col justify-between rounded-[24px] border bg-white p-7 sm:p-8 transition-all duration-300 hover:-translate-y-1.5 h-full",
                        plan.popular
                          ? "border-[#06B6D4] shadow-[0_30px_80px_-40px_rgba(6,182,212,0.25)] ring-[1.5px] ring-[#06B6D4]/15 bg-gradient-to-b from-[#E6FBFF]/20 to-white"
                          : "border-black/[0.08] shadow-[0_20px_50px_-36px_rgba(7,50,74,0.12)] hover:shadow-[0_24px_60px_-28px_rgba(6,182,212,0.18)] hover:border-[#06B6D4]/40"
                      ]}
                    >
                      {/* Popular Banner Ribbon */}
                      {plan.popular && (
                        <div class="absolute -right-16 top-6 rotate-45 bg-[#06B6D4] text-white text-[9px] font-mono font-bold tracking-[0.2em] py-1.5 px-16 uppercase shadow-md select-none">
                          Popular
                        </div>
                      )}

                      <div>
                        <div class="flex items-start justify-between gap-3">
                          <span class="flex h-12 w-12 items-center justify-center rounded-xl border border-[#BAE6FD] bg-[#E6FBFF] text-[#0E7490] shadow-xs">
                            <Icon class="h-5.5 w-5.5" stroke-width={1.9} />
                          </span>
                          {plan.popular && (
                            <span class="rounded-full border border-[#A7F3D0] bg-[#ECFDF5] px-2.5 py-1 text-[10px] font-mono font-bold uppercase tracking-[0.12em] text-[#047857] shadow-xs mr-8 lg:mr-0">
                              Recommended
                            </span>
                          )}
                        </div>

                        <p class="mt-8 text-[12px] font-mono font-bold uppercase tracking-[0.16em] text-[#64748B]">{plan.eyebrow}</p>
                        <h3 class="mt-2 text-[26px] sm:text-[30px] font-extrabold tracking-tight text-[#07324A]">{plan.name}</h3>
                        <p class="mt-2.5 text-[14.5px] leading-relaxed text-[#64748B]">{plan.summary}</p>

                        <!-- Sleek price box widget -->
                        <div class="mt-6 rounded-2xl border border-black/[0.04] bg-[#F6F8FB]/80 p-5 shadow-xs">
                          <p class="font-mono text-[9px] uppercase tracking-[0.16em] text-[#64748B]">{plan.priceLabel ?? section.priceLabel}</p>
                          <div class="mt-2 flex flex-wrap items-baseline gap-x-2 gap-y-1">
                            <p class="text-[34px] sm:text-[38px] font-extrabold leading-none tracking-tight text-[#07324A]">{plan.price}</p>
                            <p class="text-[13.5px] font-medium text-[#64748B]">{plan.suffix}</p>
                          </div>
                          {plan.quota && (
                            <div class="mt-3 inline-flex items-center gap-1 rounded bg-[#E6FBFF] px-2.5 py-0.5 text-[11px] font-mono font-bold text-[#0891B2] border border-[#06B6D4]/15">
                              ⚡ {plan.quota}
                            </div>
                          )}
                        </div>
                      </div>

                      <div class="flex flex-col">
                        <a
                          href={plan.href}
                          class:list={[
                            "mt-7 inline-flex h-11 items-center justify-center rounded-lg px-4 text-[14.5px] font-semibold transition active:scale-98 cursor-pointer shadow-xs",
                            plan.popular
                              ? "bg-[#06B6D4] text-white hover:bg-[#0891B2] shadow-[0_8px_20px_-8px_rgba(6,182,212,0.4)]"
                              : "border border-black/10 bg-white text-[#07324A] hover:border-[#06B6D4]/40 hover:text-[#0891B2] hover:bg-white"
                          ]}
                        >
                          {plan.cta}
                        </a>

                        <!-- Custom circular checkmarks list -->
                        <div class="mt-8 border-t border-black/[0.05] pt-6">
                          <p class="text-[13.5px] font-bold text-[#07324A]">{plan.includedLabel}</p>
                          <ul class="mt-4 space-y-3.5">
                            {plan.points.map((point) => (
                              <li class="flex items-start gap-3 text-[13px] leading-relaxed text-[#475569]">
                                <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-[#ECFDF5] border border-[#A7F3D0] text-[#047857] shadow-xs">
                                  <Check class="h-3 w-3" stroke-width={3} />
                                </span>
                                <span>{point}</span>
                              </li>
                            ))}
                          </ul>
                        </div>
                      </div>
                    </article>
                  );
                })}
              </div>
              
              {section.note && (
                <div class="mt-6 flex items-start gap-2 max-w-[850px] text-[13px] leading-relaxed text-[#64748B] border-l border-black/10 pl-3">
                  <span class="text-[#06B6D4]">ℹ</span>
                  <p>{section.note}</p>
                </div>
              )}
            </div>
          ))}
        </div>
      </section>

      <!-- Operational highlights section -->
      <section class="border-t border-b border-black/[0.06] bg-white">
        <div class="mx-auto grid w-full max-w-[1240px] gap-12 px-5 py-16 sm:px-8 lg:grid-cols-[0.9fr_1.1fr] lg:px-10 lg:py-24 reveal">
          <div>
            <div class="inline-flex items-center gap-1.5 rounded-full bg-[#FEF3C7] border border-[#FDE68A]/50 px-3 py-1 text-[11px] font-mono font-semibold uppercase tracking-[0.18em] text-[#B45309]">
              ✦ Lifecycle
            </div>
            <h2 class="mt-4 max-w-[720px] text-[34px] sm:text-[44px] font-extrabold leading-tight tracking-tight text-[#07324A]">
              Pay for setup complexity first, then the monthly quota you use.
            </h2>
            <p class="mt-5 text-[16px] sm:text-[17.5px] leading-relaxed text-[#475569]">
              Tactas builds are designed around reuse. Start by automating a single workflow using your existing company knowledge and business tools, and expand only as the system pattern proves its value. As your team grows, adjust quota limits around model capacity and tool volumes.
            </p>
          </div>

          <!-- Styled security cards grid -->
          <div class="grid gap-6 sm:grid-cols-2">
            {securityItems.map((item) => {
              const Icon = item.icon;
              return (
                <article class="group rounded-2xl border border-black/5 bg-[#F6F8FB]/50 p-6 shadow-xs hover:border-[#06B6D4]/30 hover:shadow-[0_16px_40px_-24px_rgba(6,182,212,0.18)] transition duration-300">
                  <div class="flex h-11 w-11 items-center justify-center rounded-xl border border-[#BAE6FD] bg-[#E6FBFF] text-[#0E7490] shadow-xs">
                    <Icon class="h-5 w-5" stroke-width={1.9} />
                  </div>
                  <h3 class="mt-5 text-[18px] font-bold tracking-tight text-[#07324A]">{item.label}</h3>
                  <p class="mt-2 text-[14px] leading-relaxed text-[#64748B]">{item.body}</p>
                </article>
              );
            })}
          </div>
        </div>
      </section>

      <!-- Sleek interactive FAQ Accordion -->
      <section class="mx-auto w-full max-w-[960px] px-5 py-20 sm:px-8 lg:px-10 lg:py-24 reveal">
        <div class="text-center max-w-[700px] mx-auto">
          <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-[#0891B2]">FAQ</p>
          <h2 class="mt-3 text-[34px] sm:text-[44px] font-extrabold leading-tight tracking-tight text-[#07324A]">
            Frequently Asked Questions
          </h2>
          <p class="mt-4 text-[16px] text-[#64748B]">
            Have questions about how setup packaging, monthly quotas, and context indexing work? Find answers here.
          </p>
        </div>

        <div class="mt-14 space-y-4">
          {faqs.map(([question, answer]) => (
            <details class="group rounded-2xl border border-black/5 bg-white shadow-xs overflow-hidden transition-all duration-300 [&[open]]:bg-[#E6FBFF]/20 [&[open]]:border-[#06B6D4]/30">
              <summary class="flex cursor-pointer list-none items-center justify-between gap-5 p-6 text-[16px] sm:text-[18px] font-bold text-[#07324A] outline-none select-none">
                {question}
                <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full border border-black/5 bg-white/70 text-[#06B6D4] transition group-open:rotate-90 group-open:border-[#06B6D4]/25 shadow-xs">
                  <ArrowRight class="h-3.5 w-3.5" stroke-width={2.2} />
                </span>
              </summary>
              <div class="px-6 pb-6 pt-1 max-w-[800px] border-t border-black/[0.02]">
                <p class="text-[14.5px] sm:text-[15.5px] leading-relaxed text-[#475569]">{answer}</p>
              </div>
            </details>
          ))}
        </div>
      </section>

      <!-- Call to Action redone with a beautiful slot override -->
      <CTASection
        eyebrow="Task review"
        title="Map one business task before you commit to a build."
        description="Share the repeated work, knowledge sources, current tools, and output you want an agent to prepare."
      >
        <div slot="aside" class="rounded-2xl border border-[#D8E1EA] bg-[#F6F8FB] p-6 shadow-sm backdrop-blur-[2px]">
          <div class="flex items-start gap-4">
            <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg border border-[#BAE6FD] bg-[#E6FBFF] text-[#0E7490]">
              <Mail class="h-5 w-5" stroke-width={1.9} />
            </span>
            <div>
              <h3 class="text-[18px] font-bold tracking-tight text-[#07324A]">Prefer email?</h3>
              <p class="mt-2 text-[14px] leading-relaxed text-[#64748B]">
                Send the details behind your task to <a href={`mailto:${brandEmail}`} class="text-[#0891B2] font-semibold hover:text-[#07324A]">{brandEmail}</a>.
              </p>
            </div>
          </div>
          <a href="/contact" class="mt-6 inline-flex h-11 w-full items-center justify-center rounded-lg bg-[#06B6D4] px-4 text-[14.5px] font-semibold text-white transition hover:bg-[#0891B2] shadow-[0_8px_20px_-8px_rgba(6,182,212,0.4)]">
            Book a review
            <ArrowRight class="ml-2 h-4 w-4" stroke-width={2} />
          </a>
        </div>
      </CTASection>
    </main>
  </div>
</BaseLayout>
