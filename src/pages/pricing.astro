---
import { ArrowRight, Check, CircleHelp, ShieldCheck, Sparkles, Zap } from "@lucide/astro";
import Navbar from "../components/Navbar.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getBrandEmail, getOrganization, getSiteUrl } from "../lib/site";

const siteUrl = getSiteUrl();
const brandEmail = getBrandEmail();
const organization = getOrganization();
const pageUrl = `${siteUrl}/pricing`;

const title = "Managed AI Agent Systems Pricing | Tactas AI";
const description =
  "Explore Tactas AI pricing for managed AI agent systems, workflow pilots, production operators, integrations, approvals, monitoring, and support for business operations.";

const plans = [
  {
    id: "pilot",
    name: "Pilot",
    eyebrow: "First workflow",
    price: "Scoped quote",
    summary: "Validate one high-value workflow with a focused agent system and clear success criteria.",
    bestFor: "Teams proving one repetitive support, admin, CRM, or back-office workflow.",
    points: [
      "Workflow discovery and success criteria",
      "One focused AI operator or agent workflow",
      "Knowledge, SOP, and data readiness review",
      "Light integration and launch plan",
      "Pilot handoff with expansion recommendations",
    ],
    cta: "Scope a pilot",
  },
  {
    id: "managed",
    name: "Managed",
    eyebrow: "Production workflow",
    price: "Custom monthly",
    summary: "Run a supervised agent system in production with integrations, approvals, monitoring, and tuning.",
    bestFor: "Operations teams ready to delegate recurring work with human control.",
    points: [
      "Production operator setup and testing",
      "Business tool and knowledge connections",
      "Approval gates, escalation paths, and logs",
      "Monitoring, issue review, and monthly tuning",
      "Ongoing implementation and operator support",
    ],
    cta: "Review managed pricing",
    highlighted: true,
  },
  {
    id: "scale",
    name: "Scale",
    eyebrow: "Multiple teams",
    price: "Enterprise",
    summary: "Standardize agent systems across teams, workflows, permissions, reporting, and deployment needs.",
    bestFor: "Companies expanding AI operations across departments or regulated workflows.",
    points: [
      "Multiple operators and workflow families",
      "Advanced governance and access design",
      "Private deployment and security review options",
      "Cross-team reporting and operating cadence",
      "Roadmap planning for broader AI adoption",
    ],
    cta: "Discuss scale plan",
  },
];

const scopeItems = [
  ["Workflow complexity", "Steps, decision rules, exception paths, approval needs, and how much judgment the operator must handle."],
  ["Systems and data", "CRMs, helpdesks, inboxes, documents, internal tools, APIs, permissions, and source quality."],
  ["Controls and risk", "Human review, escalation boundaries, audit logs, monitoring, compliance review, and deployment constraints."],
  ["Operating support", "Launch support, response expectations, monthly tuning, workflow changes, and stakeholder reporting."],
];

const comparisonRows = [
  ["Primary goal", "Prove one workflow", "Run one production workflow", "Scale across teams"],
  ["Workflow coverage", "One narrow scope", "One managed production scope", "Multiple workflow families"],
  ["Integrations", "Light integration plan", "Connected business systems", "Advanced and private options"],
  ["Controls", "Launch readiness review", "Approvals, logs, escalation", "Governance and reporting layer"],
  ["Support", "Pilot support", "Monthly tuning and support", "Operating cadence and roadmap"],
];

const faqs = [
  [
    "How does Tactas AI pricing work?",
    "Pricing is scoped around the workflow, integrations, controls, deployment needs, and support level. Most customers start with a pilot or one managed production workflow before expanding.",
  ],
  [
    "Do you offer fixed pricing for AI agent systems?",
    "Not usually. Fixed pricing can hide the real work involved in business systems, permissions, knowledge quality, approvals, and monitoring. Tactas prices the operating surface that needs to work reliably.",
  ],
  [
    "Can we start with one AI operator?",
    "Yes. The Pilot plan is designed for one focused workflow with clear success criteria, so your team can validate the use case before moving into production or adding more operators.",
  ],
  [
    "Is implementation included in pricing?",
    "Yes. Pricing can include workflow mapping, agent setup, data preparation, system connections, testing, launch support, controls, monitoring, and ongoing improvement for the selected scope.",
  ],
  [
    "What types of workflows can be priced?",
    "Common pricing requests include customer support automation, CRM workflow automation, back-office automation, document intake, internal knowledge workflows, approval queues, and operations follow-up.",
  ],
];

const offerCatalog = {
  "@type": "OfferCatalog",
  name: "Tactas AI pricing plans",
  itemListElement: plans.map((plan) => ({
    "@type": "Offer",
    name: `${plan.name} plan`,
    category: plan.eyebrow,
    url: `${pageUrl}#${plan.id}`,
    priceSpecification: {
      "@type": "PriceSpecification",
      priceCurrency: "USD",
      description: plan.price,
    },
    itemOffered: {
      "@type": "Service",
      name: `${plan.name} managed AI agent system`,
      description: plan.summary,
      provider: { "@id": `${siteUrl}/#organization` },
    },
  })),
};

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    organization,
    {
      "@type": "WebPage",
      "@id": `${pageUrl}#webpage`,
      name: title,
      url: pageUrl,
      description,
      isPartOf: { "@id": `${siteUrl}/#website` },
      about: { "@id": `${siteUrl}/#organization` },
      mainEntity: { "@id": `${pageUrl}#service` },
      inLanguage: "en-US",
    },
    {
      "@type": "Service",
      "@id": `${pageUrl}#service`,
      name: "Managed AI agent systems pricing",
      description,
      serviceType: "Managed AI agent systems for business operations",
      areaServed: "Worldwide",
      provider: { "@id": `${siteUrl}/#organization` },
      hasOfferCatalog: offerCatalog,
    },
    {
      "@type": "FAQPage",
      "@id": `${pageUrl}#faq`,
      mainEntity: faqs.map(([question, answer]) => ({
        "@type": "Question",
        name: question,
        acceptedAnswer: { "@type": "Answer", text: answer },
      })),
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Home", item: `${siteUrl}/` },
        { "@type": "ListItem", position: 2, name: "Pricing", item: pageUrl },
      ],
    },
  ],
};
---

<BaseLayout
  title={title}
  description={description}
  canonical="/pricing"
  keywords={[
    "managed AI agent pricing",
    "AI agent systems pricing",
    "AI operator pricing",
    "AI workflow automation pricing",
    "business operations automation pricing",
    "managed AI agents for business operations",
    "AI agents implementation pricing",
    "AI back-office automation pricing",
  ]}
  openGraph={{
    title,
    description,
    url: pageUrl,
    type: "website",
    images: [
      {
        url: "/ef4e97cc-14e2-4157-a55f-42bfa62ad8a3.png",
        width: 1200,
        height: 630,
        alt: "Tactas AI managed AI agent systems pricing",
      },
    ],
  }}
  twitter={{
    card: "summary_large_image",
    title,
    description,
    images: ["/ef4e97cc-14e2-4157-a55f-42bfa62ad8a3.png"],
  }}
  jsonLd={jsonLd}
>
  <div class="min-h-screen bg-[#F8FAFC] text-[#0F172A]">
    <Navbar currentPath="/pricing" ctaLabel="Scope pricing" ctaHref="/contact" theme="light" />

    <main>
      <section class="border-b border-[#D8E1EA] bg-white">
        <div class="mx-auto w-full max-w-[1240px] px-5 py-16 sm:px-8 lg:px-10 lg:py-24">
          <div class="grid gap-12 lg:grid-cols-[0.95fr_1.05fr] lg:items-end">
            <div>
              <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-[#0891B2]">Pricing</p>
              <h1 class="mt-4 max-w-[820px] text-4xl font-semibold leading-tight tracking-normal text-[#0F172A] sm:text-5xl lg:text-[68px]">
                Managed AI agent systems pricing.
              </h1>
            </div>
            <div class="max-w-[590px] lg:justify-self-end">
              <p class="text-[18px] leading-relaxed text-[#475569]">
                Tactas pricing is scoped around the workflow you want to delegate, the systems it touches, and the
                controls required to run it safely in production.
              </p>
              <div class="mt-7 flex flex-col gap-3 sm:flex-row">
                <a href="/contact" class="inline-flex h-12 items-center justify-center rounded-[6px] bg-[#0F172A] px-6 text-[14px] font-semibold text-white transition hover:bg-[#06B6D4]">
                  Request pricing
                </a>
                <a href="#plans" class="inline-flex h-12 items-center justify-center rounded-[6px] border border-[#94A3B8] px-6 text-[14px] font-semibold text-[#0F172A] transition hover:border-[#06B6D4] hover:text-[#0891B2]">
                  Compare plans
                </a>
              </div>
              <div class="mt-7 grid gap-3 border-t border-[#E2E8F0] pt-6 sm:grid-cols-3">
                {["Pilot first", "Production support", "Governed rollout"].map((item) => (
                  <div class="flex items-center gap-2 text-[13px] font-semibold text-[#334155]">
                    <Check class="h-4 w-4 shrink-0 text-[#06B6D4]" stroke-width={2.4} />
                    <span>{item}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </section>

      <section id="plans" class="border-b border-[#D8E1EA] bg-[#F8FAFC]">
        <div class="mx-auto w-full max-w-[1240px] px-5 py-16 sm:px-8 lg:px-10 lg:py-20">
          <div class="mb-8 max-w-3xl">
            <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-[#0891B2]">Plans</p>
            <h2 class="mt-4 text-3xl font-semibold leading-tight tracking-normal text-[#0F172A] sm:text-4xl">
              Start narrow, then expand once the operating model is proven.
            </h2>
          </div>

          <div class="grid gap-5 lg:grid-cols-3">
            {plans.map((plan) => (
              <article
                id={plan.id}
                class:list={[
                  "flex min-h-[600px] flex-col rounded-[8px] border p-6 sm:p-7",
                  plan.highlighted
                    ? "border-[#06B6D4] bg-white shadow-[0_32px_100px_-64px_rgba(8,145,178,0.65)]"
                    : "border-[#D8E1EA] bg-white",
                ]}
              >
                <div class="flex items-center justify-between gap-4">
                  <p class="font-mono text-[10px] uppercase tracking-[0.24em] text-[#0891B2]">{plan.eyebrow}</p>
                  {plan.highlighted ? (
                    <span class="inline-flex items-center gap-1 rounded-full border border-[#BAE6FD] bg-[#E6FBFF] px-2.5 py-1 text-[11px] font-semibold text-[#0E7490]">
                      <Sparkles class="h-3 w-3" stroke-width={2} />
                      Most common
                    </span>
                  ) : null}
                </div>
                <h2 class="mt-5 text-[30px] font-semibold tracking-normal text-[#0F172A]">{plan.name}</h2>
                <p class="mt-3 text-[34px] font-semibold tracking-normal text-[#0F172A]">{plan.price}</p>
                <p class="mt-4 min-h-[86px] text-[15px] leading-relaxed text-[#475569]">{plan.summary}</p>

                <div class="mt-6 rounded-[6px] border border-[#E2E8F0] bg-[#F8FAFC] p-4">
                  <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-[#64748B]">Best for</p>
                  <p class="mt-2 text-[13px] leading-relaxed text-[#334155]">{plan.bestFor}</p>
                </div>

                <ul class="mt-6 grid gap-3 border-t border-[#E2E8F0] pt-6">
                  {plan.points.map((point) => (
                    <li class="flex gap-3 text-[14px] leading-relaxed text-[#334155]">
                      <Check class="mt-0.5 h-4 w-4 shrink-0 text-[#06B6D4]" stroke-width={2.4} />
                      <span>{point}</span>
                    </li>
                  ))}
                </ul>
                <a href="/contact" class:list={[
                  "mt-auto inline-flex h-11 items-center justify-center rounded-[6px] px-4 text-[14px] font-semibold transition",
                  plan.highlighted
                    ? "bg-[#0F172A] text-white hover:bg-[#06B6D4]"
                    : "border border-[#94A3B8] text-[#0F172A] hover:border-[#06B6D4] hover:text-[#0891B2]",
                ]}>
                  {plan.cta}
                  <ArrowRight class="ml-2 h-4 w-4" stroke-width={1.8} />
                </a>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="border-b border-[#D8E1EA] bg-white">
        <div class="mx-auto w-full max-w-[1240px] px-5 py-16 sm:px-8 lg:px-10 lg:py-20">
          <div class="grid gap-10 lg:grid-cols-[0.7fr_1.3fr]">
            <div>
              <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-[#0891B2]">Compare</p>
              <h2 class="mt-4 text-3xl font-semibold leading-tight tracking-normal text-[#0F172A] sm:text-4xl">
                Choose by rollout stage.
              </h2>
              <p class="mt-4 text-[16px] leading-relaxed text-[#475569]">
                The plan is less about seat count and more about how much operational surface the agent system owns.
              </p>
            </div>
            <div class="overflow-x-auto rounded-[8px] border border-[#D8E1EA]">
              <div class="min-w-[760px]">
                <div class="grid grid-cols-[1.2fr_1fr_1fr_1fr] border-b border-[#D8E1EA] bg-[#F8FAFC] text-[12px] font-semibold uppercase tracking-[0.12em] text-[#64748B]">
                  <div class="px-4 py-3">Area</div>
                  <div class="px-4 py-3">Pilot</div>
                  <div class="px-4 py-3">Managed</div>
                  <div class="px-4 py-3">Scale</div>
                </div>
                {comparisonRows.map(([area, pilot, managed, scale]) => (
                  <div class="grid grid-cols-[1.2fr_1fr_1fr_1fr] border-b border-[#E2E8F0] text-[13px] leading-relaxed last:border-b-0">
                    <div class="bg-[#F8FAFC] px-4 py-4 font-semibold text-[#0F172A]">{area}</div>
                    <div class="px-4 py-4 text-[#475569]">{pilot}</div>
                    <div class="px-4 py-4 text-[#475569]">{managed}</div>
                    <div class="px-4 py-4 text-[#475569]">{scale}</div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </section>

      <section id="scope" class="border-b border-[#D8E1EA] bg-[#F8FAFC]">
        <div class="mx-auto grid w-full max-w-[1240px] gap-10 px-5 py-16 sm:px-8 lg:grid-cols-[0.72fr_1.28fr] lg:px-10 lg:py-20">
          <div>
            <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-[#0891B2]">How scope is priced</p>
            <h2 class="mt-4 text-4xl font-semibold leading-tight tracking-normal text-[#0F172A] sm:text-5xl">
              Clear inputs before a quote.
            </h2>
            <p class="mt-5 text-[16px] leading-relaxed text-[#475569]">
              We price the real operating surface: what the operator does, where it works, and how much control and
              support your team needs after launch.
            </p>
          </div>
          <div class="grid gap-4 sm:grid-cols-2">
            {scopeItems.map(([itemTitle, body], index) => (
              <article class="rounded-[8px] border border-[#D8E1EA] bg-white p-5">
                <div class="flex h-10 w-10 items-center justify-center rounded-[6px] border border-[#BAE6FD] bg-[#E6FBFF] text-[#06B6D4]">
                  {index === 0 ? <Zap class="h-5 w-5" stroke-width={1.8} /> : <ShieldCheck class="h-5 w-5" stroke-width={1.8} />}
                </div>
                <h3 class="mt-5 text-[18px] font-semibold tracking-normal text-[#0F172A]">{itemTitle}</h3>
                <p class="mt-2 text-[14px] leading-relaxed text-[#475569]">{body}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="bg-[#0F172A] text-white">
        <div class="mx-auto grid w-full max-w-[1240px] gap-10 px-5 py-16 sm:px-8 lg:grid-cols-[1fr_0.8fr] lg:px-10 lg:py-20">
          <div>
            <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-[#67E8F9]">Pricing review</p>
            <h2 class="mt-4 max-w-[720px] text-4xl font-semibold leading-tight tracking-normal sm:text-5xl">
              Get pricing for your first managed agent system.
            </h2>
            <p class="mt-5 max-w-[650px] text-[16px] leading-relaxed text-white/68">
              Share the workflow, tools, approval rules, and target launch timeline. We will recommend the right
              rollout path and next steps.
            </p>
          </div>
          <div class="rounded-[8px] border border-white/12 bg-white/[0.04] p-6">
            <div class="flex items-start gap-3">
              <CircleHelp class="mt-1 h-5 w-5 shrink-0 text-[#67E8F9]" stroke-width={1.8} />
              <div>
                <h3 class="text-[20px] font-semibold tracking-normal">Prefer email?</h3>
                <p class="mt-2 text-[14px] leading-relaxed text-white/68">
                  Send a short note to <a class="text-[#67E8F9] hover:text-white" href={`mailto:${brandEmail}`}>{brandEmail}</a>
                  {" "}with the workflow you want priced.
                </p>
              </div>
            </div>
            <a href="/contact" class="mt-7 inline-flex h-11 w-full items-center justify-center rounded-[6px] bg-[#06B6D4] px-4 text-[14px] font-semibold text-white transition hover:bg-[#0891B2]">
              Request pricing
            </a>
          </div>
        </div>
      </section>

      <section class="bg-white">
        <div class="mx-auto w-full max-w-[1240px] px-5 py-16 sm:px-8 lg:px-10">
          <div class="max-w-3xl">
            <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-[#0891B2]">FAQ</p>
            <h2 class="mt-4 text-4xl font-semibold leading-tight tracking-normal text-[#0F172A]">
              Managed AI agent pricing questions
            </h2>
          </div>
          <div class="mt-8 divide-y divide-[#D8E1EA] border-y border-[#D8E1EA]">
            {faqs.map(([question, answer]) => (
              <details class="group py-5">
                <summary class="flex cursor-pointer list-none items-center justify-between gap-5 text-[17px] font-semibold text-[#0F172A]">
                  {question}
                  <ArrowRight class="h-4 w-4 shrink-0 text-[#06B6D4] transition group-open:rotate-90" stroke-width={1.8} />
                </summary>
                <p class="mt-3 max-w-3xl text-[15px] leading-relaxed text-[#475569]">{answer}</p>
              </details>
            ))}
          </div>
        </div>
      </section>
    </main>
  </div>
</BaseLayout>
