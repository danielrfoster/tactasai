---
import { ArrowRight, Bot, BrainCircuit, Check, Mail, Network, ShieldCheck, Sparkles, Zap } from "@lucide/astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getBrandEmail, getOrganization, getSiteUrl } from "../lib/site";

const siteUrl = getSiteUrl();
const brandEmail = getBrandEmail();
const organization = getOrganization();
const pageUrl = `${siteUrl}/pricing`;

const title = "Managed AI Agent Pricing for Business Task Automation | Tactas AI";
const description =
  "Explore Tactas AI pricing for task reviews, managed AI agents, company knowledge layers, connected business tools, and ongoing business task automation.";

const buildPlans = [
  {
    id: "task-review",
    name: "Task Review",
    eyebrow: "Find the first task",
    summary: "Map one repeated business task, the knowledge behind it, the tools involved, and the outputs an AI agent should prepare.",
    price: "Scoped",
    suffix: "review",
    cta: "Request task review",
    href: "/contact",
    includedLabel: "Review includes:",
    points: [
      "Choose one repeated business task with clear value",
      "Map knowledge sources, tools, inputs, and expected outputs",
      "Identify where the agent should answer, summarize, update, or automate",
      "Define the first launch scope and success criteria",
    ],
    icon: Sparkles,
  },
  {
    id: "managed-task",
    name: "Managed Task",
    eyebrow: "One automated task",
    summary: "Deploy one managed AI agent that uses company knowledge and connected tools to prepare action-ready work.",
    price: "Scoped quote",
    suffix: "implementation",
    cta: "Scope task",
    href: "/contact",
    popular: true,
    includedLabel: "Everything in Task Review, plus:",
    points: [
      "Prepare the company knowledge and business context the agent needs",
      "Connect the tools involved in the task",
      "Build the output pattern, task flow, and automation steps",
      "Launch with monitoring, quality review, and improvement cycles",
    ],
    icon: Bot,
  },
  {
    id: "operating-layer",
    name: "Operating Layer",
    eyebrow: "Multiple business tasks",
    summary: "Connect several task patterns under one managed AI operating layer for business operations.",
    price: "Custom",
    suffix: "scope",
    cta: "Talk to sales",
    href: "/contact",
    includedLabel: "Everything in Managed Task, plus:",
    points: [
      "Design shared context across teams, knowledge sources, and tools",
      "Deploy multiple managed agents for related business tasks",
      "Create reusable company knowledge and task patterns",
      "Add advanced permissions, integration scope, and rollout support",
    ],
    icon: Network,
  },
];

const ongoingPlans = [
  {
    id: "plus",
    name: "Plus",
    eyebrow: "Light ongoing operation",
    summary: "For a launched task that needs basic ongoing support, monitoring, and refinement.",
    price: "$49.99",
    suffix: "/ month",
    cta: "Start ongoing",
    href: "/contact",
    includedLabel: "Ongoing includes:",
    points: ["Standard usage", "One active task pattern", "Basic monitoring", "Email support", "Monthly improvement notes"],
    icon: BrainCircuit,
  },
  {
    id: "pro",
    name: "Pro",
    eyebrow: "Growing task volume",
    summary: "For teams using managed agents across heavier daily work and connected tools.",
    price: "$99.99",
    suffix: "/ month",
    cta: "Start ongoing",
    href: "/contact",
    popular: true,
    includedLabel: "Everything in Plus, and:",
    points: ["More usage volume", "Up to 3 active task patterns", "Priority improvement cycles", "Tool connection support", "Expanded context handling"],
    icon: Zap,
  },
  {
    id: "max",
    name: "Max",
    eyebrow: "Higher operating load",
    summary: "For teams that need more context, higher volume, and more managed agent work in production.",
    price: "$199.99",
    suffix: "/ month",
    cta: "Start ongoing",
    href: "/contact",
    includedLabel: "Everything in Pro, and:",
    points: ["Highest monthly usage tier", "Up to 5 active task patterns", "Higher volume queues", "Expanded context windows", "Priority task review"],
    icon: ShieldCheck,
  },
];

const pricingSections = [
  {
    id: "build-packages",
    eyebrow: "Implementation",
    title: "Start with one task. Expand into an operating layer.",
    summary: "Tactas pricing begins with a business task review, then scopes the managed agents, company knowledge, and connected tools needed to automate real work.",
    priceLabel: "Build fee",
    plans: buildPlans,
  },
  {
    id: "ongoing-fees",
    eyebrow: "Ongoing operation",
    title: "Keep agents improving after launch.",
    summary: "After launch, choose an ongoing plan for usage, monitoring, improvement cycles, and managed operation.",
    priceLabel: "Ongoing fee",
    plans: ongoingPlans,
  },
];

const plans = [...buildPlans, ...ongoingPlans];

const securityItems = [
  ["Scoped access", "Connect only the tools and knowledge sources each task needs."],
  ["Managed operation", "Monitor outputs, improve task patterns, and refine agent behavior over time."],
  ["Source context", "Use company knowledge and business context to make work easier to review."],
  ["Rollout support", "Start with one task and expand when the operating pattern is proven."],
];

const faqs = [
  [
    "How do I start?",
    "Start with a task review. We map one repeated business task, the knowledge behind it, the tools involved, and the output an AI agent should prepare.",
  ],
  [
    "What does pricing depend on?",
    "Pricing depends on task complexity, knowledge sources, connected tools, automation steps, usage volume, and the level of ongoing managed operation required.",
  ],
  [
    "Do we need all company data connected first?",
    "No. A good first launch uses the minimum knowledge and tools required for one useful business task, then expands as the pattern proves value.",
  ],
  [
    "Can Tactas update tools automatically?",
    "Yes. Agents can prepare or apply updates in connected tools based on the permissions and automation scope chosen for the task.",
  ],
  [
    "Is the knowledge layer separate from task automation?",
    "It is a supporting capability. Company knowledge gives managed AI agents the context they need to answer, summarize, prepare outputs, and automate work.",
  ],
  [
    "Can we expand beyond the first task?",
    "Yes. Once one task works, Tactas can reuse the knowledge layer, connected tools, and task patterns across adjacent business tasks.",
  ],
];

const offerCatalog = {
  "@type": "OfferCatalog",
  name: "Tactas AI pricing plans",
  itemListElement: plans.map((plan) => ({
    "@type": "Offer",
    name: `${plan.name} plan`,
    category: plan.eyebrow,
    url: `${pageUrl}#${plan.id}`,
    priceSpecification: {
      "@type": "PriceSpecification",
      priceCurrency: "USD",
      description: `${plan.price} ${plan.suffix}`.trim(),
    },
    itemOffered: {
      "@type": "Service",
      name: `${plan.name} managed AI agent plan`,
      description: plan.summary,
      provider: { "@id": `${siteUrl}/#organization` },
    },
  })),
};

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    organization,
    {
      "@type": "WebPage",
      "@id": `${pageUrl}#webpage`,
      name: title,
      url: pageUrl,
      description,
      isPartOf: { "@id": `${siteUrl}/#website` },
      about: { "@id": `${siteUrl}/#organization` },
      mainEntity: { "@id": `${pageUrl}#service` },
      inLanguage: "en-US",
    },
    {
      "@type": "Service",
      "@id": `${pageUrl}#service`,
      name: "Managed AI agent pricing",
      description,
      serviceType: "Managed AI agents for business task automation",
      areaServed: "Worldwide",
      provider: { "@id": `${siteUrl}/#organization` },
      hasOfferCatalog: offerCatalog,
    },
    {
      "@type": "FAQPage",
      "@id": `${pageUrl}#faq`,
      mainEntity: faqs.map(([question, answer]) => ({
        "@type": "Question",
        name: question,
        acceptedAnswer: { "@type": "Answer", text: answer },
      })),
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Home", item: `${siteUrl}/` },
        { "@type": "ListItem", position: 2, name: "Pricing", item: pageUrl },
      ],
    },
  ],
};
---

<BaseLayout
  title={title}
  description={description}
  canonical="/pricing"
  currentPath="/pricing"
  navbarTheme="light"
  navbarCtaLabel="Task review"
  navbarCtaHref="/contact"
  keywords={[
    "managed AI agent pricing",
    "business task automation pricing",
    "managed AI agents for business operations",
    "company knowledge automation pricing",
    "connected business tools AI",
    "AI task automation for business teams",
  ]}
  openGraph={{
    title,
    description,
    url: pageUrl,
    type: "website",
    images: [
      {
        url: "/ef4e97cc-14e2-4157-a55f-42bfa62ad8a3.png",
        width: 1200,
        height: 630,
        alt: "Tactas AI managed AI agent pricing",
      },
    ],
  }}
  twitter={{
    card: "summary_large_image",
    title,
    description,
    images: ["/ef4e97cc-14e2-4157-a55f-42bfa62ad8a3.png"],
  }}
  jsonLd={jsonLd}
>
  <div class="min-h-screen bg-[#F6F8FB] text-[#0F172A]">
    <main>
      <section class="relative overflow-hidden border-b border-[#D8E1EA] bg-[#F6F8FB]">
        <div class="pointer-events-none absolute inset-x-0 top-0 h-px bg-[linear-gradient(90deg,transparent,#06B6D4_24%,#D7A22A_72%,transparent)]"></div>
        <div class="mx-auto grid w-full max-w-[1240px] items-center gap-10 px-5 py-16 sm:px-8 lg:grid-cols-[0.92fr_1.08fr] lg:px-10 lg:py-20">
          <div>
            <div class="mb-8 inline-flex items-center rounded-full bg-[#06AEEA] px-4 py-2 text-[14px] font-medium text-white shadow-[0_14px_32px_-24px_rgba(6,174,234,0.9)]">
              Pricing
            </div>
            <h1 class="max-w-[820px] text-[clamp(3.4rem,8vw,6.4rem)] font-semibold leading-[0.94] tracking-normal text-[#07324A]">
              Pricing for managed AI agents at work.
            </h1>
            <p class="mt-7 max-w-[44rem] text-[18px] leading-relaxed text-[#07324A]/78">
              Start with one business task, connect the company knowledge and tools behind it, then expand into managed AI automation as the value becomes clear.
            </p>
            <div class="mt-9 flex flex-col gap-3 sm:flex-row sm:items-center">
              <a href="/contact" class="inline-flex h-12 items-center justify-center rounded-[8px] bg-[#2F66FF] px-6 text-[14px] font-semibold text-white shadow-[0_16px_34px_-24px_rgba(47,102,255,0.85)] transition hover:bg-[#0EA5E9]">
                Request task review
              </a>
              <a href="#plans" class="inline-flex h-12 items-center justify-center rounded-[8px] border border-[#D9CFAE] bg-white/60 px-6 text-[14px] font-semibold text-[#07324A] transition hover:border-[#2F66FF] hover:text-[#2F66FF]">
                See plans
              </a>
            </div>
          </div>

          <div class="border border-[#D8E1EA] bg-white shadow-[0_34px_100px_-72px_rgba(7,50,74,0.42)]">
            <div class="border-b border-[#E2E8F0] bg-[#F6F8FB] px-5 py-4">
              <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-[#64748B]">Pricing model</p>
            </div>
            <div class="grid gap-3 p-5">
              {[
                ["01", "Review one repeated task"],
                ["02", "Scope knowledge and connected tools"],
                ["03", "Deploy managed agent work"],
                ["04", "Improve usage after launch"],
              ].map(([number, label]) => (
                <div class="flex items-center justify-between gap-4 border border-[#E2E8F0] bg-[#F6F8FB] px-4 py-3">
                  <span class="font-mono text-[11px] text-[#0891B2]">{number}</span>
                  <span class="text-[14px] font-semibold text-[#07324A]">{label}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </section>

      <section id="plans" class="border-b border-[#D8E1EA] bg-[#F6F8FB]">
        <div class="mx-auto grid w-full max-w-[1240px] gap-16 px-5 py-14 sm:px-8 lg:px-10 lg:py-20">
          {pricingSections.map((section) => (
            <div id={section.id} class="scroll-mt-24">
              <div class="max-w-[760px]">
                <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-[#0891B2]">{section.eyebrow}</p>
                <h2 class="mt-4 text-[38px] font-semibold leading-[1.02] tracking-normal text-[#07324A] sm:text-[54px]">
                  {section.title}
                </h2>
                <p class="mt-4 text-[16px] leading-relaxed text-[#475569] sm:text-[17px]">{section.summary}</p>
              </div>

              <div class="mt-8 grid gap-4 lg:grid-cols-3">
                {section.plans.map((plan) => {
                  const Icon = plan.icon;
                  return (
                    <article
                      id={plan.id}
                      class:list={[
                        "flex min-h-[520px] flex-col border bg-white p-6 shadow-[0_24px_70px_-62px_rgba(7,50,74,0.3)]",
                        plan.popular ? "border-[#06B6D4] ring-1 ring-[#06B6D4]/25" : "border-[#D8E1EA]",
                      ]}
                    >
                      <div class="flex items-start justify-between gap-3">
                        <span class="flex h-11 w-11 items-center justify-center rounded-[8px] border border-[#BAE6FD] bg-[#E6FBFF] text-[#0E7490]">
                          <Icon class="h-5 w-5" stroke-width={1.9} />
                        </span>
                        {plan.popular ? (
                          <span class="rounded-full border border-[#A7F3D0] bg-[#ECFDF5] px-2.5 py-1 text-[10px] font-semibold uppercase tracking-[0.12em] text-[#047857]">
                            Recommended
                          </span>
                        ) : null}
                      </div>

                      <p class="mt-8 text-[13px] font-medium text-[#64748B]">{plan.eyebrow}</p>
                      <h3 class="mt-2 text-[30px] font-semibold tracking-normal text-[#07324A]">{plan.name}</h3>
                      <p class="mt-2 min-h-[72px] text-[14px] leading-relaxed text-[#475569]">{plan.summary}</p>

                      <div class="mt-7 border border-[#D8E1EA] bg-[#F6F8FB] p-4">
                        <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-[#64748B]">{section.priceLabel}</p>
                        <div class="mt-2 flex flex-wrap items-baseline gap-x-2 gap-y-1">
                          <p class="text-[32px] font-semibold leading-none tracking-normal text-[#07324A]">{plan.price}</p>
                          <p class="text-[13px] text-[#64748B]">{plan.suffix}</p>
                        </div>
                      </div>

                      <a
                        href={plan.href}
                        class:list={[
                          "mt-7 inline-flex h-11 items-center justify-center rounded-[8px] px-4 text-[14px] font-semibold transition",
                          plan.popular
                            ? "bg-[#2F66FF] text-white hover:bg-[#0EA5E9]"
                            : "border border-[#D9CFAE] bg-white text-[#07324A] hover:border-[#2F66FF] hover:text-[#2F66FF]",
                        ]}
                      >
                        {plan.cta}
                      </a>

                      <div class="mt-7 border-t border-[#D8E1EA] pt-5">
                        <p class="text-[13px] font-semibold text-[#07324A]">{plan.includedLabel}</p>
                        <ul class="mt-4 grid gap-3">
                          {plan.points.map((point) => (
                            <li class="flex gap-2.5 text-[13px] leading-relaxed text-[#334155]">
                              <Check class="mt-0.5 h-4 w-4 shrink-0 text-[#06B6D4]" stroke-width={2.4} />
                              <span>{point}</span>
                            </li>
                          ))}
                        </ul>
                      </div>
                    </article>
                  );
                })}
              </div>
            </div>
          ))}
        </div>
      </section>

      <section class="border-b border-[#D8E1EA] bg-[#F6F8FB]">
        <div class="mx-auto grid w-full max-w-[1240px] gap-10 px-5 py-16 sm:px-8 lg:grid-cols-[0.9fr_1.1fr] lg:px-10 lg:py-20">
          <div>
            <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-[#0891B2]">How pricing scales</p>
            <h2 class="mt-4 max-w-[720px] text-[42px] font-semibold leading-[1.02] tracking-normal text-[#07324A] sm:text-[58px]">
              Pay for the task pattern, context, and operation you actually need.
            </h2>
            <p class="mt-5 max-w-[36rem] text-[17px] leading-relaxed text-[#475569]">
              Tactas starts narrow so the first managed agent has a real job. As the task proves useful, the same knowledge layer and connected tools can support more business tasks.
            </p>
          </div>

          <div class="grid gap-4 sm:grid-cols-2">
            {securityItems.map(([label, body], index) => (
              <article class="border border-[#D8E1EA] bg-white p-5 shadow-[0_20px_60px_-54px_rgba(7,50,74,0.25)]">
                <div class="flex h-11 w-11 items-center justify-center rounded-[8px] border border-[#BAE6FD] bg-[#E6FBFF] text-[#0E7490]">
                  {index % 2 === 0 ? <ShieldCheck class="h-5 w-5" stroke-width={1.9} /> : <Zap class="h-5 w-5" stroke-width={1.9} />}
                </div>
                <h3 class="mt-5 text-[20px] font-semibold tracking-normal text-[#07324A]">{label}</h3>
                <p class="mt-2 text-[14px] leading-relaxed text-[#475569]">{body}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="border-b border-[#D8E1EA] bg-[#F6F8FB]">
        <div class="mx-auto w-full max-w-[1020px] px-5 py-16 sm:px-8 lg:px-10 lg:py-20">
          <div class="text-center">
            <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-[#0891B2]">FAQ</p>
            <h2 class="mt-4 text-[42px] font-semibold leading-[1.02] tracking-normal text-[#07324A] sm:text-[58px]">
              Frequently asked questions.
            </h2>
          </div>
          <div class="mt-10 divide-y divide-[#D8E1EA] border-y border-[#D8E1EA]">
            {faqs.map(([question, answer]) => (
              <details class="group py-6">
                <summary class="flex cursor-pointer list-none items-center justify-between gap-5 text-[18px] font-semibold text-[#07324A]">
                  {question}
                  <ArrowRight class="h-4 w-4 shrink-0 text-[#06B6D4] transition group-open:rotate-90" stroke-width={2} />
                </summary>
                <p class="mt-3 max-w-[48rem] text-[15px] leading-relaxed text-[#475569]">{answer}</p>
              </details>
            ))}
          </div>
        </div>
      </section>

      <section class="bg-[#F6F8FB]">
        <div class="mx-auto w-full max-w-[1240px] px-5 py-16 sm:px-8 lg:px-10 lg:py-20">
          <div class="grid gap-8 border border-[#D8E1EA] bg-white p-7 shadow-[0_34px_100px_-72px_rgba(7,50,74,0.42)] sm:p-9 lg:grid-cols-[1fr_360px] lg:items-center">
            <div>
              <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-[#0891B2]">Task review</p>
              <h2 class="mt-4 max-w-[760px] text-[42px] font-semibold leading-[1.02] tracking-normal text-[#07324A] sm:text-[58px]">
                Map one business task before you commit to a build.
              </h2>
              <p class="mt-5 max-w-[42rem] text-[17px] leading-relaxed text-[#475569]">
                Share the repeated work, knowledge sources, current tools, and output you want an agent to prepare.
              </p>
            </div>
            <div class="border border-[#D8E1EA] bg-[#F6F8FB] p-5">
              <div class="flex items-start gap-3">
                <Mail class="mt-1 h-5 w-5 shrink-0 text-[#06B6D4]" stroke-width={1.9} />
                <div>
                  <h3 class="text-[18px] font-semibold tracking-normal text-[#07324A]">Prefer email?</h3>
                  <p class="mt-2 text-[14px] leading-relaxed text-[#475569]">
                    Send the business context to <a href={`mailto:${brandEmail}`} class="text-[#0891B2] hover:text-[#07324A]">{brandEmail}</a>.
                  </p>
                </div>
              </div>
              <a href="/contact" class="mt-6 inline-flex h-11 w-full items-center justify-center rounded-[8px] bg-[#2F66FF] px-4 text-[14px] font-semibold text-white transition hover:bg-[#0EA5E9]">
                Request task review
                <ArrowRight class="ml-2 h-4 w-4" stroke-width={2} />
              </a>
            </div>
          </div>
        </div>
      </section>
    </main>
  </div>
</BaseLayout>
