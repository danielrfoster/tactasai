---
import {
  ArrowRight,
  BriefcaseBusiness,
  Building2,
  Cloud,
  Gavel,
  HeartPulse,
  Home,
  Server,
  ShoppingCart,
} from "@lucide/astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { industryLandingPages, type IndustryIcon } from "../../lib/industryLandingPages";
import { getSiteUrl } from "../../lib/site";

const siteUrl = getSiteUrl();
const pageUrl = `${siteUrl}/industries`;

const iconMap: Record<IndustryIcon, typeof BriefcaseBusiness> = {
  briefcase: BriefcaseBusiness,
  building: Building2,
  cart: ShoppingCart,
  cloud: Cloud,
  gavel: Gavel,
  heart: HeartPulse,
  home: Home,
  server: Server,
};

const patternIndustryPages = industryLandingPages.filter(
  (industry) => !["ai-assistant-for-ecommerce", "ai-assistant-for-healthcare-clinics"].includes(industry.slug),
);

const industries = [
  ...patternIndustryPages.slice(0, 1).map((industry) => ({
    title: industry.shortName,
    href: `/industries/${industry.slug}`,
    body: industry.description,
    icon: iconMap[industry.icon],
    status: "Pattern",
  })),
  {
    title: "Ecommerce",
    href: "/industries/ecommerce",
    body: "AI customer support for ecommerce stores, including product questions, order status, returns, and revenue recovery.",
    icon: ShoppingCart,
    status: "Deep dive",
  },
  ...patternIndustryPages.slice(1, 2).map((industry) => ({
    title: industry.shortName,
    href: `/industries/${industry.slug}`,
    body: industry.description,
    icon: iconMap[industry.icon],
    status: "Pattern",
  })),
  {
    title: "Healthcare",
    href: "/industries/healthcare",
    body: "Patient intake, appointment support, forms, reminders, billing questions, and clinical handoff boundaries.",
    icon: HeartPulse,
    status: "Deep dive",
  },
  ...patternIndustryPages.slice(2).map((industry) => ({
    title: industry.shortName,
    href: `/industries/${industry.slug}`,
    body: industry.description,
    icon: iconMap[industry.icon],
    status: "Pattern",
  })),
  {
    title: "Professional services",
    href: "/industries/professional-services",
    body: "Client intake, lead qualification, document collection, proposal prep, CRM updates, and follow-up workflows.",
    icon: BriefcaseBusiness,
    status: "Deep dive",
  },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "CollectionPage",
      "@id": `${pageUrl}#collectionpage`,
      name: "AI Automation by Industry",
      url: pageUrl,
      description:
        "Tactas AI industry landing pages for SaaS, ecommerce, law firms, healthcare clinics, real estate, VPS hosting, and professional services workflow automation.",
      isPartOf: { "@id": `${siteUrl}/#website` },
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Home", item: `${siteUrl}/` },
        { "@type": "ListItem", position: 2, name: "Industries", item: pageUrl },
      ],
    },
  ],
};
---

<BaseLayout
  title="AI Automation by Industry"
  description="Explore Tactas AI industry landing pages for SaaS, ecommerce, law firms, healthcare clinics, real estate, VPS hosting, and professional services workflow automation."
  canonical="/industries"
  currentPath="/industries"
  navbarTheme="light"
  navbarCtaLabel="Discuss workflow"
  jsonLd={jsonLd}
>
  <div class="min-h-screen overflow-x-hidden bg-tactas-bg text-tactas-ink selection:bg-tactas-accent/20">
    <div class="pointer-events-none fixed inset-0 -z-20 grid-faint opacity-[0.35] [mask-image:radial-gradient(ellipse_70%_55%_at_50%_15%,black_0%,transparent_75%)]"></div>

    <main>
      <section class="py-20 lg:py-28">
        <div class="tactas-container">
          <div class="max-w-3xl">
            <p class="font-mono text-[10px] font-semibold uppercase tracking-[0.28em] text-tactas-accent-strong/85">Industries</p>
            <h1 class="mt-4 text-[clamp(2.5rem,6vw,4.7rem)] font-bold leading-[0.96] tracking-[-0.045em] text-tactas-ink">
              AI automation by industry.
            </h1>
            <p class="mt-6 max-w-2xl text-[16px] leading-relaxed text-tactas-muted-soft sm:text-[17px]">
              Start with the workflow patterns where AI support agents, supervised automation, and human handoff can
              create clear operational value.
            </p>
          </div>

          <div class="mt-14 grid border-y border-tactas-line sm:grid-cols-2 lg:grid-cols-3">
            {industries.map((industry) => {
              const Icon = industry.icon;
              return (
                <a
                  href={industry.href}
                  class="group flex min-h-[240px] flex-col justify-between border-t border-tactas-line px-0 py-8 transition hover:bg-white/50 sm:border-l sm:px-7 lg:[&:nth-child(3n+1)]:border-l-0"
                >
                  <span>
                    <span class="flex items-center justify-between gap-4">
                      <span class="flex h-10 w-10 items-center justify-center rounded-md border border-tactas-line bg-white text-tactas-accent-strong transition group-hover:border-tactas-accent/50">
                        <Icon class="h-4 w-4" stroke-width={1.7} />
                      </span>
                      <span class="rounded-full border border-tactas-line px-2.5 py-1 font-mono text-[10px] uppercase tracking-[0.18em] text-tactas-muted-soft">
                        {industry.status}
                      </span>
                    </span>
                    <span class="mt-5 block text-[18px] font-semibold tracking-tight text-tactas-ink">{industry.title}</span>
                    <span class="mt-3 block text-[14px] leading-relaxed text-tactas-muted-soft">{industry.body}</span>
                  </span>
                  <span class="mt-8 inline-flex items-center text-[13px] font-semibold text-tactas-accent-strong">
                    View workflow
                    <ArrowRight class="ml-2 h-3.5 w-3.5 transition group-hover:translate-x-0.5" />
                  </span>
                </a>
              );
            })}
          </div>
        </div>
      </section>
    </main>
  </div>
</BaseLayout>
