---
import { ArrowRight, Briefcase, GraduationCap, HeartPulse, Home, ShoppingBag } from "@lucide/astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navbar from "../../components/Navbar.astro";
import { getSiteUrl } from "../../lib/site";

const siteUrl = getSiteUrl();
const pageUrl = `${siteUrl}/industries`;
const CONTAINER = "mx-auto w-full max-w-[1240px] px-5 sm:px-8 lg:px-10";

const industries = [
  {
    title: "Ecommerce",
    href: "/industries/ecommerce",
    body: "AI customer support for ecommerce stores, including product questions, order status, returns, and revenue recovery.",
    icon: ShoppingBag,
    status: "Live",
  },
  {
    title: "Real estate",
    href: "/#contact",
    body: "Lead qualification, property questions, appointment routing, and follow-up workflows.",
    icon: Home,
    status: "Planned",
  },
  {
    title: "Education",
    href: "/#contact",
    body: "Admissions intake, course questions, student support, reminders, and enrollment workflows.",
    icon: GraduationCap,
    status: "Planned",
  },
  {
    title: "Clinics",
    href: "/#contact",
    body: "Front-desk support for appointment intake, reminders, FAQs, and human handoff.",
    icon: HeartPulse,
    status: "Planned",
  },
  {
    title: "Professional services",
    href: "/#contact",
    body: "Client intake, qualification, document collection, appointment routing, and CRM updates.",
    icon: Briefcase,
    status: "Planned",
  },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "CollectionPage",
      "@id": `${pageUrl}#collectionpage`,
      name: "AI Automation by Industry",
      url: pageUrl,
      description:
        "Tactas AI industry landing pages for ecommerce, real estate, education, clinics, and professional services workflow automation.",
      isPartOf: { "@id": `${siteUrl}/#website` },
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Home", item: `${siteUrl}/` },
        { "@type": "ListItem", position: 2, name: "Industries", item: pageUrl },
      ],
    },
  ],
};
---

<BaseLayout
  title="AI Automation by Industry"
  description="Explore Tactas AI industry landing pages for ecommerce, real estate, education, clinics, and professional services workflow automation."
  canonical="/industries"
  jsonLd={jsonLd}
>
  <div class="min-h-screen overflow-x-hidden bg-[#07090f] text-[#f5f7fb] selection:bg-[#67e8f9]/20">
    <div class="pointer-events-none fixed inset-0 -z-20 grid-faint opacity-[0.35] [mask-image:radial-gradient(ellipse_70%_55%_at_50%_15%,black_0%,transparent_75%)]"></div>
    <Navbar currentPath="/industries" ctaLabel="Discuss workflow" />

    <main>
      <section class="py-20 lg:py-28">
        <div class={CONTAINER}>
          <div class="max-w-3xl">
            <p class="font-mono text-[10px] font-semibold uppercase tracking-[0.28em] text-[#67e8f9]/85">Industries</p>
            <h1 class="mt-4 text-[clamp(2.5rem,6vw,4.7rem)] font-bold leading-[0.96] tracking-[-0.045em] text-[#f5f7fb]">
              AI automation by industry.
            </h1>
            <p class="mt-6 max-w-2xl text-[16px] leading-relaxed text-[#8a93a6] sm:text-[17px]">
              Start with the workflow patterns where AI support agents, supervised automation, and human handoff can
              create clear operational value.
            </p>
          </div>

          <div class="mt-14 grid border-y border-[#1c2333] sm:grid-cols-2 lg:grid-cols-3">
            {industries.map((industry) => {
              const Icon = industry.icon;
              return (
                <a
                  href={industry.href}
                  class="group flex min-h-[240px] flex-col justify-between border-t border-[#1c2333] px-0 py-8 transition hover:bg-[#0c111c]/50 sm:border-l sm:px-7 lg:[&:nth-child(3n+1)]:border-l-0"
                >
                  <span>
                    <span class="flex items-center justify-between gap-4">
                      <span class="flex h-10 w-10 items-center justify-center rounded-md border border-[#1c2333] bg-[#0c111c] text-[#67e8f9] transition group-hover:border-[#67e8f9]/40">
                        <Icon class="h-4 w-4" stroke-width={1.7} />
                      </span>
                      <span class="rounded-full border border-[#1c2333] px-2.5 py-1 font-mono text-[10px] uppercase tracking-[0.18em] text-[#8a93a6]">
                        {industry.status}
                      </span>
                    </span>
                    <span class="mt-5 block text-[18px] font-semibold tracking-tight text-[#f5f7fb]">{industry.title}</span>
                    <span class="mt-3 block text-[14px] leading-relaxed text-[#8a93a6]">{industry.body}</span>
                  </span>
                  <span class="mt-8 inline-flex items-center text-[13px] font-semibold text-[#67e8f9]">
                    View workflow
                    <ArrowRight class="ml-2 h-3.5 w-3.5 transition group-hover:translate-x-0.5" />
                  </span>
                </a>
              );
            })}
          </div>
        </div>
      </section>
    </main>
  </div>
</BaseLayout>
