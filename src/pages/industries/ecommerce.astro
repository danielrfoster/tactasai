---
import BaseLayout from "../../layouts/BaseLayout.astro";
import EcommerceIndustryPage from "../../components/EcommerceIndustryPage.astro";
import { getBrandEmail, getSiteUrl } from "../../lib/site";

const siteUrl = getSiteUrl();
const pageUrl = `${siteUrl}/industries/ecommerce`;
const brandEmail = getBrandEmail();

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": `${pageUrl}#webpage`,
      name: "AI Customer Support Automation for Ecommerce Stores",
      url: pageUrl,
      description:
        "Tactas AI builds supervised ecommerce AI support agents for product questions, order status automation, returns intake, Shopify customer service automation, Gorgias and Zendesk workflows, and revenue recovery.",
      isPartOf: { "@id": `${siteUrl}/#website` },
      about: { "@id": `${siteUrl}/#organization` },
      inLanguage: "en-US",
    },
    {
      "@type": "Service",
      "@id": `${pageUrl}#service`,
      name: "AI Customer Support Automation for Ecommerce Stores",
      serviceType: [
        "AI customer support for ecommerce",
        "Ecommerce AI chatbot",
        "Ecommerce support automation",
        "Shopify customer service automation",
        "AI order status automation",
        "Automated order status support",
        "AI returns automation",
        "AI returns management",
        "Gorgias AI automation",
        "Zendesk ecommerce automation",
      ],
      url: pageUrl,
      description:
        "Supervised AI agent systems for ecommerce product Q&A, order status, returns intake, support triage, Shopify support workflows, helpdesk automation, and revenue recovery.",
      provider: { "@id": `${siteUrl}/#organization` },
      areaServed: "Worldwide",
      audience: {
        "@type": "BusinessAudience",
        audienceType: "Ecommerce operators, online retailers, DTC brands, and retail support teams",
      },
      offers: {
        "@type": "Offer",
        availability: "https://schema.org/InStock",
        url: pageUrl,
        category: "Ecommerce support automation",
      },
    },
    {
      "@type": "FAQPage",
      "@id": `${pageUrl}#faq`,
      mainEntity: [
        {
          "@type": "Question",
          name: "Is this just an ecommerce AI chatbot?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "No. Tactas AI designs supervised ecommerce support automation systems that can read store data, apply policies, prepare actions, and escalate risky cases such as refunds, discounts, fraud risk, or VIP requests.",
          },
        },
        {
          "@type": "Question",
          name: "Can this work as a Shopify AI chatbot or WooCommerce support agent?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "Yes. Tactas AI designs around your stack first. Common systems include Shopify, WooCommerce, Stripe, Gorgias, Zendesk, email tools, spreadsheets, inventory systems, and fulfillment APIs.",
          },
        },
        {
          "@type": "Question",
          name: "What ecommerce customer service workflow should we automate first?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "The best first workflow is usually product Q&A, order status automation, returns intake, or support triage because the volume is frequent, measurable, and tied to support cost or conversion.",
          },
        },
      ],
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Home", item: `${siteUrl}/` },
        { "@type": "ListItem", position: 2, name: "Industries", item: `${siteUrl}/industries` },
        { "@type": "ListItem", position: 3, name: "Ecommerce", item: pageUrl },
      ],
    },
    {
      "@type": "ContactPoint",
      contactType: "sales",
      email: brandEmail,
      areaServed: "Worldwide",
      availableLanguage: ["en", "vi"],
    },
  ],
};
---

<BaseLayout
  title="AI Customer Support Automation for Ecommerce | Tactas AI"
  description="Tactas AI builds supervised ecommerce AI support agents for product questions, order status, returns intake, Shopify customer service automation, Gorgias and Zendesk workflows, and revenue recovery."
  canonical="/industries/ecommerce"
  keywords={[
    "AI customer support for ecommerce",
    "ecommerce AI chatbot",
    "AI agents for ecommerce",
    "ecommerce support automation",
    "Shopify customer service automation",
    "Shopify AI chatbot",
    "AI chatbot for online stores",
    "AI order status automation",
    "automated order status support",
    "AI returns automation",
    "AI returns management",
    "Gorgias AI automation",
    "Zendesk ecommerce automation",
    "AI support agent for Shopify stores",
    "automate ecommerce customer service",
  ]}
  openGraph={{
    title: "AI Customer Support Automation for Ecommerce | Tactas AI",
    description:
      "Supervised ecommerce AI agents for product questions, order status, returns intake, Shopify customer service automation, helpdesk workflows, and controlled support automation.",
    url: pageUrl,
    type: "website",
    images: [
      {
        url: "/ef4e97cc-14e2-4157-a55f-42bfa62ad8a3.png",
        width: 1536,
        height: 1024,
        alt: "Tactas AI workflow execution system",
      },
    ],
  }}
  twitter={{
    card: "summary_large_image",
    title: "AI Customer Support Automation for Ecommerce | Tactas AI",
    description:
      "Supervised ecommerce AI agents for product questions, order status, returns intake, Shopify customer service automation, and revenue recovery.",
    images: ["/ef4e97cc-14e2-4157-a55f-42bfa62ad8a3.png"],
  }}
  jsonLd={jsonLd}
>
  <EcommerceIndustryPage siteUrl={siteUrl} currentPath="/industries/ecommerce" />
</BaseLayout>
