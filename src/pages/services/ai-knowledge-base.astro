---
const target = "/product/ai-knowledge-base";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="robots" content="noindex, follow" />
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <link rel="canonical" href={target} />
    <title>Redirecting to Tactas AI Knowledge Base</title>
  </head>
  <body>
    <p>Redirecting to <a href={target}>AI Knowledge Base</a>.</p>
    <script is:inline>
      window.location.replace("/product/ai-knowledge-base");
    </script>
  </body>
</html>
