---
import BaseLayout from "../../layouts/BaseLayout.astro";
import AIWorkflowAutomationPage from "../../components/AIWorkflowAutomationPage.astro";
import { getBrandEmail, getSiteUrl } from "../../lib/site";

const siteUrl = getSiteUrl();
const pageUrl = `${siteUrl}/services/ai-workflow-automation`;
const brandEmail = getBrandEmail();

const title = "Business Task Automation with Managed AI Agents | Tactas AI";
const description =
  "Managed AI agents use company knowledge, business context, and connected tools to turn repeated requests into outputs, updates, next steps, and automated actions.";

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": `${pageUrl}#webpage`,
      name: "Business Task Automation with Managed AI Agents",
      url: pageUrl,
      description,
      isPartOf: { "@id": `${siteUrl}/#website` },
      about: { "@id": `${siteUrl}/#organization` },
      inLanguage: "en-US",
    },
    {
      "@type": "Service",
      "@id": `${pageUrl}#service`,
      name: "Business Task Automation with Managed AI Agents",
      serviceType: [
        "Business task automation",
        "Managed AI agents",
        "Managed agent systems",
        "AI agents for business operations",
        "Company knowledge automation",
        "Connected business tools",
        "AI operating layer",
        "Work performance AI",
        "Automated business tasks",
        "Business context automation",
      ],
      url: pageUrl,
      description:
        "Managed AI agents for business teams, including task mapping, company knowledge, connected tools, prepared outputs, updates, next steps, and automated business actions.",
      provider: { "@id": `${siteUrl}/#organization` },
      areaServed: "Worldwide",
      audience: {
        "@type": "BusinessAudience",
        audienceType: "Business teams that want to improve work performance and automate repeated tasks",
      },
      offers: {
        "@type": "Offer",
        availability: "https://schema.org/InStock",
        url: pageUrl,
        category: "Business Task Automation",
      },
    },
    {
      "@type": "FAQPage",
      "@id": `${pageUrl}#faq`,
      mainEntity: [
        {
          "@type": "Question",
          name: "What is business task automation with AI agents?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "Business task automation uses managed AI agents to understand company context, prepare useful outputs, update work, and automate repeated steps across connected tools.",
          },
        },
        {
          "@type": "Question",
          name: "Can agents take actions in our systems?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "Yes. Managed AI agents can prepare updates, create tasks, organize follow-ups, and automate repeated steps across tools your business already uses.",
          },
        },
        {
          "@type": "Question",
          name: "Which business task should we automate first?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "The best first task is frequent, has available business context, uses connected tools, and produces a clear output or next action.",
          },
        },
      ],
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Home", item: `${siteUrl}/` },
        { "@type": "ListItem", position: 2, name: "Business Task Automation", item: pageUrl },
      ],
    },
    {
      "@type": "ContactPoint",
      contactType: "sales",
      email: brandEmail,
      areaServed: "Worldwide",
      availableLanguage: ["en", "vi"],
    },
  ],
};
---

<BaseLayout
  title={title}
  description={description}
  canonical="/services/ai-workflow-automation"
  currentPath="/services/ai-workflow-automation"
  navbarTheme="light"
  navbarCtaLabel="Task review"
  keywords={[
    "business task automation",
    "managed AI agents",
    "managed agent systems",
    "AI agents for business operations",
    "automated business tasks",
    "company knowledge automation",
    "connected business tools",
    "AI operating layer",
    "work performance AI",
    "AI task automation",
    "business context automation",
    "business productivity automation",
    "AI agents that automate business tasks",
    "AI automation for business tasks",
    "company knowledge into action",
    "AI agents for work productivity",
  ]}
  openGraph={{
    title,
    description,
    url: pageUrl,
    type: "website",
    images: [
      {
        url: "/ef4e97cc-14e2-4157-a55f-42bfa62ad8a3.png",
        width: 1536,
        height: 1024,
        alt: "Tactas AI business task automation with managed AI agents",
      },
    ],
  }}
  twitter={{
    card: "summary_large_image",
    title,
    description,
    images: ["/ef4e97cc-14e2-4157-a55f-42bfa62ad8a3.png"],
  }}
  jsonLd={jsonLd}
>
  <AIWorkflowAutomationPage siteUrl={siteUrl} currentPath="/services/ai-workflow-automation" />
</BaseLayout>
