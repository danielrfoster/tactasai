---
import { ArrowLeft, ArrowRight, CheckCircle2, Copy, Sparkles } from "@lucide/astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPromptBySlug, getRelatedPrompts, promptLibrary } from "../../lib/promptLibrary";
import { getOrganization, getSiteUrl } from "../../lib/site";

export function getStaticPaths() {
  return promptLibrary.map((prompt) => ({
    params: { slug: prompt.slug },
    props: { slug: prompt.slug },
  }));
}

interface Props {
  slug: string;
}

const { slug } = Astro.props;
const prompt = getPromptBySlug(slug);

if (!prompt) {
  throw new Error(`Prompt not found: ${slug}`);
}

const siteUrl = getSiteUrl();
const organization = getOrganization();
const pageUrl = `${siteUrl}/ai-agent-prompt-library/${prompt.slug}`;
const title = `${prompt.title} AI Agent Prompt | Tactas AI`;
const description = `${prompt.body} Copy this ${prompt.department.toLowerCase()} AI agent prompt and adapt it for supervised business workflow automation.`;
const publishedAt = "2026-06-01";
const relatedPrompts = getRelatedPrompts(prompt, 3);
const inputExamples = [
  "Relevant company documents, policies, examples, or records",
  "The request, ticket, call note, form, message, or workflow details",
  "Any approval rules, escalation rules, deadlines, owners, or exceptions",
];
const outputRules = [
  "Separate confirmed facts from assumptions",
  "Flag missing context and required follow-up questions",
  "Keep sensitive decisions behind human review",
];
const usageSteps = [
  {
    name: "Add business context",
    text: "Provide the relevant documents, records, messages, tickets, policies, or notes the agent should use.",
  },
  {
    name: "Run the prompt",
    text: "Paste the prompt into your AI tool and include the workflow context below it.",
  },
  {
    name: "Review before action",
    text: "Check facts, source coverage, exceptions, and approval-sensitive recommendations before sending or automating the output.",
  },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    organization,
    {
      "@type": "TechArticle",
      "@id": `${pageUrl}#prompt`,
      headline: title,
      name: prompt.title,
      description,
      url: pageUrl,
      inLanguage: "en-US",
      about: prompt.tags,
      datePublished: publishedAt,
      dateModified: publishedAt,
      image: `${siteUrl}/tactas-ai-managed-agent-systems-og.jpg`,
      author: { "@id": `${siteUrl}/#organization` },
      publisher: { "@id": `${siteUrl}/#organization` },
      keywords: [
        `${prompt.title} prompt`,
        `${prompt.department} AI prompt`,
        `${prompt.category} AI prompt`,
        "AI agent prompt",
        "business workflow automation",
        ...prompt.tags,
      ],
      mainEntityOfPage: { "@id": `${pageUrl}#webpage` },
    },
    {
      "@type": "WebPage",
      "@id": `${pageUrl}#webpage`,
      name: title,
      url: pageUrl,
      description,
      isPartOf: { "@id": `${siteUrl}/#website` },
      breadcrumb: { "@id": `${pageUrl}#breadcrumb` },
    },
    {
      "@type": "HowTo",
      "@id": `${pageUrl}#howto`,
      name: `How to use the ${prompt.title} prompt`,
      description: `Use this prompt to support a ${prompt.department.toLowerCase()} workflow with clear inputs, structured output, and human review.`,
      step: usageSteps.map((step) => ({ "@type": "HowToStep", ...step })),
    },
    {
      "@type": "BreadcrumbList",
      "@id": `${pageUrl}#breadcrumb`,
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Home", item: `${siteUrl}/` },
        { "@type": "ListItem", position: 2, name: "AI Agent Prompt Library", item: `${siteUrl}/ai-agent-prompt-library` },
        { "@type": "ListItem", position: 3, name: prompt.title, item: pageUrl },
      ],
    },
  ],
};
---

<BaseLayout
  title={title}
  description={description}
  canonical={`/ai-agent-prompt-library/${prompt.slug}`}
  currentPath={`/ai-agent-prompt-library/${prompt.slug}`}
  navbarTheme="light"
  navbarCtaLabel="Book a review"
  keywords={[
    `${prompt.title} prompt`,
    `${prompt.department} AI prompt`,
    `${prompt.category} AI prompt`,
    "AI agent prompt",
    "AI workflow prompt",
    "business workflow automation",
    ...prompt.tags,
  ]}
  openGraph={{
    title,
    description,
    url: pageUrl,
    type: "article",
    images: [
      {
        url: "/tactas-ai-managed-agent-systems-og.jpg",
        width: 1734,
        height: 907,
        alt: title,
      },
    ],
  }}
  twitter={{
    card: "summary_large_image",
    title,
    description,
    images: ["/tactas-ai-managed-agent-systems-og.jpg"],
  }}
  jsonLd={jsonLd}
>
  <main class="min-h-screen bg-tactas-bg text-tactas-ink selection:bg-tactas-accent/20">
    <article>
      <header class="border-b border-tactas-line bg-white">
        <div class="tactas-container-narrow py-12 lg:py-16">
          <a href="/ai-agent-prompt-library" class="inline-flex items-center gap-2 text-[14px] font-semibold text-tactas-muted transition hover:text-tactas-ink-strong">
            <ArrowLeft class="h-4 w-4" stroke-width={1.9} />
            Back to prompt library
          </a>

          <div class="mt-10">
            <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.24em] text-tactas-accent-strong">
              {prompt.department} / {prompt.category}
            </p>
            <h1 class="mt-5 max-w-[900px] text-[clamp(2.35rem,5.6vw,4.8rem)] font-semibold leading-[1.02] tracking-normal text-tactas-ink-strong">
              {prompt.title}
            </h1>
            <p class="mt-6 max-w-[720px] text-[18px] leading-relaxed text-tactas-muted sm:text-[20px]">
              {prompt.body}
            </p>
          </div>
        </div>
      </header>

      <div class="mx-auto grid w-full max-w-[1120px] gap-8 px-5 py-10 sm:px-8 lg:grid-cols-[minmax(0,760px)_300px] lg:px-10 lg:py-14">
        <div class="min-w-0 space-y-8">
          <section class="border border-tactas-line bg-white p-5 sm:p-6">
            <div class="flex flex-col gap-4 border-b border-tactas-line-soft pb-5 sm:flex-row sm:items-center sm:justify-between">
              <div>
                <p class="font-mono text-[10px] font-semibold uppercase tracking-[0.22em] text-tactas-accent-strong">Copy-ready prompt</p>
                <h2 class="mt-2 text-[24px] font-semibold tracking-normal text-tactas-ink-strong">Prompt template</h2>
              </div>
              <button type="button" id="copy-prompt" class="inline-flex h-11 items-center justify-center rounded-[7px] bg-tactas-primary-strong px-5 text-[14px] font-semibold text-white transition hover:bg-tactas-accent-strong">
                <Copy class="mr-2 h-4 w-4" stroke-width={1.9} />
                Copy prompt
              </button>
            </div>
            <div class="mt-5 rounded-[8px] border border-tactas-night bg-tactas-night p-5 text-white">
              <p id="prompt-text" class="whitespace-pre-wrap text-[15px] leading-relaxed text-white/90">{prompt.prompt}</p>
            </div>
            <p id="copy-status" class="mt-3 text-[13px] text-tactas-muted-soft">Adapt this prompt with your own company context before using it in production.</p>
          </section>

          <section class="grid gap-4 md:grid-cols-2">
            <div class="border border-tactas-line bg-white p-5">
              <h2 class="text-[22px] font-semibold tracking-normal text-tactas-ink-strong">When to use it</h2>
              <p class="mt-3 text-[15px] leading-relaxed text-tactas-muted">
                Use this prompt when a {prompt.department.toLowerCase()} team needs a consistent {prompt.category.toLowerCase()} output from repeated workflow context.
              </p>
            </div>
            <div class="border border-tactas-line bg-white p-5">
              <h2 class="text-[22px] font-semibold tracking-normal text-tactas-ink-strong">Automation fit</h2>
              <p class="mt-3 text-[15px] leading-relaxed text-tactas-muted">
                Strong fit when the task has repeatable inputs, clear output rules, source context, and predictable review points.
              </p>
            </div>
          </section>

          <section class="border border-tactas-line bg-white p-5 sm:p-6">
            <h2 class="text-[26px] font-semibold tracking-normal text-tactas-ink-strong">Inputs to provide</h2>
            <div class="mt-5 grid gap-3">
              {inputExamples.map((item) => (
                <div class="flex gap-3 border border-tactas-line-soft bg-tactas-bg-soft p-4">
                  <CheckCircle2 class="mt-0.5 h-4 w-4 shrink-0 text-tactas-accent-strong" stroke-width={1.9} />
                  <p class="text-[14px] leading-relaxed text-tactas-muted">{item}</p>
                </div>
              ))}
            </div>
          </section>

          <section class="border border-tactas-line bg-white p-5 sm:p-6">
            <h2 class="text-[26px] font-semibold tracking-normal text-tactas-ink-strong">How to use this prompt</h2>
            <div class="mt-5 grid gap-3">
              {usageSteps.map((step, index) => (
                <div class="grid gap-3 border border-tactas-line-soft bg-tactas-bg-soft p-4 sm:grid-cols-[44px_1fr]">
                  <span class="flex h-10 w-10 items-center justify-center rounded-[8px] bg-white text-[13px] font-semibold text-tactas-accent-strong shadow-[0_12px_34px_-28px_rgba(7,50,74,0.45)]">
                    {String(index + 1).padStart(2, "0")}
                  </span>
                  <div>
                    <h3 class="text-[16px] font-semibold tracking-normal text-tactas-ink-strong">{step.name}</h3>
                    <p class="mt-1 text-[14px] leading-relaxed text-tactas-muted">{step.text}</p>
                  </div>
                </div>
              ))}
            </div>
          </section>

          <section class="border border-tactas-line bg-white p-5 sm:p-6">
            <h2 class="text-[26px] font-semibold tracking-normal text-tactas-ink-strong">Guardrails</h2>
            <div class="mt-5 grid gap-3">
              {outputRules.map((item) => (
                <div class="flex gap-3 border border-tactas-line-soft bg-tactas-bg-soft p-4">
                  <CheckCircle2 class="mt-0.5 h-4 w-4 shrink-0 text-tactas-accent-strong" stroke-width={1.9} />
                  <p class="text-[14px] leading-relaxed text-tactas-muted">{item}</p>
                </div>
              ))}
            </div>
          </section>
        </div>

        <aside class="space-y-5 lg:sticky lg:top-24 lg:self-start">
          <div class="border border-tactas-line bg-white p-5">
            <p class="font-mono text-[10px] font-semibold uppercase tracking-[0.22em] text-tactas-accent-strong">Prompt type</p>
            <div class="mt-4 flex flex-wrap gap-2">
              <span class="rounded-full border border-tactas-line-strong bg-tactas-bg-soft px-3 py-1 text-[12px] font-medium text-tactas-muted">{prompt.department}</span>
              <span class="rounded-full border border-tactas-accent-line bg-tactas-accent-faint px-3 py-1 text-[12px] font-medium text-tactas-accent-strong">{prompt.category}</span>
            </div>
            <div class="mt-5 flex flex-wrap gap-2">
              {prompt.tags.map((tag) => (
                <span class="rounded-full border border-tactas-line-soft bg-white px-3 py-1 text-[12px] text-tactas-muted-soft">{tag}</span>
              ))}
            </div>
          </div>

          <div class="border border-tactas-line bg-tactas-night p-5 text-white">
            <Sparkles class="h-5 w-5 text-tactas-accent-line" stroke-width={1.9} />
            <h2 class="mt-4 text-[21px] font-semibold tracking-normal">Turn this into an AI workflow.</h2>
            <p class="mt-3 text-[14px] leading-relaxed text-white/72">
              Tactas can connect the prompt to your company knowledge, tools, approval rules, and workflow outputs.
            </p>
            <a href="/contact" class="mt-5 inline-flex h-11 w-full items-center justify-center rounded-[7px] bg-white px-4 text-[14px] font-semibold text-tactas-ink transition hover:bg-tactas-accent-soft">
              Build this workflow
            </a>
          </div>

          {relatedPrompts.length > 0 ? (
            <div class="border border-tactas-line bg-white p-5">
              <h2 class="text-[19px] font-semibold tracking-normal text-tactas-ink-strong">Related prompts</h2>
              <div class="mt-4 grid gap-3">
                {relatedPrompts.map((item) => (
                  <a href={`/ai-agent-prompt-library/${item.slug}`} class="group border border-tactas-line-soft bg-tactas-bg-soft p-4 transition hover:border-tactas-accent/55 hover:bg-white">
                    <span class="block text-[14px] font-semibold leading-snug text-tactas-ink-strong group-hover:text-tactas-accent-strong">{item.title}</span>
                    <span class="mt-1 block text-[12px] text-tactas-muted-soft">{item.department} / {item.category}</span>
                  </a>
                ))}
              </div>
            </div>
          ) : null}
        </aside>
      </div>

      <section class="border-t border-tactas-line bg-white">
        <div class="mx-auto flex w-full max-w-[1120px] flex-col gap-4 px-5 py-10 sm:px-8 lg:flex-row lg:items-center lg:justify-between lg:px-10">
          <div>
            <p class="font-mono text-[10px] font-semibold uppercase tracking-[0.22em] text-tactas-accent-strong">Prompt library</p>
            <h2 class="mt-2 text-[26px] font-semibold tracking-normal text-tactas-ink-strong">Browse more AI workflow prompts.</h2>
          </div>
          <a href="/ai-agent-prompt-library" class="inline-flex h-11 items-center justify-center rounded-[7px] border border-tactas-line-strong bg-white px-5 text-[14px] font-semibold text-tactas-ink-strong transition hover:border-tactas-accent-strong hover:text-tactas-accent-strong">
            Back to library
            <ArrowRight class="ml-2 h-4 w-4" stroke-width={1.9} />
          </a>
        </div>
      </section>
    </article>
  </main>
</BaseLayout>

<script is:inline>
  const copyButton = document.getElementById("copy-prompt");
  const promptText = document.getElementById("prompt-text");
  const copyStatus = document.getElementById("copy-status");

  async function copyText(text) {
    try {
      await navigator.clipboard.writeText(text);
      return true;
    } catch {
      const textarea = document.createElement("textarea");
      textarea.value = text;
      textarea.setAttribute("readonly", "");
      textarea.style.position = "fixed";
      textarea.style.opacity = "0";
      document.body.appendChild(textarea);
      textarea.select();
      const ok = document.execCommand("copy");
      textarea.remove();
      return ok;
    }
  }

  copyButton?.addEventListener("click", async () => {
    const copied = await copyText(promptText?.textContent || "");
    if (copyStatus) {
      copyStatus.textContent = copied ? "Prompt copied." : "Copy failed. Select and copy the prompt manually.";
    }
  });
</script>
