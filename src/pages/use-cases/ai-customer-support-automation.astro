---
import BaseLayout from "../../layouts/BaseLayout.astro";
import UseCaseDetailPage from "../../components/UseCaseDetailPage.astro";
import { getBrandEmail, getSiteUrl } from "../../lib/site";

const siteUrl = getSiteUrl();
const pageUrl = `${siteUrl}/use-cases/ai-customer-support-automation`;
const brandEmail = getBrandEmail();
const title = "Answer with Context Using Managed AI Agents | Tactas AI";
const description =
  "Managed AI agents answer repeated business requests with company knowledge, source context, business data, and connected tools.";

const props = {
  siteUrl,
  currentPath: "/use-cases/ai-customer-support-automation",
  eyebrow: "Answer with context",
  title: "Help teams answer repeated requests with business context.",
  description:
    "Tactas AI connects company knowledge, source documents, business data, and team tools so managed AI agents can prepare useful answers, summaries, updates, and next steps.",
  primaryKeyword: "answer with context",
  secondaryKeywords: ["company knowledge automation", "source-backed answers", "managed AI agents", "business task automation"],
  fit: [
    {
      title: "Repeated questions slow work",
      body: "Teams answer the same operational, customer, partner, or internal questions from scattered company knowledge.",
    },
    {
      title: "Context lives across sources",
      body: "Useful answers depend on documents, records, messages, policies, product notes, account history, or internal data.",
    },
    {
      title: "Answers need source confidence",
      body: "Teams need responses grounded in source context so people can see why an answer was prepared.",
    },
    {
      title: "Speed and consistency matter",
      body: "The business wants faster answers without every team member searching the same knowledge again.",
    },
  ],
  workflow: [
    { title: "Request arrives", body: "A message, form, note, or internal question asks for information or a decision-ready answer." },
    { title: "Find context", body: "The agent retrieves relevant source documents, business records, prior messages, and connected tool data." },
    { title: "Prepare answer", body: "AI creates an answer, summary, or explanation grounded in the available company context." },
    { title: "Suggest next step", body: "The agent can recommend follow-up, create a task draft, prepare an update, or point to missing information." },
    { title: "Improve reuse", body: "Patterns from repeated questions help refine the knowledge layer and make future answers faster." },
  ],
  outcomes: [
    { title: "Faster answers", body: "Reduce repeated searching, reading, and drafting when people need business context." },
    { title: "Source-backed work", body: "Answers include useful source context so teams can review and reuse the result confidently." },
    { title: "Better next steps", body: "Responses can include recommended owners, missing data, follow-up drafts, or task updates." },
    { title: "Improved work performance", body: "Teams spend less time hunting for context and more time moving work forward." },
  ],
  integrations: ["Email", "Slack", "Forms", "Google Drive", "SharePoint", "Notion", "HubSpot", "Databases", "Knowledge base", "Internal APIs"],
  faqs: [
    { title: "Can this use our company documents?", body: "Yes. Tactas AI can connect documents, files, messages, business data, and source context for managed agents to use." },
    { title: "Can answers include source context?", body: "Yes. Source-backed answers are a useful proof point so teams can see which knowledge shaped the output." },
    { title: "What is a good first request type?", body: "Start with repeated questions where the answer depends on known documents, records, policies, or prior work." },
  ],
};

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": `${pageUrl}#webpage`,
      name: "Answer with Context Using Managed AI Agents",
      url: pageUrl,
      description,
      isPartOf: { "@id": `${siteUrl}/#website` },
      inLanguage: "en-US",
    },
    {
      "@type": "Service",
      "@id": `${pageUrl}#service`,
      name: "Answer with Context Using Managed AI Agents",
      serviceType: ["Answer with context", "Company knowledge automation", "Source-backed answers", "Managed AI agents", "Business task automation"],
      url: pageUrl,
      description,
      provider: { "@id": `${siteUrl}/#organization` },
      areaServed: "Worldwide",
    },
    {
      "@type": "FAQPage",
      "@id": `${pageUrl}#faq`,
      mainEntity: props.faqs.map((item) => ({
        "@type": "Question",
        name: item.title,
        acceptedAnswer: { "@type": "Answer", text: item.body },
      })),
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Home", item: `${siteUrl}/` },
        { "@type": "ListItem", position: 2, name: "Use Cases", item: `${siteUrl}/use-cases` },
        { "@type": "ListItem", position: 3, name: "Answer with Context", item: pageUrl },
      ],
    },
    { "@type": "ContactPoint", contactType: "sales", email: brandEmail, areaServed: "Worldwide", availableLanguage: ["en", "vi"] },
  ],
};
---

<BaseLayout
  title={title}
  description={description}
  canonical="/use-cases/ai-customer-support-automation"
  currentPath="/use-cases/ai-customer-support-automation"
  navbarTheme="light"
  navbarCtaLabel="Book a review"
  keywords={[
    "answer with context",
    "managed AI agents",
    "company knowledge automation",
    "source-backed answers",
    "business task automation",
    "AI agents for business operations",
    "connected business tools",
    "work performance AI",
  ]}
  openGraph={{ title, description, url: pageUrl, type: "website", images: [{ url: "/tactas-ai-managed-agent-systems-og.jpg", width: 1734, height: 907, alt: "Managed AI agents answering with business context" }] }}
  twitter={{ card: "summary_large_image", title, description, images: ["/tactas-ai-managed-agent-systems-og.jpg"] }}
  jsonLd={jsonLd}
>
  <UseCaseDetailPage {...props} />
</BaseLayout>
