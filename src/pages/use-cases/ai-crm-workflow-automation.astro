---
import BaseLayout from "../../layouts/BaseLayout.astro";
import UseCaseDetailPage from "../../components/UseCaseDetailPage.astro";
import { getBrandEmail, getSiteUrl } from "../../lib/site";

const siteUrl = getSiteUrl();
const pageUrl = `${siteUrl}/use-cases/ai-crm-workflow-automation`;
const brandEmail = getBrandEmail();
const title = "Prepare Next Steps with Managed AI Agents | Tactas AI";
const description =
  "Managed AI agents summarize business context, prepare follow-up drafts, recommend owners, and keep open work moving across connected tools.";

const props = {
  siteUrl,
  currentPath: "/use-cases/ai-crm-workflow-automation",
  eyebrow: "Prepare next steps",
  title: "Move work forward with action-ready next steps.",
  description:
    "Tactas AI helps teams turn messages, notes, documents, business data, and tool activity into summaries, follow-up drafts, task owners, and next actions.",
  primaryKeyword: "prepare next steps",
  secondaryKeywords: ["managed AI agents", "business task automation", "connected business tools", "work performance AI"],
  fit: [
    {
      title: "Work stalls after context gathering",
      body: "People collect notes, messages, files, and records but still need to decide what should happen next.",
    },
    {
      title: "Follow-up is inconsistent",
      body: "Next actions, owners, reminders, summaries, and task updates are often missing or prepared late.",
    },
    {
      title: "Context changes quickly",
      body: "The right next step depends on recent messages, document changes, tool activity, and company knowledge.",
    },
    {
      title: "Outputs should be ready to use",
      body: "Teams need prepared briefs, tasks, updates, or follow-up drafts that can be reviewed and acted on quickly.",
    },
  ],
  workflow: [
    { title: "Work signal appears", body: "A message, meeting note, form response, document update, or tool event indicates work should move." },
    { title: "Summarize context", body: "The agent gathers relevant history, source knowledge, recent changes, and related business data." },
    { title: "Recommend next step", body: "AI identifies the likely owner, missing information, follow-up action, or task path." },
    { title: "Prepare output", body: "The agent drafts the message, task, brief, update, checklist, or record change needed to continue." },
    { title: "Track open work", body: "The task stays visible with status, next action, owner, and related source context." },
  ],
  outcomes: [
    { title: "Clearer next actions", body: "Reduce unclear owners, missing follow-up, and work that sits between tools." },
    { title: "Faster prepared outputs", body: "Generate briefs, replies, tasks, and status updates from the same business context." },
    { title: "Better handoff quality", body: "Pass work forward with source context, summary, owner, and recommended action." },
    { title: "More consistent execution", body: "Use repeatable task patterns so teams spend less energy rebuilding next steps." },
  ],
  integrations: ["HubSpot", "Salesforce", "Airtable", "Gmail", "Outlook", "Google Calendar", "Slack", "Forms", "Project tools", "Internal APIs"],
  faqs: [
    { title: "Can this prepare follow-up drafts?", body: "Yes. The agent can prepare emails, notes, summaries, task descriptions, briefs, and status updates from business context." },
    { title: "Can it recommend an owner or next action?", body: "Yes. Tactas can use task rules, historical context, source knowledge, and connected tool data to recommend where work should go next." },
    { title: "Can it track open work?", body: "Yes. The agent can keep status, owner, next action, and source context visible across the tools your team uses." },
  ],
};

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "WebPage", "@id": `${pageUrl}#webpage`, name: "Prepare Next Steps with Managed AI Agents", url: pageUrl, description, isPartOf: { "@id": `${siteUrl}/#website` }, inLanguage: "en-US" },
    {
      "@type": "Service",
      "@id": `${pageUrl}#service`,
      name: "Prepare Next Steps with Managed AI Agents",
      serviceType: ["Prepare next steps", "Managed AI agents", "Business task automation", "Connected business tools", "Work performance AI"],
      url: pageUrl,
      description,
      provider: { "@id": `${siteUrl}/#organization` },
      areaServed: "Worldwide",
    },
    {
      "@type": "FAQPage",
      "@id": `${pageUrl}#faq`,
      mainEntity: props.faqs.map((item) => ({ "@type": "Question", name: item.title, acceptedAnswer: { "@type": "Answer", text: item.body } })),
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Home", item: `${siteUrl}/` },
        { "@type": "ListItem", position: 2, name: "Use Cases", item: `${siteUrl}/use-cases` },
        { "@type": "ListItem", position: 3, name: "Prepare Next Steps", item: pageUrl },
      ],
    },
    { "@type": "ContactPoint", contactType: "sales", email: brandEmail, areaServed: "Worldwide", availableLanguage: ["en", "vi"] },
  ],
};
---

<BaseLayout
  title={title}
  description={description}
  canonical="/use-cases/ai-crm-workflow-automation"
  currentPath="/use-cases/ai-crm-workflow-automation"
  navbarTheme="light"
  navbarCtaLabel="Task review"
  keywords={[
    "prepare next steps",
    "managed AI agents",
    "business task automation",
    "connected business tools",
    "work performance AI",
    "AI agents for business operations",
    "automated business tasks",
    "company knowledge automation",
  ]}
  openGraph={{ title, description, url: pageUrl, type: "website", images: [{ url: "/ef4e97cc-14e2-4157-a55f-42bfa62ad8a3.png", width: 1536, height: 1024, alt: "Managed AI agents preparing next steps" }] }}
  twitter={{ card: "summary_large_image", title, description, images: ["/ef4e97cc-14e2-4157-a55f-42bfa62ad8a3.png"] }}
  jsonLd={jsonLd}
>
  <UseCaseDetailPage {...props} />
</BaseLayout>
