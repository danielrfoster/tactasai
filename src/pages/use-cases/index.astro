---
import BaseLayout from "../../layouts/BaseLayout.astro";
import UseCasesIndexPage from "../../components/UseCasesIndexPage.astro";
import { getSiteUrl } from "../../lib/site";

const siteUrl = getSiteUrl();
const pageUrl = `${siteUrl}/use-cases`;
const title = "Business Task Automation Use Cases | Tactas AI";
const description =
  "Explore how managed AI agents use company knowledge, business context, and connected tools to answer with context, prepare next steps, track open work, and automate repeated business tasks.";

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "CollectionPage",
      "@id": `${pageUrl}#collectionpage`,
      name: "Business Task Automation Use Cases",
      url: pageUrl,
      description,
      isPartOf: { "@id": `${siteUrl}/#website` },
      inLanguage: "en-US",
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Home", item: `${siteUrl}/` },
        { "@type": "ListItem", position: 2, name: "Use Cases", item: pageUrl },
      ],
    },
  ],
};
---

<BaseLayout
  title={title}
  description={description}
  canonical="/use-cases"
  currentPath="/use-cases"
  navbarTheme="light"
  navbarCtaLabel="Book a review"
  keywords={[
    "business task automation use cases",
    "managed AI agents",
    "AI agents for business operations",
    "company knowledge automation",
    "connected business tools",
    "work performance AI",
    "automated business tasks",
    "AI operating layer",
  ]}
  openGraph={{
    title,
    description,
    url: pageUrl,
    type: "website",
    images: [
      {
        url: "/tactas-ai-managed-agent-systems-og.jpg",
        width: 1734,
        height: 907,
        alt: "Tactas AI business task automation use cases",
      },
    ],
  }}
  twitter={{
    card: "summary_large_image",
    title,
    description,
    images: ["/tactas-ai-managed-agent-systems-og.jpg"],
  }}
  jsonLd={jsonLd}
>
  <UseCasesIndexPage siteUrl={siteUrl} currentPath="/use-cases" />
</BaseLayout>
