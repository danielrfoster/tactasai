---
import BaseLayout from "../../layouts/BaseLayout.astro";
import UseCaseDetailPage from "../../components/UseCaseDetailPage.astro";
import { getBrandEmail, getSiteUrl } from "../../lib/site";

const siteUrl = getSiteUrl();
const pageUrl = `${siteUrl}/use-cases/ai-back-office-automation`;
const brandEmail = getBrandEmail();
const title = "Automate Repeated Business Updates with Managed AI Agents | Tactas AI";
const description =
  "Managed AI agents turn repeated business updates, document summaries, record changes, and routine coordination into action-ready work.";

const props = {
  siteUrl,
  currentPath: "/use-cases/ai-back-office-automation",
  eyebrow: "Automate repeated updates",
  title: "Automate recurring business updates across tools.",
  description:
    "Tactas AI uses company knowledge, business context, and connected systems to prepare summaries, update records, track status, and automate repeated steps.",
  primaryKeyword: "automate repeated updates",
  secondaryKeywords: ["business task automation", "connected business tools", "managed AI agents", "work performance AI"],
  fit: [
    {
      title: "Updates repeat every day",
      body: "Teams keep writing the same status notes, summaries, task updates, and follow-up messages across business tools.",
    },
    {
      title: "Inputs come from many places",
      body: "The work depends on files, messages, forms, databases, spreadsheets, or tool activity that people manually combine.",
    },
    {
      title: "Records drift out of sync",
      body: "Important fields, notes, owners, and task status need regular updates after work happens elsewhere.",
    },
    {
      title: "Teams need work ready to use",
      body: "The output should be ready to review, edit, send, assign, or push into a connected business tool.",
    },
  ],
  workflow: [
    { title: "Watch for work", body: "A message, record change, uploaded file, new form, or scheduled moment starts the task." },
    { title: "Gather context", body: "The agent pulls source content, business data, recent changes, related notes, and tool activity." },
    { title: "Prepare update", body: "AI drafts the summary, status update, record change, checklist, or next action." },
    { title: "Automate step", body: "The agent can create tasks, update fields, send a prepared message, or move work to the next tool." },
    { title: "Improve pattern", body: "Repeated updates become more consistent as the agent learns the business context and preferred output." },
  ],
  outcomes: [
    { title: "Less repetitive coordination", body: "Reduce manual searching, copying, summarizing, and updating across everyday business systems." },
    { title: "Faster work status", body: "Generate clear status updates from source context without rebuilding the same summary each time." },
    { title: "Cleaner records", body: "Keep fields, notes, owners, and task status aligned with fewer manual updates." },
    { title: "More reliable routines", body: "Turn repeated updates into a managed pattern that the team can reuse and improve." },
  ],
  integrations: ["Email", "Slack", "Google Drive", "SharePoint", "S3", "PostgreSQL", "Airtable", "HubSpot", "Notion", "Internal APIs"],
  faqs: [
    { title: "What repeated updates are a good fit?", body: "Good first tasks include weekly summaries, record updates, document recaps, status reports, and routine follow-up messages." },
    { title: "Can the agent update our tools?", body: "Yes. Tactas can connect to business tools and prepare or apply updates within the permissions you choose." },
    { title: "Does this require perfect data?", body: "No. Start with the sources you already use, then improve the knowledge layer and task pattern over time." },
  ],
};

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "WebPage", "@id": `${pageUrl}#webpage`, name: "Automate Repeated Business Updates", url: pageUrl, description, isPartOf: { "@id": `${siteUrl}/#website` }, inLanguage: "en-US" },
    {
      "@type": "Service",
      "@id": `${pageUrl}#service`,
      name: "Automate Repeated Business Updates",
      serviceType: ["Business task automation", "Managed AI agents", "Connected business tools", "Company knowledge automation", "Work performance AI"],
      url: pageUrl,
      description,
      provider: { "@id": `${siteUrl}/#organization` },
      areaServed: "Worldwide",
    },
    {
      "@type": "FAQPage",
      "@id": `${pageUrl}#faq`,
      mainEntity: props.faqs.map((item) => ({ "@type": "Question", name: item.title, acceptedAnswer: { "@type": "Answer", text: item.body } })),
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Home", item: `${siteUrl}/` },
        { "@type": "ListItem", position: 2, name: "Use Cases", item: `${siteUrl}/use-cases` },
        { "@type": "ListItem", position: 3, name: "Automate Repeated Updates", item: pageUrl },
      ],
    },
    { "@type": "ContactPoint", contactType: "sales", email: brandEmail, areaServed: "Worldwide", availableLanguage: ["en", "vi"] },
  ],
};
---

<BaseLayout
  title={title}
  description={description}
  canonical="/use-cases/ai-back-office-automation"
  currentPath="/use-cases/ai-back-office-automation"
  navbarTheme="light"
  navbarCtaLabel="Task review"
  keywords={[
    "automate repeated updates",
    "business task automation",
    "managed AI agents",
    "connected business tools",
    "company knowledge automation",
    "AI agents for business operations",
    "work performance AI",
    "automated business tasks",
  ]}
  openGraph={{ title, description, url: pageUrl, type: "website", images: [{ url: "/ef4e97cc-14e2-4157-a55f-42bfa62ad8a3.png", width: 1536, height: 1024, alt: "Managed AI agents automating repeated business updates" }] }}
  twitter={{ card: "summary_large_image", title, description, images: ["/ef4e97cc-14e2-4157-a55f-42bfa62ad8a3.png"] }}
  jsonLd={jsonLd}
>
  <UseCaseDetailPage {...props} />
</BaseLayout>
