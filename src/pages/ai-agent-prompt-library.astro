---
import BaseLayout from "../layouts/BaseLayout.astro";
import AIAgentPromptLibraryPage from "../components/AIAgentPromptLibraryPage.astro";
import { promptLibrary } from "../lib/promptLibrary";
import { getSiteUrl } from "../lib/site";

const siteUrl = getSiteUrl();
const pageUrl = `${siteUrl}/ai-agent-prompt-library`;
const title = "AI Agent Prompt Library for Business Workflows | Tactas AI";
const description =
  "Browse AI agent prompts for support, sales, operations, professional services, healthcare, ecommerce, finance, security, marketing, and engineering workflows.";

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "CollectionPage",
      "@id": `${pageUrl}#collectionpage`,
      name: "AI Agent Prompt Library for Business Workflows",
      url: pageUrl,
      description,
      isPartOf: { "@id": `${siteUrl}/#website` },
      about: [
        "AI agent prompts",
        "Business workflow automation",
        "Managed AI agents",
        "Support automation",
        "CRM workflow automation",
        "Operations automation",
      ],
      inLanguage: "en-US",
    },
    {
      "@type": "ItemList",
      "@id": `${pageUrl}#prompt-list`,
      name: "AI Agent Prompt Library",
      itemListElement: promptLibrary.map((prompt, index) => ({
        "@type": "ListItem",
        position: index + 1,
        name: prompt.title,
        url: `${pageUrl}/${prompt.slug}`,
      })),
    },
    {
      "@type": "FAQPage",
      "@id": `${pageUrl}#faq`,
      mainEntity: [
        {
          "@type": "Question",
          name: "What is an AI agent prompt library?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "An AI agent prompt library is a collection of reusable instructions for business workflows such as support triage, CRM follow-up, document review, workflow analysis, and status updates.",
          },
        },
        {
          "@type": "Question",
          name: "Can these prompts become automated workflows?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "Yes. A prompt can become a supervised workflow when it is connected to company knowledge, business systems, approval rules, exception handling, and measurable outputs.",
          },
        },
        {
          "@type": "Question",
          name: "Are these prompts a replacement for human review?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "No. The prompts are designed to prepare useful work for review. Sensitive decisions, regulated judgment, customer commitments, payments, legal terms, and security exceptions should remain under human approval.",
          },
        },
      ],
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Home", item: `${siteUrl}/` },
        { "@type": "ListItem", position: 2, name: "AI Agent Prompt Library", item: pageUrl },
      ],
    },
  ],
};
---

<BaseLayout
  title={title}
  description={description}
  canonical="/ai-agent-prompt-library"
  currentPath="/ai-agent-prompt-library"
  navbarTheme="light"
  navbarCtaLabel="Book a review"
  keywords={[
    "AI agent prompt library",
    "AI workflow prompts",
    "business workflow prompts",
    "AI agent prompts for business",
    "support automation prompts",
    "CRM workflow prompts",
    "operations automation prompts",
    "managed AI agents",
    "business task automation",
    "AI prompts for customer support",
    "AI prompts for sales operations",
    "AI prompts for business operations",
    "AI agent workflow templates",
  ]}
  openGraph={{
    title,
    description,
    url: pageUrl,
    type: "website",
    images: [
      {
        url: "/tactas-ai-managed-agent-systems-og.jpg",
        width: 1734,
        height: 907,
        alt: "Tactas AI agent prompt library for business workflows",
      },
    ],
  }}
  twitter={{
    card: "summary_large_image",
    title,
    description,
    images: ["/tactas-ai-managed-agent-systems-og.jpg"],
  }}
  jsonLd={jsonLd}
>
  <AIAgentPromptLibraryPage currentPath="/ai-agent-prompt-library" />
</BaseLayout>
