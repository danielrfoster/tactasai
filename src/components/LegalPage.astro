---
interface Props {
  eyebrow?: string;
  title: string;
  updatedAt: string;
}

const { eyebrow = "Legal", title, updatedAt } = Astro.props;
---

<main class="min-h-screen bg-[#0b1220] py-20 text-[#f8fafc]">
  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
    <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-[#06B6D4]">{eyebrow}</p>
    <h1 class="mt-3 text-3xl font-bold tracking-tight text-[#f8fafc] sm:text-4xl">{title}</h1>
    <p class="mt-3 text-sm text-[#94a3b8]">Last updated: {updatedAt}</p>
    <div class="mt-10 space-y-8 text-sm leading-relaxed text-[#94a3b8]">
      <slot />
    </div>
  </div>
</main>
