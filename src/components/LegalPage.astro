---

interface Props {
  eyebrow?: string;
  title: string;
  updatedAt: string;
  currentPath?: string;
}

const { eyebrow = "Legal", title, updatedAt, currentPath = Astro.url.pathname } = Astro.props;
---

<div class="min-h-screen bg-tactas-bg text-tactas-ink">

  <main>
    <section class="relative overflow-hidden border-b border-tactas-line bg-tactas-bg">
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[420px] bg-[linear-gradient(180deg,var(--bg-elevated)_0%,transparent_100%)]"></div>
      <div class="pointer-events-none absolute inset-0 opacity-[0.26] [background-image:linear-gradient(to_right,rgba(15,23,42,0.06)_1px,transparent_1px),linear-gradient(to_bottom,rgba(15,23,42,0.05)_1px,transparent_1px)] [background-size:64px_64px]"></div>

      <div class={`tactas-container relative py-16 lg:py-20`}>
        <div class="max-w-3xl">
          <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-tactas-accent-strong">{eyebrow}</p>
          <h1 class="mt-4 text-[clamp(2.6rem,6vw,4.7rem)] font-semibold leading-[0.96] tracking-normal text-tactas-ink">
            {title}
          </h1>
          <p class="mt-5 text-[15px] leading-relaxed text-tactas-muted-soft">Last updated: {updatedAt}</p>
        </div>
      </div>
    </section>

    <section class="border-b border-tactas-line bg-white">
      <div class={`tactas-container py-12 lg:py-16`}>
        <div class="max-w-3xl space-y-8 text-[15px] leading-relaxed text-tactas-muted">
          <slot />
        </div>

        <div class="mt-12 border-t border-tactas-line pt-6 text-[13px] font-semibold text-tactas-muted-soft">
          <a href="/" class="transition hover:text-tactas-accent">Back to home</a>
        </div>
      </div>
    </section>
  </main>
</div>
