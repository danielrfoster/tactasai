---
import {
  ArrowRight,
  Bot,
  Check,
  ClipboardCheck,
  Database,
  FileText,
  GitBranch,
  Layers,
  Mail,
  MessageSquare,
  Route,
  Send,
  ShieldCheck,
  Sparkles,
  Workflow,
  Zap,
} from "@lucide/astro";
import { getBrandEmail } from "../lib/site";

interface Props {
  siteUrl: string;
  currentPath?: string;
}

const { currentPath = "/product/ai-workflow-automation" } = Astro.props;
const brandEmail = getBrandEmail();

const trustPoints = [
  ["Improve work", "Agents help teams move faster"],
  ["Use knowledge", "Company context guides every task"],
  ["Fit existing tools", "Docs, messages, tasks, data, and apps"],
  ["Managed launch", "Setup, automation mapping, and tuning included"],
];

const inputs = ["Requests", "Forms", "Emails", "Documents", "Tasks", "Business data"];
const actions = ["Prepare output", "Update work", "Create task", "Draft follow-up", "Generate report", "Notify team"];

const serviceLayers = [
  {
    title: "Choose a business task",
    body: "Start with one repeated task, define the useful output, identify the context it needs, and map where work should move next.",
    icon: Route,
  },
  {
    title: "Connect knowledge and tools",
    body: "Connect company knowledge, business data, documents, messages, task tools, and apps the agent needs to understand the request.",
    icon: GitBranch,
  },
  {
    title: "Prepare outputs and actions",
    body: "Agents use business context to draft useful work, prepare updates, create tasks, organize follow-ups, and automate repeated steps.",
    icon: Bot,
  },
  {
    title: "Improve work performance",
    body: "Tune the task map, improve outputs, expand connected context, and reduce repeated manual effort as the business changes.",
    icon: ShieldCheck,
  },
];

const workflowSteps = [
  ["01", "Request", "A message, form, document, task, or business update starts the work."],
  ["02", "Understand context", "The agent gathers company knowledge, source context, tool data, and prior work."],
  ["03", "Prepare output", "The agent turns messy input into a useful answer, summary, brief, update, or plan."],
  ["04", "Automate step", "The agent creates tasks, prepares follow-ups, updates work, or moves repeated steps forward."],
  ["05", "Improve", "The task map is tuned as patterns, sources, outputs, and business needs change."],
];

const useCases = [
  ["Summarize changes", "Collect context from business sources and produce a clear brief of what changed and what matters."],
  ["Answer with context", "Use company knowledge and source context to prepare accurate answers and next steps."],
  ["Prepare next steps", "Turn updates, requests, and documents into task-ready plans your team can use."],
  ["Track open work", "Find pending work, group follow-ups, surface owners, and keep repeated activity moving."],
  ["Automate repeated updates", "Prepare updates, create tasks, sync useful information, and notify the right people."],
  ["Generate recurring reports", "Collect business inputs, summarize patterns, and prepare useful recurring outputs."],
];

const packages = [
  {
    name: "Task Review",
    body: "Map one repeated business task, define the target output, and identify the knowledge and tools it needs.",
    items: ["1 task mapped", "Key context sources", "Automation map"],
  },
  {
    name: "Managed Task",
    body: "Launch a managed AI agent for one production task with connected tools, prepared outputs, and ongoing improvements.",
    items: ["Connected tools", "Prepared outputs", "Ongoing tuning"],
  },
  {
    name: "Enterprise Automation",
    body: "Expand managed agents across repeated tasks with shared context, consistent task maps, and business reporting.",
    items: ["Multiple tasks", "Shared context layer", "Custom reporting"],
  },
];

const faqs = [
  ["What is business task automation with AI agents?", "Business task automation uses managed AI agents to understand company context, prepare useful outputs, update work, and automate repeated steps across connected tools."],
  ["Can agents take actions in our systems?", "Yes. Managed AI agents can prepare updates, create tasks, organize follow-ups, and automate repeated steps across tools your business already uses."],
  ["Which business task should we automate first?", "Start with a frequent task that has available context, a clear output, connected tools, and repeated manual effort."],
  ["Is this self-serve software?", "No. Tactas AI is a managed product layer. We help map, build, connect, launch, and improve the business task after it goes live."],
];
---

<div class="min-h-screen overflow-x-hidden bg-tactas-bg text-tactas-ink selection:bg-tactas-accent/20">
  <div class="pointer-events-none fixed inset-0 -z-20 grid-faint opacity-[0.24] [mask-image:radial-gradient(ellipse_70%_60%_at_50%_10%,black_0%,transparent_75%)]"></div>

  <main>
    <section class="relative overflow-hidden border-b border-tactas-line">
      <div class="pointer-events-none absolute inset-0 z-0 bg-[linear-gradient(180deg,rgba(124,58,237,0.14)_0%,rgba(5,10,20,0)_60%)]"></div>
      <div class="pointer-events-none absolute inset-0 z-0 opacity-[0.30] [background-image:linear-gradient(to_right,rgba(255,255,255,0.055)_1px,transparent_1px),linear-gradient(to_bottom,rgba(255,255,255,0.045)_1px,transparent_1px)] [background-size:72px_72px]"></div>

      <div class={`tactas-container relative z-10 grid min-h-[720px] items-center gap-14 py-16 lg:grid-cols-[0.95fr_1.05fr] lg:py-20`}>
        <div class="reveal">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-tactas-accent-line bg-tactas-accent-soft/80 px-3 py-1.5">
            <Sparkles class="h-3.5 w-3.5 text-tactas-accent-strong" stroke-width={1.8} />
            <span class="font-mono text-[10px] font-semibold uppercase tracking-[0.24em] text-tactas-accent-strong">
              Business task automation
            </span>
          </div>

          <h1 class="max-w-[13ch] text-[clamp(3rem,7vw,5.8rem)] font-extrabold leading-[0.94] tracking-[-0.045em]">
            Automate repeated business tasks with managed AI agents.
          </h1>

          <p class="mt-7 max-w-[42rem] text-[17px] leading-relaxed text-tactas-muted">
            TactasAI deploys managed AI agents that learn your company context, work with your team,
            and turn business knowledge into outputs, updates, next steps, and automated actions.
          </p>

          <div class="mt-9 flex flex-col gap-3 sm:flex-row sm:items-center">
            <a
              href="#contact"
              class="group inline-flex h-12 items-center justify-center rounded-[6px] bg-tactas-primary px-6 text-[14px] font-semibold text-white shadow-[0_18px_48px_-24px_rgba(124,58,237,0.8)] transition hover:bg-tactas-accent"
            >
              Start a task review
              <ArrowRight class="ml-2 h-4 w-4 transition group-hover:translate-x-0.5" stroke-width={1.9} />
            </a>
            <a
              href="#product"
              class="inline-flex h-12 items-center justify-center rounded-[6px] border border-tactas-line bg-white px-6 text-[14px] font-semibold text-tactas-ink-strong transition hover:border-tactas-accent/70 hover:text-tactas-accent-strong"
            >
              See automation model
            </a>
          </div>

          <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
            {trustPoints.map(([title, body]) => (
              <div class="border-l border-tactas-accent/50 pl-4">
                <p class="text-[14px] font-semibold text-tactas-ink-strong">{title}</p>
                <p class="mt-1 text-[12px] leading-relaxed text-tactas-muted-soft">{body}</p>
              </div>
            ))}
          </div>
        </div>

        <div class="reveal" data-delay="2">
          <div class="relative mx-auto max-w-[680px]">
            <div class="absolute inset-x-8 bottom-[-18px] h-12 rounded-full bg-tactas-primary/18 blur-2xl"></div>
            <div class="relative overflow-hidden rounded-[12px] border border-tactas-line bg-white shadow-[0_40px_110px_-56px_rgba(0,0,0,0.95)]">
              <div class="flex h-12 items-center justify-between border-b border-tactas-line bg-white px-4">
                <div class="flex items-center gap-2">
                  <span class="h-2.5 w-2.5 rounded-full bg-tactas-accent"></span>
                  <span class="h-2.5 w-2.5 rounded-full bg-white/24"></span>
                  <span class="h-2.5 w-2.5 rounded-full bg-white/24"></span>
                </div>
                <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-tactas-accent-strong">Task automation map</p>
              </div>

              <div class="grid gap-4 p-5 lg:grid-cols-[1fr_1.15fr_1fr]">
                <div>
                  <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-tactas-accent-strong">Inputs</p>
                  <div class="mt-4 grid gap-2">
                    {inputs.map((item, index) => (
                      <div class:list={[
                        "rounded-[6px] border px-3 py-2 text-[12px]",
                        index < 3 ? "border-tactas-accent-line bg-tactas-accent-soft text-tactas-ink-strong" : "border-tactas-line bg-white text-tactas-muted-soft",
                      ]}>
                        {item}
                      </div>
                    ))}
                  </div>
                </div>

                <div class="relative flex min-h-[360px] items-center justify-center">
                  <div class="absolute inset-x-2 top-1/2 h-px bg-tactas-primary/35"></div>
                  <div class="absolute left-1/2 top-8 h-[280px] w-px bg-tactas-primary/25"></div>
                  <div class="relative z-10 flex h-44 w-44 items-center justify-center rounded-[28px] border border-tactas-accent/50 bg-tactas-accent-soft shadow-[0_0_80px_-22px_rgba(124,58,237,0.88)]">
                    <div class="flex h-24 w-24 items-center justify-center rounded-[20px] border border-tactas-accent/45 bg-tactas-primary/20">
                      <Workflow class="h-11 w-11 text-tactas-accent-strong" stroke-width={1.45} />
                    </div>
                  </div>

                  <div class="absolute bottom-5 left-1/2 z-10 w-[210px] -translate-x-1/2 rounded-[8px] border border-tactas-line bg-white p-3">
                    <div class="flex items-center gap-2">
                      <ShieldCheck class="h-4 w-4 text-tactas-accent-strong" stroke-width={1.8} />
                      <p class="text-[12px] font-semibold text-tactas-ink-strong">Work ready</p>
                    </div>
                    <p class="mt-1 text-[11px] text-tactas-muted-soft">Use, edit, assign, or automate.</p>
                  </div>
                </div>

                <div>
                  <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-tactas-accent-strong">Actions</p>
                  <div class="mt-4 grid gap-2">
                    {actions.map((item, index) => (
                      <div class:list={[
                        "rounded-[6px] border px-3 py-2 text-[12px]",
                        index < 4 ? "border-tactas-accent-line bg-tactas-accent-soft text-tactas-ink-strong" : "border-tactas-line bg-white text-tactas-muted-soft",
                      ]}>
                        {item}
                      </div>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="border-b border-tactas-line bg-tactas-bg">
      <div class={`tactas-container py-10`}>
        <div class="grid gap-3 text-center sm:grid-cols-2 lg:grid-cols-4">
          {["Business Task Automation", "Managed AI Agents", "Connected Business Tools", "Work Performance AI"].map((term) => (
            <div class="rounded-[8px] border border-tactas-line bg-white px-4 py-4 font-mono text-[11px] uppercase tracking-[0.18em] text-tactas-accent-strong">
              {term}
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="product" class="border-b border-tactas-line bg-tactas-bg">
      <div class={`tactas-container py-18 lg:py-24`}>
        <div class="mx-auto max-w-3xl text-center">
          <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-tactas-accent-strong">Managed product</p>
          <h2 class="mt-4 text-[clamp(2rem,4vw,3.2rem)] font-bold leading-tight tracking-[-0.025em]">
            Business task automation with managed AI agents, built end to end.
          </h2>
          <p class="mt-5 text-[16px] leading-relaxed text-tactas-muted-soft">
            Tactas AI handles the operating layer around AI agents: task mapping, company knowledge, connected tools,
            prepared outputs, automated steps, and ongoing improvement.
          </p>
          <a href="/product/assistant" class="mt-6 inline-flex items-center text-[14px] font-semibold text-tactas-accent-strong transition hover:text-tactas-accent">
            Explore the assistant experience
            <ArrowRight class="ml-2 h-4 w-4" stroke-width={1.9} />
          </a>
        </div>

        <div class="mt-12 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
          {serviceLayers.map((item) => {
            const Icon = item.icon;
            return (
              <article class="group min-h-[260px] rounded-[8px] border border-tactas-line bg-white p-6 transition hover:border-tactas-accent/50 hover:bg-white">
                <span class="flex h-12 w-12 items-center justify-center rounded-[8px] border border-tactas-accent/25 bg-tactas-accent-soft text-tactas-accent-strong">
                  <Icon class="h-5 w-5" stroke-width={1.8} />
                </span>
                <h3 class="mt-7 text-[22px] font-semibold tracking-tight">{item.title}</h3>
                <p class="mt-3 text-[14px] leading-relaxed text-tactas-muted-soft">{item.body}</p>
              </article>
            );
          })}
        </div>
      </div>
    </section>

    <section id="architecture" class="border-b border-tactas-line bg-tactas-bg text-tactas-ink">
      <div class={`tactas-container py-16 lg:py-20`}>
        <div class="mx-auto max-w-3xl text-center">
          <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-tactas-accent">Execution model</p>
          <h2 class="mt-4 text-[clamp(2rem,4vw,3.1rem)] font-bold leading-tight tracking-[-0.025em]">
            From request to useful work.
          </h2>
        </div>

        <div class="mt-12 grid gap-4 lg:grid-cols-5">
          {workflowSteps.map(([step, title, body], index) => (
            <article class="relative rounded-[8px] border border-tactas-line bg-white p-5 shadow-[0_20px_60px_-52px_rgba(15,23,42,0.28)]">
              {index < workflowSteps.length - 1 ? (
                <div class="absolute -right-3 top-10 hidden h-px w-6 bg-tactas-primary/45 lg:block"></div>
              ) : null}
              <p class="font-mono text-[11px] text-tactas-accent">{step}</p>
              <h3 class="mt-5 text-[17px] font-semibold">{title}</h3>
              <p class="mt-3 text-[13px] leading-relaxed text-tactas-muted-soft">{body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="border-b border-tactas-line bg-tactas-bg">
      <div class={`tactas-container grid gap-12 py-18 lg:grid-cols-[0.72fr_1.28fr] lg:py-24`}>
        <div>
          <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-tactas-accent-strong">Task examples</p>
          <h2 class="mt-4 text-[clamp(2rem,4vw,3.15rem)] font-bold leading-tight tracking-[-0.025em]">
            Start with business tasks that repeat every day.
          </h2>
          <p class="mt-5 text-[16px] leading-relaxed text-tactas-muted-soft">
            The best first automation has clear context, repeated effort, visible output, and connected tools your team already uses.
          </p>
        </div>

        <div class="grid gap-3 sm:grid-cols-2">
          {useCases.map(([title, body]) => (
            <div class="rounded-[8px] border border-tactas-line bg-white p-5">
              <div class="flex items-center gap-3">
                <Zap class="h-4.5 w-4.5 shrink-0 text-tactas-accent-strong" stroke-width={1.8} />
                <h3 class="text-[15px] font-semibold text-tactas-ink-strong">{title}</h3>
              </div>
              <p class="mt-3 text-[13px] leading-relaxed text-tactas-muted-soft">{body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="border-b border-tactas-line bg-tactas-bg">
      <div class={`tactas-container py-18 lg:py-24`}>
        <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
          <div class="max-w-3xl">
            <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-tactas-accent-strong">Packages</p>
            <h2 class="mt-4 text-[clamp(2rem,4vw,3.15rem)] font-bold leading-tight tracking-[-0.025em]">
              Pilot one task, then expand the operating layer.
            </h2>
          </div>
          <a href="#contact" class="inline-flex h-11 items-center justify-center rounded-[6px] border border-tactas-line px-4 text-[13px] font-semibold text-tactas-ink-strong transition hover:border-tactas-accent/70 hover:text-tactas-accent-strong">
            Discuss scope
          </a>
        </div>

        <div class="mt-10 grid gap-4 lg:grid-cols-3">
          {packages.map((plan, index) => (
            <article class:list={[
              "rounded-[8px] border p-6",
              index === 1 ? "border-tactas-accent/60 bg-tactas-accent-soft" : "border-tactas-line bg-tactas-bg",
            ]}>
              <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-tactas-accent-strong">{plan.name}</p>
              <p class="mt-5 min-h-[96px] text-[15px] leading-relaxed text-tactas-muted">{plan.body}</p>
              <ul class="mt-6 grid gap-3 border-t border-tactas-line pt-5">
                {plan.items.map((item) => (
                  <li class="flex items-start gap-2.5 text-[14px] text-tactas-muted-soft">
                    <Check class="mt-0.5 h-3.5 w-3.5 shrink-0 text-tactas-accent-strong" stroke-width={2.2} />
                    {item}
                  </li>
                ))}
              </ul>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="faq" class="border-b border-tactas-line bg-tactas-bg">
      <div class={`tactas-container grid gap-12 py-18 lg:grid-cols-[0.72fr_1.28fr] lg:py-24`}>
        <div>
          <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-tactas-accent-strong">FAQ</p>
          <h2 class="mt-4 text-[clamp(2rem,4vw,3.15rem)] font-bold leading-tight tracking-[-0.025em]">
            Questions before automating business tasks.
          </h2>
        </div>

        <div class="grid rounded-[8px] border border-tactas-line bg-white">
          {faqs.map(([question, answer], index) => (
            <article class="grid gap-3 border-b border-tactas-line p-6 last:border-b-0 sm:grid-cols-[76px_1fr]">
              <p class="font-mono text-[11px] text-tactas-accent-strong">{String(index + 1).padStart(2, "0")}</p>
              <div>
                <h3 class="text-[20px] font-semibold tracking-tight">{question}</h3>
                <p class="mt-3 text-[15px] leading-relaxed text-tactas-muted-soft">{answer}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="contact" class="bg-tactas-bg">
      <div class={`tactas-container py-18 lg:py-24`}>
        <div class="grid overflow-hidden rounded-[12px] border border-tactas-accent-line bg-white lg:grid-cols-[0.92fr_1.08fr]">
          <div class="p-7 sm:p-9 lg:p-10">
            <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-tactas-accent-strong">Start a task review</p>
            <h2 class="mt-4 text-[clamp(2rem,4vw,3.2rem)] font-bold leading-tight tracking-[-0.025em]">
              Turn one business task into automated work.
            </h2>
            <p class="mt-5 max-w-[34rem] text-[16px] leading-relaxed text-tactas-muted-soft">
              Share the task, tools, knowledge sources, and repeated steps your team wants to improve first.
            </p>

            <div class="mt-8 flex items-center gap-3 text-[14px] text-tactas-muted">
              <Mail class="h-4 w-4 text-tactas-accent-strong" stroke-width={1.8} />
              <a href={`mailto:${brandEmail}`} class="border-b border-tactas-accent/50 pb-0.5 transition hover:border-tactas-accent hover:text-tactas-ink-strong">
                {brandEmail}
              </a>
            </div>
          </div>

          <form id="workflow-automation-form" class="border-t border-tactas-line bg-tactas-bg p-7 sm:p-9 lg:border-l lg:border-t-0">
            <div class="flex items-center justify-between gap-4 border-b border-tactas-line pb-4">
              <div>
                <p class="font-mono text-[10px] uppercase tracking-[0.24em] text-tactas-accent-strong">Task review</p>
                <h3 class="mt-2 text-[24px] font-semibold tracking-tight">What business task should AI help with?</h3>
              </div>
              <Send class="hidden h-5 w-5 text-tactas-accent-strong sm:block" stroke-width={1.8} />
            </div>

            <div class="mt-5 grid gap-4 sm:grid-cols-2">
              <label class="grid gap-1.5 text-[11px] font-medium uppercase tracking-[0.16em] text-tactas-muted-soft">
                First name
                <input required name="name" class="h-11 rounded-[6px] border border-tactas-line bg-white px-3.5 text-[14px] text-tactas-ink outline-none transition placeholder:text-tactas-muted-soft focus:border-tactas-accent focus:ring-2 focus:ring-tactas-accent/15" placeholder="Your name" />
              </label>
              <label class="grid gap-1.5 text-[11px] font-medium uppercase tracking-[0.16em] text-tactas-muted-soft">
                Work email
                <input required type="email" name="email" class="h-11 rounded-[6px] border border-tactas-line bg-white px-3.5 text-[14px] text-tactas-ink outline-none transition placeholder:text-tactas-muted-soft focus:border-tactas-accent focus:ring-2 focus:ring-tactas-accent/15" placeholder="you@company.com" />
              </label>
            </div>

            <label class="mt-4 grid gap-1.5 text-[11px] font-medium uppercase tracking-[0.16em] text-tactas-muted-soft">
              Company
              <input name="company" class="h-11 rounded-[6px] border border-tactas-line bg-white px-3.5 text-[14px] text-tactas-ink outline-none transition placeholder:text-tactas-muted-soft focus:border-tactas-accent focus:ring-2 focus:ring-tactas-accent/15" placeholder="Company name" />
            </label>

            <label class="mt-4 grid gap-1.5 text-[11px] font-medium uppercase tracking-[0.16em] text-tactas-muted-soft">
              Business task
              <textarea required name="workflow" class="min-h-32 rounded-[6px] border border-tactas-line bg-white px-3.5 py-3 text-[14px] text-tactas-ink outline-none transition placeholder:text-tactas-muted-soft focus:border-tactas-accent focus:ring-2 focus:ring-tactas-accent/15" placeholder="Example: summarize weekly updates, answer questions with company context, prepare next steps, track open work..."></textarea>
            </label>

            <button type="submit" class="mt-6 inline-flex h-12 w-full items-center justify-center rounded-[6px] bg-tactas-primary px-6 text-[14px] font-semibold text-white transition hover:bg-tactas-accent">
              Request task review
            </button>
            <p id="workflow-automation-status" class="mt-3 text-center text-[12px] text-tactas-muted-soft">
              Prefer email? {brandEmail}
            </p>
          </form>
        </div>
      </div>
    </section>
  </main>
</div>

<script define:vars={{ brandEmail }} is:inline>
  const workflowAutomationForm = document.getElementById("workflow-automation-form");
  const workflowAutomationStatus = document.getElementById("workflow-automation-status");
  workflowAutomationForm?.addEventListener("submit", (event) => {
    event.preventDefault();
    const form = new FormData(workflowAutomationForm);
    const company = String(form.get("company") || "").trim() || "Tactas AI";
    const subject = encodeURIComponent(`Business task automation review - ${company}`);
    const body = encodeURIComponent(
      [
        `Name: ${String(form.get("name") || "")}`,
        `Work email: ${String(form.get("email") || "")}`,
        `Company: ${String(form.get("company") || "")}`,
        "",
        "Business task:",
        String(form.get("workflow") || ""),
      ].join("\n"),
    );
    if (workflowAutomationStatus) {
      workflowAutomationStatus.textContent = "Opening your email client with the task details.";
    }
    window.location.href = `mailto:${brandEmail}?subject=${subject}&body=${body}`;
  });
</script>
