---
import {
  ArrowRight,
  Bot,
  Check,
  ClipboardCheck,
  Database,
  FileText,
  GitBranch,
  Layers,
  Mail,
  MessageSquare,
  Route,
  Send,
  ShieldCheck,
  Sparkles,
  Workflow,
  Zap,
} from "@lucide/astro";
import Navbar from "./Navbar.astro";
import { getBrandEmail } from "../lib/site";

interface Props {
  siteUrl: string;
  currentPath?: string;
}

const { siteUrl, currentPath = "/services/ai-workflow-automation" } = Astro.props;
const brandEmail = getBrandEmail();
const currentYear = new Date().getFullYear();
const CONTAINER = "mx-auto w-full max-w-[1240px] px-5 sm:px-8 lg:px-10";

const trustPoints = [
  ["Execute work", "Agents advance tasks across tools"],
  ["Stay governed", "Approvals, limits, and audit trails"],
  ["Fit existing tools", "CRM, helpdesk, docs, databases, APIs"],
  ["Managed launch", "Setup, monitoring, and tuning included"],
];

const inputs = ["Tickets", "Forms", "Emails", "Documents", "CRM", "Database"];
const actions = ["Draft reply", "Update CRM", "Create task", "Route approval", "Generate report", "Notify team"];

const serviceLayers = [
  {
    title: "Map",
    body: "Choose one repeatable workflow, define owners, identify systems, document SOPs, and decide where humans stay in control.",
    icon: Route,
  },
  {
    title: "Connect",
    body: "Give agents governed access to the tools and context they need, including CRM, helpdesk, databases, documents, email, and APIs.",
    icon: GitBranch,
  },
  {
    title: "Execute",
    body: "Agents retrieve context, follow rules, draft or take approved actions, update systems, and keep every step traceable.",
    icon: Bot,
  },
  {
    title: "Monitor",
    body: "Review logs, approvals, exceptions, quality metrics, and edge cases so the workflow improves after launch.",
    icon: ShieldCheck,
  },
];

const workflowSteps = [
  ["01", "Intake", "A ticket, form, email, record, or document starts the workflow."],
  ["02", "Retrieve context", "The agent collects CRM data, knowledge base content, SOPs, and account history."],
  ["03", "Apply rules", "Business rules, risk limits, and approval requirements shape the next action."],
  ["04", "Execute action", "Draft replies, update systems, create tasks, route approvals, or prepare reports."],
  ["05", "Log and improve", "Every action is visible for audit, exception review, and workflow tuning."],
];

const useCases = [
  ["Customer support automation", "Triage cases, retrieve customer context, draft replies, update helpdesk and CRM, and escalate sensitive issues."],
  ["Back-office workflow automation", "Review documents, prepare records, route approvals, update systems, and reduce repetitive admin work."],
  ["Finance and invoice workflows", "Check invoices, reconcile records, prepare approval notes, and route exceptions to the right owner."],
  ["CRM and sales operations", "Qualify leads, prepare follow-ups, summarize calls, enrich records, and keep pipeline tasks moving."],
  ["Document review workflows", "Check forms, contracts, IDs, claims, or evidence against rules before staff review."],
  ["Operations reporting", "Collect data, summarize exceptions, generate weekly reports, and notify teams when thresholds change."],
];

const packages = [
  {
    name: "Workflow Pilot",
    body: "Launch one narrow AI workflow with clear success criteria, integrations, controls, and human review.",
    items: ["1 workflow mapped", "1-3 system connections", "Supervised launch plan"],
  },
  {
    name: "Managed Workflow",
    body: "Operate a production workflow with monitoring, exception review, quality tuning, and monthly improvements.",
    items: ["Agent actions and logs", "Approval gates", "Ongoing tuning"],
  },
  {
    name: "Enterprise Automation",
    body: "Scale multiple workflows with stronger governance, private deployment options, and shared operating standards.",
    items: ["Multiple workflows", "SSO, RBAC, audit logs", "Custom controls and reporting"],
  },
];

const faqs = [
  ["What is AI workflow automation?", "AI workflow automation uses agents to complete repeatable business processes across tools, data, SOPs, approvals, and human handoffs."],
  ["Can agents take actions in our systems?", "Yes, but actions can be limited by permissions, approvals, risk checks, and human review depending on the workflow."],
  ["Which workflow should we automate first?", "Start with a frequent workflow that has clear rules, available data, measurable outcomes, and manageable risk."],
  ["Is this a managed service?", "Yes. Tactas AI helps map, build, integrate, launch, monitor, and improve the workflow after it goes live."],
];
---

<div class="min-h-screen overflow-x-hidden bg-[#050A14] text-white selection:bg-[#8B5CF6]/30">
  <div class="pointer-events-none fixed inset-0 -z-20 grid-faint opacity-[0.24] [mask-image:radial-gradient(ellipse_70%_60%_at_50%_10%,black_0%,transparent_75%)]"></div>

  <Navbar currentPath={currentPath} ctaLabel="Book a Demo" theme="dark" />

  <main>
    <section class="relative overflow-hidden border-b border-white/10">
      <div class="pointer-events-none absolute inset-0 z-0 bg-[linear-gradient(180deg,rgba(124,58,237,0.14)_0%,rgba(5,10,20,0)_60%)]"></div>
      <div class="pointer-events-none absolute inset-0 z-0 opacity-[0.30] [background-image:linear-gradient(to_right,rgba(255,255,255,0.055)_1px,transparent_1px),linear-gradient(to_bottom,rgba(255,255,255,0.045)_1px,transparent_1px)] [background-size:72px_72px]"></div>

      <div class={`${CONTAINER} relative z-10 grid min-h-[720px] items-center gap-14 py-16 lg:grid-cols-[0.95fr_1.05fr] lg:py-20`}>
        <div class="reveal">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#7C3AED]/35 bg-[#130B2A]/80 px-3 py-1.5">
            <Sparkles class="h-3.5 w-3.5 text-[#A78BFA]" stroke-width={1.8} />
            <span class="font-mono text-[10px] font-semibold uppercase tracking-[0.24em] text-[#C4B5FD]">
              AI workflow automation service
            </span>
          </div>

          <h1 class="max-w-[13ch] text-[clamp(3rem,7vw,5.8rem)] font-extrabold leading-[0.94] tracking-[-0.045em]">
            AI workflow automation for business operations.
          </h1>

          <p class="mt-7 max-w-[42rem] text-[17px] leading-relaxed text-[#C8D0DE]">
            Tactas AI designs, integrates, and operates supervised AI agents that retrieve context, follow SOPs,
            update systems, route approvals, and keep humans in control across support, back-office, finance, and CRM workflows.
          </p>

          <div class="mt-9 flex flex-col gap-3 sm:flex-row sm:items-center">
            <a
              href="#contact"
              class="group inline-flex h-12 items-center justify-center rounded-[6px] bg-[#7C3AED] px-6 text-[14px] font-semibold text-white shadow-[0_18px_48px_-24px_rgba(124,58,237,0.8)] transition hover:bg-[#8B5CF6]"
            >
              Start a workflow pilot
              <ArrowRight class="ml-2 h-4 w-4 transition group-hover:translate-x-0.5" stroke-width={1.9} />
            </a>
            <a
              href="#service"
              class="inline-flex h-12 items-center justify-center rounded-[6px] border border-white/18 bg-white/[0.03] px-6 text-[14px] font-semibold text-white transition hover:border-[#A78BFA]/70 hover:text-[#C4B5FD]"
            >
              See service model
            </a>
          </div>

          <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
            {trustPoints.map(([title, body]) => (
              <div class="border-l border-[#7C3AED]/50 pl-4">
                <p class="text-[14px] font-semibold text-white">{title}</p>
                <p class="mt-1 text-[12px] leading-relaxed text-[#8A93A6]">{body}</p>
              </div>
            ))}
          </div>
        </div>

        <div class="reveal" data-delay="2">
          <div class="relative mx-auto max-w-[680px]">
            <div class="absolute inset-x-8 bottom-[-18px] h-12 rounded-full bg-[#7C3AED]/18 blur-2xl"></div>
            <div class="relative overflow-hidden rounded-[12px] border border-white/12 bg-[#07101F] shadow-[0_40px_110px_-56px_rgba(0,0,0,0.95)]">
              <div class="flex h-12 items-center justify-between border-b border-white/10 bg-white/[0.035] px-4">
                <div class="flex items-center gap-2">
                  <span class="h-2.5 w-2.5 rounded-full bg-[#8B5CF6]"></span>
                  <span class="h-2.5 w-2.5 rounded-full bg-white/24"></span>
                  <span class="h-2.5 w-2.5 rounded-full bg-white/24"></span>
                </div>
                <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-[#A78BFA]">Workflow control center</p>
              </div>

              <div class="grid gap-4 p-5 lg:grid-cols-[1fr_1.15fr_1fr]">
                <div>
                  <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-[#A78BFA]">Inputs</p>
                  <div class="mt-4 grid gap-2">
                    {inputs.map((item, index) => (
                      <div class:list={[
                        "rounded-[6px] border px-3 py-2 text-[12px]",
                        index < 3 ? "border-[#7C3AED]/35 bg-[#160B36] text-[#EDE9FE]" : "border-white/10 bg-white/[0.025] text-[#8A93A6]",
                      ]}>
                        {item}
                      </div>
                    ))}
                  </div>
                </div>

                <div class="relative flex min-h-[360px] items-center justify-center">
                  <div class="absolute inset-x-2 top-1/2 h-px bg-[#7C3AED]/35"></div>
                  <div class="absolute left-1/2 top-8 h-[280px] w-px bg-[#7C3AED]/25"></div>
                  <div class="relative z-10 flex h-44 w-44 items-center justify-center rounded-[28px] border border-[#7C3AED]/50 bg-[#130B2A] shadow-[0_0_80px_-22px_rgba(124,58,237,0.88)]">
                    <div class="flex h-24 w-24 items-center justify-center rounded-[20px] border border-[#A78BFA]/45 bg-[#7C3AED]/20">
                      <Workflow class="h-11 w-11 text-[#C4B5FD]" stroke-width={1.45} />
                    </div>
                  </div>

                  <div class="absolute bottom-5 left-1/2 z-10 w-[210px] -translate-x-1/2 rounded-[8px] border border-white/12 bg-[#0A1324] p-3">
                    <div class="flex items-center gap-2">
                      <ShieldCheck class="h-4 w-4 text-[#A78BFA]" stroke-width={1.8} />
                      <p class="text-[12px] font-semibold text-white">Human review</p>
                    </div>
                    <p class="mt-1 text-[11px] text-[#8A93A6]">Approve, reject, escalate, or edit.</p>
                  </div>
                </div>

                <div>
                  <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-[#A78BFA]">Actions</p>
                  <div class="mt-4 grid gap-2">
                    {actions.map((item, index) => (
                      <div class:list={[
                        "rounded-[6px] border px-3 py-2 text-[12px]",
                        index < 4 ? "border-[#7C3AED]/35 bg-[#160B36] text-[#EDE9FE]" : "border-white/10 bg-white/[0.025] text-[#8A93A6]",
                      ]}>
                        {item}
                      </div>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="border-b border-white/10 bg-[#070B16]">
      <div class={`${CONTAINER} py-10`}>
        <div class="grid gap-3 text-center sm:grid-cols-2 lg:grid-cols-4">
          {["AI Workflow Automation", "Agentic Workflow Automation", "Business Process Automation", "AI Operations Automation"].map((term) => (
            <div class="rounded-[8px] border border-white/10 bg-white/[0.025] px-4 py-4 font-mono text-[11px] uppercase tracking-[0.18em] text-[#A78BFA]">
              {term}
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="service" class="border-b border-white/10 bg-[#050A14]">
      <div class={`${CONTAINER} py-18 lg:py-24`}>
        <div class="mx-auto max-w-3xl text-center">
          <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-[#A78BFA]">Managed service</p>
          <h2 class="mt-4 text-[clamp(2rem,4vw,3.2rem)] font-bold leading-tight tracking-[-0.025em]">
            Custom AI workflow automation implementation, managed end to end.
          </h2>
          <p class="mt-5 text-[16px] leading-relaxed text-[#8A93A6]">
            Tactas AI handles the execution layer around AI agents: process mapping, integrations, decision rules,
            approvals, logs, monitoring, and operational support for customer support, back-office, CRM, and finance teams.
          </p>
        </div>

        <div class="mt-12 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
          {serviceLayers.map((item) => {
            const Icon = item.icon;
            return (
              <article class="group min-h-[260px] rounded-[8px] border border-white/10 bg-[#07101F] p-6 transition hover:border-[#7C3AED]/55 hover:bg-[#0A1324]">
                <span class="flex h-12 w-12 items-center justify-center rounded-[8px] border border-[#7C3AED]/25 bg-[#160B36] text-[#A78BFA]">
                  <Icon class="h-5 w-5" stroke-width={1.8} />
                </span>
                <h3 class="mt-7 text-[22px] font-semibold tracking-tight">{item.title}</h3>
                <p class="mt-3 text-[14px] leading-relaxed text-[#8A93A6]">{item.body}</p>
              </article>
            );
          })}
        </div>
      </div>
    </section>

    <section id="architecture" class="border-b border-white/10 bg-[#F8FAFC] text-[#0F172A]">
      <div class={`${CONTAINER} py-16 lg:py-20`}>
        <div class="mx-auto max-w-3xl text-center">
          <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-[#7C3AED]">Execution model</p>
          <h2 class="mt-4 text-[clamp(2rem,4vw,3.1rem)] font-bold leading-tight tracking-[-0.025em]">
            From incoming work to logged outcomes.
          </h2>
        </div>

        <div class="mt-12 grid gap-4 lg:grid-cols-5">
          {workflowSteps.map(([step, title, body], index) => (
            <article class="relative rounded-[8px] border border-[#D8E1EA] bg-white p-5 shadow-[0_20px_60px_-52px_rgba(15,23,42,0.28)]">
              {index < workflowSteps.length - 1 ? (
                <div class="absolute -right-3 top-10 hidden h-px w-6 bg-[#7C3AED]/45 lg:block"></div>
              ) : null}
              <p class="font-mono text-[11px] text-[#7C3AED]">{step}</p>
              <h3 class="mt-5 text-[17px] font-semibold">{title}</h3>
              <p class="mt-3 text-[13px] leading-relaxed text-[#64748B]">{body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="border-b border-white/10 bg-[#050A14]">
      <div class={`${CONTAINER} grid gap-12 py-18 lg:grid-cols-[0.72fr_1.28fr] lg:py-24`}>
        <div>
          <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-[#A78BFA]">Use cases</p>
          <h2 class="mt-4 text-[clamp(2rem,4vw,3.15rem)] font-bold leading-tight tracking-[-0.025em]">
            Start with workflows that repeat every day.
          </h2>
          <p class="mt-5 text-[16px] leading-relaxed text-[#8A93A6]">
            The best first automation has clear context, repeated decisions, visible outcomes, and a human owner for exceptions.
          </p>
        </div>

        <div class="grid gap-3 sm:grid-cols-2">
          {useCases.map(([title, body]) => (
            <div class="rounded-[8px] border border-white/10 bg-[#07101F] p-5">
              <div class="flex items-center gap-3">
                <Zap class="h-4.5 w-4.5 shrink-0 text-[#A78BFA]" stroke-width={1.8} />
                <h3 class="text-[15px] font-semibold text-[#E5E7EB]">{title}</h3>
              </div>
              <p class="mt-3 text-[13px] leading-relaxed text-[#8A93A6]">{body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="border-b border-white/10 bg-[#070B16]">
      <div class={`${CONTAINER} py-18 lg:py-24`}>
        <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
          <div class="max-w-3xl">
            <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-[#A78BFA]">Packages</p>
            <h2 class="mt-4 text-[clamp(2rem,4vw,3.15rem)] font-bold leading-tight tracking-[-0.025em]">
              Pilot one workflow, then expand the operating layer.
            </h2>
          </div>
          <a href="#contact" class="inline-flex h-11 items-center justify-center rounded-[6px] border border-white/18 px-4 text-[13px] font-semibold text-white transition hover:border-[#A78BFA]/70 hover:text-[#C4B5FD]">
            Discuss scope
          </a>
        </div>

        <div class="mt-10 grid gap-4 lg:grid-cols-3">
          {packages.map((plan, index) => (
            <article class:list={[
              "rounded-[8px] border p-6",
              index === 1 ? "border-[#7C3AED]/65 bg-[#130B2A]" : "border-white/10 bg-[#050A14]",
            ]}>
              <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-[#A78BFA]">{plan.name}</p>
              <p class="mt-5 min-h-[96px] text-[15px] leading-relaxed text-[#C8D0DE]">{plan.body}</p>
              <ul class="mt-6 grid gap-3 border-t border-white/10 pt-5">
                {plan.items.map((item) => (
                  <li class="flex items-start gap-2.5 text-[14px] text-[#8A93A6]">
                    <Check class="mt-0.5 h-3.5 w-3.5 shrink-0 text-[#A78BFA]" stroke-width={2.2} />
                    {item}
                  </li>
                ))}
              </ul>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="faq" class="border-b border-white/10 bg-[#050A14]">
      <div class={`${CONTAINER} grid gap-12 py-18 lg:grid-cols-[0.72fr_1.28fr] lg:py-24`}>
        <div>
          <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-[#A78BFA]">FAQ</p>
          <h2 class="mt-4 text-[clamp(2rem,4vw,3.15rem)] font-bold leading-tight tracking-[-0.025em]">
            Questions before automating operational workflows.
          </h2>
        </div>

        <div class="grid rounded-[8px] border border-white/10 bg-[#07101F]">
          {faqs.map(([question, answer], index) => (
            <article class="grid gap-3 border-b border-white/10 p-6 last:border-b-0 sm:grid-cols-[76px_1fr]">
              <p class="font-mono text-[11px] text-[#A78BFA]">{String(index + 1).padStart(2, "0")}</p>
              <div>
                <h3 class="text-[20px] font-semibold tracking-tight">{question}</h3>
                <p class="mt-3 text-[15px] leading-relaxed text-[#8A93A6]">{answer}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="contact" class="bg-[#070B16]">
      <div class={`${CONTAINER} py-18 lg:py-24`}>
        <div class="grid overflow-hidden rounded-[12px] border border-[#7C3AED]/35 bg-[#0A1324] lg:grid-cols-[0.92fr_1.08fr]">
          <div class="p-7 sm:p-9 lg:p-10">
            <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-[#A78BFA]">Start a pilot</p>
            <h2 class="mt-4 text-[clamp(2rem,4vw,3.2rem)] font-bold leading-tight tracking-[-0.025em]">
              Turn one workflow into a supervised AI operation.
            </h2>
            <p class="mt-5 max-w-[34rem] text-[16px] leading-relaxed text-[#8A93A6]">
              Share the workflow, systems, documents, approvals, and repetitive decisions your team wants AI agents to handle.
            </p>

            <div class="mt-8 flex items-center gap-3 text-[14px] text-[#C8D0DE]">
              <Mail class="h-4 w-4 text-[#A78BFA]" stroke-width={1.8} />
              <a href={`mailto:${brandEmail}`} class="border-b border-[#7C3AED]/55 pb-0.5 transition hover:border-[#A78BFA] hover:text-white">
                {brandEmail}
              </a>
            </div>
          </div>

          <form id="workflow-automation-form" class="border-t border-white/10 bg-[#050A14] p-7 sm:p-9 lg:border-l lg:border-t-0">
            <div class="flex items-center justify-between gap-4 border-b border-white/10 pb-4">
              <div>
                <p class="font-mono text-[10px] uppercase tracking-[0.24em] text-[#A78BFA]">Workflow review</p>
                <h3 class="mt-2 text-[24px] font-semibold tracking-tight">What workflow should AI run?</h3>
              </div>
              <Send class="hidden h-5 w-5 text-[#A78BFA] sm:block" stroke-width={1.8} />
            </div>

            <div class="mt-5 grid gap-4 sm:grid-cols-2">
              <label class="grid gap-1.5 text-[11px] font-medium uppercase tracking-[0.16em] text-[#8A93A6]">
                First name
                <input required name="name" class="h-11 rounded-[6px] border border-white/12 bg-white/[0.035] px-3.5 text-[14px] text-white outline-none transition placeholder:text-[#5E6678] focus:border-[#8B5CF6] focus:ring-2 focus:ring-[#8B5CF6]/15" placeholder="Your name" />
              </label>
              <label class="grid gap-1.5 text-[11px] font-medium uppercase tracking-[0.16em] text-[#8A93A6]">
                Work email
                <input required type="email" name="email" class="h-11 rounded-[6px] border border-white/12 bg-white/[0.035] px-3.5 text-[14px] text-white outline-none transition placeholder:text-[#5E6678] focus:border-[#8B5CF6] focus:ring-2 focus:ring-[#8B5CF6]/15" placeholder="you@company.com" />
              </label>
            </div>

            <label class="mt-4 grid gap-1.5 text-[11px] font-medium uppercase tracking-[0.16em] text-[#8A93A6]">
              Company
              <input name="company" class="h-11 rounded-[6px] border border-white/12 bg-white/[0.035] px-3.5 text-[14px] text-white outline-none transition placeholder:text-[#5E6678] focus:border-[#8B5CF6] focus:ring-2 focus:ring-[#8B5CF6]/15" placeholder="Company name" />
            </label>

            <label class="mt-4 grid gap-1.5 text-[11px] font-medium uppercase tracking-[0.16em] text-[#8A93A6]">
              Workflow
              <textarea required name="workflow" class="min-h-32 rounded-[6px] border border-white/12 bg-white/[0.035] px-3.5 py-3 text-[14px] text-white outline-none transition placeholder:text-[#5E6678] focus:border-[#8B5CF6] focus:ring-2 focus:ring-[#8B5CF6]/15" placeholder="Example: support ticket triage, invoice approval, CRM follow-up, document review, weekly ops reporting..."></textarea>
            </label>

            <button type="submit" class="mt-6 inline-flex h-12 w-full items-center justify-center rounded-[6px] bg-[#7C3AED] px-6 text-[14px] font-semibold text-white transition hover:bg-[#8B5CF6]">
              Request workflow pilot
            </button>
            <p id="workflow-automation-status" class="mt-3 text-center text-[12px] text-[#8A93A6]">
              Prefer email? {brandEmail}
            </p>
          </form>
        </div>
      </div>
    </section>
  </main>

  <footer class="border-t border-white/10 bg-[#050A14] py-14">
    <div class={`${CONTAINER}`}>
      <div class="flex flex-col gap-8 lg:flex-row lg:items-start lg:justify-between">
        <div class="max-w-md">
          <div class="flex items-center gap-2.5">
            <img src="/favicon-96x96.png" alt="" width="30" height="30" class="rounded-md" aria-hidden="true" loading="lazy" decoding="async" />
            <span class="text-sm font-semibold">Tactas AI</span>
          </div>
          <p class="mt-4 text-[14px] leading-relaxed text-[#8A93A6]">
