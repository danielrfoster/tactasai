---
import {
  ArrowRight,
  Bot,
  Check,
  ClipboardCheck,
  Database,
  FileText,
  GitBranch,
  Layers,
  Mail,
  MessageSquare,
  Route,
  Send,
  ShieldCheck,
  Sparkles,
  Workflow,
  Zap,
} from "@lucide/astro";
import { getBrandEmail } from "../lib/site";

interface Props {
  siteUrl: string;
  currentPath?: string;
}

const { currentPath = "/services/ai-workflow-automation" } = Astro.props;
const brandEmail = getBrandEmail();
const CONTAINER = "mx-auto w-full max-w-[1240px] px-5 sm:px-8 lg:px-10";

const trustPoints = [
  ["Improve work", "Agents help teams move faster"],
  ["Use knowledge", "Company context guides every task"],
  ["Fit existing tools", "Docs, messages, tasks, data, and apps"],
  ["Managed launch", "Setup, automation mapping, and tuning included"],
];

const inputs = ["Requests", "Forms", "Emails", "Documents", "Tasks", "Business data"];
const actions = ["Prepare output", "Update work", "Create task", "Draft follow-up", "Generate report", "Notify team"];

const serviceLayers = [
  {
    title: "Choose a business task",
    body: "Start with one repeated task, define the useful output, identify the context it needs, and map where work should move next.",
    icon: Route,
  },
  {
    title: "Connect knowledge and tools",
    body: "Connect company knowledge, business data, documents, messages, task tools, and apps the agent needs to understand the request.",
    icon: GitBranch,
  },
  {
    title: "Prepare outputs and actions",
    body: "Agents use business context to draft useful work, prepare updates, create tasks, organize follow-ups, and automate repeated steps.",
    icon: Bot,
  },
  {
    title: "Improve work performance",
    body: "Tune the task map, improve outputs, expand connected context, and reduce repeated manual effort as the business changes.",
    icon: ShieldCheck,
  },
];

const workflowSteps = [
  ["01", "Request", "A message, form, document, task, or business update starts the work."],
  ["02", "Understand context", "The agent gathers company knowledge, source context, tool data, and prior work."],
  ["03", "Prepare output", "The agent turns messy input into a useful answer, summary, brief, update, or plan."],
  ["04", "Automate step", "The agent creates tasks, prepares follow-ups, updates work, or moves repeated steps forward."],
  ["05", "Improve", "The task map is tuned as patterns, sources, outputs, and business needs change."],
];

const useCases = [
  ["Summarize changes", "Collect context from business sources and produce a clear brief of what changed and what matters."],
  ["Answer with context", "Use company knowledge and source context to prepare accurate answers and next steps."],
  ["Prepare next steps", "Turn updates, requests, and documents into task-ready plans your team can use."],
  ["Track open work", "Find pending work, group follow-ups, surface owners, and keep repeated activity moving."],
  ["Automate repeated updates", "Prepare updates, create tasks, sync useful information, and notify the right people."],
  ["Generate recurring reports", "Collect business inputs, summarize patterns, and prepare useful recurring outputs."],
];

const packages = [
  {
    name: "Task Review",
    body: "Map one repeated business task, define the target output, and identify the knowledge and tools it needs.",
    items: ["1 task mapped", "Key context sources", "Automation map"],
  },
  {
    name: "Managed Task",
    body: "Launch a managed AI agent for one production task with connected tools, prepared outputs, and ongoing improvements.",
    items: ["Connected tools", "Prepared outputs", "Ongoing tuning"],
  },
  {
    name: "Enterprise Automation",
    body: "Expand managed agents across repeated tasks with shared context, consistent task maps, and business reporting.",
    items: ["Multiple tasks", "Shared context layer", "Custom reporting"],
  },
];

const faqs = [
  ["What is business task automation with AI agents?", "Business task automation uses managed AI agents to understand company context, prepare useful outputs, update work, and automate repeated steps across connected tools."],
  ["Can agents take actions in our systems?", "Yes. Managed AI agents can prepare updates, create tasks, organize follow-ups, and automate repeated steps across tools your business already uses."],
  ["Which business task should we automate first?", "Start with a frequent task that has available context, a clear output, connected tools, and repeated manual effort."],
  ["Is this a managed service?", "Yes. Tactas AI helps map, build, connect, launch, and improve the business task after it goes live."],
];
---

<div class="min-h-screen overflow-x-hidden bg-[#F6F8FB] text-[#0F172A] selection:bg-[#06B6D4]/20">
  <div class="pointer-events-none fixed inset-0 -z-20 grid-faint opacity-[0.24] [mask-image:radial-gradient(ellipse_70%_60%_at_50%_10%,black_0%,transparent_75%)]"></div>

  <main>
    <section class="relative overflow-hidden border-b border-[#D8E1EA]">
      <div class="pointer-events-none absolute inset-0 z-0 bg-[linear-gradient(180deg,rgba(124,58,237,0.14)_0%,rgba(5,10,20,0)_60%)]"></div>
      <div class="pointer-events-none absolute inset-0 z-0 opacity-[0.30] [background-image:linear-gradient(to_right,rgba(255,255,255,0.055)_1px,transparent_1px),linear-gradient(to_bottom,rgba(255,255,255,0.045)_1px,transparent_1px)] [background-size:72px_72px]"></div>

      <div class={`${CONTAINER} relative z-10 grid min-h-[720px] items-center gap-14 py-16 lg:grid-cols-[0.95fr_1.05fr] lg:py-20`}>
        <div class="reveal">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#BAE6FD] bg-[#E6FBFF]/80 px-3 py-1.5">
            <Sparkles class="h-3.5 w-3.5 text-[#0891B2]" stroke-width={1.8} />
            <span class="font-mono text-[10px] font-semibold uppercase tracking-[0.24em] text-[#0891B2]">
              Business task automation
            </span>
          </div>

          <h1 class="max-w-[13ch] text-[clamp(3rem,7vw,5.8rem)] font-extrabold leading-[0.94] tracking-[-0.045em]">
            Automate repeated business tasks with managed AI agents.
          </h1>

          <p class="mt-7 max-w-[42rem] text-[17px] leading-relaxed text-[#475569]">
            Tactas AI deploys managed AI agents that learn how your business works, use company knowledge and connected tools,
            then prepare outputs, updates, next steps, and automated actions.
          </p>

          <div class="mt-9 flex flex-col gap-3 sm:flex-row sm:items-center">
            <a
              href="#contact"
              class="group inline-flex h-12 items-center justify-center rounded-[6px] bg-[#2F66FF] px-6 text-[14px] font-semibold text-white shadow-[0_18px_48px_-24px_rgba(124,58,237,0.8)] transition hover:bg-[#0EA5E9]"
            >
              Start a task review
              <ArrowRight class="ml-2 h-4 w-4 transition group-hover:translate-x-0.5" stroke-width={1.9} />
            </a>
            <a
              href="#service"
              class="inline-flex h-12 items-center justify-center rounded-[6px] border border-[#D8E1EA] bg-white px-6 text-[14px] font-semibold text-[#07324A] transition hover:border-[#06B6D4]/70 hover:text-[#0891B2]"
            >
              See automation model
            </a>
          </div>

          <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
            {trustPoints.map(([title, body]) => (
              <div class="border-l border-[#06B6D4]/50 pl-4">
                <p class="text-[14px] font-semibold text-[#07324A]">{title}</p>
                <p class="mt-1 text-[12px] leading-relaxed text-[#64748B]">{body}</p>
              </div>
            ))}
          </div>
        </div>

        <div class="reveal" data-delay="2">
          <div class="relative mx-auto max-w-[680px]">
            <div class="absolute inset-x-8 bottom-[-18px] h-12 rounded-full bg-[#2F66FF]/18 blur-2xl"></div>
            <div class="relative overflow-hidden rounded-[12px] border border-[#D8E1EA] bg-white shadow-[0_40px_110px_-56px_rgba(0,0,0,0.95)]">
              <div class="flex h-12 items-center justify-between border-b border-[#D8E1EA] bg-white px-4">
                <div class="flex items-center gap-2">
                  <span class="h-2.5 w-2.5 rounded-full bg-[#06B6D4]"></span>
                  <span class="h-2.5 w-2.5 rounded-full bg-white/24"></span>
                  <span class="h-2.5 w-2.5 rounded-full bg-white/24"></span>
                </div>
                <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-[#0891B2]">Task automation map</p>
              </div>

              <div class="grid gap-4 p-5 lg:grid-cols-[1fr_1.15fr_1fr]">
                <div>
                  <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-[#0891B2]">Inputs</p>
                  <div class="mt-4 grid gap-2">
                    {inputs.map((item, index) => (
                      <div class:list={[
                        "rounded-[6px] border px-3 py-2 text-[12px]",
                        index < 3 ? "border-[#BAE6FD] bg-[#E6FBFF] text-[#07324A]" : "border-[#D8E1EA] bg-white text-[#64748B]",
                      ]}>
                        {item}
                      </div>
                    ))}
                  </div>
                </div>

                <div class="relative flex min-h-[360px] items-center justify-center">
                  <div class="absolute inset-x-2 top-1/2 h-px bg-[#2F66FF]/35"></div>
                  <div class="absolute left-1/2 top-8 h-[280px] w-px bg-[#2F66FF]/25"></div>
                  <div class="relative z-10 flex h-44 w-44 items-center justify-center rounded-[28px] border border-[#06B6D4]/50 bg-[#E6FBFF] shadow-[0_0_80px_-22px_rgba(124,58,237,0.88)]">
                    <div class="flex h-24 w-24 items-center justify-center rounded-[20px] border border-[#06B6D4]/45 bg-[#2F66FF]/20">
                      <Workflow class="h-11 w-11 text-[#0891B2]" stroke-width={1.45} />
                    </div>
                  </div>

                  <div class="absolute bottom-5 left-1/2 z-10 w-[210px] -translate-x-1/2 rounded-[8px] border border-[#D8E1EA] bg-white p-3">
                    <div class="flex items-center gap-2">
                      <ShieldCheck class="h-4 w-4 text-[#0891B2]" stroke-width={1.8} />
                      <p class="text-[12px] font-semibold text-[#07324A]">Work ready</p>
                    </div>
                    <p class="mt-1 text-[11px] text-[#64748B]">Use, edit, assign, or automate.</p>
                  </div>
                </div>

                <div>
                  <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-[#0891B2]">Actions</p>
                  <div class="mt-4 grid gap-2">
                    {actions.map((item, index) => (
                      <div class:list={[
                        "rounded-[6px] border px-3 py-2 text-[12px]",
                        index < 4 ? "border-[#BAE6FD] bg-[#E6FBFF] text-[#07324A]" : "border-[#D8E1EA] bg-white text-[#64748B]",
                      ]}>
                        {item}
                      </div>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="border-b border-[#D8E1EA] bg-[#F6F8FB]">
      <div class={`${CONTAINER} py-10`}>
        <div class="grid gap-3 text-center sm:grid-cols-2 lg:grid-cols-4">
          {["Business Task Automation", "Managed AI Agents", "Connected Business Tools", "Work Performance AI"].map((term) => (
            <div class="rounded-[8px] border border-[#D8E1EA] bg-white px-4 py-4 font-mono text-[11px] uppercase tracking-[0.18em] text-[#0891B2]">
              {term}
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="service" class="border-b border-[#D8E1EA] bg-[#F6F8FB]">
      <div class={`${CONTAINER} py-18 lg:py-24`}>
        <div class="mx-auto max-w-3xl text-center">
          <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-[#0891B2]">Managed service</p>
          <h2 class="mt-4 text-[clamp(2rem,4vw,3.2rem)] font-bold leading-tight tracking-[-0.025em]">
            Business task automation with managed AI agents, built end to end.
          </h2>
          <p class="mt-5 text-[16px] leading-relaxed text-[#64748B]">
            Tactas AI handles the operating layer around AI agents: task mapping, company knowledge, connected tools,
            prepared outputs, automated steps, and ongoing improvement.
          </p>
        </div>

        <div class="mt-12 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
          {serviceLayers.map((item) => {
            const Icon = item.icon;
            return (
              <article class="group min-h-[260px] rounded-[8px] border border-[#D8E1EA] bg-white p-6 transition hover:border-[#06B6D4]/50 hover:bg-white">
                <span class="flex h-12 w-12 items-center justify-center rounded-[8px] border border-[#06B6D4]/25 bg-[#E6FBFF] text-[#0891B2]">
                  <Icon class="h-5 w-5" stroke-width={1.8} />
                </span>
                <h3 class="mt-7 text-[22px] font-semibold tracking-tight">{item.title}</h3>
                <p class="mt-3 text-[14px] leading-relaxed text-[#64748B]">{item.body}</p>
              </article>
            );
          })}
        </div>
      </div>
    </section>

    <section id="architecture" class="border-b border-[#D8E1EA] bg-[#F6F8FB] text-[#0F172A]">
      <div class={`${CONTAINER} py-16 lg:py-20`}>
        <div class="mx-auto max-w-3xl text-center">
          <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-[#06B6D4]">Execution model</p>
          <h2 class="mt-4 text-[clamp(2rem,4vw,3.1rem)] font-bold leading-tight tracking-[-0.025em]">
            From request to useful work.
          </h2>
        </div>

        <div class="mt-12 grid gap-4 lg:grid-cols-5">
          {workflowSteps.map(([step, title, body], index) => (
            <article class="relative rounded-[8px] border border-[#D8E1EA] bg-white p-5 shadow-[0_20px_60px_-52px_rgba(15,23,42,0.28)]">
              {index < workflowSteps.length - 1 ? (
                <div class="absolute -right-3 top-10 hidden h-px w-6 bg-[#2F66FF]/45 lg:block"></div>
              ) : null}
              <p class="font-mono text-[11px] text-[#06B6D4]">{step}</p>
              <h3 class="mt-5 text-[17px] font-semibold">{title}</h3>
              <p class="mt-3 text-[13px] leading-relaxed text-[#64748B]">{body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="border-b border-[#D8E1EA] bg-[#F6F8FB]">
      <div class={`${CONTAINER} grid gap-12 py-18 lg:grid-cols-[0.72fr_1.28fr] lg:py-24`}>
        <div>
          <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-[#0891B2]">Task examples</p>
          <h2 class="mt-4 text-[clamp(2rem,4vw,3.15rem)] font-bold leading-tight tracking-[-0.025em]">
            Start with business tasks that repeat every day.
          </h2>
          <p class="mt-5 text-[16px] leading-relaxed text-[#64748B]">
            The best first automation has clear context, repeated effort, visible output, and connected tools your team already uses.
          </p>
        </div>

        <div class="grid gap-3 sm:grid-cols-2">
          {useCases.map(([title, body]) => (
            <div class="rounded-[8px] border border-[#D8E1EA] bg-white p-5">
              <div class="flex items-center gap-3">
                <Zap class="h-4.5 w-4.5 shrink-0 text-[#0891B2]" stroke-width={1.8} />
                <h3 class="text-[15px] font-semibold text-[#07324A]">{title}</h3>
              </div>
              <p class="mt-3 text-[13px] leading-relaxed text-[#64748B]">{body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="border-b border-[#D8E1EA] bg-[#F6F8FB]">
      <div class={`${CONTAINER} py-18 lg:py-24`}>
        <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
          <div class="max-w-3xl">
            <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-[#0891B2]">Packages</p>
            <h2 class="mt-4 text-[clamp(2rem,4vw,3.15rem)] font-bold leading-tight tracking-[-0.025em]">
              Pilot one task, then expand the operating layer.
            </h2>
          </div>
          <a href="#contact" class="inline-flex h-11 items-center justify-center rounded-[6px] border border-[#D8E1EA] px-4 text-[13px] font-semibold text-[#07324A] transition hover:border-[#06B6D4]/70 hover:text-[#0891B2]">
            Discuss scope
          </a>
        </div>

        <div class="mt-10 grid gap-4 lg:grid-cols-3">
          {packages.map((plan, index) => (
            <article class:list={[
              "rounded-[8px] border p-6",
              index === 1 ? "border-[#06B6D4]/60 bg-[#E6FBFF]" : "border-[#D8E1EA] bg-[#F6F8FB]",
            ]}>
              <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-[#0891B2]">{plan.name}</p>
              <p class="mt-5 min-h-[96px] text-[15px] leading-relaxed text-[#475569]">{plan.body}</p>
              <ul class="mt-6 grid gap-3 border-t border-[#D8E1EA] pt-5">
                {plan.items.map((item) => (
                  <li class="flex items-start gap-2.5 text-[14px] text-[#64748B]">
                    <Check class="mt-0.5 h-3.5 w-3.5 shrink-0 text-[#0891B2]" stroke-width={2.2} />
                    {item}
                  </li>
                ))}
              </ul>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="faq" class="border-b border-[#D8E1EA] bg-[#F6F8FB]">
      <div class={`${CONTAINER} grid gap-12 py-18 lg:grid-cols-[0.72fr_1.28fr] lg:py-24`}>
        <div>
          <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-[#0891B2]">FAQ</p>
          <h2 class="mt-4 text-[clamp(2rem,4vw,3.15rem)] font-bold leading-tight tracking-[-0.025em]">
            Questions before automating business tasks.
          </h2>
        </div>

        <div class="grid rounded-[8px] border border-[#D8E1EA] bg-white">
          {faqs.map(([question, answer], index) => (
            <article class="grid gap-3 border-b border-[#D8E1EA] p-6 last:border-b-0 sm:grid-cols-[76px_1fr]">
              <p class="font-mono text-[11px] text-[#0891B2]">{String(index + 1).padStart(2, "0")}</p>
              <div>
                <h3 class="text-[20px] font-semibold tracking-tight">{question}</h3>
                <p class="mt-3 text-[15px] leading-relaxed text-[#64748B]">{answer}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="contact" class="bg-[#F6F8FB]">
      <div class={`${CONTAINER} py-18 lg:py-24`}>
        <div class="grid overflow-hidden rounded-[12px] border border-[#BAE6FD] bg-white lg:grid-cols-[0.92fr_1.08fr]">
          <div class="p-7 sm:p-9 lg:p-10">
            <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-[#0891B2]">Start a task review</p>
            <h2 class="mt-4 text-[clamp(2rem,4vw,3.2rem)] font-bold leading-tight tracking-[-0.025em]">
              Turn one business task into automated work.
            </h2>
            <p class="mt-5 max-w-[34rem] text-[16px] leading-relaxed text-[#64748B]">
              Share the task, tools, knowledge sources, and repeated steps your team wants to improve first.
            </p>

            <div class="mt-8 flex items-center gap-3 text-[14px] text-[#475569]">
              <Mail class="h-4 w-4 text-[#0891B2]" stroke-width={1.8} />
              <a href={`mailto:${brandEmail}`} class="border-b border-[#06B6D4]/50 pb-0.5 transition hover:border-[#06B6D4] hover:text-[#07324A]">
                {brandEmail}
              </a>
            </div>
          </div>

          <form id="workflow-automation-form" class="border-t border-[#D8E1EA] bg-[#F6F8FB] p-7 sm:p-9 lg:border-l lg:border-t-0">
            <div class="flex items-center justify-between gap-4 border-b border-[#D8E1EA] pb-4">
              <div>
                <p class="font-mono text-[10px] uppercase tracking-[0.24em] text-[#0891B2]">Task review</p>
                <h3 class="mt-2 text-[24px] font-semibold tracking-tight">What business task should AI help with?</h3>
              </div>
              <Send class="hidden h-5 w-5 text-[#0891B2] sm:block" stroke-width={1.8} />
            </div>

            <div class="mt-5 grid gap-4 sm:grid-cols-2">
              <label class="grid gap-1.5 text-[11px] font-medium uppercase tracking-[0.16em] text-[#64748B]">
                First name
                <input required name="name" class="h-11 rounded-[6px] border border-[#D8E1EA] bg-white px-3.5 text-[14px] text-[#0F172A] outline-none transition placeholder:text-[#94A3B8] focus:border-[#06B6D4] focus:ring-2 focus:ring-[#06B6D4]/15" placeholder="Your name" />
              </label>
              <label class="grid gap-1.5 text-[11px] font-medium uppercase tracking-[0.16em] text-[#64748B]">
                Work email
                <input required type="email" name="email" class="h-11 rounded-[6px] border border-[#D8E1EA] bg-white px-3.5 text-[14px] text-[#0F172A] outline-none transition placeholder:text-[#94A3B8] focus:border-[#06B6D4] focus:ring-2 focus:ring-[#06B6D4]/15" placeholder="you@company.com" />
              </label>
            </div>

            <label class="mt-4 grid gap-1.5 text-[11px] font-medium uppercase tracking-[0.16em] text-[#64748B]">
              Company
              <input name="company" class="h-11 rounded-[6px] border border-[#D8E1EA] bg-white px-3.5 text-[14px] text-[#0F172A] outline-none transition placeholder:text-[#94A3B8] focus:border-[#06B6D4] focus:ring-2 focus:ring-[#06B6D4]/15" placeholder="Company name" />
            </label>

            <label class="mt-4 grid gap-1.5 text-[11px] font-medium uppercase tracking-[0.16em] text-[#64748B]">
              Business task
              <textarea required name="workflow" class="min-h-32 rounded-[6px] border border-[#D8E1EA] bg-white px-3.5 py-3 text-[14px] text-[#0F172A] outline-none transition placeholder:text-[#94A3B8] focus:border-[#06B6D4] focus:ring-2 focus:ring-[#06B6D4]/15" placeholder="Example: summarize weekly updates, answer questions with company context, prepare next steps, track open work..."></textarea>
            </label>

            <button type="submit" class="mt-6 inline-flex h-12 w-full items-center justify-center rounded-[6px] bg-[#2F66FF] px-6 text-[14px] font-semibold text-white transition hover:bg-[#0EA5E9]">
              Request task review
            </button>
            <p id="workflow-automation-status" class="mt-3 text-center text-[12px] text-[#64748B]">
              Prefer email? {brandEmail}
            </p>
          </form>
        </div>
      </div>
    </section>
  </main>
</div>

<script define:vars={{ brandEmail }} is:inline>
  const workflowAutomationForm = document.getElementById("workflow-automation-form");
  const workflowAutomationStatus = document.getElementById("workflow-automation-status");
  workflowAutomationForm?.addEventListener("submit", (event) => {
    event.preventDefault();
    const form = new FormData(workflowAutomationForm);
    const company = String(form.get("company") || "").trim() || "Tactas AI";
    const subject = encodeURIComponent(`Business task automation review - ${company}`);
    const body = encodeURIComponent(
      [
        `Name: ${String(form.get("name") || "")}`,
        `Work email: ${String(form.get("email") || "")}`,
        `Company: ${String(form.get("company") || "")}`,
        "",
        "Business task:",
        String(form.get("workflow") || ""),
      ].join("\n"),
    );
    if (workflowAutomationStatus) {
      workflowAutomationStatus.textContent = "Opening your email client with the task details.";
    }
    window.location.href = `mailto:${brandEmail}?subject=${subject}&body=${body}`;
  });
</script>
