---
import { ArrowRight, Briefcase, FileText, Mail, Send, Sparkles, TrendingUp, Workflow } from "@lucide/astro";
import { getBrandEmail } from "../lib/site";

interface Props {
  siteUrl: string;
  currentPath?: string;
}

const { currentPath = "/use-cases" } = Astro.props;
const brandEmail = getBrandEmail();
const CONTAINER = "mx-auto w-full max-w-[1240px] px-5 sm:px-8 lg:px-10";

const useCases = [
  {
    title: "Answer with Context",
    href: "/use-cases/ai-customer-support-automation",
    body: "Use company knowledge, business data, and source context to answer repeated requests with useful next steps.",
    icon: FileText,
    keywords: ["company knowledge", "source context", "faster answers"],
  },
  {
    title: "Automate Repeated Updates",
    href: "/use-cases/ai-back-office-automation",
    body: "Turn recurring status updates, document summaries, record changes, and routine coordination into managed agent work.",
    icon: Workflow,
    keywords: ["repeated tasks", "connected tools", "automated updates"],
  },
  {
    title: "Prepare Next Steps",
    href: "/use-cases/ai-crm-workflow-automation",
    body: "Summarize business context, create follow-up drafts, recommend owners, and keep open work moving across tools.",
    icon: TrendingUp,
    keywords: ["next steps", "work handoff", "task follow-up"],
  },
];

const evaluationPoints = [
  "Repeated often enough to improve team performance",
  "Uses knowledge, context, or data your business already has",
  "Can produce a clear output, update, next step, or action",
  "Connects naturally to the tools where work already happens",
];
---

<div class="min-h-screen bg-[#F6F8FB] text-[#0F172A] selection:bg-[#06B6D4]/20">
  <main>
    <section class="relative overflow-hidden border-b border-[#D8E1EA] bg-[#F6F8FB]">
      <div class="pointer-events-none absolute inset-x-0 top-0 h-px bg-[linear-gradient(90deg,transparent,#06B6D4_24%,#D7A22A_72%,transparent)]"></div>
      <div class={`${CONTAINER} grid min-h-[620px] items-center gap-12 py-16 lg:grid-cols-[0.92fr_1.08fr] lg:py-20`}>
        <div class="reveal">
          <div class="mb-8 inline-flex items-center rounded-full bg-[#06AEEA] px-4 py-2 text-[14px] font-medium text-white shadow-[0_14px_32px_-24px_rgba(6,174,234,0.9)]">
            Business task examples
          </div>

          <h1 class="max-w-[860px] text-[clamp(3.4rem,8vw,6.6rem)] font-semibold leading-[0.94] tracking-normal text-[#07324A]">
            Where managed AI agents create useful work.
          </h1>
          <p class="mt-7 max-w-[42rem] text-[18px] leading-relaxed text-[#07324A]/78">
            Explore practical ways Tactas AI turns company knowledge, business context, and connected tools into answers, outputs, updates, and automated actions.
          </p>

          <div class="mt-9 flex flex-col gap-3 sm:flex-row sm:items-center">
            <a href="#use-cases" class="group inline-flex h-12 items-center justify-center rounded-[8px] bg-[#2F66FF] px-6 text-[14px] font-semibold text-white shadow-[0_16px_34px_-24px_rgba(47,102,255,0.85)] transition hover:bg-[#0EA5E9]">
              Explore tasks
              <ArrowRight class="ml-2 h-4 w-4 transition group-hover:translate-x-0.5" stroke-width={1.9} />
            </a>
            <a href="#contact" class="inline-flex h-12 items-center justify-center rounded-[8px] border border-[#D9CFAE] bg-white/60 px-6 text-[14px] font-semibold text-[#07324A] transition hover:border-[#2F66FF] hover:text-[#2F66FF]">
              Discuss a task
            </a>
          </div>
        </div>

        <div class="reveal" data-delay="2">
          <div class="border border-[#D8E1EA] bg-white shadow-[0_34px_100px_-72px_rgba(7,50,74,0.42)]">
            <div class="flex items-center justify-between border-b border-[#E2E8F0] bg-[#F6F8FB] px-5 py-4">
              <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-[#64748B]">Task fit</p>
              <Briefcase class="h-5 w-5 text-[#06B6D4]" stroke-width={1.8} />
            </div>
            <div class="grid gap-3 p-5">
              {evaluationPoints.map((point, index) => (
                <div class="flex items-start gap-3 border border-[#E2E8F0] bg-[#F6F8FB] p-4">
                  <span class="font-mono text-[11px] text-[#0891B2]">{String(index + 1).padStart(2, "0")}</span>
                  <p class="text-[14px] leading-relaxed text-[#334155]">{point}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="use-cases" class="border-b border-[#D8E1EA] bg-[#F6F8FB]">
      <div class={`${CONTAINER} py-18 lg:py-24`}>
        <div class="mx-auto max-w-3xl text-center">
          <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-[#0891B2]">Use case library</p>
          <h2 class="mt-4 text-[clamp(2rem,4vw,3.2rem)] font-semibold leading-tight tracking-normal text-[#07324A]">
            Start with tasks where knowledge becomes action.
          </h2>
        </div>

        <div class="mt-12 grid gap-4 lg:grid-cols-3">
          {useCases.map((item) => {
            const Icon = item.icon;
            return (
              <a href={item.href} class="group flex min-h-[330px] flex-col justify-between border border-[#D8E1EA] bg-white p-6 shadow-[0_24px_70px_-62px_rgba(7,50,74,0.3)] transition hover:-translate-y-0.5 hover:border-[#06B6D4]/50">
                <span>
                  <span class="flex h-12 w-12 items-center justify-center rounded-[8px] border border-[#BAE6FD] bg-[#E6FBFF] text-[#0E7490]">
                    <Icon class="h-5 w-5" stroke-width={1.8} />
                  </span>
                  <span class="mt-7 block text-[22px] font-semibold tracking-tight text-[#07324A]">{item.title}</span>
                  <span class="mt-3 block text-[14px] leading-relaxed text-[#475569]">{item.body}</span>
                  <span class="mt-6 flex flex-wrap gap-2">
                    {item.keywords.map((keyword) => (
                      <span class="rounded-full border border-[#D8E1EA] bg-[#F6F8FB] px-3 py-1 text-[11px] text-[#334155]">{keyword}</span>
                    ))}
                  </span>
                </span>
                <span class="mt-8 inline-flex items-center text-[13px] font-semibold text-[#0891B2]">
                  View task
                  <ArrowRight class="ml-2 h-3.5 w-3.5 transition group-hover:translate-x-0.5" />
                </span>
              </a>
            );
          })}
        </div>
      </div>
    </section>

    <section id="contact" class="bg-[#F6F8FB]">
      <div class={`${CONTAINER} py-18 lg:py-24`}>
        <div class="grid overflow-hidden border border-[#D8E1EA] bg-white shadow-[0_34px_100px_-72px_rgba(7,50,74,0.42)] lg:grid-cols-[0.92fr_1.08fr]">
          <div class="p-7 sm:p-9 lg:p-10">
            <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-[#0891B2]">Find the first use case</p>
            <h2 class="mt-4 text-[clamp(2rem,4vw,3.2rem)] font-semibold leading-tight tracking-normal text-[#07324A]">
              Not sure which business task to automate first?
            </h2>
            <p class="mt-5 max-w-[34rem] text-[16px] leading-relaxed text-[#475569]">
              Share the repeated work your team handles today. Tactas AI can help map the knowledge, tools, outputs, and automation steps behind a practical first task.
            </p>

            <div class="mt-8 flex items-center gap-3 text-[14px] text-[#334155]">
              <Mail class="h-4 w-4 text-[#06B6D4]" stroke-width={1.8} />
              <a href={`mailto:${brandEmail}`} class="border-b border-[#06B6D4]/55 pb-0.5 transition hover:border-[#0891B2] hover:text-[#0891B2]">
                {brandEmail}
              </a>
            </div>
          </div>

          <form id="use-case-form" class="border-t border-[#D8E1EA] bg-[#F6F8FB] p-7 sm:p-9 lg:border-l lg:border-t-0">
            <div class="flex items-center justify-between gap-4 border-b border-[#D8E1EA] pb-4">
              <div>
                <p class="font-mono text-[10px] uppercase tracking-[0.24em] text-[#0891B2]">Task review</p>
                <h3 class="mt-2 text-[24px] font-semibold tracking-tight text-[#07324A]">Describe the business task.</h3>
              </div>
              <Send class="hidden h-5 w-5 text-[#06B6D4] sm:block" stroke-width={1.8} />
            </div>

            <div class="mt-5 grid gap-4 sm:grid-cols-2">
              <label class="grid gap-1.5 text-[11px] font-semibold uppercase tracking-[0.16em] text-[#64748B]">
                First name
                <input required name="name" class="h-11 rounded-[6px] border border-[#CBD5E1] bg-white px-3.5 text-[14px] normal-case tracking-normal text-[#0F172A] outline-none transition placeholder:text-[#94A3B8] focus:border-[#06B6D4] focus:ring-2 focus:ring-[#06B6D4]/15" placeholder="Your name" />
              </label>
              <label class="grid gap-1.5 text-[11px] font-semibold uppercase tracking-[0.16em] text-[#64748B]">
                Work email
                <input required type="email" name="email" class="h-11 rounded-[6px] border border-[#CBD5E1] bg-white px-3.5 text-[14px] normal-case tracking-normal text-[#0F172A] outline-none transition placeholder:text-[#94A3B8] focus:border-[#06B6D4] focus:ring-2 focus:ring-[#06B6D4]/15" placeholder="you@company.com" />
              </label>
            </div>

            <label class="mt-4 grid gap-1.5 text-[11px] font-semibold uppercase tracking-[0.16em] text-[#64748B]">
              Business task
              <textarea required name="workflow" class="min-h-32 rounded-[6px] border border-[#CBD5E1] bg-white px-3.5 py-3 text-[14px] normal-case tracking-normal text-[#0F172A] outline-none transition placeholder:text-[#94A3B8] focus:border-[#06B6D4] focus:ring-2 focus:ring-[#06B6D4]/15" placeholder="Example: summarize updates, answer repeated requests, prepare next steps, track open work..."></textarea>
            </label>

            <button type="submit" class="mt-6 inline-flex h-12 w-full items-center justify-center rounded-[8px] bg-[#2F66FF] px-6 text-[14px] font-semibold text-white transition hover:bg-[#0EA5E9]">
              Request task review
            </button>
            <p id="use-case-status" class="mt-3 text-center text-[12px] text-[#64748B]">
              Prefer email? {brandEmail}
            </p>
          </form>
        </div>
      </div>
    </section>
  </main>
</div>

<script define:vars={{ brandEmail }} is:inline>
  const useCaseForm = document.getElementById("use-case-form");
  const useCaseStatus = document.getElementById("use-case-status");
  useCaseForm?.addEventListener("submit", (event) => {
    event.preventDefault();
    const form = new FormData(useCaseForm);
    const subject = encodeURIComponent("Business task automation review");
    const body = encodeURIComponent(
      [
        `Name: ${String(form.get("name") || "")}`,
        `Work email: ${String(form.get("email") || "")}`,
        "",
        "Business task:",
        String(form.get("workflow") || ""),
      ].join("\n"),
    );
    if (useCaseStatus) {
      useCaseStatus.textContent = "Opening your email client with the task details.";
    }
    window.location.href = `mailto:${brandEmail}?subject=${subject}&body=${body}`;
  });
</script>
