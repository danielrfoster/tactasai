---
import {
  ArrowRight,
  Briefcase,
  Check,
  ClipboardCheck,
  Headphones,
  Mail,
  Send,
  Sparkles,
  TrendingUp,
} from "@lucide/astro";
import { getBrandEmail } from "../lib/site";

interface Props {
  siteUrl: string;
  currentPath?: string;
}

const { currentPath = "/use-cases" } = Astro.props;
const brandEmail = getBrandEmail();
const CONTAINER = "mx-auto w-full max-w-[1240px] px-5 sm:px-8 lg:px-10";

const useCases = [
  {
    title: "AI Customer Support Automation",
    href: "/use-cases/ai-customer-support-automation",
    body: "Triage tickets, retrieve customer context, draft replies, update helpdesk records, and escalate sensitive cases.",
    icon: Headphones,
    keywords: ["support automation", "ticket triage", "human handoff"],
  },
  {
    title: "AI Back-Office Automation",
    href: "/use-cases/ai-back-office-automation",
    body: "Review documents, prepare records, route approvals, reconcile data, and reduce repetitive admin work.",
    icon: ClipboardCheck,
    keywords: ["back-office automation", "document checks", "approval routing"],
  },
  {
    title: "AI CRM Workflow Automation",
    href: "/use-cases/ai-crm-workflow-automation",
    body: "Qualify leads, summarize conversations, enrich CRM records, prepare follow-ups, and keep sales tasks moving.",
    icon: TrendingUp,
    keywords: ["CRM automation", "lead qualification", "sales follow-up"],
  },
];

const evaluationPoints = [
  "Frequent enough to create measurable savings",
  "Clear rules, owners, and exception paths",
  "Accessible data across tools, documents, and systems",
  "Low enough risk for a supervised first launch",
];
---

<div class="min-h-screen overflow-x-hidden bg-[#050A14] text-white selection:bg-[#8B5CF6]/30">
  <div class="pointer-events-none fixed inset-0 -z-20 grid-faint opacity-[0.24] [mask-image:radial-gradient(ellipse_70%_60%_at_50%_10%,black_0%,transparent_75%)]"></div>

  <main>
    <section class="relative overflow-hidden border-b border-white/10">
      <div class="pointer-events-none absolute inset-0 z-0 bg-[linear-gradient(180deg,rgba(124,58,237,0.14)_0%,rgba(5,10,20,0)_58%)]"></div>
      <div class="pointer-events-none absolute inset-0 z-0 opacity-[0.30] [background-image:linear-gradient(to_right,rgba(255,255,255,0.055)_1px,transparent_1px),linear-gradient(to_bottom,rgba(255,255,255,0.045)_1px,transparent_1px)] [background-size:72px_72px]"></div>

      <div class={`${CONTAINER} relative z-10 grid min-h-[620px] items-center gap-12 py-16 lg:grid-cols-[0.92fr_1.08fr] lg:py-20`}>
        <div class="reveal">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#7C3AED]/35 bg-[#130B2A]/80 px-3 py-1.5">
            <Sparkles class="h-3.5 w-3.5 text-[#A78BFA]" stroke-width={1.8} />
            <span class="font-mono text-[10px] font-semibold uppercase tracking-[0.24em] text-[#C4B5FD]">AI automation use cases</span>
          </div>

          <h1 class="max-w-[11ch] text-[clamp(3rem,7vw,5.8rem)] font-extrabold leading-[0.94] tracking-[-0.045em]">
            Use cases for AI workflow automation.
          </h1>
          <p class="mt-7 max-w-[42rem] text-[17px] leading-relaxed text-[#C8D0DE]">
            Explore practical AI automation workflows for support, back-office operations, CRM, documents, approvals, and team handoff.
          </p>

          <div class="mt-9 flex flex-col gap-3 sm:flex-row sm:items-center">
            <a href="#use-cases" class="group inline-flex h-12 items-center justify-center rounded-[6px] bg-[#7C3AED] px-6 text-[14px] font-semibold text-white shadow-[0_18px_48px_-24px_rgba(124,58,237,0.8)] transition hover:bg-[#8B5CF6]">
              Explore use cases
              <ArrowRight class="ml-2 h-4 w-4 transition group-hover:translate-x-0.5" stroke-width={1.9} />
            </a>
            <a href="#contact" class="inline-flex h-12 items-center justify-center rounded-[6px] border border-white/18 bg-white/[0.03] px-6 text-[14px] font-semibold text-white transition hover:border-[#A78BFA]/70 hover:text-[#C4B5FD]">
              Discuss a workflow
            </a>
          </div>
        </div>

        <div class="reveal" data-delay="2">
          <div class="rounded-[12px] border border-white/12 bg-[#07101F] p-5 shadow-[0_40px_110px_-56px_rgba(0,0,0,0.95)]">
            <div class="flex items-center justify-between border-b border-white/10 pb-4">
              <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-[#A78BFA]">Pilot criteria</p>
              <Briefcase class="h-5 w-5 text-[#A78BFA]" stroke-width={1.8} />
            </div>
            <div class="mt-5 grid gap-3">
              {evaluationPoints.map((point, index) => (
                <div class="flex items-start gap-3 rounded-[8px] border border-white/10 bg-white/[0.025] p-4">
                  <span class="font-mono text-[11px] text-[#A78BFA]">{String(index + 1).padStart(2, "0")}</span>
                  <p class="text-[14px] leading-relaxed text-[#C8D0DE]">{point}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="use-cases" class="border-b border-white/10 bg-[#050A14]">
      <div class={`${CONTAINER} py-18 lg:py-24`}>
        <div class="mx-auto max-w-3xl text-center">
          <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-[#A78BFA]">Use case library</p>
          <h2 class="mt-4 text-[clamp(2rem,4vw,3.2rem)] font-bold leading-tight tracking-[-0.025em]">
            Start where AI agents can create visible operational value.
          </h2>
        </div>

        <div class="mt-12 grid gap-4 lg:grid-cols-3">
          {useCases.map((item) => {
            const Icon = item.icon;
            return (
              <a href={item.href} class="group flex min-h-[330px] flex-col justify-between rounded-[8px] border border-white/10 bg-[#07101F] p-6 transition hover:border-[#7C3AED]/60 hover:bg-[#0A1324]">
                <span>
                  <span class="flex h-12 w-12 items-center justify-center rounded-[8px] border border-[#7C3AED]/25 bg-[#160B36] text-[#A78BFA]">
                    <Icon class="h-5 w-5" stroke-width={1.8} />
                  </span>
                  <span class="mt-7 block text-[22px] font-semibold tracking-tight text-white">{item.title}</span>
                  <span class="mt-3 block text-[14px] leading-relaxed text-[#8A93A6]">{item.body}</span>
                  <span class="mt-6 flex flex-wrap gap-2">
                    {item.keywords.map((keyword) => (
                      <span class="rounded-full border border-white/10 bg-white/[0.03] px-3 py-1 text-[11px] text-[#C8D0DE]">{keyword}</span>
                    ))}
                  </span>
                </span>
                <span class="mt-8 inline-flex items-center text-[13px] font-semibold text-[#A78BFA]">
                  View workflow
                  <ArrowRight class="ml-2 h-3.5 w-3.5 transition group-hover:translate-x-0.5" />
                </span>
              </a>
            );
          })}
        </div>
      </div>
    </section>

    <section id="contact" class="bg-[#070B16]">
      <div class={`${CONTAINER} py-18 lg:py-24`}>
        <div class="grid overflow-hidden rounded-[12px] border border-[#7C3AED]/35 bg-[#0A1324] lg:grid-cols-[0.92fr_1.08fr]">
          <div class="p-7 sm:p-9 lg:p-10">
            <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-[#A78BFA]">Find the first use case</p>
            <h2 class="mt-4 text-[clamp(2rem,4vw,3.2rem)] font-bold leading-tight tracking-[-0.025em]">
              Not sure which workflow to automate first?
            </h2>
            <p class="mt-5 max-w-[34rem] text-[16px] leading-relaxed text-[#8A93A6]">
              Share the repetitive work your team handles today. Tactas AI can help identify a practical pilot with clear controls.
            </p>

            <div class="mt-8 flex items-center gap-3 text-[14px] text-[#C8D0DE]">
              <Mail class="h-4 w-4 text-[#A78BFA]" stroke-width={1.8} />
              <a href={`mailto:${brandEmail}`} class="border-b border-[#7C3AED]/55 pb-0.5 transition hover:border-[#A78BFA] hover:text-white">
                {brandEmail}
              </a>
            </div>
          </div>

          <form id="use-case-form" class="border-t border-white/10 bg-[#050A14] p-7 sm:p-9 lg:border-l lg:border-t-0">
            <div class="flex items-center justify-between gap-4 border-b border-white/10 pb-4">
              <div>
                <p class="font-mono text-[10px] uppercase tracking-[0.24em] text-[#A78BFA]">Use case review</p>
                <h3 class="mt-2 text-[24px] font-semibold tracking-tight">Describe the workflow.</h3>
              </div>
              <Send class="hidden h-5 w-5 text-[#A78BFA] sm:block" stroke-width={1.8} />
            </div>

            <div class="mt-5 grid gap-4 sm:grid-cols-2">
              <label class="grid gap-1.5 text-[11px] font-medium uppercase tracking-[0.16em] text-[#8A93A6]">
                First name
                <input required name="name" class="h-11 rounded-[6px] border border-white/12 bg-white/[0.035] px-3.5 text-[14px] text-white outline-none transition placeholder:text-[#5E6678] focus:border-[#8B5CF6] focus:ring-2 focus:ring-[#8B5CF6]/15" placeholder="Your name" />
              </label>
              <label class="grid gap-1.5 text-[11px] font-medium uppercase tracking-[0.16em] text-[#8A93A6]">
                Work email
                <input required type="email" name="email" class="h-11 rounded-[6px] border border-white/12 bg-white/[0.035] px-3.5 text-[14px] text-white outline-none transition placeholder:text-[#5E6678] focus:border-[#8B5CF6] focus:ring-2 focus:ring-[#8B5CF6]/15" placeholder="you@company.com" />
              </label>
            </div>

            <label class="mt-4 grid gap-1.5 text-[11px] font-medium uppercase tracking-[0.16em] text-[#8A93A6]">
              Workflow
              <textarea required name="workflow" class="min-h-32 rounded-[6px] border border-white/12 bg-white/[0.035] px-3.5 py-3 text-[14px] text-white outline-none transition placeholder:text-[#5E6678] focus:border-[#8B5CF6] focus:ring-2 focus:ring-[#8B5CF6]/15" placeholder="Example: support tickets, invoice approvals, CRM follow-up, document checks..."></textarea>
            </label>

            <button type="submit" class="mt-6 inline-flex h-12 w-full items-center justify-center rounded-[6px] bg-[#7C3AED] px-6 text-[14px] font-semibold text-white transition hover:bg-[#8B5CF6]">
              Request use case review
            </button>
            <p id="use-case-status" class="mt-3 text-center text-[12px] text-[#8A93A6]">
              Prefer email? {brandEmail}
            </p>
          </form>
        </div>
      </div>
    </section>
  </main>
</div>

<script define:vars={{ brandEmail }} is:inline>
  const useCaseForm = document.getElementById("use-case-form");
  const useCaseStatus = document.getElementById("use-case-status");
  useCaseForm?.addEventListener("submit", (event) => {
    event.preventDefault();
    const form = new FormData(useCaseForm);
    const subject = encodeURIComponent("AI automation use case review");
    const body = encodeURIComponent(
      [
        `Name: ${String(form.get("name") || "")}`,
        `Work email: ${String(form.get("email") || "")}`,
        "",
        "Workflow:",
        String(form.get("workflow") || ""),
      ].join("\n"),
    );
    if (useCaseStatus) {
      useCaseStatus.textContent = "Opening your email client with the use case details.";
    }
    window.location.href = `mailto:${brandEmail}?subject=${subject}&body=${body}`;
  });
</script>
