---
import {
  ArrowUpRight,
  Bot,
  Check,
  Globe,
  Layers,
  Mail,
  Network,
  Send,
  ShieldCheck,
  Zap,
} from "@lucide/astro";
import Navbar from "./Navbar.astro";

interface Props {
  siteUrl: string;
  currentPath?: string;
}

const { siteUrl, currentPath = "/" } = Astro.props;
const currentYear = new Date().getFullYear();
const CONTAINER = "mx-auto w-full max-w-[1240px] px-5 sm:px-8 lg:px-10";

const platformColumns = [
  {
    title: "connect",
    heading: "Connect the tools your team already uses",
    body: "Give AI operators the context they need to resolve real requests.",
    points: ["Business systems", "Documents and SOPs", "Secure access"],
    icon: Network,
  },
  {
    title: "govern",
    heading: "Define what AI can decide and do",
    body: "Set approval rules, escalation paths, and limits for sensitive work.",
    points: ["Approval gates", "Action logs", "Human handoff"],
    icon: ShieldCheck,
  },
  {
    title: "operate",
    heading: "Operate and improve after launch",
    body: "Monitor outcomes, review exceptions, and improve the operator over time.",
    points: ["Operator setup", "Exception monitoring", "Ongoing support"],
    icon: Zap,
  },
];

const solutionCards = [
  {
    title: "Support operators",
    body: "Triage tickets, draft replies, update records, and escalate sensitive cases.",
  },
  {
    title: "Back-office operators",
    body: "Check documents, update records, route requests, and prepare routine reviews.",
  },
  {
    title: "Admin and finance operators",
    body: "Review invoices, route approvals, reconcile data, and prepare summaries.",
  },
  {
    title: "Operator control center",
    body: "Track actions, explain decisions, and keep high-impact work controlled.",
  },
];

---

<div class="min-h-screen bg-[#F8FAFC] text-[#0F172A]">
  <Navbar currentPath={currentPath} ctaLabel="Operator review" ctaHref="/contact" theme="light" />

  <main>
    <section class="relative overflow-hidden border-b border-[#D8E1EA] bg-[#F8FAFC]">
      <div id="hero-globe-background" class="absolute inset-0 z-0 h-full min-h-[720px] opacity-90" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-0 z-[1] bg-[linear-gradient(90deg,rgba(248,250,252,0.96)_0%,rgba(248,250,252,0.86)_42%,rgba(248,250,252,0.58)_72%,rgba(248,250,252,0.32)_100%)]"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 z-[1] h-[640px] bg-[linear-gradient(180deg,rgba(248,250,252,0.76)_0%,rgba(238,246,251,0.42)_62%,rgba(238,246,251,0)_100%)]"></div>
      <div class="pointer-events-none absolute inset-0 z-[2] opacity-[0.28] [background-image:linear-gradient(to_right,rgba(15,23,42,0.06)_1px,transparent_1px),linear-gradient(to_bottom,rgba(15,23,42,0.05)_1px,transparent_1px)] [background-size:64px_64px]"></div>

      <div class="pointer-events-none absolute bottom-[-2rem] right-[-1.5rem] z-0 hidden w-[min(760px,58vw)] rotate-[-1.5deg] opacity-[0.72] lg:block" aria-hidden="true">
        <div class="overflow-hidden rounded-[8px] border border-[#CBD5E1] bg-white/82 shadow-[0_36px_90px_-66px_rgba(15,23,42,0.38)] backdrop-blur-sm">
          <div class="flex h-11 items-center justify-between border-b border-[#D8E1EA] bg-[#F1F5F9] px-4">
            <div class="flex items-center gap-2">
              <span class="h-2.5 w-2.5 rounded-full bg-[#06B6D4]"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-[#94A3B8]"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-[#94A3B8]"></span>
            </div>
            <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-[#0E7490]">Operator flow orchestration</p>
          </div>

          <div class="grid min-h-[360px] grid-cols-[170px_1fr]">
            <aside class="border-r border-[#D8E1EA] bg-[#F1F5F9] p-4">
              <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-[#0E7490]">Runtime</p>
              <div class="mt-4 grid gap-2">
                {["Support triage", "Billing update", "Order exception"].map((item, index) => (
                  <div class:list={[
                    "rounded-[4px] border px-3 py-2 text-[12px] font-semibold",
                    index === 0 ? "border-[#67E8F9] bg-white text-[#0F172A]" : "border-[#D8E1EA] bg-white/70 text-[#64748B]",
                  ]}>
                    {item}
                  </div>
                ))}
              </div>
              <div class="mt-6 rounded-[4px] border border-[#D8E1EA] bg-white/75 p-3">
                <p class="text-[11px] font-semibold text-[#0F172A]">Human gate</p>
                <p class="mt-1 text-[10px] leading-relaxed text-[#64748B]">Approval required for refunds, account changes, and exceptions.</p>
              </div>
            </aside>

            <div class="relative p-5">
              <div class="absolute left-[96px] right-[84px] top-[112px] h-px bg-[#CBD5E1]"></div>
              <div class="absolute left-[242px] top-[112px] h-[104px] w-px bg-[#CBD5E1]"></div>
              <div class="absolute left-[242px] right-[92px] top-[216px] h-px bg-[#CBD5E1]"></div>

              <div class="relative grid grid-cols-3 gap-4">
                <div class="rounded-[6px] border border-[#D8E1EA] bg-white p-4 shadow-[0_18px_38px_-34px_rgba(15,23,42,0.24)]">
                  <div class="flex h-9 w-9 items-center justify-center rounded-[4px] bg-[#E6FBFF] text-[#06B6D4]">
                    <Network class="h-4.5 w-4.5" stroke-width={1.7} />
                  </div>
                  <p class="mt-4 text-[13px] font-semibold text-[#0F172A]">Intake</p>
                  <p class="mt-1 text-[11px] leading-relaxed text-[#64748B]">Read ticket, CRM, docs, and SOP context.</p>
                </div>

                <div class="rounded-[6px] border border-[#67E8F9] bg-[#F8FAFC] p-4 shadow-[0_18px_38px_-34px_rgba(15,23,42,0.24)]">
                  <div class="flex h-9 w-9 items-center justify-center rounded-[4px] bg-[#06B6D4] text-white">
                    <Bot class="h-4.5 w-4.5" stroke-width={1.7} />
                  </div>
                  <p class="mt-4 text-[13px] font-semibold text-[#0F172A]">Operator planner</p>
                  <p class="mt-1 text-[11px] leading-relaxed text-[#64748B]">Choose action path and assign specialist operators.</p>
                </div>

                <div class="rounded-[6px] border border-[#D8E1EA] bg-white p-4 shadow-[0_18px_38px_-34px_rgba(15,23,42,0.24)]">
                  <div class="flex h-9 w-9 items-center justify-center rounded-[4px] bg-[#E6FBFF] text-[#06B6D4]">
                    <ShieldCheck class="h-4.5 w-4.5" stroke-width={1.7} />
                  </div>
                  <p class="mt-4 text-[13px] font-semibold text-[#0F172A]">Policy check</p>
                  <p class="mt-1 text-[11px] leading-relaxed text-[#64748B]">Verify risk, approvals, limits, and audit notes.</p>
                </div>
              </div>

              <div class="relative mt-12 grid grid-cols-[1fr_1fr_0.85fr] gap-4">
                <div class="rounded-[6px] border border-[#D8E1EA] bg-white p-4 shadow-[0_18px_38px_-34px_rgba(15,23,42,0.24)]">
                  <p class="font-mono text-[9px] uppercase tracking-[0.18em] text-[#0E7490]">Operator A</p>
                  <p class="mt-2 text-[13px] font-semibold text-[#0F172A]">Draft response</p>
                  <div class="mt-3 h-2 rounded bg-[#D8E1EA]"></div>
                  <div class="mt-2 h-2 w-2/3 rounded bg-[#D8E1EA]"></div>
                </div>

                <div class="rounded-[6px] border border-[#D8E1EA] bg-white p-4 shadow-[0_18px_38px_-34px_rgba(15,23,42,0.24)]">
                  <p class="font-mono text-[9px] uppercase tracking-[0.18em] text-[#0E7490]">Operator B</p>
                  <p class="mt-2 text-[13px] font-semibold text-[#0F172A]">Prepare action</p>
                  <div class="mt-3 h-2 rounded bg-[#D8E1EA]"></div>
                  <div class="mt-2 h-2 w-1/2 rounded bg-[#D8E1EA]"></div>
                </div>

                <div class="rounded-[6px] border border-[#020617] bg-[#0F172A] p-4 text-white shadow-[0_18px_38px_-34px_rgba(15,23,42,0.36)]">
                  <div class="flex items-center gap-2">
                    <Zap class="h-4 w-4 text-[#67E8F9]" stroke-width={1.8} />
                    <p class="text-[13px] font-semibold">Execute</p>
                  </div>
                  <p class="mt-2 text-[11px] leading-relaxed text-[#CFFAFE]">Send, update, log, or escalate.</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class={`${CONTAINER} relative z-10 py-12 sm:py-16 lg:pb-12 lg:pt-20`}>
        <div class="min-h-[460px] max-w-[1120px] pb-24 lg:min-h-[560px] lg:pb-40">
          <h1 class="max-w-[1040px] text-[clamp(3.45rem,8.7vw,7.05rem)] font-semibold leading-[0.91] tracking-[-0.055em] text-[#0F172A]">
            AI Operators for Business Operations
          </h1>
          <p class="mt-7 max-w-[62rem] text-[18px] leading-[1.65] text-[#475569] sm:text-[20px]">
            Tactas AI deploys managed AI agents that learn how your business works, turn company knowledge
            into action, and help employees and customers get work done faster.
          </p>

          <div class="mt-8 flex flex-col gap-3 sm:flex-row">
            <a href="/contact" class="inline-flex h-12 items-center justify-center rounded-[4px] bg-[#06B6D4] px-6 text-[14px] font-semibold text-white transition hover:bg-[#0891B2]">
              Book an operator review
            </a>
            <a href="#platform" class="inline-flex h-12 items-center justify-center rounded-[4px] border border-[#94A3B8] bg-transparent px-6 text-[14px] font-semibold text-[#0F172A] transition hover:border-[#06B6D4] hover:text-[#0891B2]">
              Explore the operating layer
            </a>
          </div>
        </div>

      </div>
    </section>

    <section class="border-b border-[#D8E1EA] bg-white">
      <div class={`${CONTAINER} py-14 lg:py-16`}>
        <div class="grid gap-8 lg:grid-cols-[0.8fr_1.2fr] lg:items-start">
          <div>
            <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-[#0891B2]">Example operators</p>
            <h2 class="mt-4 max-w-[620px] text-4xl font-semibold leading-tight tracking-normal text-[#0F172A] sm:text-5xl">
              See how work moves through chat.
            </h2>
            <p class="mt-4 max-w-[36rem] text-[16px] leading-relaxed text-[#475569]">
              Ask a question, request an action, or hand off a repeatable process. The operator pulls context,
              checks the right systems, and drafts the next step.
            </p>
          </div>

          <div class="border border-[#D8E1EA] bg-[#F8FAFC]">
            <div class="grid gap-px bg-[#D8E1EA] p-px sm:grid-cols-2 lg:grid-cols-4" role="tablist" aria-label="Example operator conversations">
              {[
                ["analysis", "Business analysis"],
                ["client", "Client support"],
                ["employee", "Employee support"],
                ["workspace", "Workspace ops"],
              ].map(([id, label], index) => (
                <button
                  type="button"
                  class:list={[
                    "example-tab h-12 bg-white px-3 text-[13px] font-semibold transition hover:text-[#06B6D4]",
                    index === 0 ? "text-[#06B6D4]" : "text-[#334155]",
                  ]}
                  data-example-tab={id}
                  aria-selected={index === 0 ? "true" : "false"}
                  aria-controls={`example-panel-${id}`}
                  role="tab"
                >
                  {label}
                </button>
              ))}
            </div>

            <div class="relative overflow-hidden px-4 py-5 sm:px-5">
              <div class="absolute inset-0 opacity-[0.45] [background-image:linear-gradient(to_right,rgba(15,23,42,0.05)_1px,transparent_1px),linear-gradient(to_bottom,rgba(15,23,42,0.04)_1px,transparent_1px)] [background-size:28px_28px]"></div>

              <div id="example-panel-analysis" class="example-panel relative grid gap-4" role="tabpanel">
                <div class="flex justify-end">
                  <div class="max-w-[82%] rounded-2xl rounded-tr-sm bg-[#0F172A] px-4 py-3 text-white shadow-[0_16px_36px_-28px_rgba(15,23,42,0.7)]">
                    <p class="text-[12px] font-semibold text-[#67E8F9]">Admin</p>
                    <p class="mt-1 text-[15px] leading-relaxed">This month, what changed in the business?</p>
                  </div>
                </div>

                <div class="flex justify-start">
                  <div class="max-w-[86%] rounded-2xl rounded-tl-sm border border-[#D8E1EA] bg-white px-4 py-3 shadow-[0_16px_36px_-32px_rgba(15,23,42,0.35)]">
                    <div class="flex items-center gap-2">
                      <Bot class="h-4 w-4 text-[#06B6D4]" stroke-width={1.8} />
                      <p class="text-[12px] font-semibold text-[#0F172A]">Analysis operator</p>
                    </div>
                    <p class="mt-2 text-[14px] leading-relaxed text-[#475569]">
                      Checking Google Sheets, project boards, CRM, and marketing dashboards.
                    </p>
                    <div class="mt-3 flex flex-wrap gap-2">
                      {["Sheets", "Projects", "CRM", "Marketing"].map((source) => (
                        <span class="rounded-full border border-[#BAE6FD] bg-[#E6FBFF] px-2.5 py-1 text-[11px] font-semibold text-[#0E7490]">
                          {source}
                        </span>
                      ))}
                    </div>
                  </div>
                </div>

                <div class="ml-6 flex items-center gap-2 text-[12px] text-[#64748B]">
                  <span class="h-2 w-2 rounded-full bg-[#06B6D4]"></span>
                  <span>Summarizing progress, customer growth, and demand signals...</span>
                </div>

                <div class="flex justify-start">
                  <div class="max-w-[92%] rounded-2xl rounded-tl-sm border border-[#D8E1EA] bg-white px-4 py-4 shadow-[0_16px_36px_-32px_rgba(15,23,42,0.35)]">
                    <div class="flex items-center gap-2">
                      <Bot class="h-4 w-4 text-[#06B6D4]" stroke-width={1.8} />
                      <p class="text-[12px] font-semibold text-[#0F172A]">Draft monthly brief</p>
                    </div>
                    <div class="mt-3 grid gap-3">
                      {[
                        ["Project X", "about 80% complete, with handoff tasks still open."],
                        ["Marketing", "campaigns brought in 20% more new customers."],
                        ["Demand", "recent interest is trending toward Product A."],
                      ].map(([label, value]) => (
                        <div class="flex gap-3">
                          <Check class="mt-0.5 h-4 w-4 shrink-0 text-[#06B6D4]" stroke-width={2.4} />
                          <p class="text-[14px] leading-relaxed text-[#334155]">
                            <span class="font-semibold text-[#0F172A]">{label}:</span> {value}
                          </p>
                        </div>
                      ))}
                    </div>
                  </div>
                </div>
              </div>

              <div id="example-panel-client" class="example-panel relative hidden grid gap-4" role="tabpanel">
                <div class="flex justify-end">
                  <div class="max-w-[82%] rounded-2xl rounded-tr-sm bg-[#0F172A] px-4 py-3 text-white shadow-[0_16px_36px_-28px_rgba(15,23,42,0.7)]">
                    <p class="text-[12px] font-semibold text-[#67E8F9]">Client</p>
                    <p class="mt-1 text-[15px] leading-relaxed">Does Product A support team workspaces?</p>
                  </div>
                </div>

                <div class="flex justify-start">
                  <div class="max-w-[90%] rounded-2xl rounded-tl-sm border border-[#D8E1EA] bg-white px-4 py-3 shadow-[0_16px_36px_-32px_rgba(15,23,42,0.35)]">
                    <div class="flex items-center gap-2">
                      <Bot class="h-4 w-4 text-[#06B6D4]" stroke-width={1.8} />
                      <p class="text-[12px] font-semibold text-[#0F172A]">Support operator</p>
                    </div>
                    <p class="mt-2 text-[14px] leading-relaxed text-[#475569]">
                      Yes. Product A supports shared workspaces, role-based access, and member invites. For your plan,
                      up to 25 members are included.
                    </p>
                  </div>
                </div>

                <div class="flex justify-end">
                  <div class="max-w-[84%] rounded-2xl rounded-tr-sm bg-[#0F172A] px-4 py-3 text-white shadow-[0_16px_36px_-28px_rgba(15,23,42,0.7)]">
                    <p class="text-[12px] font-semibold text-[#67E8F9]">Client</p>
                    <p class="mt-1 text-[15px] leading-relaxed">
                      Great. Please issue this month's invoice and add Mai Nguyen to our workspace.
                    </p>
                  </div>
                </div>

                <div class="ml-6 flex items-center gap-2 text-[12px] text-[#64748B]">
                  <span class="h-2 w-2 rounded-full bg-[#06B6D4]"></span>
                  <span>Checking billing account, invoice rules, and workspace permissions...</span>
                </div>

                <div class="flex justify-start">
                  <div class="max-w-[92%] rounded-2xl rounded-tl-sm border border-[#D8E1EA] bg-white px-4 py-4 shadow-[0_16px_36px_-32px_rgba(15,23,42,0.35)]">
                    <div class="flex items-center gap-2">
                      <Bot class="h-4 w-4 text-[#06B6D4]" stroke-width={1.8} />
                      <p class="text-[12px] font-semibold text-[#0F172A]">Prepared actions</p>
                    </div>
                    <div class="mt-3 grid gap-3">
                      {[
                        ["Invoice", "drafted for the current billing period and ready to send."],
                        ["Workspace", "Mai Nguyen invite prepared with member-level access."],
                        ["Approval", "billing send and workspace invite are waiting for human approval."],
                      ].map(([label, value]) => (
                        <div class="flex gap-3">
                          <Check class="mt-0.5 h-4 w-4 shrink-0 text-[#06B6D4]" stroke-width={2.4} />
                          <p class="text-[14px] leading-relaxed text-[#334155]">
                            <span class="font-semibold text-[#0F172A]">{label}:</span> {value}
                          </p>
                        </div>
                      ))}
                    </div>
                  </div>
                </div>
              </div>

              <div id="example-panel-workspace" class="example-panel relative hidden grid gap-4" role="tabpanel">
                <div class="flex justify-end">
                  <div class="max-w-[82%] rounded-2xl rounded-tr-sm bg-[#0F172A] px-4 py-3 text-white shadow-[0_16px_36px_-28px_rgba(15,23,42,0.7)]">
                    <p class="text-[12px] font-semibold text-[#67E8F9]">Operations</p>
                    <p class="mt-1 text-[15px] leading-relaxed">Which open requests need follow-up before Friday?</p>
                  </div>
                </div>

                <div class="flex justify-start">
                  <div class="max-w-[88%] rounded-2xl rounded-tl-sm border border-[#D8E1EA] bg-white px-4 py-3 shadow-[0_16px_36px_-32px_rgba(15,23,42,0.35)]">
                    <div class="flex items-center gap-2">
                      <Bot class="h-4 w-4 text-[#06B6D4]" stroke-width={1.8} />
                      <p class="text-[12px] font-semibold text-[#0F172A]">Workspace operator</p>
                    </div>
                    <p class="mt-2 text-[14px] leading-relaxed text-[#475569]">
                      Reviewing inboxes, project tasks, support tickets, and owner assignments.
                    </p>
                  </div>
                </div>

                <div class="flex justify-start">
                  <div class="max-w-[92%] rounded-2xl rounded-tl-sm border border-[#D8E1EA] bg-white px-4 py-4 shadow-[0_16px_36px_-32px_rgba(15,23,42,0.35)]">
                    <div class="flex items-center gap-2">
                      <Bot class="h-4 w-4 text-[#06B6D4]" stroke-width={1.8} />
                      <p class="text-[12px] font-semibold text-[#0F172A]">Follow-up queue</p>
                    </div>
                    <div class="mt-3 grid gap-3">
                      {[
                        ["Client renewal", "waiting on legal review from Minh."],
                        ["Onboarding task", "workspace setup is blocked by missing billing details."],
                        ["Support issue", "VIP account needs a status update today."],
                      ].map(([label, value]) => (
                        <div class="flex gap-3">
                          <Check class="mt-0.5 h-4 w-4 shrink-0 text-[#06B6D4]" stroke-width={2.4} />
                          <p class="text-[14px] leading-relaxed text-[#334155]">
                            <span class="font-semibold text-[#0F172A]">{label}:</span> {value}
                          </p>
                        </div>
                      ))}
                    </div>
                  </div>
                </div>

                <div class="flex justify-end">
                  <div class="max-w-[78%] rounded-2xl rounded-tr-sm bg-[#E6FBFF] px-4 py-3 text-[#0F172A]">
                    <p class="text-[14px] leading-relaxed">Create follow-up drafts and assign owners?</p>
                  </div>
                </div>
              </div>

              <div id="example-panel-employee" class="example-panel relative hidden grid gap-4" role="tabpanel">
                <div class="flex justify-start">
                  <div class="max-w-[90%] rounded-2xl rounded-tl-sm border border-[#D8E1EA] bg-white px-4 py-3 shadow-[0_16px_36px_-32px_rgba(15,23,42,0.35)]">
                    <div class="flex items-center gap-2">
                      <Bot class="h-4 w-4 text-[#06B6D4]" stroke-width={1.8} />
                      <p class="text-[12px] font-semibold text-[#0F172A]">Employee operator</p>
                    </div>
                    <p class="mt-2 text-[14px] leading-relaxed text-[#475569]">
                      Project Manager just updated Project Z. Please review the new rollout checklist before tomorrow's standup.
                    </p>
                  </div>
                </div>

                <div class="flex justify-end">
                  <div class="max-w-[82%] rounded-2xl rounded-tr-sm bg-[#0F172A] px-4 py-3 text-white shadow-[0_16px_36px_-28px_rgba(15,23,42,0.7)]">
                    <p class="text-[12px] font-semibold text-[#67E8F9]">Employee</p>
                    <p class="mt-1 text-[15px] leading-relaxed">
                      What changed in Project Z, and what should I do next?
                    </p>
                  </div>
                </div>

                <div class="ml-6 flex items-center gap-2 text-[12px] text-[#64748B]">
                  <span class="h-2 w-2 rounded-full bg-[#06B6D4]"></span>
                  <span>Reading project notes, training docs, and manager comments...</span>
                </div>

                <div class="flex justify-start">
                  <div class="max-w-[92%] rounded-2xl rounded-tl-sm border border-[#D8E1EA] bg-white px-4 py-4 shadow-[0_16px_36px_-32px_rgba(15,23,42,0.35)]">
                    <div class="flex items-center gap-2">
                      <Bot class="h-4 w-4 text-[#06B6D4]" stroke-width={1.8} />
                      <p class="text-[12px] font-semibold text-[#0F172A]">Training answer</p>
                    </div>
                    <div class="mt-3 grid gap-3">
                      {[
                        ["Update", "Project Z now requires the new QA checklist before client handoff."],
                        ["Your task", "review the checklist, confirm the test owner, and update the status by 4 PM."],
                        ["Guidance", "use the onboarding playbook section 3 if you need the step-by-step process."],
                      ].map(([label, value]) => (
                        <div class="flex gap-3">
