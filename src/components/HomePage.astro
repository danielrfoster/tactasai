  ArrowUpRight,
  Bot,
  Check,
  CheckCheck,
  Globe,
  Layers,
  Mail,
  MoreHorizontal,
  Network,
  Paperclip,
  Plus,
  Search,
  Send,
  ShieldCheck,
  Sparkles,
  Zap,
} from "@lucide/astro";
import Navbar from "./Navbar.astro";

interface Props {
  siteUrl: string;
  currentPath?: string;
}

const { siteUrl, currentPath = "/" } = Astro.props;
const currentYear = new Date().getFullYear();
const CONTAINER = "mx-auto w-full max-w-[1240px] px-5 sm:px-8 lg:px-10";

