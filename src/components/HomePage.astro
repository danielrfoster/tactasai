---

<div class="min-h-screen bg-[#F8FAFC] text-[#0F172A]">
  <Navbar currentPath={currentPath} ctaLabel="Operator review" ctaHref="/contact" theme="light" />

  <main>
    <section class="border-b border-[#D8E1EA] bg-white">
      <div class={`${CONTAINER} py-16 sm:py-20 lg:py-24`}>
        <div class="max-w-[980px]">
          <h1 class="max-w-[940px] text-[clamp(3rem,7.2vw,6.35rem)] font-semibold leading-[0.96] tracking-normal text-[#0F172A]">
            AI Operators for Business Operations
          </h1>
          <p class="mt-7 max-w-[48rem] text-[18px] leading-[1.62] text-[#475569] sm:text-[20px]">
            Tactas AI deploys managed AI agents that learn how your business works, turn company knowledge
            into action, and help employees and customers get work done faster.
          </p>

          <div class="mt-9 flex flex-col gap-3 sm:flex-row">
            <a href="/contact" class="inline-flex h-12 items-center justify-center rounded-[4px] bg-[#0F172A] px-6 text-[14px] font-semibold text-white transition hover:bg-[#06B6D4]">
              Book an operator review
            </a>
            <a href="#platform" class="inline-flex h-12 items-center justify-center rounded-[4px] border border-[#94A3B8] px-6 text-[14px] font-semibold text-[#0F172A] transition hover:border-[#06B6D4] hover:text-[#0891B2]">
              Explore the operating layer
            </a>
          </div>
        </div>
      </div>
    </section>

    <section id="solutions" class="border-b border-[#D8E1EA] bg-white">
      <div class={`${CONTAINER} py-16 lg:py-20`}>
        <div class="flex flex-col gap-6 border-b border-[#D8E1EA] pb-8 lg:flex-row lg:items-end lg:justify-between">
          <div class="max-w-3xl">
            <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-[#0891B2]">Operator use cases</p>
            <h2 class="mt-4 text-4xl font-semibold leading-tight tracking-normal text-[#0F172A] sm:text-5xl lg:text-[52px]">
              Deploy AI operators into the workflows your business runs every day.
            </h2>
          </div>
          <a href="/contact" class="inline-flex h-11 items-center justify-center rounded-[4px] border border-[#94A3B8] px-4 text-[14px] font-semibold text-[#0F172A] hover:border-[#06B6D4] hover:text-[#06B6D4]">
            Scope an operator
          </a>
        </div>

        <div class="grid border-x border-[#D8E1EA] md:grid-cols-2 xl:grid-cols-4">
          {solutionCards.map((card, index) => (
            <article class="border-b border-r border-[#D8E1EA] p-6 last:border-r-0 xl:border-b-0">
              <div class="flex h-10 w-10 items-center justify-center rounded-[4px] border border-[#BAE6FD] bg-[#E6FBFF] text-[#06B6D4]">
                {index === 0 ? <Bot class="h-5 w-5" stroke-width={1.8} /> : index === 1 ? <ShieldCheck class="h-5 w-5" stroke-width={1.8} /> : index === 2 ? <Layers class="h-5 w-5" stroke-width={1.8} /> : <Zap class="h-5 w-5" stroke-width={1.8} />}
              </div>
              <h3 class="mt-6 text-[20px] font-semibold tracking-normal text-[#0F172A]">{card.title}</h3>
              <p class="mt-3 text-[15px] leading-relaxed text-[#475569]">{card.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>


    <section class="border-b border-[#D8E1EA] bg-[#F8FAFC]">
      <div class={`${CONTAINER} py-16 lg:py-20`}>
        <div class="grid gap-10 lg:grid-cols-[0.68fr_1.32fr] lg:items-start">
          <div class="max-w-[500px] lg:sticky lg:top-24 lg:pt-2">
            <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-[#0891B2]">Example operators</p>
            <h2 class="mt-4 max-w-[620px] text-4xl font-semibold leading-[1.05] tracking-[-0.015em] text-[#0F172A] sm:text-5xl">
              See how work moves through chat.
            </h2>
            <p class="mt-5 text-[16px] leading-relaxed text-[#475569]">
              Your team talks to specialist operators like a colleague. Each thread pulls live context,
              explains its reasoning, and prepares actions for approval when policy requires it.
            </p>
            <dl class="mt-8 grid gap-x-8 gap-y-5 border-t border-[#E2E8F0] pt-7 sm:grid-cols-2">
              {[
                ["Grounded", "Live context from CRM, docs, tickets, and projects."],
                ["Governed", "Sensitive actions wait for human approval."],
                ["Observable", "Every step is logged, explained, and reviewable."],
                ["Composable", "Specialist operators routed to the right workflow."],
              ].map(([term, desc]) => (
                <div>
                  <dt class="flex items-center gap-2 text-[13px] font-semibold text-[#0F172A]">
                    <span class="h-1.5 w-1.5 rounded-full bg-[#06B6D4]"></span>
                    {term}
                  </dt>
                  <dd class="mt-1.5 pl-3.5 text-[13px] leading-relaxed text-[#64748B]">{desc}</dd>
                </div>
              ))}
            </dl>

            <div class="mt-8 flex flex-wrap items-center gap-2 text-[11px] text-[#64748B]">
              <span class="inline-flex items-center gap-1 rounded-full border border-[#A7F3D0] bg-[#ECFDF5] px-2.5 py-1 font-semibold text-[#047857]">
                <ShieldCheck class="h-3 w-3" stroke-width={2} />
                SOC 2 ready
              </span>
              <span class="inline-flex items-center gap-1 rounded-full border border-[#E2E8F0] bg-white px-2.5 py-1 font-semibold text-[#475569]">
                SSO &middot; SCIM &middot; SAML
              </span>
            </div>
          </div>

          <div class="overflow-hidden rounded-[14px] border border-[#CBD5E1]/80 bg-white shadow-[0_48px_120px_-64px_rgba(15,23,42,0.45)] ring-1 ring-[#0F172A]/[0.04]">
            <div class="flex h-11 items-center justify-between gap-3 border-b border-[#E2E8F0] bg-[#F8FAFC] px-4">
              <div class="flex min-w-0 items-center gap-3">
                <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-[6px] bg-[#06B6D4] text-white">
                  <Bot class="h-4 w-4" stroke-width={1.9} />
                </span>
                <div class="min-w-0">
                  <p class="truncate text-[13px] font-semibold text-[#0F172A]">Tactas Operator Console</p>
                  <p class="truncate font-mono text-[10px] uppercase tracking-[0.18em] text-[#64748B]">Acme Corp workspace</p>
                </div>
              </div>
              <div class="flex shrink-0 items-center gap-2">
                <span class="hidden items-center gap-1.5 rounded-full border border-[#A7F3D0] bg-[#ECFDF5] px-2.5 py-1 text-[10px] font-medium text-[#047857] sm:inline-flex">
                  <span class="h-1.5 w-1.5 rounded-full bg-[#10B981]"></span>
                  Policies active
                </span>
                <div class="hidden h-7 items-center gap-1.5 rounded-[5px] border border-[#E2E8F0] bg-white px-2 text-[11px] text-[#94A3B8] md:flex md:w-40">
                  <Search class="h-3.5 w-3.5" stroke-width={1.8} />
                  <span class="truncate">Search</span>
                  <span class="ml-auto font-mono text-[9px] text-[#64748B]">⌘K</span>
                </div>
              </div>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-[268px_1fr_220px]">
              <aside class="border-b border-[#E2E8F0] bg-[#F8FAFC] lg:border-b-0 lg:border-r" role="tablist" aria-label="Example operator conversations">
                <div class="flex items-center justify-between px-3.5 pt-3.5 pb-2">
                  <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-[#64748B]">Operators</p>
                  <button type="button" class="flex h-6 w-6 items-center justify-center rounded-[4px] text-[#94A3B8] transition hover:bg-white hover:text-[#0F172A]" aria-label="New conversation">
                    <Plus class="h-3.5 w-3.5" stroke-width={2} />
                  </button>
                </div>

                <div class="flex gap-2 overflow-x-auto px-2 pb-2 lg:grid lg:gap-1 lg:overflow-visible lg:px-2 lg:pb-2">
                  {exampleOperators.map((op, idx) => (
                    <button
                      type="button"
                      id={`example-tab-${op.id}`}
                      data-example-tab={op.id}
                      aria-selected={idx === 0 ? "true" : "false"}
                      aria-controls={`example-panel-${op.id}`}
                      role="tab"
                      class:list={[
                        "example-tab group flex w-[232px] shrink-0 items-start gap-3 rounded-[8px] border px-3 py-2.5 text-left transition lg:w-auto lg:shrink",
                        idx === 0
                          ? "border-[#BAE6FD] bg-white shadow-[inset_3px_0_0_0_#06B6D4,0_12px_26px_-22px_rgba(8,145,178,0.45)]"
                          : "border-transparent hover:border-[#E2E8F0] hover:bg-white",
                      ]}
                    >
                      <span class="relative mt-0.5 flex shrink-0">
                        <span class:list={["flex h-9 w-9 items-center justify-center rounded-[8px] font-mono text-[11px] font-semibold tracking-wide ring-1 ring-white/70", op.avatar]}>
                          {op.initials}
                        </span>
                        <span class:list={["absolute -bottom-0.5 -right-0.5 h-2.5 w-2.5 rounded-full ring-2 ring-[#F8FAFC]", op.statusColor]}></span>
                      </span>
                      <span class="min-w-0 flex-1">
                        <span class="flex items-center justify-between gap-2">
                          <span class="truncate text-[12.5px] font-semibold text-[#0F172A]">{op.name}</span>
                          <span class="shrink-0 font-mono text-[10px] text-[#94A3B8]">{op.time}</span>
                        </span>
                        <span class="mt-1 line-clamp-2 block text-[11.5px] leading-snug text-[#64748B]">{op.preview}</span>
                        <span class="mt-2 flex items-center justify-between gap-2">
                          <span class:list={["rounded-full border px-1.5 py-0.5 text-[9.5px] font-semibold leading-none", op.badgeClass]}>
                            {op.badge}
                          </span>
                          <span class="font-mono text-[9px] uppercase tracking-[0.14em] text-[#94A3B8]">{op.responds}</span>
                        </span>
                      </span>
                    </button>
                  ))}
                </div>

                <div class="hidden px-3 pb-3.5 pt-1 lg:block">
                  <div class="rounded-[8px] border border-[#E2E8F0] bg-white p-3">
                    <div class="flex items-center justify-between">
                      <p class="font-mono text-[9.5px] uppercase tracking-[0.2em] text-[#0E7490]">Approval queue</p>
                      <span class="rounded-full bg-[#FEF3C7] px-1.5 py-0.5 text-[9.5px] font-semibold text-[#B45309]">3</span>
                    </div>
                    <p class="mt-2 text-[12px] font-semibold leading-snug text-[#0F172A]">3 actions waiting on you</p>
                    <p class="mt-1 text-[11px] leading-relaxed text-[#64748B]">Refund, workspace invite, and outbound email pending human review.</p>
                    <a href="/contact" class="mt-2.5 inline-flex items-center gap-1 text-[11px] font-semibold text-[#06B6D4] hover:text-[#0891B2]">
                      Review queue
                      <ArrowUpRight class="h-3 w-3" stroke-width={2} />
                    </a>
                  </div>
                </div>
              </aside>

              <div class="flex min-h-[620px] flex-col border-b border-[#E2E8F0] lg:min-h-[680px] lg:border-b-0">
                <div class="relative flex-1">
                  {exampleOperators.map((op, idx) => (
                    <div
                      id={`example-panel-${op.id}`}
                      class:list={[
                        "example-panel absolute inset-0 flex flex-col",
                        idx === 0 ? "" : "hidden",
                      ]}
                      role="tabpanel"
                      aria-labelledby={`example-tab-${op.id}`}
                    >
                      <div class="flex items-center justify-between gap-3 border-b border-[#E2E8F0] bg-white px-4 py-3 sm:px-5">
                        <div class="flex min-w-0 items-center gap-3">
                          <span class="relative shrink-0">
                            <span class="flex h-9 w-9 items-center justify-center rounded-[8px] bg-[#E6FBFF] text-[#06B6D4] ring-1 ring-[#BAE6FD]">
                              <Bot class="h-4.5 w-4.5" stroke-width={1.8} />
                            </span>
                            <span class:list={["absolute -bottom-0.5 -right-0.5 h-2.5 w-2.5 rounded-full ring-2 ring-white", op.statusColor]}></span>
                          </span>
                          <div class="min-w-0">
                            <div class="flex flex-wrap items-center gap-2">
                              <p class="truncate text-[14px] font-semibold text-[#0F172A]">{op.name}</p>
                              <span class="inline-flex items-center gap-1 rounded-full border border-[#BAE6FD] bg-[#E6FBFF] px-1.5 py-0.5 text-[10px] font-semibold text-[#0E7490]">
                                AI operator
                              </span>
                              <span class="hidden items-center gap-1 rounded-full bg-[#ECFDF5] px-1.5 py-0.5 text-[10px] font-semibold text-[#047857] sm:inline-flex">
                                <span class="h-1 w-1 rounded-full bg-[#10B981]"></span>
                                {op.statusLabel}
                              </span>
                            </div>
                            <p class="mt-0.5 truncate text-[11.5px] text-[#64748B]">{op.role} &middot; {op.responds} avg response</p>
                          </div>
                        </div>
                        <div class="flex shrink-0 items-center gap-1.5">
                          <div class="hidden items-center gap-1 rounded-full border border-[#E2E8F0] bg-[#F8FAFC] px-2 py-1 text-[10px] font-medium text-[#475569] md:flex">
                            <Network class="h-3 w-3 text-[#06B6D4]" stroke-width={2} />
                            <span>{op.connectors} connected</span>
                          </div>
                          <button type="button" class="flex h-7 w-7 items-center justify-center rounded-[4px] text-[#94A3B8] transition hover:bg-[#F1F5F9] hover:text-[#0F172A]" aria-label="Conversation menu">
                            <MoreHorizontal class="h-4 w-4" stroke-width={1.8} />
                          </button>
                        </div>
                      </div>

                      <div class="example-conversation flex-1 space-y-4 overflow-y-auto bg-[linear-gradient(180deg,#FAFBFC_0%,#F1F5F9_100%)] px-4 py-5 sm:px-5">
                        <div class="flex items-center gap-3 text-[10px] font-medium uppercase tracking-[0.2em] text-[#94A3B8]">
                          <span class="h-px flex-1 bg-[#E2E8F0]"></span>
                          <span>Today &middot; {op.time}</span>
                          <span class="h-px flex-1 bg-[#E2E8F0]"></span>
                        </div>

                        {op.id === "analysis" && (
                          <>
                            <div class="flex justify-end">
                              <div class="flex max-w-[80%] flex-col items-end gap-1">
                                <div class="rounded-[12px] rounded-br-[3px] bg-[#06B6D4] px-3.5 py-2.5 text-[14px] leading-relaxed text-white shadow-[0_8px_20px_-16px_rgba(15,23,42,0.5)]">
                                  This month, what changed in the business?
                                </div>
                                <p class="flex items-center gap-1 pr-1 text-[10px] text-[#94A3B8]">
                                  <span>You &middot; 10:24 AM</span>
                                  <CheckCheck class="h-3 w-3 text-[#06B6D4]" stroke-width={2.2} />
                                </p>
                              </div>
                            </div>

                            <div class="flex gap-2.5">
                              <span class="mt-1 flex h-7 w-7 shrink-0 items-center justify-center rounded-[7px] bg-[#E6FBFF] text-[#06B6D4] ring-1 ring-[#BAE6FD]">
                                <Bot class="h-3.5 w-3.5" stroke-width={2} />
                              </span>
                              <div class="flex max-w-[88%] flex-1 flex-col gap-1.5">
                                <div class="flex items-baseline gap-2">
                                  <p class="text-[11.5px] font-semibold text-[#0F172A]">{op.name}</p>
                                  <p class="text-[10px] text-[#94A3B8]">10:24 AM</p>
