---
import {
  ArrowRight,
  ArrowUpRight,
  Bot,
  Check,
  Globe,
  Layers,
  Mail,
  Network,
  Send,
  ShieldCheck,
  Zap,
} from "@lucide/astro";
import Navbar from "./Navbar.astro";
import { getBrandEmail } from "../lib/site";

interface Props {
  siteUrl: string;
  currentPath?: string;
}

const { siteUrl, currentPath = "/" } = Astro.props;
const brandEmail = getBrandEmail();
const currentYear = new Date().getFullYear();
const CONTAINER = "mx-auto w-full max-w-[1240px] px-5 sm:px-8 lg:px-10";

const stats = [
  ["8+", "agent roles configured around real business workflows"],
  ["24/7", "operational monitoring and support coverage"],
  ["100%", "traceable actions, decisions, and system updates"],
  ["1", "control layer across data, tools, workflows, and agents"],
];

const platformColumns = [
  {
    title: "connect",
    heading: "Connect your business systems",
    body: "Link agents with the tools, data sources, documents, APIs, and internal systems your teams already use to run daily operations.",
    points: ["CRM, helpdesk, docs, and API context", "Workflow-specific data setup", "Integration-ready operating model"],
    icon: Network,
  },
  {
    title: "protect",
    heading: "Monitor and explain agent work",
    body: "Track what agents do, why they made decisions, which data was used, and where each workflow needs review or escalation.",
    points: ["Action and decision logs", "Behavior explanation", "Performance and exception monitoring"],
    icon: ShieldCheck,
  },
  {
    title: "build",
    heading: "Build around your operating process",
    body: "Design agents around your SOPs, resources, approval rules, data, and goals so automation fits the way the company actually works.",
    points: ["Agent training and workflow setup", "Resource and access management", "Hands-on implementation support"],
    icon: Zap,
  },
];

const productSections = [
  {
    eyebrow: "Operations platform",
    heading: "One platform to automate and control internal workflows.",
    body: "Tactas combines AI agents, workflow configuration, system integration, monitoring, and support into one company-specific automation system.",
    cta: "See the platform",
    href: "#platform",
    imageLabel: "Workflow control",
    imageTitle: "Designed for real business processes, not generic chat surfaces.",
    imageBody: "Every workflow can move through intake, data lookup, policy review, action execution, logging, and human approval without losing context.",
  },
  {
    eyebrow: "Operational visibility",
    heading: "See what every agent is doing and why.",
    body: "Activity tracking, decision explanation, performance monitoring, and escalation paths help teams manage automation with confidence.",
    cta: "Review control layer",
    href: "#control",
    imageLabel: "Control layer",
    imageTitle: "Operators keep visibility and control.",
    imageBody: "Use approval queues, action limits, risk scoring, decision notes, and exception alerts to keep automation aligned with the business.",
  },
  {
    eyebrow: "Implementation support",
    heading: "Set up agents around your data, tools, and goals.",
    body: "Start with one workflow, configure the required data and systems, train agents on real operations, then expand once the process is stable.",
    cta: "View solution patterns",
    href: "#solutions",
    imageLabel: "Deployment path",
    imageTitle: "Start narrow, then expand with support.",
    imageBody: "Tactas is strongest where teams have scattered tools, repeatable decisions, and a need for automation that can be monitored and improved.",
  },
];

const solutionCards = [
  {
    title: "Automate support workflows",
    body: "Triage tickets, gather customer context, apply policies, draft responses, update records, and escalate exceptions from one controlled workflow.",
  },
  {
    title: "Manage AI agents with control",
    body: "Track agent actions, explain decisions, monitor performance, manage resources, and keep important workflows inside clear operating boundaries.",
  },
  {
    title: "Deploy AI into back-office operations",
    body: "Move repetitive checks, routing, document handling, data preparation, and record updates from manual queues into monitored automation.",
  },
  {
    title: "Scale with implementation support",
    body: "Get help mapping workflows, configuring systems, training agents, monitoring operations, and improving automation after launch.",
  },
];

const resourceCards = [
  {
    type: "Guide",
    title: "How to choose the first workflow for AI automation",
    body: "A practical starting point for finding internal workflows with clear ROI, available data, and manageable operating risk.",
  },
  {
    type: "Use case",
    title: "What a controlled AI workflow looks like in production",
    body: "See how intake, data lookup, decision explanation, action logging, and human handoff can live in one managed loop.",
  },
  {
    type: "Brief",
    title: "Why generic chatbots stall in real operations",
    body: "The gap between answering questions and completing internal work is where most teams feel the friction.",
  },
  {
    type: "Workshop",
    title: "Map your data, tools, workflows, and agent boundaries with Tactas",
    body: "A structured session for deciding what agents should do, what systems they need, and where support or approval is required.",
  },
];

const getStartedCards = [
  {
    title: "Start with one workflow",
    body: "Pick the internal process where faster execution, better tracking, and reliable support matter most.",
    cta: "Book workflow review",
  },
  {
    title: "Need help choosing?",
    body: "We can help identify which workflow has the cleanest path to measurable impact and practical setup.",
    cta: "Find the right starting point",
  },
  {
    title: "Talk to an implementation expert",
    body: "Discuss your SOPs, data, tools, edge cases, agent training, and support needs with someone who builds for real operations.",
    cta: "Contact Tactas",
  },
];

const quotes = [
  {
    company: "Support teams",
    quote:
      "Tactas helps teams move from scattered tabs and tribal knowledge into one control layer where agent actions are visible, logged, and explainable.",
    role: "Workflow design perspective",
  },
  {
    company: "Finance operations",
    quote:
      "The value is not just speed. It is having a system that can apply policy, prepare actions, monitor resources, and surface the right exception at the right time.",
    role: "Controlled automation perspective",
  },
];

---

<div class="min-h-screen bg-[#F8FAFC] text-[#0F172A]">
  <Navbar currentPath={currentPath} ctaLabel="Book demo" ctaHref="#contact" theme="light" />

  <main>
    <section class="relative overflow-hidden border-b border-[#D8E1EA] bg-[#F8FAFC]">
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[640px] bg-[linear-gradient(180deg,#F8FAFC_0%,#EEF6FB_62%,rgba(238,246,251,0)_100%)]"></div>
      <div class="pointer-events-none absolute inset-0 opacity-[0.34] [background-image:linear-gradient(to_right,rgba(15,23,42,0.06)_1px,transparent_1px),linear-gradient(to_bottom,rgba(15,23,42,0.05)_1px,transparent_1px)] [background-size:64px_64px]"></div>

      <div class="pointer-events-none absolute bottom-[-2rem] right-[-1.5rem] z-0 hidden w-[min(760px,58vw)] rotate-[-1.5deg] opacity-[0.72] lg:block" aria-hidden="true">
        <div class="overflow-hidden rounded-[8px] border border-[#CBD5E1] bg-white/82 shadow-[0_36px_90px_-66px_rgba(15,23,42,0.38)] backdrop-blur-sm">
          <div class="flex h-11 items-center justify-between border-b border-[#D8E1EA] bg-[#F1F5F9] px-4">
            <div class="flex items-center gap-2">
              <span class="h-2.5 w-2.5 rounded-full bg-[#06B6D4]"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-[#94A3B8]"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-[#94A3B8]"></span>
            </div>
            <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-[#0E7490]">Agent flow orchestration</p>
          </div>

          <div class="grid min-h-[360px] grid-cols-[170px_1fr]">
            <aside class="border-r border-[#D8E1EA] bg-[#F1F5F9] p-4">
              <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-[#0E7490]">Runtime</p>
              <div class="mt-4 grid gap-2">
                {["Support triage", "Billing update", "Order exception"].map((item, index) => (
                  <div class:list={[
                    "rounded-[4px] border px-3 py-2 text-[12px] font-semibold",
                    index === 0 ? "border-[#67E8F9] bg-white text-[#0F172A]" : "border-[#D8E1EA] bg-white/70 text-[#64748B]",
                  ]}>
                    {item}
                  </div>
                ))}
              </div>
              <div class="mt-6 rounded-[4px] border border-[#D8E1EA] bg-white/75 p-3">
                <p class="text-[11px] font-semibold text-[#0F172A]">Human gate</p>
                <p class="mt-1 text-[10px] leading-relaxed text-[#64748B]">Approval required for refunds, account changes, and exceptions.</p>
              </div>
            </aside>

            <div class="relative p-5">
              <div class="absolute left-[96px] right-[84px] top-[112px] h-px bg-[#CBD5E1]"></div>
              <div class="absolute left-[242px] top-[112px] h-[104px] w-px bg-[#CBD5E1]"></div>
              <div class="absolute left-[242px] right-[92px] top-[216px] h-px bg-[#CBD5E1]"></div>

              <div class="relative grid grid-cols-3 gap-4">
                <div class="rounded-[6px] border border-[#D8E1EA] bg-white p-4 shadow-[0_18px_38px_-34px_rgba(15,23,42,0.24)]">
                  <div class="flex h-9 w-9 items-center justify-center rounded-[4px] bg-[#E6FBFF] text-[#06B6D4]">
                    <Network class="h-4.5 w-4.5" stroke-width={1.7} />
                  </div>
                  <p class="mt-4 text-[13px] font-semibold text-[#0F172A]">Intake</p>
                  <p class="mt-1 text-[11px] leading-relaxed text-[#64748B]">Read ticket, CRM, docs, and SOP context.</p>
                </div>

                <div class="rounded-[6px] border border-[#67E8F9] bg-[#F8FAFC] p-4 shadow-[0_18px_38px_-34px_rgba(15,23,42,0.24)]">
                  <div class="flex h-9 w-9 items-center justify-center rounded-[4px] bg-[#06B6D4] text-white">
                    <Bot class="h-4.5 w-4.5" stroke-width={1.7} />
                  </div>
                  <p class="mt-4 text-[13px] font-semibold text-[#0F172A]">Agent planner</p>
                  <p class="mt-1 text-[11px] leading-relaxed text-[#64748B]">Choose action path and assign specialist agents.</p>
                </div>

                <div class="rounded-[6px] border border-[#D8E1EA] bg-white p-4 shadow-[0_18px_38px_-34px_rgba(15,23,42,0.24)]">
                  <div class="flex h-9 w-9 items-center justify-center rounded-[4px] bg-[#E6FBFF] text-[#06B6D4]">
                    <ShieldCheck class="h-4.5 w-4.5" stroke-width={1.7} />
                  </div>
                  <p class="mt-4 text-[13px] font-semibold text-[#0F172A]">Policy check</p>
                  <p class="mt-1 text-[11px] leading-relaxed text-[#64748B]">Verify risk, approvals, limits, and audit notes.</p>
                </div>
              </div>

              <div class="relative mt-12 grid grid-cols-[1fr_1fr_0.85fr] gap-4">
                <div class="rounded-[6px] border border-[#D8E1EA] bg-white p-4 shadow-[0_18px_38px_-34px_rgba(15,23,42,0.24)]">
                  <p class="font-mono text-[9px] uppercase tracking-[0.18em] text-[#0E7490]">Agent A</p>
                  <p class="mt-2 text-[13px] font-semibold text-[#0F172A]">Draft response</p>
                  <div class="mt-3 h-2 rounded bg-[#D8E1EA]"></div>
                  <div class="mt-2 h-2 w-2/3 rounded bg-[#D8E1EA]"></div>
                </div>

                <div class="rounded-[6px] border border-[#D8E1EA] bg-white p-4 shadow-[0_18px_38px_-34px_rgba(15,23,42,0.24)]">
                  <p class="font-mono text-[9px] uppercase tracking-[0.18em] text-[#0E7490]">Agent B</p>
                  <p class="mt-2 text-[13px] font-semibold text-[#0F172A]">Prepare action</p>
                  <div class="mt-3 h-2 rounded bg-[#D8E1EA]"></div>
                  <div class="mt-2 h-2 w-1/2 rounded bg-[#D8E1EA]"></div>
                </div>

                <div class="rounded-[6px] border border-[#020617] bg-[#0F172A] p-4 text-white shadow-[0_18px_38px_-34px_rgba(15,23,42,0.36)]">
                  <div class="flex items-center gap-2">
                    <Zap class="h-4 w-4 text-[#67E8F9]" stroke-width={1.8} />
                    <p class="text-[13px] font-semibold">Execute</p>
                  </div>
                  <p class="mt-2 text-[11px] leading-relaxed text-[#CFFAFE]">Send, update, log, or escalate.</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class={`${CONTAINER} relative z-10 py-12 sm:py-16 lg:pb-12 lg:pt-20`}>
        <div class="min-h-[460px] max-w-[1120px] pb-24 lg:min-h-[560px] lg:pb-40">
          <h1 class="max-w-[1040px] text-[clamp(3.45rem,8.7vw,7.05rem)] font-semibold leading-[0.91] tracking-[-0.055em] text-[#0F172A]">
            AI workflow automation with full operational control.
          </h1>
          <p class="mt-7 max-w-[61rem] text-[18px] leading-[1.65] text-[#475569] sm:text-[20px]">
            Tactas helps businesses build, monitor, and manage AI agents that run internal workflows.
            From system integration and data setup to agent training, activity tracking, decision explanation,
            resource management, and 24/7 support, we help automation fit real operations.
          </p>

          <div class="mt-8 flex flex-col gap-3 sm:flex-row">
            <a href="#contact" class="inline-flex h-12 items-center justify-center rounded-[4px] bg-[#06B6D4] px-6 text-[14px] font-semibold text-white transition hover:bg-[#0891B2]">
              Book a demo
            </a>
            <a href="#platform" class="inline-flex h-12 items-center justify-center rounded-[4px] border border-[#94A3B8] bg-transparent px-6 text-[14px] font-semibold text-[#0F172A] transition hover:border-[#06B6D4] hover:text-[#0891B2]">
              Explore platform
            </a>
          </div>
        </div>

        <div class="mt-8 grid gap-5 lg:mt-10 lg:grid-cols-2">
          <a href="#contact" class="group grid overflow-hidden rounded-[3px] border border-[#D8E1EA] bg-white shadow-[0_22px_60px_-52px_rgba(15,23,42,0.22)] transition hover:border-[#06B6D4] lg:grid-cols-[0.72fr_1fr]">
            <div class="min-h-[170px] bg-[#0F172A] p-5 text-white">
              <div class="h-full rounded-[2px] border border-white/10 bg-[radial-gradient(circle_at_76%_24%,rgba(6,182,212,0.62),transparent_28%),linear-gradient(135deg,rgba(255,255,255,0.08),rgba(255,255,255,0))] p-4">
                <div class="flex h-full flex-col justify-between">
                  <div class="flex items-center gap-2 text-[11px] font-semibold uppercase tracking-[0.2em] text-[#67E8F9]">
                    <span class="h-2 w-2 rounded-full bg-[#06B6D4]"></span>
                    Live workshop
                  </div>
                  <div class="grid grid-cols-3 gap-2">
                    <span class="h-10 rounded bg-white/12"></span>
                    <span class="h-10 rounded bg-white/20"></span>
                    <span class="h-10 rounded bg-[#06B6D4]"></span>
                  </div>
                </div>
              </div>
            </div>
            <div class="p-6">
              <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-[#0E7490]">Join a workflow review</p>
              <h2 class="mt-3 text-[22px] font-semibold leading-tight tracking-[-0.03em] text-[#0F172A]">
                See how one internal process becomes a monitored AI workflow.
              </h2>
              <span class="mt-5 inline-flex items-center gap-2 text-[14px] font-semibold text-[#0F172A] group-hover:text-[#06B6D4]">
                Book a session
                <ArrowRight class="h-4 w-4" stroke-width={2} />
              </span>
            </div>
          </a>

          <a href="#resources" class="group grid overflow-hidden rounded-[3px] border border-[#D8E1EA] bg-white shadow-[0_22px_60px_-52px_rgba(15,23,42,0.22)] transition hover:border-[#06B6D4] lg:grid-cols-[0.72fr_1fr]">
            <div class="min-h-[170px] bg-[#EEF6FB] p-5">
              <div class="h-full rounded-[2px] border border-[#CBD5E1] bg-[#F8FAFC] p-4">
                <div class="grid h-full grid-cols-[1fr_0.8fr] gap-3">
                  <div class="space-y-2">
                    <span class="block h-3 w-16 rounded bg-[#06B6D4]"></span>
                    <span class="block h-3 w-full rounded bg-[#CBD5E1]"></span>
                    <span class="block h-3 w-4/5 rounded bg-[#CBD5E1]"></span>
                    <span class="block h-3 w-3/5 rounded bg-[#CBD5E1]"></span>
                  </div>
                  <div class="rounded bg-[linear-gradient(160deg,#06B6D4,#67E8F9_46%,#0F172A_47%,#0F172A)]"></div>
                </div>
              </div>
            </div>
            <div class="p-6">
              <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-[#0E7490]">New AI operations guide</p>
              <h2 class="mt-3 text-[22px] font-semibold leading-tight tracking-[-0.03em] text-[#0F172A]">
                Six principles for building AI agents that fit business operations.
              </h2>
              <span class="mt-5 inline-flex items-center gap-2 text-[14px] font-semibold text-[#0F172A] group-hover:text-[#06B6D4]">
                Get the guide
                <ArrowRight class="h-4 w-4" stroke-width={2} />
              </span>
            </div>
          </a>
        </div>
      </div>
    </section>

    <section class="border-b border-[#D8E1EA] bg-white">
      <div class={`${CONTAINER} py-7`}>
        <div class="grid border-y border-[#D8E1EA] sm:grid-cols-2 lg:grid-cols-4">
          {stats.map(([value, label], index) => (
            <div class:list={[
              "border-b border-[#D8E1EA] px-4 py-5 lg:border-b-0 lg:border-r",
              index >= 2 ? "sm:border-b-0" : "",
              index === stats.length - 1 ? "lg:border-r-0" : "",
            ]}>
              <div class="text-4xl font-semibold leading-none tracking-normal text-[#0F172A] lg:text-[42px]">{value}</div>
              <p class="mt-2 max-w-[24ch] text-[14px] leading-relaxed text-[#475569]">{label}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="platform" class="border-b border-[#D8E1EA] bg-[#F8FAFC]">
      <div class={`${CONTAINER} py-16 lg:py-20`}>
        <div class="grid gap-10 lg:grid-cols-[0.8fr_1.2fr] lg:items-end">
          <div>
            <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-[#0891B2]">Tactas platform</p>
            <h2 class="mt-4 text-4xl font-semibold leading-tight tracking-normal text-[#0F172A] sm:text-5xl lg:text-[56px]">
              The control layer for AI agents that touch real systems.
            </h2>
          </div>
          <p class="max-w-[48rem] text-[17px] leading-relaxed text-[#475569] lg:justify-self-end">
            Tactas combines workflow automation with hands-on implementation support, giving teams one place
            to configure agents, connect systems, track work, explain behavior, monitor performance, and improve operations.
          </p>
        </div>

        <div class="relative mt-10 border border-[#D8E1EA] bg-[#F8FAFC] shadow-[0_28px_90px_-64px_rgba(15,23,42,0.36)]">
          <div class="pointer-events-none absolute inset-0 z-10 hidden select-none md:block" aria-hidden="true">
            <div class="absolute left-[-7px] top-[-7px] h-3.5 w-3.5 rounded-[3px] border border-[#CBD5E1] bg-[#F8FAFC]"></div>
            <div class="absolute right-[-7px] top-[-7px] h-3.5 w-3.5 rounded-[3px] border border-[#CBD5E1] bg-[#F8FAFC]"></div>
            <div class="absolute bottom-[-7px] left-[-7px] h-3.5 w-3.5 rounded-[3px] border border-[#CBD5E1] bg-[#F8FAFC]"></div>
            <div class="absolute bottom-[-7px] right-[-7px] h-3.5 w-3.5 rounded-[3px] border border-[#CBD5E1] bg-[#F8FAFC]"></div>
          </div>

          <div class="relative min-h-[560px] overflow-x-auto overflow-y-hidden border-t bg-[#F1F5F9] font-mono md:border">
            <div class="relative h-[560px] min-w-[1160px]">
              <div class="absolute inset-0 [background-image:radial-gradient(circle,rgba(15,23,42,0.18)_1px,transparent_1px)] [background-size:20px_20px]"></div>

              <div class="absolute left-[230px] top-[280px] h-[104px] w-[118px] rounded-[2px] border border-[#06B6D4]/70 bg-[#06B6D4]/10">
                <div class="absolute left-[-4px] top-[-4px] h-2 w-2 rounded-[1.5px] border border-[#06B6D4]/70 bg-[#F8FAFC]"></div>
                <div class="absolute right-[-4px] top-[-4px] h-2 w-2 rounded-[1.5px] border border-[#06B6D4]/70 bg-[#F8FAFC]"></div>
                <div class="absolute bottom-[-4px] left-[-4px] h-2 w-2 rounded-[1.5px] border border-[#06B6D4]/70 bg-[#F8FAFC]"></div>
                <div class="absolute bottom-[-4px] right-[-4px] h-2 w-2 rounded-[1.5px] border border-[#06B6D4]/70 bg-[#F8FAFC]"></div>
              </div>
              <p class="absolute left-[289px] top-[254px] -translate-x-1/2 text-[12px] text-[#0E7490]">Business Data</p>

              <div class="absolute left-[430px] top-[228px] h-[214px] w-[134px] rounded-[2px] border border-[#7C3AED]/60 bg-[#7C3AED]/10">
                <div class="absolute left-[-4px] top-[-4px] h-2 w-2 rounded-[1.5px] border border-[#7C3AED]/60 bg-[#F8FAFC]"></div>
                <div class="absolute right-[-4px] top-[-4px] h-2 w-2 rounded-[1.5px] border border-[#7C3AED]/60 bg-[#F8FAFC]"></div>
                <div class="absolute bottom-[-4px] left-[-4px] h-2 w-2 rounded-[1.5px] border border-[#7C3AED]/60 bg-[#F8FAFC]"></div>
                <div class="absolute bottom-[-4px] right-[-4px] h-2 w-2 rounded-[1.5px] border border-[#7C3AED]/60 bg-[#F8FAFC]"></div>
              </div>
              <p class="absolute left-[497px] top-[202px] -translate-x-1/2 text-[12px] text-[#6D28D9]">Agent Runtime</p>

              <div class="absolute left-[628px] top-[228px] h-[214px] w-[150px] rounded-[2px] border border-[#14B8A6]/65 bg-[#14B8A6]/10">
                <div class="absolute left-[-4px] top-[-4px] h-2 w-2 rounded-[1.5px] border border-[#14B8A6]/65 bg-[#F8FAFC]"></div>
                <div class="absolute right-[-4px] top-[-4px] h-2 w-2 rounded-[1.5px] border border-[#14B8A6]/65 bg-[#F8FAFC]"></div>
                <div class="absolute bottom-[-4px] left-[-4px] h-2 w-2 rounded-[1.5px] border border-[#14B8A6]/65 bg-[#F8FAFC]"></div>
                <div class="absolute bottom-[-4px] right-[-4px] h-2 w-2 rounded-[1.5px] border border-[#14B8A6]/65 bg-[#F8FAFC]"></div>
              </div>
              <p class="absolute left-[703px] top-[202px] -translate-x-1/2 text-[12px] text-[#0F766E]">Control Layer</p>

              <div class="absolute left-[835px] top-[228px] h-[214px] w-[128px] rounded-[2px] border border-[#F59E0B]/65 bg-[#F59E0B]/10">
