        </div>
      </div>
    </section>

    <WiringDiagramTool />

    <section id="solutions" class="relative overflow-hidden border-b border-[#D8E1EA] bg-[#F6F8FB]">
      <div class="pointer-events-none absolute inset-x-0 top-0 h-px bg-[linear-gradient(90deg,transparent,#06B6D4_24%,#D7A22A_72%,transparent)]"></div>
      <div class={`${CONTAINER} py-16 lg:py-20`}>
        <div class="grid gap-8 lg:grid-cols-[minmax(0,0.98fr)_minmax(360px,0.74fr)] lg:items-end lg:justify-between">
