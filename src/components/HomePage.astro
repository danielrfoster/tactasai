const integrationFeatureNodes = [
  { title: "Knowledge", x: 430, y: 148, width: 170, feature: "activity" },
  { title: "Tasks", x: 950, y: 124, width: 136, feature: "tasks" },
  { title: "Outputs", x: 360, y: 398, width: 154, feature: "projects" },
  { title: "Teams", x: 990, y: 398, width: 142, feature: "people" },
  { title: "Data", x: 660, y: 536, width: 118, feature: "data" },
];

const featureOrbit = {
  activity: { rx: 210, ry: 118, start: -2.65 },
  tasks: { rx: 205, ry: 118, start: -1.35 },
  projects: { rx: 215, ry: 126, start: -2.95 },
  people: { rx: 205, ry: 126, start: -0.55 },
  data: { rx: 260, ry: 118, start: 0.05 },
};

const rawIntegrationNodes = integrationGroups.flatMap((group, groupIndex) =>
  group.logos.map(([label, slug, source, logoStyle], itemIndex) => ({
    label,
    slug,
    source,
    logoStyle,
    accent: group.accent,
    feature:
      groupIndex === 0
        ? itemIndex < 8
          ? "activity"
          : "projects"
        : groupIndex === 1
          ? "people"
          : groupIndex === 2
            ? "tasks"
            : "data",
  })),
);

const featureCounts = rawIntegrationNodes.reduce((counts, node) => {
  counts[node.feature] = (counts[node.feature] || 0) + 1;
  return counts;
}, {});
const featureSeen = {};

const integrationNodes = rawIntegrationNodes.map((node) => {
  const feature = integrationFeatureNodes.find((item) => item.feature === node.feature) || integrationFeatureNodes[0];
  const orbit = featureOrbit[node.feature];
  const localIndex = featureSeen[node.feature] || 0;
  featureSeen[node.feature] = localIndex + 1;
  const count = featureCounts[node.feature];
  const angle = orbit.start + (localIndex * Math.PI * 2) / count;
  const radiusScale = localIndex % 3 === 0 ? 0.78 : localIndex % 3 === 1 ? 1 : 1.16;

  return {
    ...node,
    anchorX: feature.x,
    anchorY: feature.y,
    x: Math.max(46, Math.min(1194, feature.x + Math.cos(angle) * orbit.rx * radiusScale)),
    y: Math.max(46, Math.min(594, feature.y + Math.sin(angle) * orbit.ry * radiusScale)),
  };
});

