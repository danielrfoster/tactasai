---

<div class="min-h-screen bg-[#F8FAFC] text-[#0F172A]">
  <Navbar currentPath={currentPath} ctaLabel="Workflow review" ctaHref="#contact" theme="light" />

  <main>
    <section class="relative overflow-hidden border-b border-[#D8E1EA] bg-[#F8FAFC]">
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[640px] bg-[linear-gradient(180deg,#F8FAFC_0%,#EEF6FB_62%,rgba(238,246,251,0)_100%)]"></div>
      <div class="pointer-events-none absolute inset-0 opacity-[0.34] [background-image:linear-gradient(to_right,rgba(15,23,42,0.06)_1px,transparent_1px),linear-gradient(to_bottom,rgba(15,23,42,0.05)_1px,transparent_1px)] [background-size:64px_64px]"></div>

      <div class="pointer-events-none absolute bottom-[-2rem] right-[-1.5rem] z-0 hidden w-[min(760px,58vw)] rotate-[-1.5deg] opacity-[0.72] lg:block" aria-hidden="true">
        <div class="overflow-hidden rounded-[8px] border border-[#CBD5E1] bg-white/82 shadow-[0_36px_90px_-66px_rgba(15,23,42,0.38)] backdrop-blur-sm">
          <div class="flex h-11 items-center justify-between border-b border-[#D8E1EA] bg-[#F1F5F9] px-4">
            <div class="flex items-center gap-2">
              <span class="h-2.5 w-2.5 rounded-full bg-[#06B6D4]"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-[#94A3B8]"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-[#94A3B8]"></span>
            </div>
            <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-[#0E7490]">Agent flow orchestration</p>
          </div>

          <div class="grid min-h-[360px] grid-cols-[170px_1fr]">
            <aside class="border-r border-[#D8E1EA] bg-[#F1F5F9] p-4">
              <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-[#0E7490]">Runtime</p>
              <div class="mt-4 grid gap-2">
                {["Support triage", "Billing update", "Order exception"].map((item, index) => (
                  <div class:list={[
                    "rounded-[4px] border px-3 py-2 text-[12px] font-semibold",
                    index === 0 ? "border-[#67E8F9] bg-white text-[#0F172A]" : "border-[#D8E1EA] bg-white/70 text-[#64748B]",
                  ]}>
                    {item}
                  </div>
                ))}
              </div>
              <div class="mt-6 rounded-[4px] border border-[#D8E1EA] bg-white/75 p-3">
                <p class="text-[11px] font-semibold text-[#0F172A]">Human gate</p>
                <p class="mt-1 text-[10px] leading-relaxed text-[#64748B]">Approval required for refunds, account changes, and exceptions.</p>
              </div>
            </aside>

            <div class="relative p-5">
              <div class="absolute left-[96px] right-[84px] top-[112px] h-px bg-[#CBD5E1]"></div>
              <div class="absolute left-[242px] top-[112px] h-[104px] w-px bg-[#CBD5E1]"></div>
              <div class="absolute left-[242px] right-[92px] top-[216px] h-px bg-[#CBD5E1]"></div>

              <div class="relative grid grid-cols-3 gap-4">
                <div class="rounded-[6px] border border-[#D8E1EA] bg-white p-4 shadow-[0_18px_38px_-34px_rgba(15,23,42,0.24)]">
                  <div class="flex h-9 w-9 items-center justify-center rounded-[4px] bg-[#E6FBFF] text-[#06B6D4]">
                    <Network class="h-4.5 w-4.5" stroke-width={1.7} />
                  </div>
                  <p class="mt-4 text-[13px] font-semibold text-[#0F172A]">Intake</p>
                  <p class="mt-1 text-[11px] leading-relaxed text-[#64748B]">Read ticket, CRM, docs, and SOP context.</p>
                </div>

                <div class="rounded-[6px] border border-[#67E8F9] bg-[#F8FAFC] p-4 shadow-[0_18px_38px_-34px_rgba(15,23,42,0.24)]">
                  <div class="flex h-9 w-9 items-center justify-center rounded-[4px] bg-[#06B6D4] text-white">
                    <Bot class="h-4.5 w-4.5" stroke-width={1.7} />
                  </div>
                  <p class="mt-4 text-[13px] font-semibold text-[#0F172A]">Agent planner</p>
                  <p class="mt-1 text-[11px] leading-relaxed text-[#64748B]">Choose action path and assign specialist agents.</p>
                </div>

                <div class="rounded-[6px] border border-[#D8E1EA] bg-white p-4 shadow-[0_18px_38px_-34px_rgba(15,23,42,0.24)]">
                  <div class="flex h-9 w-9 items-center justify-center rounded-[4px] bg-[#E6FBFF] text-[#06B6D4]">
                    <ShieldCheck class="h-4.5 w-4.5" stroke-width={1.7} />
                  </div>
                  <p class="mt-4 text-[13px] font-semibold text-[#0F172A]">Policy check</p>
                  <p class="mt-1 text-[11px] leading-relaxed text-[#64748B]">Verify risk, approvals, limits, and audit notes.</p>
                </div>
              </div>

              <div class="relative mt-12 grid grid-cols-[1fr_1fr_0.85fr] gap-4">
                <div class="rounded-[6px] border border-[#D8E1EA] bg-white p-4 shadow-[0_18px_38px_-34px_rgba(15,23,42,0.24)]">
                  <p class="font-mono text-[9px] uppercase tracking-[0.18em] text-[#0E7490]">Agent A</p>
                  <p class="mt-2 text-[13px] font-semibold text-[#0F172A]">Draft response</p>
                  <div class="mt-3 h-2 rounded bg-[#D8E1EA]"></div>
                  <div class="mt-2 h-2 w-2/3 rounded bg-[#D8E1EA]"></div>
                </div>

                <div class="rounded-[6px] border border-[#D8E1EA] bg-white p-4 shadow-[0_18px_38px_-34px_rgba(15,23,42,0.24)]">
                  <p class="font-mono text-[9px] uppercase tracking-[0.18em] text-[#0E7490]">Agent B</p>
                  <p class="mt-2 text-[13px] font-semibold text-[#0F172A]">Prepare action</p>
                  <div class="mt-3 h-2 rounded bg-[#D8E1EA]"></div>
                  <div class="mt-2 h-2 w-1/2 rounded bg-[#D8E1EA]"></div>
                </div>

                <div class="rounded-[6px] border border-[#020617] bg-[#0F172A] p-4 text-white shadow-[0_18px_38px_-34px_rgba(15,23,42,0.36)]">
                  <div class="flex items-center gap-2">
                    <Zap class="h-4 w-4 text-[#67E8F9]" stroke-width={1.8} />
                    <p class="text-[13px] font-semibold">Execute</p>
                  </div>
                  <p class="mt-2 text-[11px] leading-relaxed text-[#CFFAFE]">Send, update, log, or escalate.</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class={`${CONTAINER} relative z-10 py-12 sm:py-16 lg:pb-12 lg:pt-20`}>
        <div class="min-h-[460px] max-w-[1120px] pb-24 lg:min-h-[560px] lg:pb-40">
          <h1 class="max-w-[1040px] text-[clamp(3.45rem,8.7vw,7.05rem)] font-semibold leading-[0.91] tracking-[-0.055em] text-[#0F172A]">
            AI agents that run business workflows with human control.
          </h1>
          <p class="mt-7 max-w-[61rem] text-[18px] leading-[1.65] text-[#475569] sm:text-[20px]">
            Tactas AI helps operations teams automate support, admin, finance, and back-office workflows
            across existing tools, SOPs, and approval rules. Start with one high-value process, keep every
            action logged, and add human review wherever business judgment matters.
          </p>

          <div class="mt-8 flex flex-col gap-3 sm:flex-row">
            <a href="#contact" class="inline-flex h-12 items-center justify-center rounded-[4px] bg-[#06B6D4] px-6 text-[14px] font-semibold text-white transition hover:bg-[#0891B2]">
              Book a workflow review
            </a>
            <a href="#platform" class="inline-flex h-12 items-center justify-center rounded-[4px] border border-[#94A3B8] bg-transparent px-6 text-[14px] font-semibold text-[#0F172A] transition hover:border-[#06B6D4] hover:text-[#0891B2]">
              Explore platform
            </a>
          </div>
          <p class="mt-4 max-w-[45rem] text-[14px] leading-relaxed text-[#64748B]">
            In a 30-minute review, we identify the first workflow to automate, map the systems and data
            required, and show where approvals or handoffs should stay human.
          </p>
        </div>

        <div class="mt-8 grid gap-5 lg:mt-10 lg:grid-cols-2">
          <a href="#contact" class="group grid overflow-hidden rounded-[3px] border border-[#D8E1EA] bg-white shadow-[0_22px_60px_-52px_rgba(15,23,42,0.22)] transition hover:border-[#06B6D4] lg:grid-cols-[0.72fr_1fr]">
            <div class="min-h-[170px] bg-[#0F172A] p-5 text-white">
              <div class="h-full rounded-[2px] border border-white/10 bg-[radial-gradient(circle_at_76%_24%,rgba(6,182,212,0.62),transparent_28%),linear-gradient(135deg,rgba(255,255,255,0.08),rgba(255,255,255,0))] p-4">
                <div class="flex h-full flex-col justify-between">
                  <div class="flex items-center gap-2 text-[11px] font-semibold uppercase tracking-[0.2em] text-[#67E8F9]">
                    <span class="h-2 w-2 rounded-full bg-[#06B6D4]"></span>
                    Live workshop
                  </div>
                  <div class="grid grid-cols-3 gap-2">
                    <span class="h-10 rounded bg-white/12"></span>
                    <span class="h-10 rounded bg-white/20"></span>
                    <span class="h-10 rounded bg-[#06B6D4]"></span>
                  </div>
                </div>
              </div>
            </div>
            <div class="p-6">
              <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-[#0E7490]">Workflow automation review</p>
              <h2 class="mt-3 text-[22px] font-semibold leading-tight tracking-[-0.03em] text-[#0F172A]">
                Identify the workflow with the clearest path to controlled automation.
              </h2>
              <span class="mt-5 inline-flex items-center gap-2 text-[14px] font-semibold text-[#0F172A] group-hover:text-[#06B6D4]">
                Book a session
                <ArrowRight class="h-4 w-4" stroke-width={2} />
              </span>
            </div>
          </a>

          <a href="#resources" class="group grid overflow-hidden rounded-[3px] border border-[#D8E1EA] bg-white shadow-[0_22px_60px_-52px_rgba(15,23,42,0.22)] transition hover:border-[#06B6D4] lg:grid-cols-[0.72fr_1fr]">
            <div class="min-h-[170px] bg-[#EEF6FB] p-5">
              <div class="h-full rounded-[2px] border border-[#CBD5E1] bg-[#F8FAFC] p-4">
                <div class="grid h-full grid-cols-[1fr_0.8fr] gap-3">
                  <div class="space-y-2">
                    <span class="block h-3 w-16 rounded bg-[#06B6D4]"></span>
                    <span class="block h-3 w-full rounded bg-[#CBD5E1]"></span>
                    <span class="block h-3 w-4/5 rounded bg-[#CBD5E1]"></span>
                    <span class="block h-3 w-3/5 rounded bg-[#CBD5E1]"></span>
                  </div>
                  <div class="rounded bg-[linear-gradient(160deg,#06B6D4,#67E8F9_46%,#0F172A_47%,#0F172A)]"></div>
                </div>
              </div>
            </div>
            <div class="p-6">
              <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-[#0E7490]">AI operations playbook</p>
              <h2 class="mt-3 text-[22px] font-semibold leading-tight tracking-[-0.03em] text-[#0F172A]">
                A practical model for production-grade AI workflow execution.
              </h2>
              <span class="mt-5 inline-flex items-center gap-2 text-[14px] font-semibold text-[#0F172A] group-hover:text-[#06B6D4]">
                Get the guide
                <ArrowRight class="h-4 w-4" stroke-width={2} />
              </span>
            </div>
          </a>
        </div>
      </div>
    </section>

    <section class="border-b border-[#D8E1EA] bg-white">
      <div class={`${CONTAINER} py-7`}>
        <div class="grid border-y border-[#D8E1EA] sm:grid-cols-2 lg:grid-cols-3">
          {stats.map(([value, label], index) => (
            <div class:list={[
              "border-b border-[#D8E1EA] px-4 py-5 lg:border-b-0 lg:border-r",
              index >= 2 ? "sm:border-b-0" : "",
              index === stats.length - 1 ? "lg:border-r-0" : "",
            ]}>
              <div class="text-4xl font-semibold leading-none tracking-normal text-[#0F172A] lg:text-[42px]">{value}</div>
              <p class="mt-2 max-w-[24ch] text-[14px] leading-relaxed text-[#475569]">{label}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="why-choose" class="border-b border-[#D8E1EA] bg-[#F8FAFC]">
      <div class={`${CONTAINER} py-16 lg:py-20`}>
        <div class="grid gap-10 lg:grid-cols-[0.84fr_1.16fr] lg:items-center">
          <div>
            <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-[#0891B2]">Why choose Tactas AI</p>
            <h2 class="mt-4 max-w-[760px] text-4xl font-semibold leading-tight tracking-normal text-[#0F172A] sm:text-5xl lg:text-[58px]">
              AI workflow automation built for teams that need control.
            </h2>
            <p class="mt-5 max-w-[42rem] text-[17px] leading-relaxed text-[#475569]">
              Tactas AI turns repeatable support, finance, admin, and operations work into agent-run workflows with connected context, approval gates, action logs, and live monitoring.
            </p>
            <div class="mt-7 flex flex-col gap-3 sm:flex-row">
              <a href="#contact" class="inline-flex h-11 items-center justify-center rounded-[4px] bg-[#06B6D4] px-5 text-[14px] font-semibold text-white transition hover:bg-[#0891B2]">
                Review your workflow
              </a>
              <a href="#platform" class="inline-flex h-11 items-center justify-center rounded-[4px] border border-[#94A3B8] px-5 text-[14px] font-semibold text-[#0F172A] transition hover:border-[#06B6D4] hover:text-[#0891B2]">
                See control layer
              </a>
            </div>
          </div>

          <div class="overflow-hidden rounded-[8px] border border-[#CBD5E1] bg-white shadow-[0_28px_80px_-66px_rgba(15,23,42,0.34)]">
            <div class="flex items-center justify-between border-b border-[#D8E1EA] bg-[#F1F5F9] px-4 py-3">
              <div class="flex items-center gap-2">
                <span class="h-2.5 w-2.5 rounded-full bg-[#06B6D4]"></span>
                <span class="h-2.5 w-2.5 rounded-full bg-[#CBD5E1]"></span>
                <span class="h-2.5 w-2.5 rounded-full bg-[#CBD5E1]"></span>
              </div>
              <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-[#0E7490]">Workflow live</p>
            </div>

