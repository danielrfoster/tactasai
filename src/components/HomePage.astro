<script is:inline>
  (() => {
    const initHeroGlobe = () => {
      const globeElement = document.getElementById("hero-globe-background");
      if (!globeElement || !window.VANTA?.GLOBE) {
        return;
      }

      window.__tactasHeroGlobe?.destroy?.();
      window.__tactasHeroGlobe = window.VANTA.GLOBE({
        el: "#hero-globe-background",
        mouseControls: true,
        touchControls: true,
        gyroControls: false,
        minHeight: 200.0,
        minWidth: 200.0,
        scale: 1.0,
        scaleMobile: 1.0,
        color: 0x06b6d4,
        color2: 0x0f172a,
        backgroundColor: 0xf8fafc,
        size: 0.95,
      });
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initHeroGlobe, { once: true });
    } else {
      initHeroGlobe();
    }

    document.addEventListener("astro:page-load", initHeroGlobe);
  })();
</script>

