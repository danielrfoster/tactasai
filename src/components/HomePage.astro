---
import {
  ArrowRight,
  ArrowUpRight,
  Bot,
  Check,
  Globe,
  Layers,
  Mail,
  Network,
  Send,
  ShieldCheck,
  Zap,
} from "@lucide/astro";
import Navbar from "./Navbar.astro";
import { getBrandEmail } from "../lib/site";

interface Props {
  siteUrl: string;
  currentPath?: string;
}

const { siteUrl, currentPath = "/" } = Astro.props;
const brandEmail = getBrandEmail();
const currentYear = new Date().getFullYear();
const CONTAINER = "mx-auto w-full max-w-[1240px] px-5 sm:px-8 lg:px-10";

const stats = [
  ["8+", "specialized agent roles ready to coordinate real work"],
  ["24/7", "workflow coverage without relying on manual routing"],
  ["100%", "traceable actions, decisions, and human handoffs"],
  ["1", "operational layer across CRM, helpdesk, billing, and internal tools"],
];

const platformColumns = [
  {
    title: "connect",
    heading: "Connect your workflow context",
    body: "Pull together inboxes, tickets, CRM records, spreadsheets, APIs, and internal tools so each workflow starts with the right facts.",
    points: ["Cross-tool context retrieval", "Shared workflow memory", "Operator-ready intake packets"],
    icon: Network,
  },
  {
    title: "protect",
    heading: "Protect every high-impact action",
    body: "Tactas keeps approvals, policy checks, escalation rules, and least-privilege access inside the same operating layer as the automation.",
    points: ["Approval-aware execution", "Escalation by risk threshold", "Continuous audit trails"],
    icon: ShieldCheck,
  },
  {
    title: "build",
    heading: "Build agents that finish work",
    body: "Move beyond prompt demos. Design specialist agents that plan, decide, act, verify, and hand off only when judgment is actually needed.",
    points: ["Specialized multi-agent runtime", "Production-ready action flows", "Iterate on real operational scenarios"],
    icon: Zap,
  },
];

const productSections = [
  {
    eyebrow: "Operations cloud",
    heading: "One platform for the workflows that keep your business moving.",
    body: "Tactas packages workflow mapping, supervised execution, action controls, and operational observability into one company-specific system.",
    cta: "See the platform",
    href: "#platform",
    imageLabel: "Execution fabric",
    imageTitle: "Designed for real operators, not generic chat surfaces.",
    imageBody: "Every request can move through intent intake, data gathering, policy evaluation, action execution, QA, and human review without losing context.",
  },
  {
    eyebrow: "Secure execution",
    heading: "Protect every repetitive task without slowing your team down.",
    body: "Approval-aware automation lets you automate the work people repeat every day while keeping the exception paths visible and controllable.",
    cta: "Review control model",
    href: "#control",
    imageLabel: "Control plane",
    imageTitle: "Operators keep the right decisions.",
    imageBody: "Use approval queues, action limits, risk scoring, and escalation notes to keep humans focused on edge cases instead of routine processing.",
  },
  {
    eyebrow: "Agent builder",
    heading: "Build supervised AI systems around your own SOPs and tools.",
    body: "Start with one workflow, prove impact, and expand from support, back-office, and finance operations into a broader execution layer.",
    cta: "View solution patterns",
    href: "#solutions",
    imageLabel: "Deployment path",
    imageTitle: "Start narrow, expand cleanly.",
    imageBody: "Tactas is strongest where teams have clear operational pain, scattered context, and repetitive decisions that deserve a safer automation model.",
  },
];

const solutionCards = [
  {
    title: "Modernize support operations",
    body: "Triage tickets, gather account context, enforce policy, and draft or execute the right next step without bouncing between systems.",
  },
  {
    title: "Secure generative and agentic AI",
    body: "Roll out AI execution in a way that respects your approval boundaries, audit requirements, and exception workflows from day one.",
  },
  {
    title: "Deploy AI into back-office workflows",
    body: "Move repetitive checks, routing, and record updates from manual queues into a supervised agent runtime with clear traceability.",
  },
  {
    title: "Scale operations without headcount sprawl",
    body: "Use one execution layer to absorb repetitive work while operators focus on judgment, escalation, and customer-critical edge cases.",
  },
];

const resourceCards = [
  {
    type: "Guide",
    title: "How to choose the first workflow for supervised automation",
    body: "A practical starting point for finding operational flows with clear ROI and manageable risk.",
  },
  {
    type: "Use case",
    title: "What an approval-aware support workflow looks like in production",
    body: "See how intake, policy checks, actions, and human handoff can live in one controlled loop.",
  },
  {
    type: "Brief",
    title: "Why generic chatbots stall in operations-heavy environments",
    body: "The gap between answering questions and actually completing work is where most teams feel the friction.",
  },
  {
    type: "Workshop",
    title: "Map your ops stack, approvals, and agent boundaries with Tactas",
    body: "A structured session for deciding where automation should act, pause, or escalate.",
  },
];

const getStartedCards = [
  {
    title: "Start with one workflow",
    body: "Pick the repetitive process where faster execution and better control matter most.",
    cta: "Book workflow review",
  },
  {
    title: "Need help choosing?",
    body: "We can help identify which workflow has the cleanest path to measurable impact.",
    cta: "Find the right starting point",
  },
  {
    title: "Talk to an operator-minded expert",
    body: "Discuss your SOPs, tools, edge cases, and approval logic with someone who builds for real ops.",
    cta: "Contact Tactas",
  },
];

const quotes = [
  {
    company: "Support teams",
    quote:
      "Tactas helps teams move from scattered tabs and tribal knowledge into one operational layer where the next action is clear, logged, and governable.",
    role: "Workflow design perspective",
  },
  {
    company: "Finance operations",
    quote:
      "The value is not just speed. It is having a system that can apply policy, prepare actions, and surface the right exception at the right time.",
    role: "Controlled automation perspective",
  },
];
---

<div class="min-h-screen bg-[#f7f3ef] text-[#1f1a17]">
  <Navbar currentPath={currentPath} ctaLabel="Under attack?" ctaHref="#contact" theme="light" />

  <main>
    <section class="relative overflow-hidden border-b border-[#ead9c6] bg-[#f8f4ee]">
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[640px] bg-[linear-gradient(180deg,#fff8ef_0%,#f6efe7_62%,rgba(246,239,231,0)_100%)]"></div>
      <div class="pointer-events-none absolute inset-0 opacity-[0.34] [background-image:linear-gradient(to_right,rgba(49,36,24,0.07)_1px,transparent_1px),linear-gradient(to_bottom,rgba(49,36,24,0.06)_1px,transparent_1px)] [background-size:64px_64px]"></div>

      <div class="pointer-events-none absolute bottom-[-2rem] right-[-1.5rem] z-0 hidden w-[min(760px,58vw)] rotate-[-1.5deg] opacity-[0.72] lg:block" aria-hidden="true">
        <div class="overflow-hidden rounded-[8px] border border-[#ddc8b2] bg-white/82 shadow-[0_36px_90px_-66px_rgba(50,25,0,0.72)] backdrop-blur-sm">
          <div class="flex h-11 items-center justify-between border-b border-[#ead9c6] bg-[#fff8f1] px-4">
            <div class="flex items-center gap-2">
              <span class="h-2.5 w-2.5 rounded-full bg-[#f48120]"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-[#dfc7ae]"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-[#dfc7ae]"></span>
            </div>
            <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-[#aa6d30]">Agent flow orchestration</p>
          </div>

          <div class="grid min-h-[360px] grid-cols-[170px_1fr]">
            <aside class="border-r border-[#ead9c6] bg-[#fbf4ed] p-4">
              <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-[#b07032]">Runtime</p>
              <div class="mt-4 grid gap-2">
                {["Support triage", "Billing update", "Order exception"].map((item, index) => (
                  <div class:list={[
                    "rounded-[4px] border px-3 py-2 text-[12px] font-semibold",
                    index === 0 ? "border-[#f4b071] bg-white text-[#211a15]" : "border-[#ead9c6] bg-white/70 text-[#6b5c4f]",
                  ]}>
                    {item}
                  </div>
                ))}
              </div>
              <div class="mt-6 rounded-[4px] border border-[#ead9c6] bg-white/75 p-3">
                <p class="text-[11px] font-semibold text-[#211a15]">Human gate</p>
                <p class="mt-1 text-[10px] leading-relaxed text-[#786a5e]">Approval required for refunds, account changes, and exceptions.</p>
              </div>
            </aside>

            <div class="relative p-5">
              <div class="absolute left-[96px] right-[84px] top-[112px] h-px bg-[#e4c9ac]"></div>
              <div class="absolute left-[242px] top-[112px] h-[104px] w-px bg-[#e4c9ac]"></div>
              <div class="absolute left-[242px] right-[92px] top-[216px] h-px bg-[#e4c9ac]"></div>

              <div class="relative grid grid-cols-3 gap-4">
                <div class="rounded-[6px] border border-[#ead3bd] bg-white p-4 shadow-[0_18px_38px_-34px_rgba(55,24,0,0.48)]">
                  <div class="flex h-9 w-9 items-center justify-center rounded-[4px] bg-[#fff0e2] text-[#f48120]">
                    <Network class="h-4.5 w-4.5" stroke-width={1.7} />
                  </div>
                  <p class="mt-4 text-[13px] font-semibold text-[#211a15]">Intake</p>
                  <p class="mt-1 text-[11px] leading-relaxed text-[#77685c]">Read ticket, CRM, docs, and SOP context.</p>
                </div>

                <div class="rounded-[6px] border border-[#f0b274] bg-[#fff9f3] p-4 shadow-[0_18px_38px_-34px_rgba(55,24,0,0.48)]">
                  <div class="flex h-9 w-9 items-center justify-center rounded-[4px] bg-[#f48120] text-white">
                    <Bot class="h-4.5 w-4.5" stroke-width={1.7} />
                  </div>
                  <p class="mt-4 text-[13px] font-semibold text-[#211a15]">Agent planner</p>
                  <p class="mt-1 text-[11px] leading-relaxed text-[#77685c]">Choose action path and assign specialist agents.</p>
                </div>

                <div class="rounded-[6px] border border-[#ead3bd] bg-white p-4 shadow-[0_18px_38px_-34px_rgba(55,24,0,0.48)]">
                  <div class="flex h-9 w-9 items-center justify-center rounded-[4px] bg-[#fff0e2] text-[#f48120]">
                    <ShieldCheck class="h-4.5 w-4.5" stroke-width={1.7} />
                  </div>
                  <p class="mt-4 text-[13px] font-semibold text-[#211a15]">Policy check</p>
                  <p class="mt-1 text-[11px] leading-relaxed text-[#77685c]">Verify risk, approvals, limits, and audit notes.</p>
                </div>
              </div>

              <div class="relative mt-12 grid grid-cols-[1fr_1fr_0.85fr] gap-4">
                <div class="rounded-[6px] border border-[#ead3bd] bg-white p-4 shadow-[0_18px_38px_-34px_rgba(55,24,0,0.48)]">
                  <p class="font-mono text-[9px] uppercase tracking-[0.18em] text-[#b07032]">Agent A</p>
                  <p class="mt-2 text-[13px] font-semibold text-[#211a15]">Draft response</p>
                  <div class="mt-3 h-2 rounded bg-[#f2dfce]"></div>
                  <div class="mt-2 h-2 w-2/3 rounded bg-[#f2dfce]"></div>
                </div>

                <div class="rounded-[6px] border border-[#ead3bd] bg-white p-4 shadow-[0_18px_38px_-34px_rgba(55,24,0,0.48)]">
                  <p class="font-mono text-[9px] uppercase tracking-[0.18em] text-[#b07032]">Agent B</p>
                  <p class="mt-2 text-[13px] font-semibold text-[#211a15]">Prepare action</p>
                  <div class="mt-3 h-2 rounded bg-[#f2dfce]"></div>
                  <div class="mt-2 h-2 w-1/2 rounded bg-[#f2dfce]"></div>
                </div>

                <div class="rounded-[6px] border border-[#251b14] bg-[#211a15] p-4 text-white shadow-[0_18px_38px_-34px_rgba(55,24,0,0.68)]">
                  <div class="flex items-center gap-2">
                    <Zap class="h-4 w-4 text-[#f7a75f]" stroke-width={1.8} />
                    <p class="text-[13px] font-semibold">Execute</p>
                  </div>
                  <p class="mt-2 text-[11px] leading-relaxed text-[#f4dfcc]">Send, update, log, or escalate.</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class={`${CONTAINER} relative z-10 py-12 sm:py-16 lg:pb-12 lg:pt-20`}>
        <div class="min-h-[460px] max-w-[1120px] pb-24 lg:min-h-[560px] lg:pb-40">
          <h1 class="max-w-[1040px] text-[clamp(3.45rem,8.7vw,7.05rem)] font-semibold leading-[0.91] tracking-[-0.055em] text-[#1c1714]">
            Connect, protect, and build AI operations.
          </h1>
          <p class="mt-7 max-w-[61rem] text-[18px] leading-[1.65] text-[#5f554b] sm:text-[20px]">
            Tactas makes workflows, internal tools, approvals, and supervised AI agents faster and more secure.
            Build a controlled execution layer for the repetitive work your team handles every day.
          </p>

          <div class="mt-8 flex flex-col gap-3 sm:flex-row">
            <a href="#contact" class="inline-flex h-12 items-center justify-center rounded-[4px] bg-[#f48120] px-6 text-[14px] font-semibold text-white transition hover:bg-[#dc6f14]">
              Start for free
            </a>
            <a href="#platform" class="inline-flex h-12 items-center justify-center rounded-[4px] border border-[#b8a998] bg-transparent px-6 text-[14px] font-semibold text-[#211a15] transition hover:border-[#f48120] hover:text-[#cf6914]">
              See platform
            </a>
          </div>
        </div>

        <div class="mt-8 grid gap-5 lg:mt-10 lg:grid-cols-2">
          <a href="#contact" class="group grid overflow-hidden rounded-[3px] border border-[#e7d6c3] bg-white shadow-[0_22px_60px_-52px_rgba(45,20,0,0.45)] transition hover:border-[#f48120] lg:grid-cols-[0.72fr_1fr]">
            <div class="min-h-[170px] bg-[#211a15] p-5 text-white">
              <div class="h-full rounded-[2px] border border-white/10 bg-[radial-gradient(circle_at_76%_24%,rgba(244,129,32,0.72),transparent_28%),linear-gradient(135deg,rgba(255,255,255,0.08),rgba(255,255,255,0))] p-4">
                <div class="flex h-full flex-col justify-between">
                  <div class="flex items-center gap-2 text-[11px] font-semibold uppercase tracking-[0.2em] text-[#f8b36f]">
                    <span class="h-2 w-2 rounded-full bg-[#f48120]"></span>
                    Live workshop
                  </div>
                  <div class="grid grid-cols-3 gap-2">
                    <span class="h-10 rounded bg-white/12"></span>
                    <span class="h-10 rounded bg-white/20"></span>
                    <span class="h-10 rounded bg-[#f48120]"></span>
                  </div>
                </div>
              </div>
            </div>
            <div class="p-6">
              <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-[#b97532]">Join a workflow review</p>
              <h2 class="mt-3 text-[22px] font-semibold leading-tight tracking-[-0.03em] text-[#1f1a17]">
                See how one repetitive operation becomes a supervised AI workflow.
              </h2>
              <span class="mt-5 inline-flex items-center gap-2 text-[14px] font-semibold text-[#1f1a17] group-hover:text-[#f48120]">
                Book a session
                <ArrowRight class="h-4 w-4" stroke-width={2} />
              </span>
            </div>
          </a>

          <a href="#resources" class="group grid overflow-hidden rounded-[3px] border border-[#e7d6c3] bg-white shadow-[0_22px_60px_-52px_rgba(45,20,0,0.45)] transition hover:border-[#f48120] lg:grid-cols-[0.72fr_1fr]">
            <div class="min-h-[170px] bg-[#f4eee6] p-5">
              <div class="h-full rounded-[2px] border border-[#e3cbb4] bg-[#fff9f3] p-4">
                <div class="grid h-full grid-cols-[1fr_0.8fr] gap-3">
                  <div class="space-y-2">
                    <span class="block h-3 w-16 rounded bg-[#f48120]"></span>
                    <span class="block h-3 w-full rounded bg-[#d9c5b2]"></span>
                    <span class="block h-3 w-4/5 rounded bg-[#d9c5b2]"></span>
                    <span class="block h-3 w-3/5 rounded bg-[#d9c5b2]"></span>
                  </div>
                  <div class="rounded bg-[linear-gradient(160deg,#f48120,#ffbd73_46%,#211a15_47%,#211a15)]"></div>
                </div>
              </div>
            </div>
            <div class="p-6">
              <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-[#b97532]">New AI operations guide</p>
              <h2 class="mt-3 text-[22px] font-semibold leading-tight tracking-[-0.03em] text-[#1f1a17]">
                Six principles for safer agentic automation in production teams.
              </h2>
              <span class="mt-5 inline-flex items-center gap-2 text-[14px] font-semibold text-[#1f1a17] group-hover:text-[#f48120]">
                Get the guide
                <ArrowRight class="h-4 w-4" stroke-width={2} />
              </span>
            </div>
          </a>
        </div>
      </div>
    </section>

    <section class="border-b border-[#ead9c6] bg-white">
      <div class={`${CONTAINER} py-6 lg:py-8`}>
        <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
          {stats.map(([value, label]) => (
            <div class="border-l border-[#eedfce] pl-4 first:border-l-0 first:pl-0">
              <div class="text-[clamp(2rem,4vw,2.8rem)] font-semibold leading-none tracking-[-0.05em] text-[#1f1a17]">{value}</div>
              <p class="mt-2 max-w-[22ch] text-[14px] leading-relaxed text-[#6a5d51]">{label}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="platform" class="border-b border-[#ead9c6] bg-[#f7f3ef]">
      <div class={`${CONTAINER} py-16 lg:py-20`}>
        <div class="max-w-4xl">
          <p class="font-mono text-[11px] uppercase tracking-[0.26em] text-[#f48120]">Our operational cloud is the best place to</p>
          <h2 class="mt-4 text-[clamp(2.3rem,4.8vw,4rem)] font-semibold leading-[0.98] tracking-[-0.045em] text-[#1f1a17]">
            connect workflow context, protect high-risk actions, and build agents that finish work.
          </h2>
        </div>

        <div class="mt-10 grid gap-6 lg:grid-cols-3">
          {platformColumns.map((item) => {
            const Icon = item.icon;
            return (
              <article class="rounded-2xl border border-[#e9d9c8] bg-white p-6 shadow-[0_24px_60px_-48px_rgba(49,24,0,0.28)]">
                <span class="flex h-12 w-12 items-center justify-center rounded-xl bg-[#fff2e6] text-[#f48120]">
                  <Icon class="h-5 w-5" stroke-width={1.8} />
                </span>
                <p class="mt-5 font-mono text-[10px] uppercase tracking-[0.24em] text-[#b77a3f]">{item.title}</p>
                <h3 class="mt-2 text-[22px] font-semibold tracking-[-0.03em] text-[#1f1a17]">{item.heading}</h3>
                <p class="mt-3 text-[15px] leading-relaxed text-[#61554a]">{item.body}</p>
                <ul class="mt-5 grid gap-2.5 text-[14px] text-[#3c3129]">
                  {item.points.map((point) => (
                    <li class="flex items-start gap-2.5">
                      <Check class="mt-1 h-3.5 w-3.5 shrink-0 text-[#f48120]" stroke-width={2.4} />
                      <span>{point}</span>
                    </li>
                  ))}
                </ul>
              </article>
            );
          })}
        </div>
      </div>
    </section>

    <section class="border-b border-[#ead9c6] bg-white">
      <div class={`${CONTAINER} py-16 lg:py-20`}>
        <div class="grid gap-14">
          {productSections.map((section, index) => (
            <div class="grid gap-8 border-t border-[#efe2d5] pt-10 first:border-t-0 first:pt-0 lg:grid-cols-[0.85fr_1.15fr] lg:items-center lg:gap-14">
              <div>
                <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-[#f48120]">{section.eyebrow}</p>
                <h2 class="mt-4 max-w-[16ch] text-[clamp(2rem,4vw,3.3rem)] font-semibold leading-[1] tracking-[-0.045em] text-[#1f1a17]">
                  {section.heading}
                </h2>
                <p class="mt-5 max-w-[34rem] text-[17px] leading-relaxed text-[#62564b]">{section.body}</p>
                <a href={section.href} class="mt-7 inline-flex items-center gap-2 text-[14px] font-semibold text-[#1f1a17] hover:text-[#f48120]">
                  {section.cta}
                  <ArrowRight class="h-4 w-4" stroke-width={2} />
                </a>
              </div>

              <div class:list={[
                "overflow-hidden rounded-[28px] border border-[#ead9c6] p-6 shadow-[0_24px_64px_-46px_rgba(44,22,3,0.24)]",
                index % 2 === 0 ? "bg-[#fff8f2]" : "bg-[#f6efe8]",
              ]}>
                <div class="flex items-center justify-between gap-4 border-b border-[#eddccc] pb-4">
                  <div>
                    <p class="font-mono text-[10px] uppercase tracking-[0.24em] text-[#b77a3f]">{section.imageLabel}</p>
                    <h3 class="mt-2 text-[20px] font-semibold tracking-[-0.03em] text-[#1f1a17]">{section.imageTitle}</h3>
                  </div>
                  <ArrowUpRight class="h-4.5 w-4.5 shrink-0 text-[#f48120]" stroke-width={1.9} />
                </div>
                <p class="mt-4 max-w-[40rem] text-[15px] leading-relaxed text-[#61554a]">{section.imageBody}</p>
                <div class="mt-6 overflow-hidden rounded-2xl border border-[#ecdccd] bg-white">
                  <img
                    src="/ef4e97cc-14e2-4157-a55f-42bfa62ad8a3.png"
                    alt="Tactas workflow diagram"
                    width="1536"
                    height="1024"
                    class="h-auto w-full"
                    loading={index === 0 ? "eager" : "lazy"}
                    decoding="async"
                  />
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="control" class="border-b border-[#ead9c6] bg-[#fcf7f2]">
      <div class={`${CONTAINER} py-16 lg:py-20`}>
        <div class="grid gap-10 lg:grid-cols-[0.85fr_1.15fr] lg:items-start lg:gap-14">
          <div>
            <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-[#f48120]">One global workflow layer unlike generic AI demos</p>
            <h2 class="mt-4 text-[clamp(2.2rem,4.4vw,3.8rem)] font-semibold leading-[0.98] tracking-[-0.045em] text-[#1f1a17]">
              Only Tactas is built to keep automation fast, supervised, and operationally legible.
            </h2>
            <p class="mt-5 max-w-[34rem] text-[17px] leading-relaxed text-[#62564b]">
              The point is not to generate text faster. The point is to reduce manual work while making the next action,
              the responsible agent, and the escalation path visible.
            </p>
          </div>

          <div class="grid gap-5">
            {quotes.map((quote) => (
              <article class="rounded-2xl border border-[#e7d9c7] bg-white p-6 shadow-[0_24px_60px_-48px_rgba(49,24,0,0.22)]">
                <div class="flex items-center justify-between gap-4">
                  <p class="text-[15px] font-semibold text-[#1f1a17]">{quote.company}</p>
