---
import {
  ArrowUpRight,
  Bot,
  Check,
  Globe,
  Layers,
  Mail,
  Network,
  Send,
  ShieldCheck,
  Zap,
} from "@lucide/astro";
import Navbar from "./Navbar.astro";
import { getBrandEmail } from "../lib/site";

interface Props {
  siteUrl: string;
  currentPath?: string;
}

const { siteUrl, currentPath = "/" } = Astro.props;
const brandEmail = getBrandEmail();
const currentYear = new Date().getFullYear();
const CONTAINER = "mx-auto w-full max-w-[1240px] px-5 sm:px-8 lg:px-10";

const stats = [
  {
    value: "30 min",
    label: "workflow review to identify the first practical automation",
    eyebrow: "Discovery",
  },
  {
    value: "1",
    label: "high-value workflow mapped before expanding across teams",
    eyebrow: "Pilot scope",
  },
  {
    value: "100%",
    label: "agent actions logged with context and decision notes",
    eyebrow: "Traceability",
  },
  {
    value: "24/7",
    label: "workflow monitoring and operational support coverage",
    eyebrow: "Operations",
  },
];

const whyComparison = [
  {
    pain: "Workflow execution depends on disconnected tools, manual handoffs, and undocumented judgment.",
    outcome: "Tactas AI creates a managed execution layer where agents retrieve context, follow SOPs, and advance the workflow with clear ownership.",
  },
  {
    pain: "Approval rules, edge cases, and operational exceptions are difficult to standardize across teams.",
    outcome: "Each workflow includes approval gates, exception routing, monitoring, and human handoff as part of the operating model.",
  },
  {
    pain: "Leaders need evidence of what happened before AI can own meaningful operational work.",
    outcome: "Every action keeps its context, decision rationale, system update history, and audit trail attached.",
  },
];

const platformColumns = [
  {
    title: "connect",
    heading: "Connect the systems work depends on",
    body: "Give agents governed access to the CRM, helpdesk, documents, databases, APIs, and internal tools they need to complete real work.",
    points: ["CRM, helpdesk, docs, and API context", "Workflow-specific data preparation", "Secure tool and resource access"],
    icon: Network,
  },
  {
    title: "govern",
    heading: "Control what agents can decide and do",
    body: "Keep AI inside your operating rules with approvals, risk checks, escalation paths, action limits, and complete decision visibility.",
    points: ["Approval gates and risk checks", "Action and decision logs", "Human handoff for exceptions"],
    icon: ShieldCheck,
  },
  {
    title: "operate",
    heading: "Improve workflows after launch",
    body: "Monitor performance, review edge cases, adjust agent behavior, and keep workflows aligned as your process, data, and team change.",
    points: ["Agent training and workflow setup", "Performance and exception monitoring", "Hands-on implementation support"],
    icon: Zap,
  },
];

const solutionCards = [
  {
    title: "AI customer support automation",
    body: "Triage tickets, retrieve customer context, apply policies, draft replies, update CRM records, and escalate sensitive cases with a complete activity trail.",
  },
  {
    title: "AI back-office automation",
    body: "Handle document checks, invoice preparation, record updates, routing, reconciliation tasks, and repetitive reviews with monitored AI agents.",
  },
  {
    title: "Finance and admin workflows",
    body: "Review invoices, route approvals, reconcile records, prepare summaries, and keep every decision tied to the source data and policy used.",
  },
  {
    title: "AI agent control center",
    body: "Track agent actions, explain decisions, manage resources, monitor exceptions, and keep high-impact work inside clear operating boundaries.",
  },
];

const workflowReviewPoints = [
  "Identify one business process AI agents can automate safely",
  "Map the tools, data, SOPs, approvals, and human handoffs required",
  "Define the first launch plan with controls, logs, and measurable outcomes",
];

const faqItems = [
  {
    q: "What is AI workflow automation?",
    a: "AI workflow automation uses agents to handle repeatable business processes across tools, data, SOPs, approvals, and human handoffs. Common examples include support triage, CRM updates, invoice review, document checks, and routing work to the right owner.",
  },
  {
    q: "Can Tactas AI work with our existing tools?",
    a: "Yes. Tactas AI designs around the systems your team already uses, including CRMs, helpdesks, documents, databases, spreadsheets, APIs, and internal tools.",
  },
  {
    q: "Do humans approve agent actions?",
    a: "They can. Workflows can include approval gates, risk checks, action limits, escalation paths, and human review for sensitive or high-impact decisions.",
  },
  {
    q: "Which workflow should we automate first?",
    a: "The best first workflow has clear business value, repeatable steps, available data, manageable risk, and a measurable outcome such as faster response time, fewer manual reviews, or better approval visibility.",
  },
  {
    q: "How long does the first workflow take to launch?",
    a: "Most teams should start with a narrow pilot rather than a broad transformation. The timeline depends on data access, system integrations, approval rules, and the amount of testing required before live use.",
  },
];

---

<div class="min-h-screen bg-[#F8FAFC] text-[#0F172A]">
  <Navbar currentPath={currentPath} ctaLabel="Workflow review" ctaHref="#contact" theme="light" />

  <main>
    <section class="relative overflow-hidden border-b border-[#D8E1EA] bg-[#F8FAFC]">
      <div id="hero-globe-background" class="absolute inset-0 z-0 h-full min-h-[720px] opacity-90" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-0 z-[1] bg-[linear-gradient(90deg,rgba(248,250,252,0.96)_0%,rgba(248,250,252,0.86)_42%,rgba(248,250,252,0.58)_72%,rgba(248,250,252,0.32)_100%)]"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 z-[1] h-[640px] bg-[linear-gradient(180deg,rgba(248,250,252,0.76)_0%,rgba(238,246,251,0.42)_62%,rgba(238,246,251,0)_100%)]"></div>
      <div class="pointer-events-none absolute inset-0 z-[2] opacity-[0.28] [background-image:linear-gradient(to_right,rgba(15,23,42,0.06)_1px,transparent_1px),linear-gradient(to_bottom,rgba(15,23,42,0.05)_1px,transparent_1px)] [background-size:64px_64px]"></div>

      <div class="pointer-events-none absolute bottom-[-2rem] right-[-1.5rem] z-0 hidden w-[min(760px,58vw)] rotate-[-1.5deg] opacity-[0.72] lg:block" aria-hidden="true">
        <div class="overflow-hidden rounded-[8px] border border-[#CBD5E1] bg-white/82 shadow-[0_36px_90px_-66px_rgba(15,23,42,0.38)] backdrop-blur-sm">
          <div class="flex h-11 items-center justify-between border-b border-[#D8E1EA] bg-[#F1F5F9] px-4">
            <div class="flex items-center gap-2">
              <span class="h-2.5 w-2.5 rounded-full bg-[#06B6D4]"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-[#94A3B8]"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-[#94A3B8]"></span>
            </div>
            <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-[#0E7490]">Agent flow orchestration</p>
          </div>

          <div class="grid min-h-[360px] grid-cols-[170px_1fr]">
            <aside class="border-r border-[#D8E1EA] bg-[#F1F5F9] p-4">
              <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-[#0E7490]">Runtime</p>
              <div class="mt-4 grid gap-2">
                {["Support triage", "Billing update", "Order exception"].map((item, index) => (
                  <div class:list={[
                    "rounded-[4px] border px-3 py-2 text-[12px] font-semibold",
                    index === 0 ? "border-[#67E8F9] bg-white text-[#0F172A]" : "border-[#D8E1EA] bg-white/70 text-[#64748B]",
                  ]}>
                    {item}
                  </div>
                ))}
              </div>
              <div class="mt-6 rounded-[4px] border border-[#D8E1EA] bg-white/75 p-3">
                <p class="text-[11px] font-semibold text-[#0F172A]">Human gate</p>
                <p class="mt-1 text-[10px] leading-relaxed text-[#64748B]">Approval required for refunds, account changes, and exceptions.</p>
              </div>
            </aside>

            <div class="relative p-5">
              <div class="absolute left-[96px] right-[84px] top-[112px] h-px bg-[#CBD5E1]"></div>
              <div class="absolute left-[242px] top-[112px] h-[104px] w-px bg-[#CBD5E1]"></div>
              <div class="absolute left-[242px] right-[92px] top-[216px] h-px bg-[#CBD5E1]"></div>

              <div class="relative grid grid-cols-3 gap-4">
                <div class="rounded-[6px] border border-[#D8E1EA] bg-white p-4 shadow-[0_18px_38px_-34px_rgba(15,23,42,0.24)]">
                  <div class="flex h-9 w-9 items-center justify-center rounded-[4px] bg-[#E6FBFF] text-[#06B6D4]">
                    <Network class="h-4.5 w-4.5" stroke-width={1.7} />
                  </div>
                  <p class="mt-4 text-[13px] font-semibold text-[#0F172A]">Intake</p>
                  <p class="mt-1 text-[11px] leading-relaxed text-[#64748B]">Read ticket, CRM, docs, and SOP context.</p>
                </div>

                <div class="rounded-[6px] border border-[#67E8F9] bg-[#F8FAFC] p-4 shadow-[0_18px_38px_-34px_rgba(15,23,42,0.24)]">
                  <div class="flex h-9 w-9 items-center justify-center rounded-[4px] bg-[#06B6D4] text-white">
                    <Bot class="h-4.5 w-4.5" stroke-width={1.7} />
                  </div>
                  <p class="mt-4 text-[13px] font-semibold text-[#0F172A]">Agent planner</p>
                  <p class="mt-1 text-[11px] leading-relaxed text-[#64748B]">Choose action path and assign specialist agents.</p>
                </div>

                <div class="rounded-[6px] border border-[#D8E1EA] bg-white p-4 shadow-[0_18px_38px_-34px_rgba(15,23,42,0.24)]">
                  <div class="flex h-9 w-9 items-center justify-center rounded-[4px] bg-[#E6FBFF] text-[#06B6D4]">
                    <ShieldCheck class="h-4.5 w-4.5" stroke-width={1.7} />
                  </div>
                  <p class="mt-4 text-[13px] font-semibold text-[#0F172A]">Policy check</p>
                  <p class="mt-1 text-[11px] leading-relaxed text-[#64748B]">Verify risk, approvals, limits, and audit notes.</p>
                </div>
              </div>

              <div class="relative mt-12 grid grid-cols-[1fr_1fr_0.85fr] gap-4">
                <div class="rounded-[6px] border border-[#D8E1EA] bg-white p-4 shadow-[0_18px_38px_-34px_rgba(15,23,42,0.24)]">
                  <p class="font-mono text-[9px] uppercase tracking-[0.18em] text-[#0E7490]">Agent A</p>
                  <p class="mt-2 text-[13px] font-semibold text-[#0F172A]">Draft response</p>
                  <div class="mt-3 h-2 rounded bg-[#D8E1EA]"></div>
                  <div class="mt-2 h-2 w-2/3 rounded bg-[#D8E1EA]"></div>
                </div>

                <div class="rounded-[6px] border border-[#D8E1EA] bg-white p-4 shadow-[0_18px_38px_-34px_rgba(15,23,42,0.24)]">
                  <p class="font-mono text-[9px] uppercase tracking-[0.18em] text-[#0E7490]">Agent B</p>
                  <p class="mt-2 text-[13px] font-semibold text-[#0F172A]">Prepare action</p>
                  <div class="mt-3 h-2 rounded bg-[#D8E1EA]"></div>
                  <div class="mt-2 h-2 w-1/2 rounded bg-[#D8E1EA]"></div>
                </div>

                <div class="rounded-[6px] border border-[#020617] bg-[#0F172A] p-4 text-white shadow-[0_18px_38px_-34px_rgba(15,23,42,0.36)]">
                  <div class="flex items-center gap-2">
                    <Zap class="h-4 w-4 text-[#67E8F9]" stroke-width={1.8} />
                    <p class="text-[13px] font-semibold">Execute</p>
                  </div>
                  <p class="mt-2 text-[11px] leading-relaxed text-[#CFFAFE]">Send, update, log, or escalate.</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class={`${CONTAINER} relative z-10 py-12 sm:py-16 lg:pb-12 lg:pt-20`}>
        <div class="min-h-[460px] max-w-[1120px] pb-24 lg:min-h-[560px] lg:pb-40">
          <h1 class="max-w-[1040px] text-[clamp(3.45rem,8.7vw,7.05rem)] font-semibold leading-[0.91] tracking-[-0.055em] text-[#0F172A]">
            AI agents that run business workflows with human control.
          </h1>
          <p class="mt-7 max-w-[61rem] text-[18px] leading-[1.65] text-[#475569] sm:text-[20px]">
            Tactas AI helps operations teams automate support, admin, finance, and back-office workflows
            across existing tools, SOPs, and approval rules. Start with one high-value process, keep every
            action logged, and add human review wherever business judgment matters.
          </p>

          <div class="mt-8 flex flex-col gap-3 sm:flex-row">
            <a href="#contact" class="inline-flex h-12 items-center justify-center rounded-[4px] bg-[#06B6D4] px-6 text-[14px] font-semibold text-white transition hover:bg-[#0891B2]">
              Book a workflow review
            </a>
            <a href="#platform" class="inline-flex h-12 items-center justify-center rounded-[4px] border border-[#94A3B8] bg-transparent px-6 text-[14px] font-semibold text-[#0F172A] transition hover:border-[#06B6D4] hover:text-[#0891B2]">
              Explore platform
            </a>
          </div>
          <p class="mt-4 max-w-[45rem] text-[14px] leading-relaxed text-[#64748B]">
            In a 30-minute review, we identify the first workflow to automate, map the systems and data
            required, and show where approvals or handoffs should stay human.
          </p>
        </div>

      </div>
    </section>

    <section class="border-b border-[#D8E1EA] bg-white">
      <div class={`${CONTAINER} py-8`}>
        <div class="grid gap-6 border-y border-[#D8E1EA] py-6 lg:grid-cols-[260px_1fr] lg:items-stretch">
          <div class="flex flex-col justify-between border-b border-[#D8E1EA] pb-5 lg:border-b-0 lg:border-r lg:pb-0 lg:pr-8">
            <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-[#0891B2]">Operating baseline</p>
            <p class="mt-3 max-w-[28rem] text-[15px] leading-relaxed text-[#475569] lg:mt-auto">
              Start small, keep the control layer visible, and scale only after the workflow is measurable.
            </p>
          </div>

          <div class="grid gap-px overflow-hidden bg-[#D8E1EA] sm:grid-cols-2 xl:grid-cols-4">
            {stats.map((stat) => (
              <div class="bg-white px-5 py-5">
                <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-[#0E7490]">{stat.eyebrow}</p>
                <div class="mt-3 text-[clamp(2.15rem,4.3vw,3rem)] font-semibold leading-none tracking-normal text-[#0F172A]">
                  {stat.value}
                </div>
                <p class="mt-3 max-w-[25ch] text-[14px] leading-relaxed text-[#475569]">{stat.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section id="why-choose" class="border-b border-[#D8E1EA] bg-[#F8FAFC]">
      <div class={`${CONTAINER} py-16 lg:py-20`}>
        <div class="grid gap-10 lg:grid-cols-[0.84fr_1.16fr] lg:items-center">
          <div>
            <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-[#0891B2]">Why choose Tactas AI</p>
            <h2 class="mt-4 max-w-[760px] text-4xl font-semibold leading-tight tracking-normal text-[#0F172A] sm:text-5xl lg:text-[58px]">
              AI workflow automation built for teams that need control.
            </h2>
            <p class="mt-5 max-w-[42rem] text-[17px] leading-relaxed text-[#475569]">
              Tactas AI turns repeatable support, finance, admin, and operations work into agent-run workflows with connected context, approval gates, action logs, and live monitoring.
            </p>
            <div class="mt-7 flex flex-col gap-3 sm:flex-row">
              <a href="#contact" class="inline-flex h-11 items-center justify-center rounded-[4px] bg-[#06B6D4] px-5 text-[14px] font-semibold text-white transition hover:bg-[#0891B2]">
                Review your workflow
              </a>
              <a href="#platform" class="inline-flex h-11 items-center justify-center rounded-[4px] border border-[#94A3B8] px-5 text-[14px] font-semibold text-[#0F172A] transition hover:border-[#06B6D4] hover:text-[#0891B2]">
                See control layer
              </a>
            </div>
          </div>

          <div class="overflow-hidden rounded-[8px] border border-[#CBD5E1] bg-white shadow-[0_28px_80px_-66px_rgba(15,23,42,0.34)]">
            <div class="flex items-center justify-between border-b border-[#D8E1EA] bg-[#F1F5F9] px-4 py-3">
              <div class="flex items-center gap-2">
                <span class="h-2.5 w-2.5 rounded-full bg-[#06B6D4]"></span>
                <span class="h-2.5 w-2.5 rounded-full bg-[#CBD5E1]"></span>
                <span class="h-2.5 w-2.5 rounded-full bg-[#CBD5E1]"></span>
              </div>
              <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-[#0E7490]">Workflow live</p>
            </div>

            <div class="p-5 sm:p-6">
              <div class="grid gap-3 sm:grid-cols-5">
                {["Intake", "Context", "Reason", "Approve", "Execute"].map((step, index) => (
                  <div class:list={[
                    "relative min-h-24 rounded-[6px] border p-3",
                    index === 2 ? "border-[#06B6D4] bg-[#E6FBFF]" : "border-[#D8E1EA] bg-[#F8FAFC]",
                  ]}>
                    <div class:list={[
                      "flex h-8 w-8 items-center justify-center rounded-[4px]",
                      index === 2 ? "bg-[#06B6D4] text-white" : "bg-white text-[#06B6D4]",
                    ]}>
                      {index === 0 ? <Mail class="h-4 w-4" stroke-width={1.8} /> : index === 1 ? <Network class="h-4 w-4" stroke-width={1.8} /> : index === 2 ? <Bot class="h-4 w-4" stroke-width={1.8} /> : index === 3 ? <ShieldCheck class="h-4 w-4" stroke-width={1.8} /> : <Send class="h-4 w-4" stroke-width={1.8} />}
                    </div>
                    <p class="mt-3 text-[13px] font-semibold text-[#0F172A]">{step}</p>
                    <p class="mt-1 text-[11px] leading-relaxed text-[#64748B]">
                      {index === 0 ? "Request captured" : index === 1 ? "Data retrieved" : index === 2 ? "Decision drafted" : index === 3 ? "Policy checked" : "Action logged"}
                    </p>
                  </div>
                ))}
              </div>

              <div class="mt-5 grid gap-3 sm:grid-cols-3">
                {[
                  ["Decision", "Refund allowed under policy"],
                  ["Source", "CRM, ticket history, SOP"],
                  ["Next step", "Human approval required"],
                ].map(([label, value]) => (
                  <div class="rounded-[6px] border border-[#D8E1EA] bg-white p-4">
                    <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-[#64748B]">{label}</p>
                    <p class="mt-2 text-[14px] font-semibold leading-snug text-[#0F172A]">{value}</p>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>

        <div class="mt-12 overflow-hidden rounded-[8px] border border-[#D8E1EA] bg-white">
          <div class="grid border-b border-[#D8E1EA] lg:grid-cols-[0.92fr_1.08fr]">
            <div class="border-b border-[#D8E1EA] p-6 lg:border-b-0 lg:border-r lg:p-7">
              <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-[#64748B]">Without an operating layer</p>
              <h3 class="mt-3 text-[28px] font-semibold leading-tight tracking-normal text-[#0F172A]">
                Critical workflows depend on manual coordination and fragmented context.
              </h3>
            </div>
            <div class="bg-[#0F172A] p-6 text-white lg:p-7">
              <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-[#67E8F9]">Tactas AI operating layer</p>
              <h3 class="mt-3 text-[28px] font-semibold leading-tight tracking-normal">
                Agents execute defined processes with governance, visibility, and accountability.
              </h3>
            </div>
          </div>

          <div class="divide-y divide-[#D8E1EA]">
            {whyComparison.map((item) => (
              <div class="grid lg:grid-cols-[0.92fr_1.08fr]">
                <div class="border-b border-[#D8E1EA] p-5 lg:border-b-0 lg:border-r lg:p-6">
                  <div class="flex gap-3">
                    <span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-[#94A3B8]"></span>
                    <p class="text-[15px] leading-relaxed text-[#475569]">{item.pain}</p>
                  </div>
                </div>
                <div class="bg-[#F8FAFC] p-5 lg:p-6">
                  <div class="flex gap-3">
                    <Check class="mt-0.5 h-4.5 w-4.5 shrink-0 text-[#06B6D4]" stroke-width={2.4} />
                    <p class="text-[15px] font-medium leading-relaxed text-[#334155]">{item.outcome}</p>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>

      </div>
    </section>

    <section id="platform" class="border-b border-[#D8E1EA] bg-[#F8FAFC]">
      <div class={`${CONTAINER} py-16 lg:py-20`}>
        <div class="grid gap-10 lg:grid-cols-[0.8fr_1.2fr] lg:items-end">
          <div>
            <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-[#0891B2]">Tactas platform</p>
            <h2 class="mt-4 text-4xl font-semibold leading-tight tracking-normal text-[#0F172A] sm:text-5xl lg:text-[56px]">
              The operating layer for AI workflow automation.
            </h2>
          </div>
          <p class="max-w-[48rem] text-[17px] leading-relaxed text-[#475569] lg:justify-self-end">
            Tactas AI gives teams one place to configure agents, connect business systems, govern actions,
            explain decisions, monitor performance, and improve workflows that run across real operations.
          </p>
        </div>

        <div class="relative mt-10 border border-[#D8E1EA] bg-[#F8FAFC] shadow-[0_28px_90px_-64px_rgba(15,23,42,0.36)]">
          <div class="pointer-events-none absolute inset-0 z-10 hidden select-none md:block" aria-hidden="true">
            <div class="absolute left-[-7px] top-[-7px] h-3.5 w-3.5 rounded-[3px] border border-[#CBD5E1] bg-[#F8FAFC]"></div>
            <div class="absolute right-[-7px] top-[-7px] h-3.5 w-3.5 rounded-[3px] border border-[#CBD5E1] bg-[#F8FAFC]"></div>
            <div class="absolute bottom-[-7px] left-[-7px] h-3.5 w-3.5 rounded-[3px] border border-[#CBD5E1] bg-[#F8FAFC]"></div>
            <div class="absolute bottom-[-7px] right-[-7px] h-3.5 w-3.5 rounded-[3px] border border-[#CBD5E1] bg-[#F8FAFC]"></div>
          </div>

          <div class="relative min-h-[560px] overflow-x-auto overflow-y-hidden border-t bg-[#F1F5F9] font-mono md:border">
            <div class="relative h-[560px] min-w-[1160px]">
              <div class="absolute inset-0 [background-image:radial-gradient(circle,rgba(15,23,42,0.18)_1px,transparent_1px)] [background-size:20px_20px]"></div>

              <div class="absolute left-[230px] top-[280px] h-[104px] w-[118px] rounded-[2px] border border-[#06B6D4]/70 bg-[#06B6D4]/10">
