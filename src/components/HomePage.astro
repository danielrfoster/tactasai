<style is:global>
  .hero-eyebrow {
    position: relative;
    isolation: isolate;
    background:
      radial-gradient(circle at 12% 50%, rgba(103, 232, 249, 0.28), transparent 30%),
      linear-gradient(135deg, #07324A 0%, #0B4562 48%, #071C32 100%);
  }

  .hero-eyebrow::before {
    content: "";
    position: absolute;
    inset: 1px;
    z-index: -1;
    border-radius: 999px;
    background: linear-gradient(90deg, rgba(255, 255, 255, 0.16), rgba(255, 255, 255, 0.02), rgba(215, 162, 42, 0.18));
  }

  .hero-eyebrow-sheen {
    position: absolute;
    inset: -45% auto -45% -18%;
    width: 38%;
    transform: skewX(-18deg);
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.32), transparent);
    animation: tactas-hero-sheen 4.8s ease-in-out infinite;
  }

  .hero-eyebrow-orb {
    position: relative;
    z-index: 10;
    display: inline-flex;
    width: 12px;
    height: 12px;
    flex: 0 0 auto;
    margin-right: 12px;
    border-radius: 999px;
    background: rgba(103, 232, 249, 0.18);
    box-shadow: 0 0 0 6px rgba(103, 232, 249, 0.08);
  }

  .hero-eyebrow-orb span {
    display: block;
    width: 100%;
    height: 100%;
    border-radius: inherit;
    background: #67E8F9;
    box-shadow: 0 0 18px rgba(103, 232, 249, 0.95);
    animation: tactas-hero-orb 1.8s ease-in-out infinite;
  }

  .hero-eyebrow-progress {
    position: absolute;
    left: 24px;
    right: 24px;
    bottom: 5px;
    height: 2px;
    overflow: hidden;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.14);
  }

  .hero-eyebrow-progress::after {
    content: "";
    display: block;
    width: 100%;
    height: 100%;
    transform-origin: left;
    background: linear-gradient(90deg, #67E8F9, #D7A22A);
    animation: tactas-hero-progress 2.4s linear infinite;
  }

  .example-conversation [class*="border-l-[#06B6D4]"] {
    background-image: linear-gradient(180deg, #ffffff 0%, #f6f8fb 100%);
  }

  .example-panel.is-playing .example-conversation > * {
    animation: tactas-message-in 520ms cubic-bezier(0.22, 1, 0.36, 1) both;
    animation-delay: calc(var(--message-index, 0) * 420ms);
  }

  .example-panel.is-playing .example-conversation > *:first-child {
    animation-duration: 300ms;
  }

  .example-panel.is-playing .example-conversation > *:has(.tactas-dot) {
    animation-duration: 360ms;
  }

  .tactas-dot {
    animation: tactas-typing 1.2s ease-in-out infinite;
  }

  .capability-carousel-panel {
    opacity: 0;
    pointer-events: none;
    transform: translateX(18px);
    animation: tactas-capability-panel 19.2s cubic-bezier(0.22, 1, 0.36, 1) infinite;
    animation-delay: var(--panel-delay, 0s);
    will-change: opacity, transform;
  }

  .capability-carousel-chip {
    opacity: 0;
    transform: translateY(8px);
    animation: tactas-capability-chip 19.2s cubic-bezier(0.22, 1, 0.36, 1) infinite;
    animation-delay: calc(var(--panel-delay, 0s) + 120ms);
    will-change: opacity, transform;
  }

  .capability-carousel-step > span {
    animation: tactas-capability-progress 19.2s linear infinite;
    animation-delay: var(--panel-delay, 0s);
  }

  @keyframes tactas-message-in {
    0% {
      opacity: 0;
      transform: translateY(10px) scale(0.985);
      filter: blur(3px);
    }
    100% {
      opacity: 1;
      transform: translateY(0) scale(1);
      filter: blur(0);
    }
  }

  @keyframes tactas-typing {
    0%, 60%, 100% { opacity: 0.35; transform: translateY(0); }
    30% { opacity: 1; transform: translateY(-2px); }
  }

  @keyframes tactas-hero-sheen {
    0%, 58% {
      transform: translateX(0) skewX(-18deg);
      opacity: 0;
    }

    68% {
      opacity: 1;
    }

    100% {
      transform: translateX(360%) skewX(-18deg);
      opacity: 0;
    }
  }

  @keyframes tactas-hero-orb {
    0%, 100% {
      transform: scale(0.74);
      opacity: 0.72;
    }

    50% {
      transform: scale(1);
      opacity: 1;
    }
  }

  @keyframes tactas-hero-progress {
    0% {
      transform: scaleX(0);
    }

    88%, 100% {
      transform: scaleX(1);
    }
  }

  @keyframes tactas-capability-panel {
    0% {
      opacity: 0;
      pointer-events: none;
      transform: translateX(18px);
    }

    3%, 21.5% {
      opacity: 1;
      pointer-events: auto;
      transform: translateX(0);
    }

    25%, 100% {
      opacity: 0;
      pointer-events: none;
      transform: translateX(-18px);
    }
  }

  @keyframes tactas-capability-chip {
    0%, 3% {
      opacity: 0;
      transform: translateY(8px);
    }

    7%, 21.5% {
      opacity: 1;
      transform: translateY(0);
    }

    25%, 100% {
      opacity: 0;
      transform: translateY(8px);
    }
  }

  @keyframes tactas-capability-progress {
    0% {
      transform: scaleX(0);
    }

    24.8% {
      transform: scaleX(1);
    }

    25%, 100% {
      transform: scaleX(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-eyebrow-sheen,
    .hero-eyebrow-orb span,
    .hero-eyebrow-progress::after,
    .example-panel.is-playing .example-conversation > *,
    .tactas-dot {
      animation: none;
    }
  }
</style>

<script is:inline>
  (() => {
    const ACTIVE_CLASSES = [
      "border-[#BAE6FD]",
      "bg-white",
      "shadow-[inset_3px_0_0_0_#06B6D4,0_12px_26px_-22px_rgba(8,145,178,0.45)]",
    ];
    const INACTIVE_CLASSES = ["border-transparent", "hover:border-[#E2E8F0]", "hover:bg-white"];

    const syncExampleTabs = () => {
      const tabs = Array.from(document.querySelectorAll("[data-example-tab]"));
      const panels = Array.from(document.querySelectorAll(".example-panel"));
      const contexts = Array.from(document.querySelectorAll(".example-context"));
      if (!tabs.length || !panels.length) return;

      const preparePanel = (panel) => {
        const items = Array.from(panel.querySelectorAll(".example-conversation > *"));
        items.forEach((item, index) => {
          item.style.setProperty("--message-index", String(index));
        });
      };

      const playPanel = (panel) => {
        if (!panel) return;
        panel.classList.remove("is-playing");
        void panel.offsetWidth;
        panel.classList.add("is-playing");
      };

      panels.forEach(preparePanel);
      playPanel(panels.find((panel) => !panel.classList.contains("hidden")));

      tabs.forEach((tab) => {
        if (tab.dataset.exampleBound === "true") return;
        tab.dataset.exampleBound = "true";
        tab.addEventListener("click", () => {
          const target = tab.getAttribute("data-example-tab");
          let activePanel = null;
          tabs.forEach((item) => {
            const active = item === tab;
            item.setAttribute("aria-selected", active ? "true" : "false");
            ACTIVE_CLASSES.forEach((cls) => item.classList.toggle(cls, active));
            INACTIVE_CLASSES.forEach((cls) => item.classList.toggle(cls, !active));
          });
          panels.forEach((panel) => {
            const active = panel.id === `example-panel-${target}`;
            panel.classList.toggle("hidden", !active);
            panel.classList.toggle("is-playing", false);
            if (active) activePanel = panel;
          });
          contexts.forEach((ctx) => {
            ctx.classList.toggle("hidden", ctx.id !== `example-context-${target}`);
          });
          playPanel(activePanel);
        });
      });
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", syncExampleTabs, { once: true });
    } else {
      syncExampleTabs();
    }

    document.addEventListener("astro:page-load", syncExampleTabs);
  })();

  (() => {
    const syncHeroEyebrow = () => {
      const eyebrow = document.querySelector("[data-hero-eyebrow]");
      if (!eyebrow || eyebrow.dataset.heroEyebrowBound === "true") return;

      let messages = [];
      try {
        messages = JSON.parse(eyebrow.getAttribute("data-messages") || "[]");
      } catch {
        messages = [];
      }

      if (messages.length < 2) return;

      eyebrow.dataset.heroEyebrowBound = "true";
      let index = 0;

      window.setInterval(() => {
        index = (index + 1) % messages.length;
        eyebrow.classList.add("opacity-0", "translate-y-1");
        window.setTimeout(() => {
          eyebrow.textContent = messages[index];
          eyebrow.classList.remove("opacity-0", "translate-y-1");
        }, 220);
      }, 2400);
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", syncHeroEyebrow, { once: true });
    } else {
      syncHeroEyebrow();
    }

    document.addEventListener("astro:page-load", syncHeroEyebrow);
  })();
</script>
