      "shadow-[inset_3px_0_0_0_#06B6D4,0_12px_26px_-22px_rgba(8,145,178,0.45)]",
    ];
    const INACTIVE_CLASSES = ["border-transparent", "hover:border-[#E2E8F0]", "hover:bg-white"];

    const syncExampleTabs = () => {
      const tabs = Array.from(document.querySelectorAll("[data-example-tab]"));
      const panels = Array.from(document.querySelectorAll(".example-panel"));
      const contexts = Array.from(document.querySelectorAll(".example-context"));
      if (!tabs.length || !panels.length) return;

      const preparePanel = (panel) => {
        const items = Array.from(panel.querySelectorAll(".example-conversation > *"));
        items.forEach((item, index) => {
          item.style.setProperty("--message-index", String(index));
        });
      };

      const playPanel = (panel) => {
        if (!panel) return;
        panel.classList.remove("is-playing");
        void panel.offsetWidth;
        panel.classList.add("is-playing");
      };

      panels.forEach(preparePanel);
      playPanel(panels.find((panel) => !panel.classList.contains("hidden")));

      tabs.forEach((tab) => {
        if (tab.dataset.exampleBound === "true") return;
        tab.dataset.exampleBound = "true";
        tab.addEventListener("click", () => {
          const target = tab.getAttribute("data-example-tab");
          let activePanel = null;
          tabs.forEach((item) => {
            const active = item === tab;
            item.setAttribute("aria-selected", active ? "true" : "false");
            ACTIVE_CLASSES.forEach((cls) => item.classList.toggle(cls, active));
            INACTIVE_CLASSES.forEach((cls) => item.classList.toggle(cls, !active));
          });
          panels.forEach((panel) => {
            const active = panel.id === `example-panel-${target}`;
            panel.classList.toggle("hidden", !active);
            panel.classList.toggle("is-playing", false);
            if (active) activePanel = panel;
          });
          contexts.forEach((ctx) => {
            ctx.classList.toggle("hidden", ctx.id !== `example-context-${target}`);
          });
          playPanel(activePanel);
        });
      });
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", syncExampleTabs, { once: true });
    } else {
      syncExampleTabs();
    }

    document.addEventListener("astro:page-load", syncExampleTabs);
  })();
</script>
