<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r134/three.min.js"></script>
<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/vanta/0.5.24/vanta.globe.min.js"></script>
<script is:inline>
  (() => {
    const initHeroGlobe = () => {
      const globeElement = document.getElementById("hero-globe-background");
      if (!globeElement || !window.VANTA?.GLOBE) {
        return;
      }

      window.__tactasHeroGlobe?.destroy?.();
      window.__tactasHeroGlobe = window.VANTA.GLOBE({
        el: "#hero-globe-background",
        mouseControls: true,
        touchControls: true,
        gyroControls: false,
        minHeight: 200.0,
        minWidth: 200.0,
        scale: 1.0,
        scaleMobile: 1.0,
        color: 0x06b6d4,
        color2: 0x0f172a,
        backgroundColor: 0xf8fafc,
        size: 0.95,
      });
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initHeroGlobe, { once: true });
    } else {
      initHeroGlobe();
    }

    document.addEventListener("astro:page-load", initHeroGlobe);
  })();
</script>

<script define:vars={{ brandEmail }} is:inline>
  const workflowForm = document.getElementById("workflow-inquiry-form");
  const workflowStatus = document.getElementById("workflow-form-status");
  workflowForm?.addEventListener("submit", (event) => {
    event.preventDefault();
    const form = new FormData(workflowForm);
    const company = String(form.get("company") || "").trim() || "Tactas AI";
    const subject = encodeURIComponent(`Workflow inquiry — ${company}`);
    const body = encodeURIComponent(
      [
        `Name: ${String(form.get("name") || "")}`,
        `Work email: ${String(form.get("email") || "")}`,
        `Company: ${String(form.get("company") || "")}`,
        "",
        "Workflow:",
        String(form.get("workflow") || ""),
      ].join("\n"),
    );
    if (workflowStatus) {
      workflowStatus.textContent = "Opening your email client with the workflow details.";
    }
    window.location.href = `mailto:${brandEmail}?subject=${subject}&body=${body}`;
  });
</script>
