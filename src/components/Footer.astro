---
import { ArrowUpRight, Bot, Globe, Network, Search, ShieldCheck, Sparkles } from "@lucide/astro";
import { getSiteUrl } from "../lib/site";

const siteUrl = getSiteUrl();
const currentYear = new Date().getFullYear();
const CONTAINER = "mx-auto w-full max-w-[1240px] px-5 sm:px-8 lg:px-10";
---

<footer class="border-t border-white/10 bg-[#05073B] text-white">
  <div class={`${CONTAINER} py-12 lg:py-14`}>
    <div class="grid gap-12 lg:grid-cols-[320px_minmax(0,1fr)] lg:gap-20">
      <div>
        <a href="/" class="inline-flex items-center gap-3" aria-label="Tactas AI home">
          <img src="/favicon-96x96.png" alt="" width="42" height="42" class="h-10 w-10 rounded-[8px]" loading="lazy" decoding="async" />
          <span class="text-[28px] font-semibold leading-none tracking-normal">Tactas AI</span>
        </a>

        <p class="mt-8 max-w-[18rem] text-[15px] leading-relaxed text-white/82">
          Ask AI operators to research, decide, and prepare work across the systems your team already uses.
        </p>

        <div class="mt-5 flex items-center gap-4 text-white/68">
          {[Bot, Search, Network, Sparkles, ShieldCheck].map((Icon) => (
            <span class="flex h-7 w-7 items-center justify-center rounded-full border border-white/10 bg-white/[0.04]">
              <Icon class="h-4 w-4" stroke-width={1.8} />
            </span>
          ))}
        </div>

        <div class="mt-8 grid gap-1.5 text-[14px] leading-relaxed text-white/82">
          <p>Managed AI operations</p>
          <p>Pilot to production</p>
          <a href="/contact" class="mt-1 inline-flex w-fit items-center gap-2 text-white transition hover:text-[#67E8F9]">
            Request operator review
            <ArrowUpRight class="h-3.5 w-3.5" stroke-width={2} />
          </a>
        </div>

        <div class="mt-8 flex items-center gap-2 text-[14px] text-white/72">
          <Globe class="h-5 w-5" stroke-width={1.8} />
          <span>English</span>
        </div>
      </div>

      <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-4 lg:gap-12">
        <div>
          <p class="font-mono text-[12px] uppercase tracking-[0.12em] text-white">Product</p>
          <div class="mt-4 h-px w-full bg-white/14"></div>
          <div class="mt-5 grid gap-3 text-[15px] leading-relaxed">
            {[
              ["Operator runtime", "/#platform", true],
              ["Workplace knowledge", "/services/ai-knowledge-base", true],
              ["Workflow automation", "/services/ai-workflow-automation", true],
              ["Business research", "/#solutions", false],
              ["Decision briefs", "/#solutions", false],
              ["Approval control", "/#platform", false],
              ["Audit visibility", "/#platform", false],
            ].map(([label, href, strong]) => (
              <a href={href} class:list={["transition hover:text-[#67E8F9]", strong ? "font-semibold text-white" : "text-white/68"]}>{label}</a>
            ))}
          </div>
        </div>

        <div>
          <p class="font-mono text-[12px] uppercase tracking-[0.12em] text-white">Solutions</p>
          <div class="mt-4 h-px w-full bg-white/14"></div>
          <div class="mt-5 grid gap-3 text-[15px] leading-relaxed text-white/82">
            {[
              ["All use cases", "/use-cases"],
              ["Customer support", "/use-cases/ai-customer-support-automation"],
              ["Back office", "/use-cases/ai-back-office-automation"],
              ["CRM workflows", "/use-cases/ai-crm-workflow-automation"],
              ["Healthcare", "/industries/healthcare"],
              ["Ecommerce", "/industries/ecommerce"],
              ["Professional services", "/industries/professional-services"],
            ].map(([label, href]) => (
              <a href={href} class="transition hover:text-[#67E8F9]">{label}</a>
            ))}
          </div>

          <p class="mt-7 font-mono text-[12px] uppercase tracking-[0.12em] text-white">Use Cases</p>
          <div class="mt-4 h-px w-full bg-white/14"></div>
          <div class="mt-5 grid gap-3 text-[15px] leading-relaxed text-white/82">
            {[
              ["AI workflow automation", "/services/ai-workflow-automation"],
              ["AI knowledge base", "/services/ai-knowledge-base"],
              ["AI operator systems", "/#solutions"],
            ].map(([label, href]) => (
              <a href={href} class="transition hover:text-[#67E8F9]">{label}</a>
            ))}
          </div>
        </div>

        <div>
          <p class="font-mono text-[12px] uppercase tracking-[0.12em] text-white">Resources</p>
          <div class="mt-4 h-px w-full bg-white/14"></div>
          <div class="mt-5 grid gap-3 text-[15px] leading-relaxed text-white/82">
            {[
              ["Pricing", "/pricing"],
              ["Industries", "/industries"],
              ["Operator patterns", "/#solutions"],
              ["Integrations", "/#platform"],
              ["Platform overview", "/#platform"],
              ["Contact", "/contact"],
            ].map(([label, href]) => (
              <a href={href} class="transition hover:text-[#67E8F9]">{label}</a>
            ))}
          </div>
        </div>

        <div>
          <p class="font-mono text-[12px] uppercase tracking-[0.12em] text-white">Company</p>
          <div class="mt-4 h-px w-full bg-white/14"></div>
          <div class="mt-5 grid gap-3 text-[15px] leading-relaxed text-white/82">
            {[
              ["About", "/about"],
              ["Contact", "/contact"],
              ["Pricing", "/pricing"],
              ["Privacy", "/privacy"],
              ["Terms", "/terms"],
            ].map(([label, href]) => (
              <a href={href} class="transition hover:text-[#67E8F9]">{label}</a>
            ))}
          </div>
        </div>
      </div>
    </div>

    <div class="mt-12 flex flex-col gap-3 border-t border-white/14 pt-6 text-[12px] text-white/54 sm:flex-row sm:items-center sm:justify-between">
      <p>© {currentYear} Tactas AI. All rights reserved.</p>
      <div class="flex flex-wrap items-center gap-x-4 gap-y-2">
        <a href="/terms" class="transition hover:text-white">Terms</a>
        <a href="/privacy" class="transition hover:text-white">Privacy</a>
        <a href="/contact" class="transition hover:text-white">Contact</a>
        <a href={siteUrl} class="transition hover:text-white">{siteUrl.replace(/^https?:\/\//, "")}</a>
      </div>
    </div>
  </div>
</footer>
