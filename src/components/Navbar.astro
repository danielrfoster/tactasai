          ) : (
          <details class="group/mobile">
            <summary class:list={[
              "flex cursor-pointer list-none items-center justify-between py-4 text-[16px] font-semibold",
              isDark ? "text-white" : "text-[#111111]",
            ]}>
              {group.label}
              <ChevronDown class="h-4 w-4 transition group-open/mobile:rotate-180" stroke-width={1.8} />
            </summary>
            <div class="grid gap-5 pb-5">
              {group.label === "Product" ? (
                <div class="grid gap-5">
                  <a href="/#platform" class:list={[
                    "rounded-lg p-4",
                    isDark ? "border border-white/10 bg-white/[0.04]" : "bg-[#f7f7f7]",
                  ]} data-mobile-link>
                    <span class:list={[
                      "block text-[15px] font-semibold",
                      isDark ? "text-white" : "text-[#111111]",
                    ]}>Platform Overview</span>
                    <span class:list={[
                      "mt-1 block text-[13px] leading-relaxed",
                      isDark ? "text-white/62" : "text-[#5f5f5f]",
                    ]}>Agents, knowledge, context, outputs, and automated actions in one operating layer.</span>
                  </a>
                  {[
                    ["Work Console", "/#platform"],
                    ["AI Agents", "/services/ai-workflow-automation"],
                    ["Knowledge Layer", "/services/ai-knowledge-base"],
                    ["Connectors & Actions", "/#platform"],
                    ["Security", "/#platform"],
                    ["APIs", "/#platform"],
                  ].map(([label, href]) => (
                    <a href={href} class:list={[
                      "text-[14px] font-medium",
                      isDark ? "text-white/78" : "text-[#222222]",
                    ]} data-mobile-link>{label}</a>
                  ))}
                </div>
              ) : null}
              {group.featured ? (
                <a href={group.featured.href} class:list={[
                  "rounded-lg p-4",
                  isDark ? "border border-white/10 bg-white/[0.04]" : "bg-[#f7f7f7]",
                ]} data-mobile-link>
                  <span class:list={[
                    "block text-[15px] font-semibold",
                    isDark ? "text-white" : "text-[#111111]",
                  ]}>{group.featured.title}</span>
                  <span class:list={[
                    "mt-1 block text-[13px] leading-relaxed",
                    isDark ? "text-white/62" : "text-[#5f5f5f]",
                  ]}>{group.featured.description}</span>
                </a>
              ) : null}
              {group.columns.map((column) => (
                <div>
                  <p class:list={[
                    "mb-3 text-[11px] font-semibold uppercase tracking-[0.18em]",
                    isDark ? "text-[#A78BFA]" : "text-[#6d6d6d]",
                  ]}>{column.title}</p>
                  <div class:list={[
                    group.label === "Operations" ? "grid gap-3.5" : "grid gap-3",
                  ]}>
                    {column.links.map((link) => {
                      const Icon = link.icon;
                      return (
                        <a href={link.href} class:list={[
                          group.label === "Operations" ? "flex items-center gap-3 text-[15px] font-semibold" : "text-[14px] font-medium",
                          isDark ? "text-white/78" : "text-[#222222]",
                        ]} data-mobile-link>
                          {group.label === "Operations" ? (
                            Icon ? (
                              <Icon class="h-4 w-4 shrink-0 text-[#8c8c8c]" stroke-width={2} />
                            ) : (
                              <span class="h-4 w-4 shrink-0" aria-hidden="true"></span>
                            )
                          ) : null}
                          <span>{link.label}</span>
                        </a>
                      );
                    })}
                  </div>
                </div>
              ))}
            </div>
          </details>
          )
        ))}
      </div>

      <div class:list={[
        "mt-5 grid gap-3 text-[14px]",
        isDark ? "text-white/70" : "text-[#4f4f4f]",
      ]}>
        <a href="/#solutions" class="inline-flex items-center gap-2" data-mobile-link>
          <Zap class="h-4 w-4 text-[#06B6D4]" stroke-width={1.8} />
          Operations
        </a>
        <a href="/services/ai-knowledge-base" class="inline-flex items-center gap-2" data-mobile-link>
          <BrainCircuit class="h-4 w-4 text-[#06B6D4]" stroke-width={1.8} />
