---
import {
  ArrowRight,
  Briefcase,
  ChevronDown,
  FileText,
  Globe2,
  HeartPulse,
  Headphones,
  Menu,
  Network,
  Server,
  ShieldCheck,
  ShoppingBag,
  X,
  Zap,
} from "@lucide/astro";
import { getBrandEmail } from "../lib/site";

interface NavColumn {
  title: string;
  links: Array<{ label: string; href: string; description?: string }>;
}

interface NavGroup {
  label: string;
  href: string;
  featured?: {
    title: string;
    href: string;
    description: string;
    icon: typeof Zap;
  };
  columns: NavColumn[];
}

interface Props {
  currentPath?: string;
  ctaLabel?: string;
  ctaHref?: string;
  theme?: "dark" | "light";
}

const { currentPath = "/", ctaLabel = "Book demo", ctaHref = "#contact" } = Astro.props;
const brandEmail = getBrandEmail();
const CONTAINER = "mx-auto w-full max-w-[1240px] px-5 sm:px-8 lg:px-10";

const navGroups: NavGroup[] = [
  {
    label: "Platform",
    href: "/#platform",
    featured: {
      title: "AI workflow control",
      href: "/#platform",
      description: "Tactas connects agents, workflows, business systems, monitoring, and implementation support in one operating layer.",
      icon: Network,
    },
    columns: [
      {
        title: "Use cases",
        links: [
          { label: "Modernize operations", href: "/#solutions" },
          { label: "Automate workflows", href: "/#platform" },
          { label: "Monitor AI agents", href: "/#why-choose" },
        ],
      },
      {
        title: "CxO topics",
        links: [
          { label: "Adopt AI", href: "/#platform", description: "Bring agents into daily workflows" },
          { label: "AI control", href: "/#why-choose", description: "Track actions and decisions" },
          { label: "Data setup", href: "/#platform", description: "Prepare systems for automation" },
        ],
      },
      {
        title: "Industries",
        links: [
          { label: "Ecommerce", href: "/industries/ecommerce" },
          { label: "Healthcare", href: "/industries/healthcare" },
          { label: "Professional services", href: "/industries/professional-services" },
          { label: "SaaS operations", href: "/#solutions" },
        ],
      },
      {
        title: "Engage",
        links: [
          { label: "Automation guides", href: "/#faq" },
          { label: "Reference architectures", href: "/#platform" },
          { label: "Request a demo", href: "#contact" },
        ],
      },
    ],
  },
  {
    label: "Products",
    href: "/#solutions",
    columns: [
      {
      title: "Agent operations",
      links: [
          { label: "Workflow automation", href: "/#platform" },
          { label: "Support automation", href: "/#solutions" },
          { label: "Back-office automation", href: "/#solutions" },
        ],
      },
      {
      title: "Governance",
      links: [
          { label: "Agent monitoring", href: "/#why-choose" },
          { label: "Action tracking", href: "/#why-choose" },
          { label: "Human handoff", href: "/#why-choose" },
        ],
      },
      {
        title: "Plans & pricing",
        links: [
          { label: "Enterprise plans", href: "#contact" },
          { label: "Workflow setup review", href: "#contact" },
          { label: "Compare use cases", href: "/#solutions" },
        ],
      },
    ],
  },
  {
    label: "Developers",
    href: "/#platform",
    columns: [
      {
        title: "Documentation",
        links: [
          { label: "Developer library", href: "/#platform", description: "Implementation guides" },
          { label: "Application demos", href: "/#solutions", description: "Workflow examples" },
          { label: "Tutorials", href: "/#faq", description: "Step-by-step build notes" },
        ],
      },
      {
        title: "Products",
        links: [
          { label: "Artificial intelligence", href: "/#platform" },
          { label: "Agent observability", href: "/#why-choose" },
          { label: "Internal tools", href: "/#solutions" },
        ],
      },
    ],
  },
  {
    label: "Partners",
    href: "/#contact",
    featured: {
      title: "Partner network",
      href: "#contact",
      description: "Work with Tactas to design, deploy, monitor, and support AI workflow automation for client teams.",
      icon: Briefcase,
    },
    columns: [
      {
        title: "Partnership types",
        links: [
          { label: "Technology partners", href: "#contact" },
          { label: "Service providers", href: "#contact" },
          { label: "Implementation partners", href: "#contact" },
        ],
      },
      {
        title: "Resources",
        links: [
          { label: "Partner brief", href: "#contact" },
          { label: "Solution guide", href: "/#solutions" },
          { label: "Contact partnerships", href: "#contact" },
        ],
      },
    ],
  },
  {
    label: "Resources",
    href: "/#faq",
    columns: [
      {
        title: "Engage",
        links: [
          { label: "Demos + product tours", href: "#contact" },
          { label: "Case studies", href: "/#solutions" },
          { label: "Webinars", href: "#contact" },
          { label: "Workshops", href: "#contact" },
        ],
      },
      {
        title: "Build",
        links: [
          { label: "Reference architecture", href: "/#platform" },
          { label: "Solution + product guides", href: "/#solutions" },
          { label: "Developer documentation", href: "/#platform" },
        ],
      },
      {
        title: "Explore",
        links: [
          { label: "Operational AI brief", href: "/#faq" },
          { label: "Security reports", href: "/#why-choose" },
          { label: "Learning center", href: "/#faq" },
        ],
      },
    ],
  },
  {
    label: "Company",
    href: "/about",
    columns: [
      {
        title: "Company info",
        links: [
          { label: "About Tactas AI", href: "/about" },
          { label: "Industries", href: "/industries" },
          { label: "Ecommerce", href: "/industries/ecommerce" },
          { label: "Healthcare", href: "/industries/healthcare" },
          { label: "Professional services", href: "/industries/professional-services" },
        ],
      },
      {
        title: "Trust, privacy, & safety",
        links: [
          { label: "Privacy Policy", href: "/privacy" },
          { label: "Terms of Service", href: "/terms" },
          { label: "Contact", href: "#contact" },
        ],
      },
    ],
  },
];

const isActive = (href: string) => {
  if (href === "/") return currentPath === "/";
  if (href.startsWith("/#")) return false;
  return currentPath === href || currentPath.startsWith(`${href}/`);
};
---

<header
  id="site-header"
  class="sticky top-0 z-[11111] border-b border-black/10 bg-white/95 text-[#111111] shadow-[0_1px_0_rgba(0,0,0,0.05)] backdrop-blur"
>
  <div class={`${CONTAINER} hidden h-8 items-center justify-end gap-5 text-[12px] text-[#4f4f4f] lg:flex`}>
    <a href={`mailto:${brandEmail}`} class="transition hover:text-[#06B6D4]">Log in</a>
    <a href="#contact" class="transition hover:text-[#06B6D4]">Support</a>
    <button type="button" class="inline-flex items-center gap-1 transition hover:text-[#06B6D4]" aria-label="Languages">
      <Globe2 class="h-3.5 w-3.5" stroke-width={1.8} />
      Languages
      <ChevronDown class="h-3 w-3" stroke-width={1.9} />
    </button>
  </div>

  <div class={`${CONTAINER} flex h-[64px] items-center justify-between gap-5 lg:h-[68px]`}>
    <a href="/" class="flex min-w-0 items-center gap-3" aria-label="Tactas AI home">
      <img src="/favicon-96x96.png" alt="" width="32" height="32" class="h-8 w-8 rounded-[6px]" aria-hidden="true" loading="eager" decoding="async" />
      <span class="text-[22px] font-semibold leading-none tracking-[-0.03em] text-[#111111]">Tactas AI</span>
    </a>

    <nav class="hidden h-full items-center lg:flex" aria-label="Primary">
      {navGroups.map((group) => (
        <div class="group/nav h-full">
          <a
            href={group.href}
            class:list={[
              "flex h-full items-center gap-1.5 px-3 text-[14px] font-semibold text-[#1f1f1f] transition hover:text-[#06B6D4]",
              isActive(group.href) ? "text-[#06B6D4]" : "",
            ]}
          >
            {group.label}
            <ChevronDown class="h-3.5 w-3.5 transition group-hover/nav:rotate-180" stroke-width={1.9} />
          </a>

          <div class="invisible absolute left-0 top-full w-full translate-y-2 border-y border-black/10 bg-white opacity-0 shadow-[0_26px_70px_-46px_rgba(0,0,0,0.34)] transition duration-150 group-hover/nav:visible group-hover/nav:translate-y-0 group-hover/nav:opacity-100 group-focus-within/nav:visible group-focus-within/nav:translate-y-0 group-focus-within/nav:opacity-100">
            <div class={`${CONTAINER} grid gap-8 py-8 ${group.featured ? "lg:grid-cols-[290px_1fr]" : "lg:grid-cols-1"}`}>
              {group.featured ? (
                <a href={group.featured.href} class="flex min-h-[170px] flex-col justify-between rounded-xl bg-[#f7f7f7] p-5 transition hover:bg-[#f1f1f1]">
                  <span>
                    <span class="mb-5 flex h-12 w-12 items-center justify-center rounded-lg bg-white text-[#06B6D4] shadow-[0_12px_26px_-22px_rgba(0,0,0,0.45)]">
                      <group.featured.icon class="h-5 w-5" stroke-width={1.8} />
                    </span>
                    <span class="block text-[17px] font-semibold tracking-[-0.02em] text-[#111111]">{group.featured.title}</span>
                    <span class="mt-2 block text-[13px] leading-relaxed text-[#5f5f5f]">{group.featured.description}</span>
                  </span>
                  <span class="mt-5 inline-flex items-center text-[13px] font-semibold text-[#06B6D4]">
                    Request a demo
                    <ArrowRight class="ml-1.5 h-3.5 w-3.5" />
                  </span>
                </a>
              ) : null}

              <div class={`grid gap-7 ${group.columns.length >= 4 ? "lg:grid-cols-4" : group.columns.length === 3 ? "lg:grid-cols-3" : "lg:grid-cols-2"}`}>
                {group.columns.map((column) => (
                  <div class="border-l border-black/10 pl-5 first:border-l-0 first:pl-0">
                    <p class="mb-4 text-[12px] font-semibold uppercase tracking-[0.18em] text-[#6d6d6d]">{column.title}</p>
                    <ul class="grid gap-3">
                      {column.links.map((link) => (
                        <li>
                          <a href={link.href} class="group/item block text-[14px] leading-snug text-[#222222] transition hover:text-[#06B6D4]">
                            <span class="font-semibold">{link.label}</span>
                            {link.description ? <span class="mt-1 block text-[12px] leading-relaxed text-[#6a6a6a] group-hover/item:text-[#4f4f4f]">{link.description}</span> : null}
                          </a>
                        </li>
                      ))}
                    </ul>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      ))}
    </nav>

    <div class="hidden items-center gap-4 lg:flex">
      <a href={`mailto:${brandEmail}`} class="text-[14px] font-semibold text-[#1f1f1f] transition hover:text-[#06B6D4]">
        Log in
      </a>
      <a href={ctaHref} class="inline-flex h-10 items-center justify-center rounded-[3px] bg-[#1f1f1f] px-4 text-[14px] font-semibold text-white transition hover:bg-[#06B6D4]">
        {ctaLabel}
      </a>
    </div>

    <button
      id="mobile-nav-toggle"
      type="button"
      class="inline-flex h-10 w-10 items-center justify-center rounded-[3px] border border-black/15 bg-white text-[#111111] lg:hidden"
      aria-label="Open navigation"
      aria-expanded="false"
      aria-controls="mobile-nav"
    >
      <Menu class="h-5 w-5 mobile-open-icon" />
      <X class="hidden h-5 w-5 mobile-close-icon" />
    </button>
  </div>

  <div id="mobile-nav" class="hidden border-t border-black/10 bg-white lg:hidden">
    <div class={`${CONTAINER} max-h-[calc(100vh-72px)] overflow-y-auto py-5`}>
      <div class="mb-5 grid grid-cols-2 gap-3 text-[13px] font-semibold">
        <a href={`mailto:${brandEmail}`} class="rounded-[3px] border border-black/15 px-3 py-2.5 text-center text-[#111111]" data-mobile-link>Log in</a>
        <a href={ctaHref} class="rounded-[3px] bg-[#1f1f1f] px-3 py-2.5 text-center text-white" data-mobile-link>{ctaLabel}</a>
      </div>

      <div class="divide-y divide-black/10 border-y border-black/10">
        {navGroups.map((group) => (
          <details class="group/mobile">
            <summary class="flex cursor-pointer list-none items-center justify-between py-4 text-[16px] font-semibold text-[#111111]">
              {group.label}
              <ChevronDown class="h-4 w-4 transition group-open/mobile:rotate-180" stroke-width={1.8} />
            </summary>
            <div class="grid gap-5 pb-5">
              {group.featured ? (
                <a href={group.featured.href} class="rounded-lg bg-[#f7f7f7] p-4" data-mobile-link>
                  <span class="block text-[15px] font-semibold text-[#111111]">{group.featured.title}</span>
                  <span class="mt-1 block text-[13px] leading-relaxed text-[#5f5f5f]">{group.featured.description}</span>
                </a>
              ) : null}
              {group.columns.map((column) => (
                <div>
                  <p class="mb-3 text-[11px] font-semibold uppercase tracking-[0.18em] text-[#6d6d6d]">{column.title}</p>
                  <div class="grid gap-3">
                    {column.links.map((link) => (
                      <a href={link.href} class="text-[14px] font-medium text-[#222222]" data-mobile-link>{link.label}</a>
                    ))}
                  </div>
                </div>
              ))}
            </div>
          </details>
        ))}
      </div>

      <div class="mt-5 grid gap-3 text-[14px] text-[#4f4f4f]">
        <a href="#contact" class="inline-flex items-center gap-2" data-mobile-link>
          <FileText class="h-4 w-4 text-[#06B6D4]" stroke-width={1.8} />
          Support
        </a>
        <a href="/#faq" class="inline-flex items-center gap-2" data-mobile-link>
          <Server class="h-4 w-4 text-[#06B6D4]" stroke-width={1.8} />
          Resources
        </a>
        <a href="/industries/ecommerce" class="inline-flex items-center gap-2" data-mobile-link>
          <ShoppingBag class="h-4 w-4 text-[#06B6D4]" stroke-width={1.8} />
          Ecommerce
        </a>
        <a href="/industries/healthcare" class="inline-flex items-center gap-2" data-mobile-link>
          <HeartPulse class="h-4 w-4 text-[#06B6D4]" stroke-width={1.8} />
          Healthcare
        </a>
        <a href="/industries/professional-services" class="inline-flex items-center gap-2" data-mobile-link>
          <Briefcase class="h-4 w-4 text-[#06B6D4]" stroke-width={1.8} />
          Professional services
        </a>
        <a href="/#solutions" class="inline-flex items-center gap-2" data-mobile-link>
          <Headphones class="h-4 w-4 text-[#06B6D4]" stroke-width={1.8} />
          Solutions
        </a>
        <a href="/#why-choose" class="inline-flex items-center gap-2" data-mobile-link>
          <ShieldCheck class="h-4 w-4 text-[#06B6D4]" stroke-width={1.8} />
          Control
        </a>
      </div>
    </div>
  </div>
</header>

<script is:inline>
  const toggle = document.getElementById("mobile-nav-toggle");
  const nav = document.getElementById("mobile-nav");
  const openIcon = toggle?.querySelector(".mobile-open-icon");
  const closeIcon = toggle?.querySelector(".mobile-close-icon");
  const mobileLinks = nav?.querySelectorAll("[data-mobile-link]");
  let mobileOpen = false;

  const syncMobile = () => {
    if (!toggle || !nav || !openIcon || !closeIcon) return;
    toggle.setAttribute("aria-expanded", mobileOpen ? "true" : "false");
    toggle.setAttribute("aria-label", mobileOpen ? "Close navigation" : "Open navigation");
    nav.classList.toggle("hidden", !mobileOpen);
    openIcon.classList.toggle("hidden", mobileOpen);
    closeIcon.classList.toggle("hidden", !mobileOpen);
    document.body.style.overflow = mobileOpen ? "hidden" : "";
  };

  syncMobile();

  toggle?.addEventListener("click", () => {
    mobileOpen = !mobileOpen;
    syncMobile();
  });

  mobileLinks?.forEach((link) => {
    link.addEventListener("click", () => {
      mobileOpen = false;
      syncMobile();
    });
  });
</script>
