        "divide-y border-y",
        isDark ? "divide-white/10 border-white/10" : "divide-black/10 border-black/10",
      ]}>
        {navGroups.map((group) => (
          group.simple ? (
            <a href={group.href} class:list={[
              "flex items-center justify-between py-4 text-[16px] font-semibold",
              isDark ? "text-white" : "text-tactas-ink",
            ]} data-mobile-link>
              {group.label}
              <ArrowRight class="h-4 w-4" stroke-width={1.8} />
            </a>
          ) : (
          <details class="group/mobile">
            <summary class:list={[
              "flex cursor-pointer list-none items-center justify-between py-4 text-[16px] font-semibold",
              isDark ? "text-white" : "text-tactas-ink",
            ]}>
              {group.label}
              <ChevronDown class="h-4 w-4 transition group-open/mobile:rotate-180" stroke-width={1.8} />
            </summary>
            <div class="grid gap-5 pb-5">
              {group.label === "Product" ? (
                <div class="grid gap-5">
                  <a href="/product" class:list={[
                    "rounded-lg p-4",
                    isDark ? "border border-white/10 bg-white/[0.04]" : "bg-tactas-bg",
                  ]} data-mobile-link>
                    <span class:list={[
                      "block text-[15px] font-semibold",
                      isDark ? "text-white" : "text-tactas-ink",
                    ]}>Product Overview</span>
                    <span class:list={[
                      "mt-1 block text-[13px] leading-relaxed",
                      isDark ? "text-white/62" : "text-tactas-muted",
                    ]}>Agents, knowledge, context, outputs, and automated actions in one operating layer.</span>
                  </a>
                  {[
                    ["Data Readiness", "/product/data-readiness"],
                    ["Agent System Design", "/product/agent-system-design"],
                    ["Managed AI Agents", "/product/ai-workflow-automation"],
                    ["Knowledge Layer", "/product/ai-knowledge-base"],
                    ["Workflows & Actions", "/#platform"],
                    ["Task Review", "/contact"],
                    ["Connectors & Actions", "/#platform"],
                    ["Guardrails", "/product"],
