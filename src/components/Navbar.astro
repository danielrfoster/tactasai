---
import {
  ArrowRight,
  Banknote,
  BarChart3,
  Bot,
  Briefcase,
  BrainCircuit,
  ChevronDown,
  ClipboardCheck,
  Code2,
  Database,
  Factory,
  FileText,
  FileSearch,
  GraduationCap,
  HeartPulse,
  Headphones,
  Home,
  KeyRound,
  Landmark,
  Layers,
  Mail,
  Menu,
  Megaphone,
  Network,
  Puzzle,
  Search,
  Settings,
  Server,
  ShieldCheck,
  ShoppingBag,
  Sparkles,
  Truck,
  User,
  Users,
  X,
  Zap,
} from "@lucide/astro";
import { getBrandEmail } from "../lib/site";

interface NavColumn {
  title: string;
  links: Array<{ label: string; href: string; description?: string; icon?: typeof Zap; nested?: boolean }>;
}

interface NavGroup {
  label: string;
  href: string;
  simple?: boolean;
  featured?: {
    title: string;
    href: string;
    description: string;
    icon: typeof Zap;
  };
  columns: NavColumn[];
}

interface Props {
  currentPath?: string;
  ctaLabel?: string;
  ctaHref?: string;
  theme?: "dark" | "light";
}

const { currentPath = "/", ctaLabel = "Book a review", ctaHref = "/contact", theme = "light" } = Astro.props;
const brandEmail = getBrandEmail();
const isDark = theme === "dark";

const navGroups: NavGroup[] = [
  {
    label: "Product",
    href: "/product",
    columns: [],
  },
  {
    label: "Solutions",
    href: "/#solutions",
    columns: [
      {
        title: "Industries",
        links: [
          { label: "SaaS Companies", href: "/industries/ai-assistant-for-saas-companies", icon: Factory },
          { label: "Ecommerce Stores", href: "/industries/ecommerce", icon: ShoppingBag },
          { label: "Law Firms", href: "/industries/ai-assistant-for-law-firms", icon: Landmark },
          { label: "Healthcare Clinics", href: "/industries/healthcare", icon: HeartPulse },
          { label: "Real Estate Teams", href: "/industries/ai-assistant-for-real-estate", icon: Home },
          { label: "VPS Hosting Providers", href: "/industries/ai-assistant-for-vps-hosting-providers", icon: Server },
        ],
      },
      {
        title: "Context & Tools",
        links: [
          { label: "Knowledge & Files", href: "/product/ai-knowledge-base", icon: FileText },
          { label: "Messages & Forms", href: "/contact", icon: Mail },
          { label: "Tasks & Projects", href: "/contact", icon: Briefcase },
          { label: "Business Data", href: "/#platform", icon: Database },
          { label: "Connected Tools", href: "/#platform", icon: Puzzle },
          { label: "Automation Steps", href: "/contact", icon: Zap },
        ],
      },
    ],
  },
  {
    label: "Pricing",
    href: "/pricing",
    simple: true,
    columns: [],
  },
  {
    label: "Resources",
    href: "/use-cases",
    columns: [
      {
        title: "Explore",
        links: [
          { label: "Blog", href: "/blog" },
          { label: "AI Agent Prompt Library", href: "/ai-agent-prompt-library" },
          { label: "Task Examples", href: "/use-cases" },
          { label: "Automation Guide", href: "/product/ai-workflow-automation" },
          { label: "AI Operating Layer", href: "/#platform" },
          { label: "Connected Tools", href: "/#platform" },
          { label: "Contact", href: "/contact" },
        ],
      },
      {
        title: "Engage",
        links: [
          { label: "Task Review", href: "/contact" },
          { label: "Automation Map", href: "/contact" },
          { label: "Company Knowledge Review", href: "/product/ai-knowledge-base" },
          { label: "Tool Connection Review", href: "/contact" },
          { label: "Partner Inquiry", href: "/contact" },
        ],
      },
      {
        title: "Core Areas",
        links: [
          { label: "Managed AI Agents", href: "/product/ai-workflow-automation" },
          { label: "Business Task Automation", href: "/use-cases" },
          { label: "Company Knowledge", href: "/product/ai-knowledge-base" },
          { label: "Connected Business Tools", href: "/#platform" },
          { label: "Work Performance", href: "/#solutions" },
        ],
      },
    ],
  },
  {
    label: "Company",
    href: "/about",
    columns: [
      {
        title: "Company",
        links: [
          { label: "About Tactas AI", href: "/about" },
          { label: "Contact", href: "/contact" },
          { label: "Task Review", href: "/contact" },
          { label: "Implementation", href: "/contact" },
        ],
      },
      {
        title: "Explore",
        links: [
          { label: "Task Examples", href: "/use-cases" },
          { label: "Connected Tools", href: "/#platform" },
          { label: "Company Knowledge", href: "/product/ai-knowledge-base" },
          { label: "Pricing", href: "/pricing" },
        ],
      },
      {
        title: "Trust & Legal",
        links: [
          { label: "Privacy Policy", href: "/privacy" },
          { label: "Terms of Service", href: "/terms" },
          { label: "Refund Policy", href: "/refund-policy" },
          { label: "Security Review", href: "/contact" },
        ],
      },
    ],
  },
];

const isActive = (href: string) => {
  if (href === "/") return currentPath === "/";
  if (href.startsWith("/#")) return false;
  return currentPath === href || currentPath.startsWith(`${href}/`);
};
---

<header
  id="site-header"
  class:list={[
    "sticky top-0 z-[11111] backdrop-blur",
    isDark
      ? "border-b border-white/10 bg-tactas-night/92 text-white shadow-[0_1px_0_rgba(255,255,255,0.06)]"
      : "border-b border-black/10 bg-white/95 text-tactas-ink shadow-[0_1px_0_rgba(0,0,0,0.05)]",
  ]}
>
  <div class={`tactas-container flex h-[64px] items-center justify-between gap-5 lg:h-[68px]`}>
    <a href="/" class="flex min-w-0 items-center gap-3" aria-label="Tactas AI home">
      <img src="/favicon-96x96.png" alt="" width="32" height="32" class="h-8 w-8 rounded-[6px]" aria-hidden="true" loading="eager" decoding="async" />
      <span class:list={[
        "text-[22px] font-semibold leading-none tracking-[-0.03em]",
        isDark ? "text-white" : "text-tactas-ink",
      ]}>Tactas AI</span>
    </a>

    <nav class="hidden h-full items-center lg:flex" aria-label="Primary">
      {navGroups.map((group) => (
        <div class="group/nav h-full">
          <a
            href={group.href}
            class:list={[
              "flex h-full items-center gap-1.5 px-3 text-[14px] font-semibold transition",
              isDark ? "text-white/82 hover:text-tactas-violet" : "text-tactas-ink hover:text-tactas-accent",
              isActive(group.href) ? (isDark ? "text-tactas-violet" : "text-tactas-accent") : "",
            ]}
          >
            {group.label}
            {group.simple ? null : <ChevronDown class="h-3.5 w-3.5 transition group-hover/nav:rotate-180" stroke-width={1.9} />}
          </a>

          {group.simple ? null : (
          <div class="invisible absolute left-0 top-full w-full translate-y-2 border-y border-black/10 bg-white opacity-0 shadow-[0_26px_70px_-46px_rgba(0,0,0,0.34)] transition duration-150 group-hover/nav:visible group-hover/nav:translate-y-0 group-hover/nav:opacity-100 group-focus-within/nav:visible group-focus-within/nav:translate-y-0 group-focus-within/nav:opacity-100">
            <div class={`tactas-container grid gap-8 py-8 ${group.featured ? "lg:grid-cols-[290px_1fr]" : "lg:grid-cols-1"}`}>
              {group.featured ? (
                <a href={group.featured.href} class="flex min-h-[170px] flex-col justify-between rounded-xl bg-tactas-bg p-5 transition hover:bg-tactas-bg-soft">
                  <span>
                    <span class="mb-5 flex h-12 w-12 items-center justify-center rounded-lg bg-white text-tactas-accent shadow-[0_12px_26px_-22px_rgba(0,0,0,0.45)]">
                      <group.featured.icon class="h-5 w-5" stroke-width={1.8} />
                    </span>
                    <span class="block text-[17px] font-semibold tracking-[-0.02em] text-tactas-ink">{group.featured.title}</span>
                    <span class="mt-2 block text-[13px] leading-relaxed text-tactas-muted">{group.featured.description}</span>
                  </span>
                  <span class="mt-5 inline-flex items-center text-[13px] font-semibold text-tactas-accent">
                    Request a demo
                    <ArrowRight class="ml-1.5 h-3.5 w-3.5" />
                  </span>
                </a>
              ) : null}

              {group.label === "Product" ? (
                <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_320px]">
                  <div>
                    <div class="grid gap-8 lg:grid-cols-[270px_1fr] lg:items-start">
                      <p class="text-[20px] font-bold uppercase tracking-[-0.02em] text-tactas-ink">Managed AI Agent System</p>
                      <a href="/product" class="flex h-14 items-center justify-between rounded-[10px] border border-tactas-accent-line bg-[linear-gradient(90deg,#D9F8FF_0%,#EAF0FF_50%,#F0EAFF_100%)] px-5 text-[20px] font-bold text-tactas-ink-strong transition hover:brightness-[0.98]">
                        Product Overview
                        <ArrowRight class="h-5 w-5" stroke-width={1.8} />
                      </a>
                    </div>

                    <div class="mt-7 grid gap-8 md:grid-cols-2 xl:grid-cols-4">
                      {[
                        {
                          cluster: "Foundation",
                          title: "Data Readiness",
                          description: "Prepare data for reliable agents",
                          href: "/product/data-readiness",
                          icon: Database,
                          links: [
                            ["Agent data handling", "/product/data-readiness#agent-data-handling"],
                            ["Expert preparation", "/product/data-readiness#expert-data-preparation"],
                            ["Large data sets", "/product/data-readiness#data-sources"],
                            ["Specialized sources", "/product/data-readiness#data-sources"],
                          ],
                        },
                        {
                          cluster: "Execution",
                          title: "Agent System Design",
                          description: "Fit agents to your business",
                          href: "/product/agent-system-design",
                          icon: Settings,
                          links: [
                            ["Workflow design", "/product/agent-system-design#workflow-fit"],
                            ["Workspace isolation", "/product/agent-system-design#workspace-isolation"],
                            ["Business rules", "/product/agent-system-design#agent-behavior"],
                            ["Approval paths", "/product/agent-system-design#design-principles"],
                          ],
                        },
                        {
                          cluster: "Execution",
                          title: "Managed AI Agents",
                          description: "Automate repeated business tasks",
                          href: "/product/ai-workflow-automation",
                          icon: Bot,
                          links: [
                            ["Task mapping", "/product/ai-workflow-automation#product"],
                            ["Assistant", "/product/assistant"],
                            ["Prepared outputs", "/product/ai-workflow-automation#architecture"],
                            ["Human review", "/product/ai-workflow-automation#faq"],
                          ],
                        },
                        {
                          cluster: "Foundation",
                          title: "Knowledge Layer",
                          description: "Company context for agent work",
                          href: "/product/ai-knowledge-base",
                          icon: Search,
                          links: [
                            ["Source-backed answers", "/product/ai-knowledge-base#product"],
                            ["Document context", "/product/ai-knowledge-base#architecture"],
                            ["Deep research", "/product/deep-research"],
                            ["Quality tuning", "/product/ai-knowledge-base#faq"],
                          ],
                        },
                      ].map((item) => {
                        const Icon = item.icon;
                        return (
                          <div>
                            <a href={item.href} class="group/item flex items-start gap-3">
                              <Icon class="mt-0.5 h-5 w-5 shrink-0 text-tactas-primary-strong" stroke-width={1.9} />
                              <span>
                                <span class="block font-mono text-[10px] uppercase tracking-[0.2em] text-tactas-accent-strong">{item.cluster}</span>
                                <span class="mt-1 block text-[20px] font-bold leading-tight text-tactas-primary-strong group-hover/item:text-tactas-accent">{item.title}</span>
                                <span class="mt-1 block text-[14px] leading-relaxed text-tactas-muted-soft">{item.description}</span>
                              </span>
                            </a>
                            <div class="mt-5 grid gap-3 text-[15px] font-semibold text-tactas-ink">
                              {item.links.map(([label, href]) => (
                                <a href={href} class="transition hover:text-tactas-accent">{label}</a>
                              ))}
                            </div>
                          </div>
                        );
                      })}
                    </div>

                    <div class="mt-10 grid gap-6 border-t border-black/12 pt-8 sm:grid-cols-2 lg:grid-cols-3">
                      {[
                        ["Task Review", "Pick the first workflow to automate", ClipboardCheck, "/contact"],
                        ["Data Preparation", "Make company data usable by agents", Database, "/product/data-readiness"],
                        ["Workspace Isolation", "Keep workflow context and tools separate", Layers, "/product/agent-system-design#workspace-isolation"],
                        ["Deep Research", "Turn broad questions into cited briefs", FileSearch, "/product/deep-research"],
                        ["Connectors & Actions", "Use existing apps as inputs and destinations", Puzzle, "/#platform"],
                        ["Guardrails", "Define approvals, limits, and escalation paths", ShieldCheck, "/product/agent-system-design#design-principles"],
                        ["Monitoring", "Track output quality and operational usage", BarChart3, "/product#capabilities"],
                        ["Implementation", "Launch one managed workflow end to end", Sparkles, "/product#launch-model"],
                        ["Managed Improvement", "Tune context, prompts, and actions over time", Sparkles, "/product#launch-model"],
                      ].map(([title, body, Icon, href]) => (
                        <a href={href} class="group/item flex gap-3">
                          <Icon class="mt-1 h-4 w-4 shrink-0 text-tactas-ink" stroke-width={1.9} />
                          <span>
                            <span class="block text-[15px] font-bold text-tactas-ink group-hover/item:text-tactas-accent">{title}</span>
                            <span class="mt-1 block text-[14px] leading-relaxed text-tactas-muted-soft">{body}</span>
                          </span>
                        </a>
                      ))}
                    </div>
                  </div>

                  <aside class="border-l border-black/12 bg-tactas-bg-soft px-8 py-5">
                    <p class="text-[20px] font-bold uppercase tracking-[-0.02em] text-tactas-ink">How Tactas ships</p>
                    <div class="mt-8 grid gap-5">
                      {[
                        ["01", "Review one task"],
                        ["02", "Connect sources and tools"],
                        ["03", "Launch a supervised agent"],
                        ["04", "Improve with real work"],
                      ].map(([step, label]) => (
                        <a href="/contact" class="flex items-center gap-3 text-[15px] font-semibold text-tactas-ink transition hover:text-tactas-accent">
                          <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-[6px] border border-tactas-accent-line bg-white font-mono text-[10px] text-tactas-accent-strong">{step}</span>
                          <span>{label}</span>
                        </a>
                      ))}
                      <a href="/contact" class="flex items-center gap-3 text-[15px] font-semibold text-tactas-ink transition hover:text-tactas-accent">
                        <Mail class="h-4 w-4 text-tactas-ink" stroke-width={1.8} />
                        Book a product review
                      </a>
                    </div>
                  </aside>
                </div>
              ) : (
              <div class={`grid ${
                group.label === "Solutions" || group.label === "Resources" || group.label === "Company"
                    ? "gap-x-16 gap-y-8 lg:grid-cols-[minmax(0,820px)_334px]"
                    : `gap-7 ${group.columns.length >= 4 ? "lg:grid-cols-4" : group.columns.length === 3 ? "lg:grid-cols-3" : "lg:grid-cols-2"}`
              }`}>
                <div class={`grid ${
                  group.label === "Solutions"
                    ? "gap-x-16 gap-y-8 lg:grid-cols-2"
                    : group.label === "Resources" || group.label === "Company"
                      ? "gap-x-14 gap-y-8 lg:grid-cols-3"
                      : "contents"
                }`}>
                {group.columns.map((column) => (
                  <div class:list={[
                    group.label === "Solutions" || group.label === "Resources" || group.label === "Company" ? "" : "border-l border-black/10 pl-5 first:border-l-0 first:pl-0",
                  ]}>
                    <p class:list={[
                      group.label === "Solutions"
                        ? "mb-6 text-[20px] font-bold uppercase tracking-[-0.02em] text-tactas-ink"
                        : group.label === "Resources" || group.label === "Company"
                          ? "mb-6 text-[20px] font-bold uppercase tracking-[-0.02em] text-tactas-ink"
                        : "mb-4 text-[12px] font-semibold uppercase tracking-[0.18em] text-tactas-muted",
                    ]}>{column.title}</p>
                    <ul class:list={[
                      group.label === "Solutions" ? "grid gap-4" : group.label === "Resources" || group.label === "Company" ? "grid gap-4" : "grid gap-3",
                    ]}>
                      {column.links.map((link) => {
                        const Icon = link.icon;
                        return (
                          <li>
                            <a
                              href={link.href}
                              class:list={[
                                "group/item text-tactas-ink transition hover:text-tactas-accent",
                                group.label === "Solutions"
                                  ? "flex min-h-5 items-center gap-4 text-[16px] font-semibold leading-tight"
                                  : group.label === "Resources" || group.label === "Company"
                                    ? "block text-[15px] font-semibold leading-tight"
                                  : "block text-[14px] leading-snug",
                              ]}
                            >
                              {group.label === "Solutions" ? (
                                Icon ? (
                                  <Icon class="h-4 w-4 shrink-0 text-tactas-muted-soft transition group-hover/item:text-tactas-accent" stroke-width={2} />
                                ) : (
                                  <span class="h-4 w-4 shrink-0" aria-hidden="true"></span>
                                )
                              ) : null}
                              <span>{link.label}</span>
                              {link.description ? <span class="mt-1 block text-[12px] leading-relaxed text-tactas-muted group-hover/item:text-tactas-muted">{link.description}</span> : null}
                            </a>
                          </li>
                        );
                      })}
                    </ul>
                  </div>
                ))}
                </div>

                {group.label === "Solutions" ? (
                  <div>
                    <a href="/industries" class="block overflow-hidden rounded-[6px] bg-tactas-night transition hover:translate-y-[-1px]">
                      <div class="relative flex h-48 items-center justify-center overflow-hidden bg-[radial-gradient(circle_at_22%_16%,rgba(234,250,106,0.72),transparent_34%),radial-gradient(circle_at_82%_74%,rgba(6,182,212,0.46),transparent_36%),linear-gradient(135deg,#F6F8FB_0%,#DFF7FB_44%,#0F172A_132%)]">
                        <div class="absolute inset-0 opacity-35 [background-image:linear-gradient(to_right,rgba(15,23,42,0.10)_1px,transparent_1px),linear-gradient(to_bottom,rgba(15,23,42,0.08)_1px,transparent_1px)] [background-size:28px_28px]"></div>
                        <div class="relative text-center text-tactas-ink">
                          <p class="text-[30px] font-semibold leading-none tracking-[-0.04em]">Tactas AI</p>
                          <p class="mt-2 font-mono text-[11px] uppercase tracking-[0.34em] text-tactas-accent-strong">Solutions</p>
                        </div>
                      </div>
                    </a>
                    <div class="mt-5">
                      <h3 class="text-[19px] font-semibold leading-tight text-tactas-ink">AI assistants by industry</h3>
                      <p class="mt-2 text-[15px] leading-relaxed text-tactas-muted">
                        Start with the buyer workflow your market already understands: SaaS, ecommerce, legal, healthcare, real estate, or hosting.
                      </p>
                      <a href="/industries" class="mt-5 inline-flex items-center text-[15px] font-semibold text-tactas-primary-strong transition hover:text-tactas-accent">
                        Explore industries
                        <ArrowRight class="ml-1.5 h-3.5 w-3.5" />
                      </a>
                    </div>
                  </div>
                ) : null}

                {group.label === "Resources" ? (
                  <div>
                    <a href="/product/ai-workflow-automation" class="block overflow-hidden rounded-[6px] bg-tactas-night transition hover:translate-y-[-1px]">
                      <div class="relative flex h-48 items-center justify-center overflow-hidden bg-[radial-gradient(circle_at_20%_10%,rgba(6,182,212,0.55),transparent_35%),radial-gradient(circle_at_80%_70%,rgba(124,58,237,0.42),transparent_34%),linear-gradient(135deg,#0F172A_0%,#111827_48%,#E6FBFF_140%)]">
                        <div class="absolute inset-0 opacity-25 [background-image:radial-gradient(circle,rgba(255,255,255,0.8)_1px,transparent_1px)] [background-size:18px_18px]"></div>
                        <div class="relative text-center text-white">
                          <p class="text-[30px] font-semibold leading-none tracking-[-0.04em]">Tactas AI</p>
                          <p class="mt-2 font-mono text-[11px] uppercase tracking-[0.34em] text-white/72">Task Guide</p>
                        </div>
                      </div>
                    </a>
                    <div class="mt-5">
                      <h3 class="text-[19px] font-semibold leading-tight text-tactas-ink">The Business Task Automation Guide</h3>
                      <p class="mt-2 text-[15px] leading-relaxed text-tactas-muted">
                        Explore how managed AI agents turn company knowledge, context, and connected tools into automated work.
                      </p>
                      <a href="/product/ai-workflow-automation" class="mt-5 inline-flex items-center text-[15px] font-semibold text-tactas-primary-strong transition hover:text-tactas-accent">
                        Read the guide
                        <ArrowRight class="ml-1.5 h-3.5 w-3.5" />
                      </a>
                    </div>
                  </div>
                ) : null}

                {group.label === "Company" ? (
                  <div>
                    <a href="/about" class="block overflow-hidden rounded-[6px] bg-tactas-night transition hover:translate-y-[-1px]">
                      <div class="relative flex h-48 items-center justify-center overflow-hidden bg-[radial-gradient(circle_at_18%_18%,rgba(6,182,212,0.42),transparent_36%),radial-gradient(circle_at_88%_76%,rgba(15,23,42,0.72),transparent_38%),linear-gradient(135deg,#F6F8FB_0%,#DFF7FB_42%,#0F172A_132%)]">
                        <div class="absolute inset-0 opacity-35 [background-image:linear-gradient(to_right,rgba(15,23,42,0.10)_1px,transparent_1px),linear-gradient(to_bottom,rgba(15,23,42,0.08)_1px,transparent_1px)] [background-size:28px_28px]"></div>
                        <div class="relative text-center text-tactas-ink">
                          <p class="text-[30px] font-semibold leading-none tracking-[-0.04em]">Tactas AI</p>
                          <p class="mt-2 font-mono text-[11px] uppercase tracking-[0.34em] text-tactas-accent-strong">Company</p>
                        </div>
                      </div>
                    </a>
                    <div class="mt-5">
                      <h3 class="text-[19px] font-semibold leading-tight text-tactas-ink">Built for managed AI agents at work</h3>
                      <p class="mt-2 text-[15px] leading-relaxed text-tactas-muted">
                        Learn how TactasAI helps teams turn business knowledge into useful outputs and action.
                      </p>
                      <a href="/about" class="mt-5 inline-flex items-center text-[15px] font-semibold text-tactas-primary-strong transition hover:text-tactas-accent">
                        About Tactas
                        <ArrowRight class="ml-1.5 h-3.5 w-3.5" />
                      </a>
                    </div>
                  </div>
                ) : null}
              </div>
              )}
            </div>
          </div>
          )}
        </div>
      ))}
    </nav>

    <div class="hidden items-center gap-4 lg:flex">
      <a href={ctaHref} class:list={[
        "inline-flex h-10 items-center justify-center rounded-[3px] px-4 text-[14px] font-semibold text-white transition",
        isDark ? "bg-tactas-violet hover:bg-tactas-violet" : "bg-tactas-ink hover:bg-tactas-accent",
      ]}>
        {ctaLabel}
      </a>
    </div>

    <button
      id="mobile-nav-toggle"
      type="button"
      class:list={[
        "inline-flex h-10 w-10 items-center justify-center rounded-[3px] border lg:hidden",
        isDark ? "border-white/15 bg-white/8 text-white" : "border-black/15 bg-white text-tactas-ink",
