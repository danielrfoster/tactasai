              ) : null}
              {group.columns.map((column) => (
                <div>
                  <p class:list={[
                    "mb-3 text-[11px] font-semibold uppercase tracking-[0.18em]",
                    isDark ? "text-tactas-violet" : "text-tactas-muted",
                  ]}>{column.title}</p>
                  <div class:list={[
                    group.label === "Solutions" ? "grid gap-3.5" : "grid gap-3",
                  ]}>
                    {column.links.map((link) => {
                      const Icon = link.icon;
                      return (
                        <a href={link.href} class:list={[
                          group.label === "Solutions" ? "flex items-center gap-3 text-[15px] font-semibold" : "text-[14px] font-medium",
                          isDark ? "text-white/78" : "text-tactas-ink",
