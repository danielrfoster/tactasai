---
import {
  ArrowRight,
  Banknote,
  BarChart3,
  Bot,
  Briefcase,
  BrainCircuit,
  ChevronDown,
  Code2,
  Database,
  Factory,
  FileText,
  GraduationCap,
  HeartPulse,
  Headphones,
  KeyRound,
  Landmark,
  Mail,
  Menu,
  Megaphone,
  Network,
  Puzzle,
  Search,
  Settings,
  Server,
  ShieldCheck,
  ShoppingBag,
  Sparkles,
  Truck,
  User,
  Users,
  X,
  Zap,
} from "@lucide/astro";
import { getBrandEmail } from "../lib/site";

interface NavColumn {
  title: string;
  links: Array<{ label: string; href: string; description?: string; icon?: typeof Zap; nested?: boolean }>;
}

interface NavGroup {
  label: string;
  href: string;
  simple?: boolean;
  featured?: {
    title: string;
    href: string;
    description: string;
    icon: typeof Zap;
  };
  columns: NavColumn[];
}

interface Props {
  currentPath?: string;
  ctaLabel?: string;
  ctaHref?: string;
  theme?: "dark" | "light";
}

const { currentPath = "/", ctaLabel = "Book a review", ctaHref = "/contact", theme = "light" } = Astro.props;
const brandEmail = getBrandEmail();
const CONTAINER = "mx-auto w-full max-w-[1240px] px-5 sm:px-8 lg:px-10";
const isDark = theme === "dark";

const navGroups: NavGroup[] = [
  {
    label: "Product",
    href: "/#platform",
    columns: [],
  },
  {
    label: "Operations",
    href: "/#solutions",
    columns: [
      {
        title: "Task Outcomes",
        links: [
          { label: "Task Examples", href: "/use-cases", icon: Users },
          { label: "Summarize Changes", href: "/contact", icon: BarChart3 },
          { label: "Answer with Context", href: "/use-cases/ai-customer-support-automation", icon: Headphones },
          { label: "Prepare Next Steps", href: "/use-cases/ai-crm-workflow-automation", icon: Sparkles },
          { label: "Track Open Work", href: "/contact", icon: Search },
          { label: "Create Follow-ups", href: "/contact", nested: true },
          { label: "Update Work Status", href: "/contact", nested: true },
          { label: "Find Business Context", href: "/services/ai-knowledge-base", icon: BrainCircuit },
          { label: "Automate Repeated Tasks", href: "/services/ai-workflow-automation", icon: Zap },
        ],
      },
      {
        title: "Context & Tools",
        links: [
          { label: "Knowledge & Files", href: "/services/ai-knowledge-base", icon: FileText },
          { label: "Messages & Forms", href: "/contact", icon: Mail },
          { label: "Tasks & Projects", href: "/contact", icon: Briefcase },
          { label: "Business Data", href: "/#platform", icon: Database },
          { label: "Connected Tools", href: "/#platform", icon: Puzzle },
          { label: "Automation Steps", href: "/contact", icon: Zap },
        ],
      },
    ],
  },
  {
    label: "Pricing",
    href: "/pricing",
    simple: true,
    columns: [],
  },
  {
    label: "Resources",
    href: "/use-cases",
    columns: [
      {
        title: "Explore",
        links: [
          { label: "Blog", href: "/blog" },
          { label: "Task Examples", href: "/use-cases" },
          { label: "Automation Guide", href: "/services/ai-workflow-automation" },
          { label: "AI Operating Layer", href: "/#platform" },
          { label: "Connected Tools", href: "/#platform" },
          { label: "Contact", href: "/contact" },
        ],
      },
      {
        title: "Engage",
        links: [
          { label: "Task Review", href: "/contact" },
          { label: "Automation Map", href: "/contact" },
          { label: "Company Knowledge Review", href: "/services/ai-knowledge-base" },
          { label: "Tool Connection Review", href: "/contact" },
          { label: "Partner Inquiry", href: "/contact" },
        ],
      },
      {
        title: "Core Areas",
        links: [
          { label: "Managed AI Agents", href: "/services/ai-workflow-automation" },
          { label: "Business Task Automation", href: "/use-cases" },
          { label: "Company Knowledge", href: "/services/ai-knowledge-base" },
          { label: "Connected Business Tools", href: "/#platform" },
          { label: "Work Performance", href: "/#solutions" },
        ],
      },
    ],
  },
  {
    label: "Company",
    href: "/about",
    columns: [
      {
        title: "Company",
        links: [
          { label: "About Tactas AI", href: "/about" },
          { label: "Contact", href: "/contact" },
          { label: "Task Review", href: "/contact" },
          { label: "Implementation", href: "/contact" },
        ],
      },
      {
        title: "Explore",
        links: [
          { label: "Task Examples", href: "/use-cases" },
          { label: "Connected Tools", href: "/#platform" },
          { label: "Company Knowledge", href: "/services/ai-knowledge-base" },
          { label: "Pricing", href: "/pricing" },
        ],
      },
      {
        title: "Trust & Legal",
        links: [
          { label: "Privacy Policy", href: "/privacy" },
          { label: "Terms of Service", href: "/terms" },
          { label: "Refund Policy", href: "/refund-policy" },
          { label: "Security Review", href: "/contact" },
        ],
      },
    ],
  },
];

const isActive = (href: string) => {
  if (href === "/") return currentPath === "/";
  if (href.startsWith("/#")) return false;
  return currentPath === href || currentPath.startsWith(`${href}/`);
};
---

<header
  id="site-header"
  class:list={[
    "sticky top-0 z-[11111] backdrop-blur",
    isDark
      ? "border-b border-white/10 bg-[#050A14]/92 text-white shadow-[0_1px_0_rgba(255,255,255,0.06)]"
      : "border-b border-black/10 bg-white/95 text-[#111111] shadow-[0_1px_0_rgba(0,0,0,0.05)]",
  ]}
>
  <div class={`${CONTAINER} flex h-[64px] items-center justify-between gap-5 lg:h-[68px]`}>
    <a href="/" class="flex min-w-0 items-center gap-3" aria-label="Tactas AI home">
      <img src="/favicon-96x96.png" alt="" width="32" height="32" class="h-8 w-8 rounded-[6px]" aria-hidden="true" loading="eager" decoding="async" />
      <span class:list={[
        "text-[22px] font-semibold leading-none tracking-[-0.03em]",
        isDark ? "text-white" : "text-[#111111]",
      ]}>Tactas AI</span>
    </a>

    <nav class="hidden h-full items-center lg:flex" aria-label="Primary">
      {navGroups.map((group) => (
        <div class="group/nav h-full">
          <a
            href={group.href}
            class:list={[
              "flex h-full items-center gap-1.5 px-3 text-[14px] font-semibold transition",
              isDark ? "text-white/82 hover:text-[#A78BFA]" : "text-[#1f1f1f] hover:text-[#06B6D4]",
              isActive(group.href) ? (isDark ? "text-[#A78BFA]" : "text-[#06B6D4]") : "",
            ]}
          >
            {group.label}
            {group.simple ? null : <ChevronDown class="h-3.5 w-3.5 transition group-hover/nav:rotate-180" stroke-width={1.9} />}
          </a>

          {group.simple ? null : (
          <div class="invisible absolute left-0 top-full w-full translate-y-2 border-y border-black/10 bg-white opacity-0 shadow-[0_26px_70px_-46px_rgba(0,0,0,0.34)] transition duration-150 group-hover/nav:visible group-hover/nav:translate-y-0 group-hover/nav:opacity-100 group-focus-within/nav:visible group-focus-within/nav:translate-y-0 group-focus-within/nav:opacity-100">
            <div class={`${CONTAINER} grid gap-8 py-8 ${group.featured ? "lg:grid-cols-[290px_1fr]" : "lg:grid-cols-1"}`}>
              {group.featured ? (
                <a href={group.featured.href} class="flex min-h-[170px] flex-col justify-between rounded-xl bg-[#f7f7f7] p-5 transition hover:bg-[#f1f1f1]">
                  <span>
                    <span class="mb-5 flex h-12 w-12 items-center justify-center rounded-lg bg-white text-[#06B6D4] shadow-[0_12px_26px_-22px_rgba(0,0,0,0.45)]">
                      <group.featured.icon class="h-5 w-5" stroke-width={1.8} />
                    </span>
                    <span class="block text-[17px] font-semibold tracking-[-0.02em] text-[#111111]">{group.featured.title}</span>
                    <span class="mt-2 block text-[13px] leading-relaxed text-[#5f5f5f]">{group.featured.description}</span>
                  </span>
                  <span class="mt-5 inline-flex items-center text-[13px] font-semibold text-[#06B6D4]">
                    Request a demo
                    <ArrowRight class="ml-1.5 h-3.5 w-3.5" />
                  </span>
                </a>
              ) : null}

              {group.label === "Product" ? (
                <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_320px]">
                  <div>
                    <div class="grid gap-8 lg:grid-cols-[250px_1fr] lg:items-start">
                      <p class="text-[20px] font-bold uppercase tracking-[-0.02em] text-[#0F172A]">Tactas AI Platform</p>
                      <a href="/#platform" class="flex h-14 items-center justify-between rounded-[10px] bg-[linear-gradient(90deg,#EAFA6A_0%,#F7E7FF_48%,#F4F1B4_100%)] px-5 text-[20px] font-bold text-[#0F172A] transition hover:brightness-[0.98]">
                        Platform Overview
                        <ArrowRight class="h-5 w-5" stroke-width={1.8} />
                      </a>
                    </div>

                    <div class="mt-7 grid gap-8 lg:grid-cols-3">
                      {[
                        {
                          title: "Work Console",
                          description: "Turn requests into useful work",
                          href: "/#platform",
                          icon: Sparkles,
                          links: ["Requests", "Outputs", "Next steps"],
                        },
                        {
                          title: "AI Agents",
                          description: "Automate business tasks",
                          href: "/services/ai-workflow-automation",
                          icon: Bot,
                          links: ["Task setup", "Automation steps", "Connected tools", "Agent library"],
                        },
                        {
                          title: "Knowledge Layer",
                          description: "Context for business tasks",
                          href: "/services/ai-knowledge-base",
                          icon: Search,
                          links: ["Company knowledge", "Business context", "Source context", "Document search"],
                        },
                      ].map((item) => {
                        const Icon = item.icon;
                        return (
                          <div>
                            <a href={item.href} class="group/item flex items-start gap-3">
                              <Icon class="mt-0.5 h-5 w-5 shrink-0 text-[#3B49FF]" stroke-width={1.9} />
                              <span>
                                <span class="block text-[20px] font-bold leading-tight text-[#3341FF] group-hover/item:text-[#06B6D4]">{item.title}</span>
                                <span class="mt-1 block text-[14px] leading-relaxed text-[#7a6f63]">{item.description}</span>
                              </span>
                            </a>
                            <div class="mt-5 grid gap-3 text-[15px] font-semibold text-[#111111]">
                              {item.links.map((link) => (
                                <a href={item.href} class="transition hover:text-[#06B6D4]">{link}</a>
                              ))}
                            </div>
                          </div>
                        );
                      })}
                    </div>

                    <div class="mt-10 grid gap-6 border-t border-black/12 pt-8 sm:grid-cols-2 lg:grid-cols-3">
                      {[
                        ["Connectors & Actions", "Connect to your apps", Puzzle],
                        ["Model Hub", "Use the right model for each task", BrainCircuit],
                        ["APIs", "Build AI task experiences", Server],
                        ["Security", "Safely scale AI at work", KeyRound],
                        ["Agentic Engine", "Plan and adapt over company context", Network],
                      ].map(([title, body, Icon]) => (
                        <a href="/#platform" class="group/item flex gap-3">
                          <Icon class="mt-1 h-4 w-4 shrink-0 text-[#111111]" stroke-width={1.9} />
                          <span>
                            <span class="block text-[15px] font-bold text-[#111111] group-hover/item:text-[#06B6D4]">{title}</span>
                            <span class="mt-1 block text-[14px] leading-relaxed text-[#7a6f63]">{body}</span>
                          </span>
                        </a>
                      ))}
                    </div>
                  </div>

                  <aside class="border-l border-black/12 bg-[#F3F3EF] px-8 py-5">
                    <p class="text-[20px] font-bold uppercase tracking-[-0.02em] text-[#0F172A]">Tactas where you work</p>
                    <div class="mt-8 grid gap-6">
                      {[
                        ["Tactas in Slack", "slack"],
                        ["Tactas in Microsoft Teams", "microsoftteams"],
                        ["Tactas in Zoom", "zoom"],
                        ["Tactas in Salesforce", "salesforce"],
                        ["Tactas in ServiceNow", "servicenow"],
                        ["Tactas in Zendesk", "zendesk"],
                        ["Tactas in GitHub", "github"],
                        ["Tactas in Miro", "miro"],
                      ].map(([label, slug]) => (
                        <a href="/contact" class="flex items-center gap-3 text-[15px] font-semibold text-[#111111] transition hover:text-[#06B6D4]">
                          <img src={`https://cdn.simpleicons.org/${slug}`} alt="" loading="lazy" class="h-4 w-4 object-contain" />
                          {label}
                        </a>
                      ))}
                      <a href="/contact" class="flex items-center gap-3 text-[15px] font-semibold text-[#111111] transition hover:text-[#06B6D4]">
                        <Puzzle class="h-4 w-4 text-[#111111]" stroke-width={1.8} />
                        Browser Extension
                      </a>
                    </div>
                  </aside>
                </div>
              ) : (
              <div class={`grid ${
                group.label === "Operations" || group.label === "Resources" || group.label === "Company"
                    ? "gap-x-16 gap-y-8 lg:grid-cols-[minmax(0,820px)_334px]"
                    : `gap-7 ${group.columns.length >= 4 ? "lg:grid-cols-4" : group.columns.length === 3 ? "lg:grid-cols-3" : "lg:grid-cols-2"}`
              }`}>
                <div class={`grid ${
                  group.label === "Operations"
                    ? "gap-x-16 gap-y-8 lg:grid-cols-2"
                    : group.label === "Resources" || group.label === "Company"
                      ? "gap-x-14 gap-y-8 lg:grid-cols-3"
                      : "contents"
                }`}>
                {group.columns.map((column) => (
                  <div class:list={[
                    group.label === "Operations" || group.label === "Resources" || group.label === "Company" ? "" : "border-l border-black/10 pl-5 first:border-l-0 first:pl-0",
                  ]}>
                    <p class:list={[
                      group.label === "Operations"
                        ? "mb-6 text-[20px] font-bold uppercase tracking-[-0.02em] text-[#2b2b2b]"
                        : group.label === "Resources" || group.label === "Company"
                          ? "mb-6 text-[20px] font-bold uppercase tracking-[-0.02em] text-[#0F172A]"
                        : "mb-4 text-[12px] font-semibold uppercase tracking-[0.18em] text-[#6d6d6d]",
                    ]}>{column.title}</p>
                    <ul class:list={[
                      group.label === "Operations" ? "grid gap-4" : group.label === "Resources" || group.label === "Company" ? "grid gap-4" : "grid gap-3",
                    ]}>
                      {column.links.map((link) => {
                        const Icon = link.icon;
                        return (
                          <li>
                            <a
                              href={link.href}
                              class:list={[
                                "group/item text-[#151515] transition hover:text-[#06B6D4]",
                                group.label === "Operations"
                                  ? "flex min-h-5 items-center gap-4 text-[16px] font-semibold leading-tight"
                                  : group.label === "Resources" || group.label === "Company"
                                    ? "block text-[15px] font-semibold leading-tight"
                                  : "block text-[14px] leading-snug",
                              ]}
                            >
                              {group.label === "Operations" ? (
                                Icon ? (
                                  <Icon class="h-4 w-4 shrink-0 text-[#8c8c8c] transition group-hover/item:text-[#06B6D4]" stroke-width={2} />
                                ) : (
                                  <span class="h-4 w-4 shrink-0" aria-hidden="true"></span>
                                )
                              ) : null}
                              <span>{link.label}</span>
                              {link.description ? <span class="mt-1 block text-[12px] leading-relaxed text-[#6a6a6a] group-hover/item:text-[#4f4f4f]">{link.description}</span> : null}
                            </a>
                          </li>
                        );
                      })}
                    </ul>
                  </div>
                ))}
                </div>

                {group.label === "Operations" ? (
                  <div>
                    <a href="/services/ai-workflow-automation" class="block overflow-hidden rounded-[6px] bg-[#0F172A] transition hover:translate-y-[-1px]">
                      <div class="relative flex h-48 items-center justify-center overflow-hidden bg-[radial-gradient(circle_at_22%_16%,rgba(234,250,106,0.72),transparent_34%),radial-gradient(circle_at_82%_74%,rgba(6,182,212,0.46),transparent_36%),linear-gradient(135deg,#F6F8FB_0%,#DFF7FB_44%,#0F172A_132%)]">
                        <div class="absolute inset-0 opacity-35 [background-image:linear-gradient(to_right,rgba(15,23,42,0.10)_1px,transparent_1px),linear-gradient(to_bottom,rgba(15,23,42,0.08)_1px,transparent_1px)] [background-size:28px_28px]"></div>
                        <div class="relative text-center text-[#0F172A]">
                          <p class="text-[30px] font-semibold leading-none tracking-[-0.04em]">Tactas AI</p>
                          <p class="mt-2 font-mono text-[11px] uppercase tracking-[0.34em] text-[#0E7490]">Operations</p>
                        </div>
                      </div>
                    </a>
                    <div class="mt-5">
                      <h3 class="text-[19px] font-semibold leading-tight text-[#0F172A]">Business Task Automation</h3>
                      <p class="mt-2 text-[15px] leading-relaxed text-[#343434]">
                        Agents that use company knowledge, connected tools, and business context to turn requests into useful work.
                      </p>
                      <a href="/services/ai-workflow-automation" class="mt-5 inline-flex items-center text-[15px] font-semibold text-[#2563EB] transition hover:text-[#06B6D4]">
                        Explore automation
                        <ArrowRight class="ml-1.5 h-3.5 w-3.5" />
                      </a>
                    </div>
                  </div>
                ) : null}

                {group.label === "Resources" ? (
                  <div>
                    <a href="/services/ai-workflow-automation" class="block overflow-hidden rounded-[6px] bg-[#0F172A] transition hover:translate-y-[-1px]">
                      <div class="relative flex h-48 items-center justify-center overflow-hidden bg-[radial-gradient(circle_at_20%_10%,rgba(6,182,212,0.55),transparent_35%),radial-gradient(circle_at_80%_70%,rgba(124,58,237,0.42),transparent_34%),linear-gradient(135deg,#0F172A_0%,#111827_48%,#E6FBFF_140%)]">
                        <div class="absolute inset-0 opacity-25 [background-image:radial-gradient(circle,rgba(255,255,255,0.8)_1px,transparent_1px)] [background-size:18px_18px]"></div>
                        <div class="relative text-center text-white">
                          <p class="text-[30px] font-semibold leading-none tracking-[-0.04em]">Tactas AI</p>
                          <p class="mt-2 font-mono text-[11px] uppercase tracking-[0.34em] text-white/72">Task Guide</p>
                        </div>
                      </div>
                    </a>
                    <div class="mt-5">
                      <h3 class="text-[19px] font-semibold leading-tight text-[#0F172A]">The Business Task Automation Guide</h3>
                      <p class="mt-2 text-[15px] leading-relaxed text-[#343434]">
                        Explore how managed AI agents turn company knowledge, context, and connected tools into automated work.
                      </p>
                      <a href="/services/ai-workflow-automation" class="mt-5 inline-flex items-center text-[15px] font-semibold text-[#2563EB] transition hover:text-[#06B6D4]">
                        Read the guide
                        <ArrowRight class="ml-1.5 h-3.5 w-3.5" />
                      </a>
                    </div>
                  </div>
                ) : null}

                {group.label === "Company" ? (
                  <div>
                    <a href="/about" class="block overflow-hidden rounded-[6px] bg-[#0F172A] transition hover:translate-y-[-1px]">
                      <div class="relative flex h-48 items-center justify-center overflow-hidden bg-[radial-gradient(circle_at_18%_18%,rgba(6,182,212,0.42),transparent_36%),radial-gradient(circle_at_88%_76%,rgba(15,23,42,0.72),transparent_38%),linear-gradient(135deg,#F6F8FB_0%,#DFF7FB_42%,#0F172A_132%)]">
                        <div class="absolute inset-0 opacity-35 [background-image:linear-gradient(to_right,rgba(15,23,42,0.10)_1px,transparent_1px),linear-gradient(to_bottom,rgba(15,23,42,0.08)_1px,transparent_1px)] [background-size:28px_28px]"></div>
                        <div class="relative text-center text-[#0F172A]">
                          <p class="text-[30px] font-semibold leading-none tracking-[-0.04em]">Tactas AI</p>
                          <p class="mt-2 font-mono text-[11px] uppercase tracking-[0.34em] text-[#0E7490]">Company</p>
                        </div>
                      </div>
                    </a>
                    <div class="mt-5">
                      <h3 class="text-[19px] font-semibold leading-tight text-[#0F172A]">Built for managed AI agents at work</h3>
                      <p class="mt-2 text-[15px] leading-relaxed text-[#343434]">
                        Learn how Tactas helps businesses turn company knowledge into action and automate everyday work.
                      </p>
                      <a href="/about" class="mt-5 inline-flex items-center text-[15px] font-semibold text-[#2563EB] transition hover:text-[#06B6D4]">
                        About Tactas
                        <ArrowRight class="ml-1.5 h-3.5 w-3.5" />
                      </a>
                    </div>
                  </div>
                ) : null}
              </div>
              )}
            </div>
          </div>
          )}
        </div>
      ))}
    </nav>

    <div class="hidden items-center gap-4 lg:flex">
      <a href={ctaHref} class:list={[
        "inline-flex h-10 items-center justify-center rounded-[3px] px-4 text-[14px] font-semibold text-white transition",
        isDark ? "bg-[#7C3AED] hover:bg-[#8B5CF6]" : "bg-[#1f1f1f] hover:bg-[#06B6D4]",
      ]}>
        {ctaLabel}
      </a>
    </div>

    <button
      id="mobile-nav-toggle"
      type="button"
      class:list={[
        "inline-flex h-10 w-10 items-center justify-center rounded-[3px] border lg:hidden",
        isDark ? "border-white/15 bg-white/8 text-white" : "border-black/15 bg-white text-[#111111]",
      ]}
      aria-label="Open navigation"
      aria-expanded="false"
      aria-controls="mobile-nav"
    >
      <Menu class="h-5 w-5 mobile-open-icon" />
      <X class="hidden h-5 w-5 mobile-close-icon" />
    </button>
  </div>

  <div id="mobile-nav" class:list={[
    "hidden border-t lg:hidden",
    isDark ? "border-white/10 bg-[#050A14]" : "border-black/10 bg-white",
  ]}>
    <div class={`${CONTAINER} max-h-[calc(100vh-72px)] overflow-y-auto py-5`}>
      <div class="mb-5 grid gap-3 text-[13px] font-semibold sm:grid-cols-2">
        <a href={`mailto:${brandEmail}`} class:list={[
          "rounded-[3px] border px-3 py-2.5 text-center",
          isDark ? "border-white/15 text-white" : "border-black/15 text-[#111111]",
        ]} data-mobile-link>Email us</a>
        <a href={ctaHref} class:list={[
          "rounded-[3px] px-3 py-2.5 text-center text-white",
          isDark ? "bg-[#7C3AED]" : "bg-[#1f1f1f]",
        ]} data-mobile-link>{ctaLabel}</a>
      </div>

      <div class:list={[
        "divide-y border-y",
        isDark ? "divide-white/10 border-white/10" : "divide-black/10 border-black/10",
      ]}>
        {navGroups.map((group) => (
          group.simple ? (
            <a href={group.href} class:list={[
              "flex items-center justify-between py-4 text-[16px] font-semibold",
              isDark ? "text-white" : "text-[#111111]",
            ]} data-mobile-link>
              {group.label}
