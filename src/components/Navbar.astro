---
import {
  ArrowRight,
  Briefcase,
  BrainCircuit,
  ChevronDown,
  FileText,
  HeartPulse,
  Menu,
  Server,
  ShieldCheck,
  ShoppingBag,
  X,
  Zap,
} from "@lucide/astro";
import { getBrandEmail } from "../lib/site";

interface NavColumn {
  title: string;
  links: Array<{ label: string; href: string; description?: string }>;
}

interface NavGroup {
  label: string;
  href: string;
  featured?: {
    title: string;
    href: string;
    description: string;
    icon: typeof Zap;
  };
  columns: NavColumn[];
}

interface Props {
  currentPath?: string;
  ctaLabel?: string;
  ctaHref?: string;
  theme?: "dark" | "light";
}

const { currentPath = "/", ctaLabel = "Book demo", ctaHref = "#contact", theme = "light" } = Astro.props;
const brandEmail = getBrandEmail();
const CONTAINER = "mx-auto w-full max-w-[1240px] px-5 sm:px-8 lg:px-10";
const isDark = theme === "dark";

const navGroups: NavGroup[] = [
  {
    label: "Services",
    href: "/#solutions",
    featured: {
      title: "AI Knowledge Base",
      href: "/services/ai-knowledge-base",
      description: "Managed RAG, enterprise AI search, document Q&A, cited answers, permissions, APIs, and ongoing retrieval support.",
      icon: BrainCircuit,
    },
    columns: [
      {
        title: "Core services",
        links: [
          { label: "AI Workflow Automation", href: "/services/ai-workflow-automation", description: "Agents that run business workflows" },
          { label: "AI Knowledge Base", href: "/services/ai-knowledge-base", description: "Managed RAG and document search" },
          { label: "AI Document Processing", href: "/#contact", description: "OCR, extraction, validation, and routing" },
        ],
      },
      {
        title: "Operations",
        links: [
          { label: "Customer Support Assistant", href: "/use-cases/ai-customer-support-automation", description: "Triage, draft, escalate, and update systems" },
          { label: "Back-Office Automation", href: "/use-cases/ai-back-office-automation", description: "Invoices, records, approvals, and admin workflows" },
          { label: "CRM & Sales Assistant", href: "/use-cases/ai-crm-workflow-automation", description: "Lead qualification, follow-up, and CRM updates" },
        ],
      },
      {
        title: "Control layer",
        links: [
          { label: "Agent Monitoring", href: "/#why-choose", description: "Logs, visibility, and exception review" },
          { label: "Human Approval Gates", href: "/#why-choose", description: "Keep sensitive work under control" },
          { label: "Implementation Support", href: "/#contact", description: "Managed setup and ongoing tuning" },
        ],
      },
    ],
  },
  {
    label: "Industries",
    href: "/industries",
    featured: {
      title: "Industry workflows",
      href: "/industries",
      description: "Start with the operating patterns where supervised AI agents create clear business value.",
      icon: Briefcase,
    },
    columns: [
      {
        title: "Live pages",
        links: [
          { label: "Ecommerce", href: "/industries/ecommerce", description: "Support, order, return, and customer workflows" },
          { label: "Healthcare", href: "/industries/healthcare", description: "Patient intake, reminders, forms, and handoff" },
          { label: "Professional Services", href: "/industries/professional-services", description: "Client intake, documents, CRM, and follow-up" },
        ],
      },
      {
        title: "Common fits",
        links: [
          { label: "SaaS Operations", href: "/#solutions", description: "Support, docs, CRM, and internal tooling" },
          { label: "Finance & Admin", href: "/#solutions", description: "Invoices, approvals, reconciliation, and reports" },
          { label: "Logistics Teams", href: "/#contact", description: "Tracking, exception handling, and updates" },
        ],
      },
    ],
  },
  {
    label: "How It Works",
    href: "/#platform",
    featured: {
      title: "Managed implementation",
      href: "/#contact",
      description: "Tactas maps the workflow, connects the tools, adds controls, launches supervised, and keeps improving it.",
      icon: Zap,
    },
    columns: [
      {
        title: "Process",
        links: [
          { label: "Discovery", href: "/#contact", description: "Choose one workflow worth automating" },
          { label: "Build", href: "/#platform", description: "Prepare tools, data, SOPs, and prompts" },
          { label: "Integrate", href: "/#platform", description: "Connect APIs, documents, CRM, and helpdesk" },
        ],
      },
      {
        title: "Operate",
        links: [
          { label: "Monitor", href: "/#why-choose", description: "Track actions, exceptions, and quality" },
          { label: "Human Review", href: "/#why-choose", description: "Route sensitive decisions to the right owner" },
          { label: "Improve", href: "/#contact", description: "Tune retrieval, rules, and workflow behavior" },
        ],
      },
    ],
  },
  {
    label: "Resources",
    href: "/#faq",
    columns: [
      {
        title: "Explore",
        links: [
          { label: "Use Cases", href: "/use-cases" },
          { label: "Reference Architecture", href: "/#platform" },
          { label: "FAQ", href: "/#faq" },
        ],
      },
      {
        title: "Service guides",
        links: [
          { label: "AI Knowledge Base", href: "/services/ai-knowledge-base" },
          { label: "Workflow Automation", href: "/services/ai-workflow-automation" },
          { label: "Customer Support Automation", href: "/use-cases/ai-customer-support-automation" },
          { label: "Control & Monitoring", href: "/#why-choose" },
        ],
      },
    ],
  },
  {
    label: "Company",
    href: "/about",
    columns: [
      {
        title: "Company info",
        links: [
          { label: "About Tactas AI", href: "/about" },
          { label: "Industries", href: "/industries" },
          { label: "Ecommerce", href: "/industries/ecommerce" },
          { label: "Healthcare", href: "/industries/healthcare" },
          { label: "Professional services", href: "/industries/professional-services" },
        ],
      },
      {
        title: "Trust, privacy, & safety",
        links: [
          { label: "Privacy Policy", href: "/privacy" },
          { label: "Terms of Service", href: "/terms" },
          { label: "Contact", href: "#contact" },
        ],
      },
    ],
  },
];

const isActive = (href: string) => {
  if (href === "/") return currentPath === "/";
  if (href.startsWith("/#")) return false;
  return currentPath === href || currentPath.startsWith(`${href}/`);
};
---

<header
  id="site-header"
  class:list={[
    "sticky top-0 z-[11111] backdrop-blur",
    isDark
      ? "border-b border-white/10 bg-[#050A14]/92 text-white shadow-[0_1px_0_rgba(255,255,255,0.06)]"
      : "border-b border-black/10 bg-white/95 text-[#111111] shadow-[0_1px_0_rgba(0,0,0,0.05)]",
  ]}
>
  <div class={`${CONTAINER} flex h-[64px] items-center justify-between gap-5 lg:h-[68px]`}>
    <a href="/" class="flex min-w-0 items-center gap-3" aria-label="Tactas AI home">
      <img src="/favicon-96x96.png" alt="" width="32" height="32" class="h-8 w-8 rounded-[6px]" aria-hidden="true" loading="eager" decoding="async" />
      <span class:list={[
        "text-[22px] font-semibold leading-none tracking-[-0.03em]",
        isDark ? "text-white" : "text-[#111111]",
      ]}>Tactas AI</span>
    </a>

    <nav class="hidden h-full items-center lg:flex" aria-label="Primary">
      {navGroups.map((group) => (
        <div class="group/nav h-full">
          <a
            href={group.href}
            class:list={[
              "flex h-full items-center gap-1.5 px-3 text-[14px] font-semibold transition",
              isDark ? "text-white/82 hover:text-[#A78BFA]" : "text-[#1f1f1f] hover:text-[#06B6D4]",
              isActive(group.href) ? (isDark ? "text-[#A78BFA]" : "text-[#06B6D4]") : "",
            ]}
          >
            {group.label}
            <ChevronDown class="h-3.5 w-3.5 transition group-hover/nav:rotate-180" stroke-width={1.9} />
          </a>

          <div class="invisible absolute left-0 top-full w-full translate-y-2 border-y border-black/10 bg-white opacity-0 shadow-[0_26px_70px_-46px_rgba(0,0,0,0.34)] transition duration-150 group-hover/nav:visible group-hover/nav:translate-y-0 group-hover/nav:opacity-100 group-focus-within/nav:visible group-focus-within/nav:translate-y-0 group-focus-within/nav:opacity-100">
            <div class={`${CONTAINER} grid gap-8 py-8 ${group.featured ? "lg:grid-cols-[290px_1fr]" : "lg:grid-cols-1"}`}>
              {group.featured ? (
                <a href={group.featured.href} class="flex min-h-[170px] flex-col justify-between rounded-xl bg-[#f7f7f7] p-5 transition hover:bg-[#f1f1f1]">
                  <span>
                    <span class="mb-5 flex h-12 w-12 items-center justify-center rounded-lg bg-white text-[#06B6D4] shadow-[0_12px_26px_-22px_rgba(0,0,0,0.45)]">
                      <group.featured.icon class="h-5 w-5" stroke-width={1.8} />
                    </span>
                    <span class="block text-[17px] font-semibold tracking-[-0.02em] text-[#111111]">{group.featured.title}</span>
                    <span class="mt-2 block text-[13px] leading-relaxed text-[#5f5f5f]">{group.featured.description}</span>
                  </span>
                  <span class="mt-5 inline-flex items-center text-[13px] font-semibold text-[#06B6D4]">
                    Request a demo
                    <ArrowRight class="ml-1.5 h-3.5 w-3.5" />
                  </span>
                </a>
              ) : null}

              <div class={`grid gap-7 ${group.columns.length >= 4 ? "lg:grid-cols-4" : group.columns.length === 3 ? "lg:grid-cols-3" : "lg:grid-cols-2"}`}>
                {group.columns.map((column) => (
                  <div class="border-l border-black/10 pl-5 first:border-l-0 first:pl-0">
                    <p class="mb-4 text-[12px] font-semibold uppercase tracking-[0.18em] text-[#6d6d6d]">{column.title}</p>
                    <ul class="grid gap-3">
                      {column.links.map((link) => (
                        <li>
                          <a href={link.href} class="group/item block text-[14px] leading-snug text-[#222222] transition hover:text-[#06B6D4]">
                            <span class="font-semibold">{link.label}</span>
                            {link.description ? <span class="mt-1 block text-[12px] leading-relaxed text-[#6a6a6a] group-hover/item:text-[#4f4f4f]">{link.description}</span> : null}
                          </a>
                        </li>
                      ))}
                    </ul>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      ))}
    </nav>

    <div class="hidden items-center gap-4 lg:flex">
      <a href={ctaHref} class:list={[
        "inline-flex h-10 items-center justify-center rounded-[3px] px-4 text-[14px] font-semibold text-white transition",
        isDark ? "bg-[#7C3AED] hover:bg-[#8B5CF6]" : "bg-[#1f1f1f] hover:bg-[#06B6D4]",
      ]}>
        {ctaLabel}
      </a>
    </div>

    <button
      id="mobile-nav-toggle"
      type="button"
      class:list={[
        "inline-flex h-10 w-10 items-center justify-center rounded-[3px] border lg:hidden",
        isDark ? "border-white/15 bg-white/8 text-white" : "border-black/15 bg-white text-[#111111]",
      ]}
      aria-label="Open navigation"
      aria-expanded="false"
      aria-controls="mobile-nav"
    >
      <Menu class="h-5 w-5 mobile-open-icon" />
      <X class="hidden h-5 w-5 mobile-close-icon" />
    </button>
  </div>

  <div id="mobile-nav" class:list={[
    "hidden border-t lg:hidden",
    isDark ? "border-white/10 bg-[#050A14]" : "border-black/10 bg-white",
  ]}>
    <div class={`${CONTAINER} max-h-[calc(100vh-72px)] overflow-y-auto py-5`}>
      <div class="mb-5 grid gap-3 text-[13px] font-semibold sm:grid-cols-2">
        <a href={`mailto:${brandEmail}`} class:list={[
          "rounded-[3px] border px-3 py-2.5 text-center",
          isDark ? "border-white/15 text-white" : "border-black/15 text-[#111111]",
        ]} data-mobile-link>Email us</a>
        <a href={ctaHref} class:list={[
          "rounded-[3px] px-3 py-2.5 text-center text-white",
          isDark ? "bg-[#7C3AED]" : "bg-[#1f1f1f]",
        ]} data-mobile-link>{ctaLabel}</a>
      </div>

      <div class:list={[
        "divide-y border-y",
        isDark ? "divide-white/10 border-white/10" : "divide-black/10 border-black/10",
      ]}>
        {navGroups.map((group) => (
          <details class="group/mobile">
            <summary class:list={[
              "flex cursor-pointer list-none items-center justify-between py-4 text-[16px] font-semibold",
              isDark ? "text-white" : "text-[#111111]",
            ]}>
              {group.label}
              <ChevronDown class="h-4 w-4 transition group-open/mobile:rotate-180" stroke-width={1.8} />
            </summary>
            <div class="grid gap-5 pb-5">
              {group.featured ? (
                <a href={group.featured.href} class:list={[
                  "rounded-lg p-4",
                  isDark ? "border border-white/10 bg-white/[0.04]" : "bg-[#f7f7f7]",
                ]} data-mobile-link>
                  <span class:list={[
                    "block text-[15px] font-semibold",
                    isDark ? "text-white" : "text-[#111111]",
                  ]}>{group.featured.title}</span>
                  <span class:list={[
                    "mt-1 block text-[13px] leading-relaxed",
                    isDark ? "text-white/62" : "text-[#5f5f5f]",
                  ]}>{group.featured.description}</span>
                </a>
              ) : null}
              {group.columns.map((column) => (
                <div>
                  <p class:list={[
                    "mb-3 text-[11px] font-semibold uppercase tracking-[0.18em]",
                    isDark ? "text-[#A78BFA]" : "text-[#6d6d6d]",
                  ]}>{column.title}</p>
                  <div class="grid gap-3">
                    {column.links.map((link) => (
                      <a href={link.href} class:list={[
                        "text-[14px] font-medium",
                        isDark ? "text-white/78" : "text-[#222222]",
                      ]} data-mobile-link>{link.label}</a>
                    ))}
                  </div>
                </div>
              ))}
            </div>
          </details>
        ))}
      </div>

      <div class:list={[
        "mt-5 grid gap-3 text-[14px]",
        isDark ? "text-white/70" : "text-[#4f4f4f]",
      ]}>
        <a href="/#solutions" class="inline-flex items-center gap-2" data-mobile-link>
          <Zap class="h-4 w-4 text-[#06B6D4]" stroke-width={1.8} />
          Services
        </a>
        <a href="/services/ai-knowledge-base" class="inline-flex items-center gap-2" data-mobile-link>
          <BrainCircuit class="h-4 w-4 text-[#06B6D4]" stroke-width={1.8} />
          AI Knowledge Base
        </a>
        <a href="/industries/ecommerce" class="inline-flex items-center gap-2" data-mobile-link>
          <ShoppingBag class="h-4 w-4 text-[#06B6D4]" stroke-width={1.8} />
          Ecommerce
        </a>
        <a href="/industries/healthcare" class="inline-flex items-center gap-2" data-mobile-link>
          <HeartPulse class="h-4 w-4 text-[#06B6D4]" stroke-width={1.8} />
          Healthcare
        </a>
        <a href="/industries/professional-services" class="inline-flex items-center gap-2" data-mobile-link>
          <Briefcase class="h-4 w-4 text-[#06B6D4]" stroke-width={1.8} />
          Professional services
        </a>
        <a href="/#platform" class="inline-flex items-center gap-2" data-mobile-link>
          <Server class="h-4 w-4 text-[#06B6D4]" stroke-width={1.8} />
          How It Works
        </a>
        <a href="/#why-choose" class="inline-flex items-center gap-2" data-mobile-link>
          <ShieldCheck class="h-4 w-4 text-[#06B6D4]" stroke-width={1.8} />
          Control
        </a>
        <a href="/#faq" class="inline-flex items-center gap-2" data-mobile-link>
          <FileText class="h-4 w-4 text-[#06B6D4]" stroke-width={1.8} />
          Resources
        </a>
      </div>
    </div>
  </div>
</header>

<script is:inline>
  const toggle = document.getElementById("mobile-nav-toggle");
  const nav = document.getElementById("mobile-nav");
  const openIcon = toggle?.querySelector(".mobile-open-icon");
  const closeIcon = toggle?.querySelector(".mobile-close-icon");
  const mobileLinks = nav?.querySelectorAll("[data-mobile-link]");
  let mobileOpen = false;

  const syncMobile = () => {
    if (!toggle || !nav || !openIcon || !closeIcon) return;
    toggle.setAttribute("aria-expanded", mobileOpen ? "true" : "false");
    toggle.setAttribute("aria-label", mobileOpen ? "Close navigation" : "Open navigation");
    nav.classList.toggle("hidden", !mobileOpen);
    openIcon.classList.toggle("hidden", mobileOpen);
    closeIcon.classList.toggle("hidden", !mobileOpen);
    document.body.style.overflow = mobileOpen ? "hidden" : "";
  };

  syncMobile();

  toggle?.addEventListener("click", () => {
    mobileOpen = !mobileOpen;
    syncMobile();
  });

  mobileLinks?.forEach((link) => {
    link.addEventListener("click", () => {
      mobileOpen = false;
      syncMobile();
    });
  });
</script>
