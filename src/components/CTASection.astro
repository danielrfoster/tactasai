---
import { ArrowRight } from "@lucide/astro";

interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  primaryLabel?: string;
  primaryHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
  contained?: boolean;
  sectionClass?: string;
  containerClass?: string;
  cardClass?: string;
  titleClass?: string;
  descriptionClass?: string;
  actionsClass?: string;
  primaryClass?: string;
  secondaryClass?: string;
  showPrimaryArrow?: boolean;
}

const {
  eyebrow,
  title,
  description,
  primaryLabel,
  primaryHref = "/contact",
  secondaryLabel,
  secondaryHref = "/contact",
  contained = true,
  sectionClass = "bg-tactas-bg",
  containerClass = "tactas-container py-16 lg:py-20",
  cardClass = "",
  titleClass,
  descriptionClass = "tactas-body mt-5 max-w-[42rem] text-[17px]",
  actionsClass = "mt-7 flex flex-col gap-3 sm:flex-row sm:items-center",
  primaryClass = "tactas-button-primary",
  secondaryClass = "tactas-button-secondary",
  showPrimaryArrow = false,
} = Astro.props;

const hasAside = Astro.slots.has("aside");
const hasDefault = Astro.slots.has("default");
const hasActions = Boolean(primaryLabel || secondaryLabel);
const resolvedTitleClass =
  titleClass ??
  (hasAside
    ? "tactas-display max-w-[760px] text-[42px] sm:text-[58px]"
    : "tactas-display text-[clamp(1.8rem,4vw,2.8rem)]");
---

<section class:list={[sectionClass]}>
  <div class:list={[contained ? containerClass : ""]}>
    <div
      class:list={[
        "tactas-card-strong p-7 sm:p-9",
        hasAside ? "grid gap-8 lg:grid-cols-[1fr_360px] lg:items-center" : "",
        cardClass,
      ]}
    >
      <div>
        {eyebrow ? <p class="tactas-kicker">{eyebrow}</p> : null}
        <h2 class:list={[eyebrow ? "mt-4" : "", resolvedTitleClass]}>{title}</h2>
        {description ? <p class={descriptionClass}>{description}</p> : null}
        {hasDefault ? <slot /> : null}

        {hasActions ? (
          <div class={actionsClass}>
            {primaryLabel ? (
              <a href={primaryHref} class={primaryClass}>
                {primaryLabel}
                {showPrimaryArrow ? <ArrowRight class="ml-2 h-4 w-4" stroke-width={2} /> : null}
              </a>
            ) : null}
            {secondaryLabel ? (
              <a href={secondaryHref} class={secondaryClass}>
                {secondaryLabel}
              </a>
            ) : null}
          </div>
        ) : null}
      </div>

      {hasAside ? <slot name="aside" /> : null}
    </div>
  </div>
</section>
