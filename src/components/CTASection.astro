---
import { ArrowRight } from "@lucide/astro";

interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  primaryLabel?: string;
  primaryHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
  contained?: boolean;
  sectionClass?: string;
  containerClass?: string;
  cardClass?: string;
  titleClass?: string;
  descriptionClass?: string;
  actionsClass?: string;
  primaryClass?: string;
  secondaryClass?: string;
  showPrimaryArrow?: boolean;
}

const {
  eyebrow,
  title,
  description,
  primaryLabel,
  primaryHref = "/contact",
  secondaryLabel,
  secondaryHref = "/contact",
  contained = true,
  sectionClass = "bg-[#F6F8FB]",
  containerClass = "mx-auto w-full max-w-[1240px] px-5 py-16 sm:px-8 lg:px-10 lg:py-20",
  cardClass = "",
  titleClass,
  descriptionClass = "mt-5 max-w-[42rem] text-[17px] leading-relaxed text-[#475569]",
  actionsClass = "mt-7 flex flex-col gap-3 sm:flex-row sm:items-center",
  primaryClass = "inline-flex h-12 items-center justify-center rounded-[8px] bg-[#2F66FF] px-6 text-[14px] font-semibold text-white shadow-[0_16px_34px_-24px_rgba(47,102,255,0.85)] transition hover:bg-[#0EA5E9]",
  secondaryClass = "inline-flex h-12 items-center justify-center rounded-[8px] border border-[#D9CFAE] bg-white px-6 text-[14px] font-semibold text-[#07324A] transition hover:border-[#2F66FF] hover:text-[#2F66FF]",
  showPrimaryArrow = false,
} = Astro.props;

const hasAside = Astro.slots.has("aside");
const hasDefault = Astro.slots.has("default");
const hasActions = Boolean(primaryLabel || secondaryLabel);
const resolvedTitleClass =
  titleClass ??
  (hasAside
    ? "max-w-[760px] text-[42px] font-semibold leading-[1.02] tracking-normal text-[#07324A] sm:text-[58px]"
    : "text-[clamp(1.8rem,4vw,2.8rem)] font-semibold leading-tight tracking-normal text-[#07324A]");
---

<section class:list={[sectionClass]}>
  <div class:list={[contained ? containerClass : ""]}>
    <div
      class:list={[
        "border border-[#D8E1EA] bg-white p-7 shadow-[0_34px_100px_-72px_rgba(7,50,74,0.42)] sm:p-9",
        hasAside ? "grid gap-8 lg:grid-cols-[1fr_360px] lg:items-center" : "",
        cardClass,
      ]}
    >
      <div>
        {eyebrow ? <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-[#0891B2]">{eyebrow}</p> : null}
        <h2 class:list={[eyebrow ? "mt-4" : "", resolvedTitleClass]}>{title}</h2>
        {description ? <p class={descriptionClass}>{description}</p> : null}
        {hasDefault ? <slot /> : null}

        {hasActions ? (
          <div class={actionsClass}>
            {primaryLabel ? (
              <a href={primaryHref} class={primaryClass}>
                {primaryLabel}
                {showPrimaryArrow ? <ArrowRight class="ml-2 h-4 w-4" stroke-width={2} /> : null}
              </a>
            ) : null}
            {secondaryLabel ? (
              <a href={secondaryHref} class={secondaryClass}>
                {secondaryLabel}
              </a>
            ) : null}
          </div>
        ) : null}
      </div>

      {hasAside ? <slot name="aside" /> : null}
    </div>
  </div>
</section>
