---
import {
  ArrowRight,
  Bot,
  Check,
  Clock3,
  CreditCard,
  FileText,
  Headphones,
  Mail,
  PackageCheck,
  Search,
  Send,
  ShieldCheck,
  Sparkles,
} from "@lucide/astro";
import Navbar from "./Navbar.astro";
import { getBrandEmail } from "../lib/site";

interface Props {
  siteUrl: string;
  currentPath?: string;
}

const { siteUrl, currentPath = "/industries/healthcare" } = Astro.props;
const brandEmail = getBrandEmail();
const CONTAINER = "mx-auto w-full max-w-[1240px] px-5 sm:px-8 lg:px-10";

const proof = [
  ["Patient intake", "Collect appointment details, contact information, insurance context, and required forms before staff review."],
  ["Scheduling support", "Answer administrative scheduling questions, prepare appointment requests, and route changes or cancellations."],
  ["Forms and documents", "Gather consents, referral notes, images, IDs, and pre-visit details without endless back-and-forth."],
  ["Clinical handoff", "Clinical questions, urgent symptoms, medication changes, and care decisions route to licensed staff."],
];

const painPoints = [
  {
    title: "Front-desk teams handle repetitive intake",
    body: "Patients ask about availability, preparation, forms, referrals, insurance details, and next steps across phone, email, portal, and chat.",
  },
  {
    title: "Context is scattered across systems",
    body: "One request can require scheduling rules, patient records, forms, eligibility tools, billing notes, and staff judgment before action.",
  },
  {
    title: "Healthcare workflows need strict boundaries",
    body: "Administrative automation must separate routine answers from clinical risk, privacy constraints, and decisions that require licensed staff.",
  },
];

const workflows = [
  {
    title: "AI patient intake automation",
    body: "Collect visit reason, demographics, preferred times, referral details, and missing information before staff review.",
    icon: FileText,
  },
  {
    title: "AI appointment scheduling support",
    body: "Prepare appointment requests, answer administrative scheduling FAQs, send reminders, and route exceptions.",
    icon: Clock3,
  },
  {
    title: "Healthcare document collection",
    body: "Request forms, IDs, insurance cards, referrals, images, and pre-visit documents with clear status tracking.",
    icon: PackageCheck,
  },
  {
    title: "Patient support triage",
    body: "Classify administrative requests, enrich cases, draft staff-ready summaries, and escalate clinical questions.",
    icon: Headphones,
  },
  {
    title: "Billing and insurance intake",
    body: "Collect payer details, route eligibility questions, prepare billing follow-up, and keep sensitive decisions reviewed.",
    icon: CreditCard,
  },
  {
    title: "Healthcare AI control layer",
    body: "Keep PHI access, approvals, escalations, audit notes, and human review boundaries visible to the operating team.",
    icon: ShieldCheck,
  },
];

const searchIntents = [
  {
    title: "AI patient intake automation",
    body: "Reduce repetitive front-desk intake while keeping clinical questions and urgent requests routed to qualified staff.",
  },
  {
    title: "AI medical office assistant",
    body: "Support administrative tasks such as appointment requests, document collection, reminders, and patient FAQs.",
  },
  {
    title: "AI appointment scheduling for clinics",
    body: "Prepare scheduling requests, collect missing details, explain administrative next steps, and route exceptions.",
  },
  {
    title: "Healthcare administrative automation",
    body: "Automate repeatable office workflows across forms, portal messages, patient support, billing prep, and staff handoff.",
  },
  {
    title: "AI healthcare chatbot with handoff",
    body: "Answer non-clinical questions while escalating symptoms, medication, diagnosis, or treatment questions to humans.",
  },
  {
    title: "Clinic workflow automation",
    body: "Start with a measurable workflow such as intake, reminders, document collection, or billing question routing.",
  },
];

const reviewTakeaways = [
  "Identify the highest-volume administrative workflow to automate first",
  "Map scheduling, patient portal, forms, billing, insurance, and handoff requirements",
  "Define which requests can be automated and which must route to licensed staff",
];

const exampleWorkflow = [
  ["01", "Patient request", "A patient asks for an appointment and mentions symptoms in a portal message."],
  ["02", "Agent collects context", "Preferred times, contact details, existing patient status, insurance, and required forms."],
  ["03", "Boundary check", "The agent does not diagnose or advise; clinical or urgent indicators trigger staff handoff."],
  ["04", "Staff-ready summary", "The team receives a concise request with missing information, source context, and next steps."],
  ["05", "Action logged", "Every intake step, handoff, note, and follow-up recommendation stays reviewable."],
];

const integrations = [
  "EHR / EMR",
  "Patient portals",
  "Scheduling systems",
  "Secure forms",
  "Insurance tools",
  "Billing systems",
  "Telehealth platforms",
  "Call center tools",
  "Email and SMS",
  "CRMs",
  "Spreadsheets",
  "Internal tools",
];

const beforeAfter = [
  ["Patients wait for basic scheduling answers.", "AI support collects administrative details and prepares staff-ready requests."],
  ["Forms and documents arrive incomplete.", "Automation tracks missing files, sends reminders, and prepares complete intake packets."],
  ["Staff manually sort portal messages.", "Requests are classified, summarized, and routed with clinical handoff rules."],
  ["Billing questions interrupt front-desk flow.", "Agents collect payer context and prepare follow-up without making sensitive decisions."],
  ["Leaders lack visibility into request handling.", "Every action, source, escalation, and handoff is logged for review."],
];

const rollout = [
  {
    step: "01",
    title: "Choose the admin workflow",
    body: "Start with intake, scheduling support, reminders, document collection, or billing question routing.",
  },
  {
    step: "02",
    title: "Map rules and boundaries",
    body: "Define PHI access, escalation rules, clinical handoff triggers, approval paths, and staff review points.",
  },
  {
    step: "03",
    title: "Connect and test",
    body: "Run real scenarios for incomplete forms, appointment changes, urgent language, billing questions, and portal messages.",
  },
  {
    step: "04",
    title: "Launch supervised",
    body: "Go live with logs, monitoring, human review, exception alerts, and tuning from real operational feedback.",
  },
];

const faq = [
  {
    q: "Does this provide medical diagnosis or treatment advice?",
    a: "No. Tactas AI healthcare workflows are designed for administrative automation. Clinical questions, urgent symptoms, medication changes, diagnosis, and treatment decisions should route to qualified staff.",
  },
  {
    q: "Can this support healthcare privacy requirements?",
    a: "Tactas AI designs around access control, logging, escalation boundaries, and your compliance review process. Final privacy and regulatory requirements depend on your systems, vendors, policies, and deployment model.",
  },
  {
    q: "What healthcare workflow should we automate first?",
    a: "The best first workflow is usually patient intake, appointment request preparation, reminders, document collection, billing question routing, or non-clinical FAQs because the volume is frequent and measurable.",
  },
  {
    q: "Can AI handle patient messages without losing control?",
    a: "Yes, if the workflow is supervised. Routine administrative answers can be prepared or sent based on rules, while clinical risk, urgent language, PHI-sensitive actions, and exceptions can require human review.",
  },
];
---

<div class="min-h-screen overflow-x-hidden bg-[#07090f] text-[#f5f7fb] selection:bg-[#67e8f9]/20">
  <div class="pointer-events-none fixed inset-0 -z-20 grid-faint opacity-[0.35] [mask-image:radial-gradient(ellipse_70%_55%_at_50%_15%,black_0%,transparent_75%)]"></div>
  <div class="pointer-events-none fixed inset-x-0 top-0 -z-20 h-[700px] bg-[radial-gradient(ellipse_75%_55%_at_50%_0%,rgba(34,211,238,0.10),transparent_60%)]"></div>

  <Navbar currentPath={currentPath} ctaLabel="Workflow review" />

  <main>
    <section class="relative pb-20 pt-12 lg:pb-28 lg:pt-20">
      <div class={`${CONTAINER} relative grid items-center gap-14 lg:grid-cols-[1.02fr_1fr] lg:gap-14`}>
        <div>
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#1c2333] bg-[#0c111c]/80 px-3 py-1.5 backdrop-blur">
            <Sparkles class="h-3.5 w-3.5 text-[#67e8f9]" stroke-width={1.7} />
            <span class="font-mono text-[10px] font-semibold uppercase tracking-[0.24em] text-[#c8d0de]">
              AI automation for healthcare operations
            </span>
          </div>
          <h1 class="text-[clamp(2.45rem,6vw,5rem)] font-bold leading-[0.96] tracking-[-0.045em] text-[#f5f7fb]">
            AI agents for patient intake, scheduling support, and clinic admin workflows.
          </h1>
          <p class="mt-7 max-w-[41ch] text-[16px] leading-relaxed text-[#8a93a6] sm:text-[17px]">
            Tactas AI helps healthcare and clinic teams automate administrative workflows across patient intake,
            appointment requests, forms, billing questions, reminders, and staff handoff with clear clinical boundaries.
          </p>
          <div class="mt-9 flex flex-col gap-3 sm:flex-row sm:items-center">
            <a
              href="#contact"
              class="group inline-flex h-12 items-center justify-center rounded-md bg-[#22d3ee] px-6 text-[13px] font-semibold tracking-tight text-[#07090f] transition hover:bg-[#67e8f9]"
            >
              Book healthcare workflow review
              <ArrowRight class="ml-2 h-4 w-4 transition group-hover:translate-x-0.5" />
            </a>
            <a
              href="#workflows"
              class="group inline-flex h-12 items-center justify-center rounded-md px-2 text-[13px] font-semibold tracking-tight text-[#c8d0de] transition hover:text-[#f5f7fb]"
            >
              See workflows
              <ArrowRight class="ml-2 h-3.5 w-3.5 transition group-hover:translate-x-0.5" />
            </a>
          </div>
          <p class="mt-5 max-w-[46ch] text-[13px] leading-relaxed text-[#5e6678]">
            In a 30-minute review, we identify one high-volume administrative workflow, map system and privacy boundaries,
            and define where AI can assist versus where staff must review.
          </p>
        </div>

        <div class="relative">
          <div class="pointer-events-none absolute -inset-10 -z-10 bg-[radial-gradient(60%_60%_at_50%_40%,rgba(34,211,238,0.18),transparent_72%)] blur-3xl"></div>
          <div class="overflow-hidden rounded-2xl border border-[#1c2333] bg-gradient-to-b from-[#0c111c] to-[#070a12] shadow-[0_50px_120px_-60px_rgba(0,0,0,0.9),inset_0_1px_0_rgba(255,255,255,0.03)]">
            <div class="flex items-center justify-between border-b border-[#1c2333] px-5 py-4">
              <div class="flex items-center gap-2.5">
                <span class="flex h-2 w-2 rounded-full bg-[#34d399] pulse-dot" aria-hidden="true"></span>
                <span class="font-mono text-[10px] font-semibold uppercase tracking-[0.24em] text-[#c8d0de]">
                  clinic workflow
                </span>
              </div>
              <span class="font-mono text-[10px] uppercase tracking-[0.24em] text-[#5e6678]">supervised</span>
            </div>

            <div class="grid gap-0 lg:grid-cols-[1fr_230px]">
              <div class="px-5 py-5 sm:px-6">
                <div class="grid gap-3 sm:grid-cols-3">
                  {[
                    ["request", "new visit"],
                    ["risk", "handoff"],
                    ["status", "ready"],
                  ].map(([label, value]) => (
                    <div class="rounded-md border border-[#1c2333] bg-[#0a0e17] px-4 py-3">
                      <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-[#5e6678]">{label}</p>
                      <p class="mt-2 text-[15px] font-semibold text-[#f5f7fb]">{value}</p>
                    </div>
                  ))}
                </div>

                <div class="mt-5 rounded-xl border border-[#1c2333] bg-[#07090f] p-4">
                  <div class="mb-4 flex items-center gap-2 text-[12px] text-[#8a93a6]">
                    <Bot class="h-4 w-4 text-[#67e8f9]" stroke-width={1.7} />
                    intake trace
                  </div>
                  <div class="grid gap-3 font-mono text-[12px] leading-relaxed">
                    {[
                      ["intake", "patient requests appointment"],
                      ["collect", "contact, availability, insurance, forms"],
                      ["boundary", "clinical question detected"],
                      ["handoff", "route summary to licensed staff"],
                      ["log", "source, decision, and next step saved"],
                    ].map(([tag, line], index) => (
                      <div class="grid grid-cols-[28px_72px_1fr] gap-3 text-[#c8d0de]">
                        <span class="text-[#5e6678]">{String(index + 1).padStart(2, "0")}</span>
                        <span class={tag === "boundary" || tag === "handoff" ? "text-[#fbbf24]" : "text-[#67e8f9]"}>{tag}</span>
                        <span>{line}</span>
                      </div>
                    ))}
                  </div>
                </div>

                <div class="mt-5 grid gap-3 sm:grid-cols-2">
                  <div class="rounded-md border border-[#1c2333] bg-[#0a0e17] p-4">
                    <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-[#5e6678]">next action</p>
                    <p class="mt-2 text-[14px] leading-relaxed text-[#f5f7fb]">
                      Prepare intake packet and route clinical language to staff before any response.
                    </p>
                  </div>
                  <div class="rounded-md border border-[#1c2333] bg-[#0a0e17] p-4">
                    <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-[#5e6678]">guardrail</p>
                    <p class="mt-2 text-[14px] leading-relaxed text-[#f5f7fb]">
                      Diagnosis, treatment, medication, and urgent symptoms require human review.
                    </p>
                  </div>
                </div>
              </div>

              <aside class="border-t border-[#1c2333] px-5 py-5 lg:border-l lg:border-t-0">
                <p class="font-mono text-[10px] uppercase tracking-[0.24em] text-[#5e6678]">connected tools</p>
                <div class="mt-4 grid gap-2.5">
                  {["EHR", "Portal", "Schedule", "Forms", "Billing", "SMS"].map((tool) => (
                    <div class="flex items-center justify-between rounded-md border border-[#1c2333] bg-[#0a0e17] px-3 py-2.5">
                      <span class="text-[12.5px] text-[#c8d0de]">{tool}</span>
                      <Check class="h-3.5 w-3.5 text-[#34d399]" stroke-width={2.5} />
                    </div>
                  ))}
                </div>
              </aside>
            </div>
          </div>
        </div>
      </div>

      <div class={`${CONTAINER} mt-20 lg:mt-28`}>
        <div class="grid divide-y divide-[#1c2333] border-y border-[#1c2333] sm:grid-cols-2 sm:divide-x sm:divide-y-0 lg:grid-cols-4">
          {proof.map(([title, body], idx) => (
            <div class="px-5 py-7 lg:px-7">
              <span class="font-mono text-[10px] font-semibold uppercase tracking-[0.24em] text-[#5e6678]">
                {String(idx + 1).padStart(2, "0")}
              </span>
              <p class="mt-3 text-[14px] font-medium text-[#f5f7fb]">{title}</p>
              <p class="mt-2 text-[13.5px] leading-relaxed text-[#8a93a6]">{body}</p>
            </div>
          ))}
        </div>
      </div>

      <div class={`${CONTAINER} mt-16`}>
        <div class="grid items-center gap-8 border-y border-[#1c2333] py-8 lg:grid-cols-[0.9fr_1.1fr] lg:gap-12">
          <div>
            <span class="font-mono text-[10px] font-semibold uppercase tracking-[0.28em] text-[#67e8f9]/85">Execution blueprint</span>
            <h2 class="mt-4 text-[clamp(1.6rem,2.7vw,2.15rem)] font-semibold leading-[1.08] tracking-[-0.03em] text-[#f5f7fb]">
              Healthcare AI automation should run as a controlled administrative workflow.
            </h2>
            <p class="mt-4 max-w-md text-[14.5px] leading-relaxed text-[#8a93a6]">
              Patient context, forms, routing rules, approval gates, logs, and escalation paths are designed before agents act.
            </p>
          </div>
          <div class="overflow-hidden rounded-2xl border border-[#1c2333] bg-[#0c111c] shadow-[0_40px_100px_-70px_rgba(0,0,0,0.95)]">
            <img
              src="/ef4e97cc-14e2-4157-a55f-42bfa62ad8a3.png"
              alt="Tactas AI healthcare workflow execution blueprint"
              width="1536"
              height="1024"
              class="h-auto w-full"
              loading="eager"
              decoding="async"
            />
          </div>
        </div>
      </div>
    </section>

    <section id="problems" class="border-y border-[#1c2333] bg-[#0a0e17] py-24 lg:py-32">
      <div class={`${CONTAINER} grid gap-12 lg:grid-cols-[0.72fr_1.28fr] lg:gap-20`}>
        <div>
          <span class="font-mono text-[10px] font-semibold uppercase tracking-[0.28em] text-[#67e8f9]/85">Why healthcare</span>
          <h2 class="mt-4 text-[clamp(1.9rem,3.4vw,2.7rem)] font-semibold leading-[1.05] tracking-[-0.03em] text-[#f5f7fb]">
            Healthcare teams lose time when routine admin work blocks patient response.
          </h2>
          <p class="mt-5 max-w-md text-[15px] leading-relaxed text-[#8a93a6]">
            The highest-value healthcare AI automation use cases are administrative workflows with high volume,
            clear rules, and safe handoff points.
          </p>
        </div>

        <div>
          <div class="hairline mb-8"></div>
          <ul class="grid gap-0">
            {painPoints.map((item, idx) => (
              <li class="grid gap-3 border-b border-[#1c2333] py-7 last:border-b-0 sm:grid-cols-[120px_1fr] sm:gap-8">
                <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.24em] text-[#5e6678]">
                  Case {String(idx + 1).padStart(2, "0")}
                </span>
                <div>
                  <h3 class="text-[16px] font-medium tracking-tight text-[#f5f7fb]">{item.title}</h3>
                  <p class="mt-2 text-[14.5px] leading-relaxed text-[#8a93a6]">{item.body}</p>
                </div>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <section class="py-24 lg:py-32">
      <div class={CONTAINER}>
        <div class="max-w-3xl">
          <span class="font-mono text-[10px] font-semibold uppercase tracking-[0.28em] text-[#67e8f9]/85">Buyer workflows</span>
          <h2 class="mt-4 text-[clamp(1.9rem,3.4vw,2.7rem)] font-semibold leading-[1.05] tracking-[-0.03em] text-[#f5f7fb]">
            Built around healthcare administrative workflows teams ask for.
          </h2>
          <p class="mt-5 max-w-xl text-[15px] leading-relaxed text-[#8a93a6]">
            Tactas focuses on clinic workflow automation, AI patient intake, appointment scheduling support,
            document collection, billing prep, and supervised handoff.
          </p>
        </div>

        <div class="mt-12 grid border-y border-[#1c2333] sm:grid-cols-2 lg:grid-cols-3">
          {searchIntents.map((item, idx) => (
            <article class="group flex flex-col gap-3 border-t border-[#1c2333] px-0 py-7 transition duration-300 hover:bg-[#0c111c]/45 sm:border-t-0 sm:border-l sm:px-6 lg:first:border-l-0">
              <span class="font-mono text-[10px] font-semibold uppercase tracking-[0.22em] text-[#5e6678]">
                {String(idx + 1).padStart(2, "0")}
              </span>
              <h3 class="text-[16px] font-medium tracking-tight text-[#f5f7fb]">{item.title}</h3>
              <p class="text-[14px] leading-relaxed text-[#8a93a6]">{item.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="workflows" class="py-24 lg:py-32">
      <div class={CONTAINER}>
        <div class="max-w-3xl">
          <span class="font-mono text-[10px] font-semibold uppercase tracking-[0.28em] text-[#67e8f9]/85">Workflows</span>
          <h2 class="mt-4 text-[clamp(1.9rem,3.4vw,2.7rem)] font-semibold leading-[1.05] tracking-[-0.03em] text-[#f5f7fb]">
            Start with healthcare automation closest to front-desk load and patient access.
          </h2>
          <p class="mt-5 max-w-xl text-[15px] leading-relaxed text-[#8a93a6]">
            Each AI support agent is designed around your intake process, scheduling rules, forms, privacy boundaries, and existing operating stack.
          </p>
        </div>

        <div class="mt-12 grid border-y border-[#1c2333] sm:grid-cols-2 lg:grid-cols-3">
          {workflows.map((item, idx) => {
            const Icon = item.icon;
            return (
              <article class="group flex flex-col gap-4 border-t border-[#1c2333] px-0 py-8 transition duration-300 hover:-translate-y-0.5 hover:bg-[#0c111c]/45 sm:border-t-0 sm:border-l sm:px-7 sm:py-9 sm:[&:nth-child(odd)]:border-l-0 lg:[&:nth-child(odd)]:border-l lg:[&:nth-child(3n+1)]:border-l-0">
                <div class="flex items-center justify-between">
                  <span class="flex h-10 w-10 items-center justify-center rounded-md border border-[#1c2333] bg-[#0c111c] text-[#67e8f9] transition group-hover:border-[#67e8f9]/40">
                    <Icon class="h-4 w-4" stroke-width={1.6} />
                  </span>
                  <span class="font-mono text-[10px] uppercase tracking-[0.24em] text-[#5e6678]">
                    {String(idx + 1).padStart(2, "0")}
                  </span>
                </div>
                <h3 class="text-[16px] font-medium tracking-tight text-[#f5f7fb]">{item.title}</h3>
                <p class="text-[14px] leading-relaxed text-[#8a93a6]">{item.body}</p>
              </article>
            );
          })}
        </div>
      </div>
    </section>

    <section id="integrations" class="border-y border-[#1c2333] bg-[#0a0e17] py-24 lg:py-32">
      <div class={`${CONTAINER} grid gap-12 lg:grid-cols-[0.7fr_1.3fr] lg:gap-20`}>
        <div>
          <span class="font-mono text-[10px] font-semibold uppercase tracking-[0.28em] text-[#67e8f9]/85">Integrations</span>
          <h2 class="mt-4 text-[clamp(1.9rem,3.4vw,2.7rem)] font-semibold leading-[1.05] tracking-[-0.03em] text-[#f5f7fb]">
            Connected to the systems that run patient access and clinic operations.
          </h2>
          <p class="mt-5 max-w-md text-[15px] leading-relaxed text-[#8a93a6]">
            Tactas AI is built around your existing tools, not a generic chat widget. Agents can gather administrative
            context, prepare actions, and log every step.
          </p>
        </div>
        <div>
          <div class="grid grid-cols-2 gap-x-10 gap-y-0 sm:grid-cols-3">
            {integrations.map((item) => (
              <div class="group flex items-baseline gap-3 border-b border-[#1c2333] py-5 text-[14.5px] text-[#c8d0de] transition-colors duration-300 hover:border-[#2a3346] hover:text-[#f5f7fb]">
                <span class="h-1.5 w-1.5 shrink-0 rounded-full bg-[#34d399] transition-transform duration-300 group-hover:scale-125" aria-hidden="true"></span>
                {item}
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="py-24 lg:py-32">
      <div class={`${CONTAINER} grid gap-12 lg:grid-cols-[0.72fr_1.28fr] lg:gap-20`}>
        <div>
          <span class="font-mono text-[10px] font-semibold uppercase tracking-[0.28em] text-[#67e8f9]/85">Example workflow</span>
          <h2 class="mt-4 text-[clamp(1.9rem,3.4vw,2.7rem)] font-semibold leading-[1.05] tracking-[-0.03em] text-[#f5f7fb]">
            Patient intake automation that prepares work without making clinical decisions.
          </h2>
          <p class="mt-5 max-w-md text-[15px] leading-relaxed text-[#8a93a6]">
            The first healthcare AI workflow should be measurable and bounded. Intake is often a strong starting point because
            the volume is high, the required details are known, and clinical questions can route to staff.
          </p>
        </div>

        <div class="overflow-hidden rounded-2xl border border-[#1c2333] bg-[#0c111c]">
          {exampleWorkflow.map(([step, title, body]) => (
            <div class="grid gap-3 border-b border-[#1c2333] px-6 py-5 last:border-b-0 sm:grid-cols-[76px_0.75fr_1.25fr] sm:items-start">
