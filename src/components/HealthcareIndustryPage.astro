              <h3 class="text-[15px] font-medium tracking-tight text-[#f5f7fb]">{title}</h3>
              <p class="text-[14.5px] leading-relaxed text-[#8a93a6]">{body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="py-24 lg:py-32">
      <div class={CONTAINER}>
        <div class="max-w-3xl">
