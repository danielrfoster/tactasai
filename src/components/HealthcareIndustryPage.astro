            From overloaded front desk to controlled healthcare admin automation.
          </h2>
        </div>

        <div class="mt-12 overflow-hidden rounded-2xl border border-[#1c2333]">
          <div class="grid bg-[#0c111c] font-mono text-[10px] font-semibold uppercase tracking-[0.24em] text-[#5e6678] sm:grid-cols-2">
            <div class="border-b border-[#1c2333] px-6 py-4 sm:border-b-0 sm:border-r">Before Tactas</div>
            <div class="px-6 py-4 text-[#67e8f9]/85">After Tactas</div>
          </div>
          {beforeAfter.map(([before, after]) => (
            <div class="grid border-t border-[#1c2333] transition-colors duration-300 hover:bg-[#0f1420] sm:grid-cols-2">
              <div class="border-b border-[#1c2333] px-6 py-5 text-[14.5px] leading-relaxed text-[#8a93a6] sm:border-b-0 sm:border-r">{before}</div>
              <div class="flex items-baseline gap-3 px-6 py-5 text-[14.5px] leading-relaxed text-[#f5f7fb]">
                <Check class="mt-1 h-3.5 w-3.5 shrink-0 text-[#34d399]" stroke-width={2.5} />
                <span>{after}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="rollout" class="border-y border-[#1c2333] bg-[#0a0e17] py-24 lg:py-32">
      <div class={CONTAINER}>
        <div class="max-w-3xl">
          <span class="font-mono text-[10px] font-semibold uppercase tracking-[0.28em] text-[#67e8f9]/85">Rollout</span>
          <h2 class="mt-4 text-[clamp(1.9rem,3.4vw,2.7rem)] font-semibold leading-[1.05] tracking-[-0.03em] text-[#f5f7fb]">
            Launch one measurable healthcare admin workflow first.
          </h2>
          <p class="mt-5 max-w-xl text-[15px] leading-relaxed text-[#8a93a6]">
