---
import {
  ArrowRight,
  Bot,
  Check,
  FileText,
  Mail,
  Send,
  ShieldCheck,
  Sparkles,
  Workflow,
  Zap,
} from "@lucide/astro";
import { getBrandEmail } from "../lib/site";

interface Pair {
  title: string;
  body: string;
}

interface Props {
  siteUrl: string;
  currentPath: string;
  eyebrow: string;
  title: string;
  description: string;
  primaryKeyword: string;
  secondaryKeywords: string[];
  fit: Pair[];
  workflow: Pair[];
  outcomes: Pair[];
  integrations: string[];
  faqs: Pair[];
}

const {
  currentPath,
  eyebrow,
  title,
  description,
  primaryKeyword,
  secondaryKeywords,
  fit,
  workflow,
  outcomes,
  integrations,
  faqs,
} = Astro.props;

const brandEmail = getBrandEmail();
---

<div class="min-h-screen overflow-x-hidden bg-tactas-bg text-tactas-ink selection:bg-tactas-accent/20">
  <div class="pointer-events-none fixed inset-0 -z-20 grid-faint opacity-[0.24] [mask-image:radial-gradient(ellipse_70%_60%_at_50%_10%,black_0%,transparent_75%)]"></div>

  <main>
    <section class="relative overflow-hidden border-b border-tactas-line">
      <div class="pointer-events-none absolute inset-0 z-0 bg-[linear-gradient(180deg,rgba(124,58,237,0.14)_0%,rgba(5,10,20,0)_58%)]"></div>
      <div class="pointer-events-none absolute inset-0 z-0 opacity-[0.30] [background-image:linear-gradient(to_right,rgba(255,255,255,0.055)_1px,transparent_1px),linear-gradient(to_bottom,rgba(255,255,255,0.045)_1px,transparent_1px)] [background-size:72px_72px]"></div>

      <div class={`tactas-container relative z-10 grid min-h-[690px] items-center gap-14 py-16 lg:grid-cols-[0.95fr_1.05fr] lg:py-20`}>
        <div class="reveal">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-tactas-accent-line bg-tactas-accent-soft/80 px-3 py-1.5">
            <Sparkles class="h-3.5 w-3.5 text-tactas-accent-strong" stroke-width={1.8} />
            <span class="font-mono text-[10px] font-semibold uppercase tracking-[0.24em] text-tactas-accent-strong">{eyebrow}</span>
          </div>

          <h1 class="max-w-[12ch] text-[clamp(3rem,7vw,5.6rem)] font-extrabold leading-[0.94] tracking-[-0.045em]">
            {title}
          </h1>
          <p class="mt-7 max-w-[42rem] text-[17px] leading-relaxed text-tactas-muted">
            {description}
          </p>

          <div class="mt-9 flex flex-col gap-3 sm:flex-row sm:items-center">
            <a href="#contact" class="group inline-flex h-12 items-center justify-center rounded-[6px] bg-tactas-primary px-6 text-[14px] font-semibold text-white shadow-[0_18px_48px_-24px_rgba(124,58,237,0.8)] transition hover:bg-tactas-accent">
              Plan this task
              <ArrowRight class="ml-2 h-4 w-4 transition group-hover:translate-x-0.5" stroke-width={1.9} />
            </a>
            <a href="/services/ai-workflow-automation" class="inline-flex h-12 items-center justify-center rounded-[6px] border border-tactas-line bg-white px-6 text-[14px] font-semibold text-tactas-ink-strong transition hover:border-tactas-accent/70 hover:text-tactas-accent-strong">
              Business task automation
            </a>
          </div>
        </div>

        <div class="reveal" data-delay="2">
          <div class="rounded-[12px] border border-tactas-line bg-white p-5 shadow-[0_40px_110px_-56px_rgba(0,0,0,0.95)]">
            <div class="flex items-center justify-between border-b border-tactas-line pb-4">
              <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-tactas-accent-strong">Task snapshot</p>
              <Workflow class="h-5 w-5 text-tactas-accent-strong" stroke-width={1.8} />
            </div>
            <div class="mt-5 grid gap-3">
              {workflow.slice(0, 4).map((step, index) => (
                <div class="grid gap-3 rounded-[8px] border border-tactas-line bg-white p-4 sm:grid-cols-[56px_1fr]">
                  <span class="font-mono text-[11px] text-tactas-accent-strong">{String(index + 1).padStart(2, "0")}</span>
                  <div>
                    <h3 class="text-[15px] font-semibold text-tactas-ink-strong">{step.title}</h3>
                    <p class="mt-1 text-[13px] leading-relaxed text-tactas-muted-soft">{step.body}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="border-b border-tactas-line bg-tactas-bg">
      <div class={`tactas-container py-10`}>
        <div class="grid gap-3 text-center sm:grid-cols-2 lg:grid-cols-4">
          {[primaryKeyword, ...secondaryKeywords.slice(0, 3)].map((term) => (
            <div class="rounded-[8px] border border-tactas-line bg-white px-4 py-4 font-mono text-[11px] uppercase tracking-[0.18em] text-tactas-accent-strong">
              {term}
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="border-b border-tactas-line bg-tactas-bg">
      <div class={`tactas-container grid gap-12 py-18 lg:grid-cols-[0.72fr_1.28fr] lg:py-24`}>
        <div>
          <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-tactas-accent-strong">Best fit</p>
          <h2 class="mt-4 text-[clamp(2rem,4vw,3.15rem)] font-bold leading-tight tracking-[-0.025em]">
            When this task is worth automating.
          </h2>
        </div>

        <div class="grid gap-3 sm:grid-cols-2">
          {fit.map((item) => (
            <div class="rounded-[8px] border border-tactas-line bg-white p-5">
              <div class="flex items-center gap-3">
                <Check class="h-4.5 w-4.5 shrink-0 text-tactas-accent-strong" stroke-width={2.1} />
                <h3 class="text-[15px] font-semibold text-tactas-ink-strong">{item.title}</h3>
              </div>
              <p class="mt-3 text-[13px] leading-relaxed text-tactas-muted-soft">{item.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="border-b border-tactas-line bg-tactas-bg text-tactas-ink">
      <div class={`tactas-container py-16 lg:py-20`}>
        <div class="mx-auto max-w-3xl text-center">
          <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-tactas-accent">Task flow</p>
          <h2 class="mt-4 text-[clamp(2rem,4vw,3.1rem)] font-bold leading-tight tracking-[-0.025em]">
            How managed AI agents turn context into action.
          </h2>
        </div>

        <div class="mt-12 grid gap-4 lg:grid-cols-5">
          {workflow.map((step, index) => (
            <article class="relative rounded-[8px] border border-tactas-line bg-white p-5 shadow-[0_20px_60px_-52px_rgba(15,23,42,0.28)]">
              {index < workflow.length - 1 ? (
                <div class="absolute -right-3 top-10 hidden h-px w-6 bg-tactas-primary/45 lg:block"></div>
              ) : null}
              <p class="font-mono text-[11px] text-tactas-accent">{String(index + 1).padStart(2, "0")}</p>
              <h3 class="mt-5 text-[17px] font-semibold">{step.title}</h3>
              <p class="mt-3 text-[13px] leading-relaxed text-tactas-muted-soft">{step.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="border-b border-tactas-line bg-tactas-bg">
      <div class={`tactas-container grid gap-12 py-18 lg:grid-cols-[0.72fr_1.28fr] lg:py-24`}>
        <div>
          <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-tactas-accent-strong">Outcomes</p>
          <h2 class="mt-4 text-[clamp(2rem,4vw,3.15rem)] font-bold leading-tight tracking-[-0.025em]">
            What the team gets after launch.
          </h2>
        </div>

        <div class="grid gap-3 sm:grid-cols-2">
          {outcomes.map((item) => (
            <div class="rounded-[8px] border border-tactas-line bg-white p-5">
              <div class="flex items-center gap-3">
                <Zap class="h-4.5 w-4.5 shrink-0 text-tactas-accent-strong" stroke-width={1.8} />
                <h3 class="text-[15px] font-semibold text-tactas-ink-strong">{item.title}</h3>
              </div>
              <p class="mt-3 text-[13px] leading-relaxed text-tactas-muted-soft">{item.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="border-b border-tactas-line bg-tactas-bg">
      <div class={`tactas-container py-18 lg:py-24`}>
        <div class="mx-auto max-w-3xl text-center">
          <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-tactas-accent-strong">Integrations</p>
          <h2 class="mt-4 text-[clamp(2rem,4vw,3.15rem)] font-bold leading-tight tracking-[-0.025em]">
            Built around the systems your team already uses.
          </h2>
        </div>
        <div class="mt-10 flex flex-wrap justify-center gap-3">
          {integrations.map((item) => (
            <span class="rounded-full border border-tactas-line bg-white px-4 py-2 text-[13px] text-tactas-muted">{item}</span>
          ))}
        </div>
      </div>
    </section>

    <section id="faq" class="border-b border-tactas-line bg-tactas-bg">
      <div class={`tactas-container grid gap-12 py-18 lg:grid-cols-[0.72fr_1.28fr] lg:py-24`}>
        <div>
          <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-tactas-accent-strong">FAQ</p>
          <h2 class="mt-4 text-[clamp(2rem,4vw,3.15rem)] font-bold leading-tight tracking-[-0.025em]">
            Questions about this business task.
          </h2>
        </div>

        <div class="grid rounded-[8px] border border-tactas-line bg-white">
          {faqs.map((item, index) => (
            <article class="grid gap-3 border-b border-tactas-line p-6 last:border-b-0 sm:grid-cols-[76px_1fr]">
              <p class="font-mono text-[11px] text-tactas-accent-strong">{String(index + 1).padStart(2, "0")}</p>
              <div>
                <h3 class="text-[20px] font-semibold tracking-tight">{item.title}</h3>
                <p class="mt-3 text-[15px] leading-relaxed text-tactas-muted-soft">{item.body}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="contact" class="bg-tactas-bg">
      <div class={`tactas-container py-18 lg:py-24`}>
        <div class="grid overflow-hidden rounded-[12px] border border-tactas-accent-line bg-white lg:grid-cols-[0.92fr_1.08fr]">
          <div class="p-7 sm:p-9 lg:p-10">
            <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-tactas-accent-strong">Start this task</p>
            <h2 class="mt-4 text-[clamp(2rem,4vw,3.2rem)] font-bold leading-tight tracking-[-0.025em]">
              Turn this task into managed AI automation.
            </h2>
            <p class="mt-5 max-w-[34rem] text-[16px] leading-relaxed text-tactas-muted-soft">
              Share the repeated work, tools, knowledge sources, current outputs, and pain points. Tactas AI will help map a practical automation path.
            </p>

            <div class="mt-8 flex items-center gap-3 text-[14px] text-tactas-muted">
              <Mail class="h-4 w-4 text-tactas-accent-strong" stroke-width={1.8} />
              <a href={`mailto:${brandEmail}`} class="border-b border-tactas-accent/50 pb-0.5 transition hover:border-tactas-accent hover:text-tactas-ink-strong">
                {brandEmail}
              </a>
            </div>
          </div>

          <form id="detail-use-case-form" class="border-t border-tactas-line bg-tactas-bg p-7 sm:p-9 lg:border-l lg:border-t-0">
            <div class="flex items-center justify-between gap-4 border-b border-tactas-line pb-4">
              <div>
                <p class="font-mono text-[10px] uppercase tracking-[0.24em] text-tactas-accent-strong">Task request</p>
                <h3 class="mt-2 text-[24px] font-semibold tracking-tight">Tell us about the task.</h3>
              </div>
              <Send class="hidden h-5 w-5 text-tactas-accent-strong sm:block" stroke-width={1.8} />
            </div>

            <div class="mt-5 grid gap-4 sm:grid-cols-2">
              <label class="grid gap-1.5 text-[11px] font-medium uppercase tracking-[0.16em] text-tactas-muted-soft">
                First name
                <input required name="name" class="h-11 rounded-[6px] border border-tactas-line bg-white px-3.5 text-[14px] text-tactas-ink outline-none transition placeholder:text-tactas-muted-soft focus:border-tactas-accent focus:ring-2 focus:ring-tactas-accent/15" placeholder="Your name" />
              </label>
              <label class="grid gap-1.5 text-[11px] font-medium uppercase tracking-[0.16em] text-tactas-muted-soft">
                Work email
                <input required type="email" name="email" class="h-11 rounded-[6px] border border-tactas-line bg-white px-3.5 text-[14px] text-tactas-ink outline-none transition placeholder:text-tactas-muted-soft focus:border-tactas-accent focus:ring-2 focus:ring-tactas-accent/15" placeholder="you@company.com" />
              </label>
            </div>

            <label class="mt-4 grid gap-1.5 text-[11px] font-medium uppercase tracking-[0.16em] text-tactas-muted-soft">
              Business task details
              <textarea required name="workflow" class="min-h-32 rounded-[6px] border border-tactas-line bg-white px-3.5 py-3 text-[14px] text-tactas-ink outline-none transition placeholder:text-tactas-muted-soft focus:border-tactas-accent focus:ring-2 focus:ring-tactas-accent/15" placeholder="Current task, tools, knowledge sources, repeated outputs, and pain points..."></textarea>
            </label>

            <button type="submit" class="mt-6 inline-flex h-12 w-full items-center justify-center rounded-[6px] bg-tactas-primary px-6 text-[14px] font-semibold text-white transition hover:bg-tactas-accent">
              Request task review
            </button>
            <p id="detail-use-case-status" class="mt-3 text-center text-[12px] text-tactas-muted-soft">
              Prefer email? {brandEmail}
            </p>
          </form>
        </div>
      </div>
    </section>
  </main>
</div>

<script define:vars={{ brandEmail, title }} is:inline>
  const detailUseCaseForm = document.getElementById("detail-use-case-form");
  const detailUseCaseStatus = document.getElementById("detail-use-case-status");
  detailUseCaseForm?.addEventListener("submit", (event) => {
    event.preventDefault();
    const form = new FormData(detailUseCaseForm);
    const subject = encodeURIComponent(`${title} task review`);
    const body = encodeURIComponent(
      [
        `Name: ${String(form.get("name") || "")}`,
        `Work email: ${String(form.get("email") || "")}`,
        "",
        "Business task details:",
        String(form.get("workflow") || ""),
      ].join("\n"),
    );
    if (detailUseCaseStatus) {
      detailUseCaseStatus.textContent = "Opening your email client with the task details.";
    }
    window.location.href = `mailto:${brandEmail}?subject=${subject}&body=${body}`;
  });
</script>
