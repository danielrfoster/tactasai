---
import {
  ArrowRight,
  Bot,
  BrainCircuit,
  Check,
  Database,
  FileSearch,
  FileText,
  FolderSync,
  KeyRound,
  Layers,
  Mail,
  Search,
  Send,
  ShieldCheck,
  Sparkles,
} from "@lucide/astro";
import { getBrandEmail } from "../lib/site";

interface Props {
  siteUrl: string;
  currentPath?: string;
}

const { currentPath = "/services/ai-knowledge-base" } = Astro.props;
const brandEmail = getBrandEmail();
const CONTAINER = "mx-auto w-full max-w-[1240px] px-5 sm:px-8 lg:px-10";

const trustPoints = [
  ["Company knowledge", "Context agents can use"],
  ["Source-backed", "Answers tied to sources"],
  ["Action-ready", "Outputs prepared for work"],
  ["Managed layer", "Built, tuned, and operated"],
];

const sources = ["Drive", "SharePoint", "S3", "Database", "Workspace", "Messages", "PDFs", "Docs"];

const serviceLayers = [
  {
    title: "Connect",
    body: "Connect company documents, shared files, databases, messages, and business context without forcing a new way of working.",
    icon: FolderSync,
  },
  {
    title: "Prepare",
    body: "Parse, clean, organize, index, and retrieve knowledge so agents can find the right source context for each task.",
    icon: FileSearch,
  },
  {
    title: "Use",
    body: "Turn source context into answers, summaries, task outputs, next steps, and reusable knowledge for business work.",
    icon: Bot,
  },
  {
    title: "Improve",
    body: "Tune retrieval quality, refresh sources, evaluate answers, and keep the knowledge layer useful as the business changes.",
    icon: ShieldCheck,
  },
];

const workflow = [
  ["01", "Connect sources", "Docs, files, databases, messages, shared workspaces"],
  ["02", "Prepare knowledge", "Parse, clean, organize, index, and keep source context current"],
  ["03", "Retrieve context", "Find relevant passages, metadata, and business context for each request"],
  ["04", "Create output", "Answer, summarize, prepare next steps, and attach source context"],
  ["05", "Improve quality", "Tune retrieval, update sources, and improve answer usefulness"],
];

const useCases = [
  "Answer questions with source context",
  "Summarize documents into useful briefs",
  "Prepare next steps from company knowledge",
  "Reuse source context in business tasks",
  "Find the right document details quickly",
  "Turn files into action-ready outputs",
  "Connect shared drives to AI agents",
  "Keep business knowledge available at work",
];

const packages = [
  {
    name: "Pilot",
    body: "Prove value with one knowledge source, real business questions, source-backed answers, and useful task outputs.",
    items: ["1 source connection", "Representative documents", "Answers and summaries"],
  },
  {
    name: "Business",
    body: "Launch a managed company knowledge layer for business teams with multiple sources, source context, and quality tuning.",
    items: ["Multiple sources", "Task-ready context", "Monthly quality tuning"],
  },
  {
    name: "Enterprise",
    body: "Run a reusable knowledge layer for managed AI agents across teams, tools, and repeated business tasks.",
    items: ["Shared knowledge layer", "Custom evaluation sets", "Connected task experiences"],
  },
];

const faqs = [
  ["Is this a product or service?", "It is a managed capability layer. Tactas AI connects knowledge sources, builds source-backed retrieval, and turns company knowledge into context agents can use for answers, summaries, outputs, and automated work."],
  ["Can it use our current document storage?", "Yes. We can connect to existing document storage, shared files, databases, work tools, and internal repositories."],
  ["How do you reduce unsupported answers?", "Answers are generated from retrieved source passages, include citations, and are tested with evaluation questions so weak retrieval paths can be improved."],
  ["Is this still RAG?", "RAG and search are technical proof points. The business value is a company knowledge layer that managed AI agents can use to produce action-ready work."],
];
---

<div class="min-h-screen overflow-x-hidden bg-[#F6F8FB] text-[#0F172A] selection:bg-[#06B6D4]/20">
  <div class="pointer-events-none fixed inset-0 -z-20 grid-faint opacity-[0.24] [mask-image:radial-gradient(ellipse_70%_60%_at_50%_10%,black_0%,transparent_75%)]"></div>

  <main>
    <section class="relative overflow-hidden border-b border-[#D8E1EA]">
      <div class="pointer-events-none absolute inset-0 z-0 bg-[linear-gradient(180deg,rgba(124,58,237,0.13)_0%,rgba(5,10,20,0)_58%)]"></div>
      <div class="pointer-events-none absolute inset-0 z-0 opacity-[0.32] [background-image:linear-gradient(to_right,rgba(255,255,255,0.055)_1px,transparent_1px),linear-gradient(to_bottom,rgba(255,255,255,0.045)_1px,transparent_1px)] [background-size:72px_72px]"></div>

      <div class={`${CONTAINER} relative z-10 grid min-h-[720px] items-center gap-14 py-16 lg:grid-cols-[0.95fr_1.05fr] lg:py-20`}>
        <div class="reveal">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#BAE6FD] bg-[#E6FBFF]/80 px-3 py-1.5">
            <Sparkles class="h-3.5 w-3.5 text-[#0891B2]" stroke-width={1.8} />
            <span class="font-mono text-[10px] font-semibold uppercase tracking-[0.24em] text-[#0891B2]">
              Company knowledge layer
            </span>
          </div>

          <h1 class="max-w-[12ch] text-[clamp(3rem,7vw,5.8rem)] font-extrabold leading-[0.94] tracking-[-0.045em]">
            Turn company knowledge into action-ready work.
          </h1>

          <p class="mt-7 max-w-[42rem] text-[17px] leading-relaxed text-[#475569]">
            Tactas connects docs, files, business data, and source context so AI agents can answer questions, summarize information,
            prepare outputs, and support automated tasks.
          </p>

          <div class="mt-9 flex flex-col gap-3 sm:flex-row sm:items-center">
            <a
              href="#contact"
              class="group inline-flex h-12 items-center justify-center rounded-[6px] bg-[#2F66FF] px-6 text-[14px] font-semibold text-white shadow-[0_18px_48px_-24px_rgba(124,58,237,0.8)] transition hover:bg-[#0EA5E9]"
            >
              Start a knowledge review
              <ArrowRight class="ml-2 h-4 w-4 transition group-hover:translate-x-0.5" stroke-width={1.9} />
            </a>
            <a
              href="#service"
              class="inline-flex h-12 items-center justify-center rounded-[6px] border border-[#D8E1EA] bg-white px-6 text-[14px] font-semibold text-[#07324A] transition hover:border-[#06B6D4]/70 hover:text-[#0891B2]"
            >
              See knowledge layer
            </a>
          </div>

          <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
            {trustPoints.map(([title, body]) => (
              <div class="border-l border-[#06B6D4]/50 pl-4">
                <p class="text-[14px] font-semibold text-[#07324A]">{title}</p>
                <p class="mt-1 text-[12px] leading-relaxed text-[#64748B]">{body}</p>
              </div>
            ))}
          </div>
        </div>

        <div class="reveal" data-delay="2">
          <div class="relative mx-auto max-w-[640px]">
            <div class="absolute inset-x-8 bottom-[-18px] h-12 rounded-full bg-[#2F66FF]/18 blur-2xl"></div>
            <div class="relative overflow-hidden rounded-[12px] border border-[#D8E1EA] bg-white shadow-[0_40px_110px_-56px_rgba(0,0,0,0.95)]">
              <div class="flex h-12 items-center justify-between border-b border-[#D8E1EA] bg-white px-4">
                <div class="flex items-center gap-2">
                  <span class="h-2.5 w-2.5 rounded-full bg-[#06B6D4]"></span>
                  <span class="h-2.5 w-2.5 rounded-full bg-white/24"></span>
                  <span class="h-2.5 w-2.5 rounded-full bg-white/24"></span>
                </div>
                <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-[#0891B2]">Knowledge runtime</p>
              </div>

              <div class="grid lg:grid-cols-[185px_1fr]">
                <aside class="border-b border-[#D8E1EA] bg-[#F6F8FB] p-4 lg:border-b-0 lg:border-r">
                  <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-[#0891B2]">Sources</p>
                  <div class="mt-4 grid gap-2">
                    {sources.map((source, index) => (
                      <div class:list={[
                        "flex items-center justify-between rounded-[6px] border px-3 py-2 text-[12px]",
                        index < 4 ? "border-[#BAE6FD] bg-[#E6FBFF] text-[#07324A]" : "border-[#D8E1EA] bg-white text-[#64748B]",
                      ]}>
                        <span>{source}</span>
                        <span class:list={[
                          "h-1.5 w-1.5 rounded-full",
                          index < 4 ? "bg-[#06B6D4]" : "bg-white/20",
                        ]}></span>
                      </div>
                    ))}
                  </div>
                </aside>

                <div class="p-5">
                  <div class="rounded-[8px] border border-[#D8E1EA] bg-white p-4">
                    <div class="flex items-start gap-3">
                      <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-[6px] bg-[#2F66FF] text-white">
                        <Search class="h-5 w-5" stroke-width={2} />
                      </span>
                      <div>
                        <p class="text-[14px] font-semibold text-[#07324A]">What changed in the enterprise refund policy?</p>
                        <p class="mt-1 text-[12px] leading-relaxed text-[#64748B]">
                          Searching source documents, business notes, and related context.
                        </p>
                      </div>
                    </div>

                    <div class="mt-4 h-1.5 overflow-hidden rounded-full bg-white/10">
                      <div class="tactas-progress h-full rounded-full bg-[#06B6D4]"></div>
                    </div>
                  </div>

                  <div class="mt-4 rounded-[8px] border border-[#BAE6FD] bg-[#E6FBFF]/72 p-4">
                    <div class="flex items-center justify-between gap-4">
                      <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-[#0891B2]">Cited answer</p>
                      <Check class="h-4 w-4 text-[#0891B2]" stroke-width={2.2} />
                    </div>
                    <p class="mt-3 text-[14px] leading-relaxed text-[#07324A]">
                      The policy changed this quarter. The next step is to prepare a customer-ready answer, attach the source,
                      and create a follow-up task for the account owner.
                    </p>
                    <div class="mt-4 grid gap-2 sm:grid-cols-2">
                      {["Policy-update.pdf p.12", "Account-notes.md sec.3", "Product-guide p.4", "Team-playbook p.9"].map((item) => (
                        <div class="flex items-center gap-2 rounded-[5px] border border-[#D8E1EA] bg-[#F6F8FB] px-3 py-2 text-[11px] text-[#475569]">
                          <FileText class="h-3.5 w-3.5 text-[#0891B2]" stroke-width={1.8} />
                          {item}
                        </div>
                      ))}
                    </div>
                  </div>

                  <div class="mt-4 grid gap-3 sm:grid-cols-3">
                    {[
                      [Database, "Metadata"],
                      [Layers, "Hybrid index"],
                      [KeyRound, "Permissions"],
                    ].map(([Icon, label]) => (
                      <div class="rounded-[8px] border border-[#D8E1EA] bg-white p-3">
                        <Icon class="h-4 w-4 text-[#0891B2]" stroke-width={1.8} />
                        <p class="mt-3 text-[12px] font-semibold text-[#07324A]">{label}</p>
                      </div>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="border-b border-[#D8E1EA] bg-[#F6F8FB]">
      <div class={`${CONTAINER} py-10`}>
        <div class="grid gap-3 text-center sm:grid-cols-2 lg:grid-cols-4">
          {["Company Knowledge Layer", "Source-Backed Answers", "Document Search", "Action-Ready Context"].map((term) => (
            <div class="rounded-[8px] border border-[#D8E1EA] bg-white px-4 py-4 font-mono text-[11px] uppercase tracking-[0.18em] text-[#0891B2]">
              {term}
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="service" class="border-b border-[#D8E1EA] bg-[#F6F8FB]">
      <div class={`${CONTAINER} py-18 lg:py-24`}>
        <div class="mx-auto max-w-3xl text-center">
          <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-[#0891B2]">Managed service</p>
          <h2 class="mt-4 text-[clamp(2rem,4vw,3.2rem)] font-bold leading-tight tracking-[-0.025em]">
            Company knowledge for managed AI agents.
          </h2>
          <p class="mt-5 text-[16px] leading-relaxed text-[#64748B]">
            The value is not just search. It is the operating layer that turns documents, files, and source context into
            answers, summaries, task outputs, and automated work.
          </p>
        </div>

        <div class="mt-12 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
          {serviceLayers.map((item) => {
            const Icon = item.icon;
            return (
              <article class="group min-h-[250px] rounded-[8px] border border-[#D8E1EA] bg-white p-6 transition hover:border-[#06B6D4]/50 hover:bg-white">
                <span class="flex h-12 w-12 items-center justify-center rounded-[8px] border border-[#06B6D4]/25 bg-[#E6FBFF] text-[#0891B2]">
                  <Icon class="h-5 w-5" stroke-width={1.8} />
                </span>
                <h3 class="mt-7 text-[22px] font-semibold tracking-tight">{item.title}</h3>
                <p class="mt-3 text-[14px] leading-relaxed text-[#64748B]">{item.body}</p>
              </article>
            );
          })}
        </div>
      </div>
    </section>

    <section id="architecture" class="border-b border-[#D8E1EA] bg-[#F6F8FB] text-[#0F172A]">
      <div class={`${CONTAINER} py-16 lg:py-20`}>
        <div class="mx-auto max-w-3xl text-center">
          <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-[#06B6D4]">Knowledge flow</p>
          <h2 class="mt-4 text-[clamp(2rem,4vw,3.1rem)] font-bold leading-tight tracking-[-0.025em]">
            From source material to action-ready context.
          </h2>
        </div>

        <div class="mt-12 grid gap-4 lg:grid-cols-5">
          {workflow.map(([step, title, body], index) => (
            <article class="relative rounded-[8px] border border-[#D8E1EA] bg-white p-5 shadow-[0_20px_60px_-52px_rgba(15,23,42,0.28)]">
              {index < workflow.length - 1 ? (
                <div class="absolute -right-3 top-10 hidden h-px w-6 bg-[#2F66FF]/45 lg:block"></div>
              ) : null}
              <p class="font-mono text-[11px] text-[#06B6D4]">{step}</p>
              <h3 class="mt-5 text-[17px] font-semibold">{title}</h3>
              <p class="mt-3 text-[13px] leading-relaxed text-[#64748B]">{body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="border-b border-[#D8E1EA] bg-[#F6F8FB]">
      <div class={`${CONTAINER} grid gap-12 py-18 lg:grid-cols-[0.72fr_1.28fr] lg:py-24`}>
        <div>
          <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-[#0891B2]">Task outcomes</p>
          <h2 class="mt-4 text-[clamp(2rem,4vw,3.15rem)] font-bold leading-tight tracking-[-0.025em]">
            Knowledge outcomes where source-backed context matters.
          </h2>
          <p class="mt-5 text-[16px] leading-relaxed text-[#64748B]">
            Start with one knowledge source, prove answer quality, then expand the layer into business tasks and managed agents.
          </p>
        </div>

        <div class="grid gap-3 sm:grid-cols-2">
          {useCases.map((item) => (
            <div class="flex items-center gap-3 rounded-[8px] border border-[#D8E1EA] bg-white p-4">
              <BrainCircuit class="h-4.5 w-4.5 shrink-0 text-[#0891B2]" stroke-width={1.8} />
              <p class="text-[15px] font-semibold text-[#07324A]">{item}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="border-b border-[#D8E1EA] bg-[#F6F8FB]">
      <div class={`${CONTAINER} py-18 lg:py-24`}>
        <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
          <div class="max-w-3xl">
            <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-[#0891B2]">Packages</p>
            <h2 class="mt-4 text-[clamp(2rem,4vw,3.15rem)] font-bold leading-tight tracking-[-0.025em]">
              Start narrow. Prove source quality. Expand into action.
            </h2>
          </div>
          <a href="#contact" class="inline-flex h-11 items-center justify-center rounded-[6px] border border-[#D8E1EA] px-4 text-[13px] font-semibold text-[#07324A] transition hover:border-[#06B6D4]/70 hover:text-[#0891B2]">
            Discuss scope
          </a>
        </div>

        <div class="mt-10 grid gap-4 lg:grid-cols-3">
          {packages.map((plan, index) => (
            <article class:list={[
              "rounded-[8px] border p-6",
              index === 1 ? "border-[#06B6D4]/60 bg-[#E6FBFF]" : "border-[#D8E1EA] bg-[#F6F8FB]",
            ]}>
              <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-[#0891B2]">{plan.name}</p>
              <p class="mt-5 min-h-[96px] text-[15px] leading-relaxed text-[#475569]">{plan.body}</p>
              <ul class="mt-6 grid gap-3 border-t border-[#D8E1EA] pt-5">
                {plan.items.map((item) => (
                  <li class="flex items-start gap-2.5 text-[14px] text-[#64748B]">
                    <Check class="mt-0.5 h-3.5 w-3.5 shrink-0 text-[#0891B2]" stroke-width={2.2} />
                    {item}
                  </li>
                ))}
              </ul>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="faq" class="border-b border-[#D8E1EA] bg-[#F6F8FB]">
      <div class={`${CONTAINER} grid gap-12 py-18 lg:grid-cols-[0.72fr_1.28fr] lg:py-24`}>
        <div>
          <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-[#0891B2]">FAQ</p>
          <h2 class="mt-4 text-[clamp(2rem,4vw,3.15rem)] font-bold leading-tight tracking-[-0.025em]">
            Common questions before launching a company knowledge layer.
          </h2>
        </div>

        <div class="grid rounded-[8px] border border-[#D8E1EA] bg-white">
          {faqs.map(([question, answer], index) => (
            <article class="grid gap-3 border-b border-[#D8E1EA] p-6 last:border-b-0 sm:grid-cols-[76px_1fr]">
              <p class="font-mono text-[11px] text-[#0891B2]">{String(index + 1).padStart(2, "0")}</p>
              <div>
                <h3 class="text-[20px] font-semibold tracking-tight">{question}</h3>
                <p class="mt-3 text-[15px] leading-relaxed text-[#64748B]">{answer}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="contact" class="bg-[#F6F8FB]">
      <div class={`${CONTAINER} py-18 lg:py-24`}>
        <div class="grid overflow-hidden rounded-[12px] border border-[#BAE6FD] bg-white lg:grid-cols-[0.92fr_1.08fr]">
          <div class="p-7 sm:p-9 lg:p-10">
            <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-[#0891B2]">Start a knowledge review</p>
            <h2 class="mt-4 text-[clamp(2rem,4vw,3.2rem)] font-bold leading-tight tracking-[-0.025em]">
              Turn one knowledge source into action-ready AI context.
            </h2>
            <p class="mt-5 max-w-[34rem] text-[16px] leading-relaxed text-[#64748B]">
              Share the knowledge source, business questions, and task outputs your team wants AI agents to support first.
            </p>

            <div class="mt-8 flex items-center gap-3 text-[14px] text-[#475569]">
              <Mail class="h-4 w-4 text-[#0891B2]" stroke-width={1.8} />
              <a href={`mailto:${brandEmail}`} class="border-b border-[#06B6D4]/50 pb-0.5 transition hover:border-[#06B6D4] hover:text-[#07324A]">
                {brandEmail}
              </a>
            </div>
          </div>

          <form id="knowledge-inquiry-form" class="border-t border-[#D8E1EA] bg-[#F6F8FB] p-7 sm:p-9 lg:border-l lg:border-t-0">
            <div class="flex items-center justify-between gap-4 border-b border-[#D8E1EA] pb-4">
              <div>
                <p class="font-mono text-[10px] uppercase tracking-[0.24em] text-[#0891B2]">Knowledge review</p>
                <h3 class="mt-2 text-[24px] font-semibold tracking-tight">What knowledge should AI use at work?</h3>
              </div>
              <Send class="hidden h-5 w-5 text-[#0891B2] sm:block" stroke-width={1.8} />
            </div>

            <div class="mt-5 grid gap-4 sm:grid-cols-2">
              <label class="grid gap-1.5 text-[11px] font-medium uppercase tracking-[0.16em] text-[#64748B]">
                First name
                <input required name="name" class="h-11 rounded-[6px] border border-[#D8E1EA] bg-white px-3.5 text-[14px] text-[#0F172A] outline-none transition placeholder:text-[#94A3B8] focus:border-[#06B6D4] focus:ring-2 focus:ring-[#06B6D4]/15" placeholder="Your name" />
              </label>
              <label class="grid gap-1.5 text-[11px] font-medium uppercase tracking-[0.16em] text-[#64748B]">
                Work email
                <input required type="email" name="email" class="h-11 rounded-[6px] border border-[#D8E1EA] bg-white px-3.5 text-[14px] text-[#0F172A] outline-none transition placeholder:text-[#94A3B8] focus:border-[#06B6D4] focus:ring-2 focus:ring-[#06B6D4]/15" placeholder="you@company.com" />
              </label>
            </div>

            <label class="mt-4 grid gap-1.5 text-[11px] font-medium uppercase tracking-[0.16em] text-[#64748B]">
              Company
              <input name="company" class="h-11 rounded-[6px] border border-[#D8E1EA] bg-white px-3.5 text-[14px] text-[#0F172A] outline-none transition placeholder:text-[#94A3B8] focus:border-[#06B6D4] focus:ring-2 focus:ring-[#06B6D4]/15" placeholder="Company name" />
            </label>

            <label class="mt-4 grid gap-1.5 text-[11px] font-medium uppercase tracking-[0.16em] text-[#64748B]">
              Knowledge sources and task outputs
              <textarea required name="knowledge" class="min-h-32 rounded-[6px] border border-[#D8E1EA] bg-white px-3.5 py-3 text-[14px] text-[#0F172A] outline-none transition placeholder:text-[#94A3B8] focus:border-[#06B6D4] focus:ring-2 focus:ring-[#06B6D4]/15" placeholder="Example: product docs in Drive, company notes in Notion, contracts in S3, questions and summaries teams prepare every week..."></textarea>
            </label>

            <button type="submit" class="mt-6 inline-flex h-12 w-full items-center justify-center rounded-[6px] bg-[#2F66FF] px-6 text-[14px] font-semibold text-white transition hover:bg-[#0EA5E9]">
              Request knowledge review
            </button>
            <p id="knowledge-form-status" class="mt-3 text-center text-[12px] text-[#64748B]">
              Prefer email? {brandEmail}
            </p>
          </form>
        </div>
      </div>
    </section>
  </main>
</div>

<script define:vars={{ brandEmail }} is:inline>
  const knowledgeForm = document.getElementById("knowledge-inquiry-form");
  const knowledgeStatus = document.getElementById("knowledge-form-status");
  knowledgeForm?.addEventListener("submit", (event) => {
    event.preventDefault();
    const form = new FormData(knowledgeForm);
    const company = String(form.get("company") || "").trim() || "Tactas AI";
    const subject = encodeURIComponent(`Company knowledge layer review - ${company}`);
    const body = encodeURIComponent(
      [
        `Name: ${String(form.get("name") || "")}`,
        `Work email: ${String(form.get("email") || "")}`,
        `Company: ${String(form.get("company") || "")}`,
        "",
        "Knowledge sources and task outputs:",
        String(form.get("knowledge") || ""),
      ].join("\n"),
    );
    if (knowledgeStatus) {
      knowledgeStatus.textContent = "Opening your email client with the knowledge details.";
    }
    window.location.href = `mailto:${brandEmail}?subject=${subject}&body=${body}`;
  });
</script>
