---
import {
  ArrowRight,
  Bot,
  BrainCircuit,
  Check,
  Database,
  FileSearch,
  FileText,
  FolderSync,
  KeyRound,
  Layers,
  Mail,
  Search,
  Send,
  ShieldCheck,
  Sparkles,
} from "@lucide/astro";
import { getBrandEmail } from "../lib/site";

interface Props {
  siteUrl: string;
  currentPath?: string;
}

const { currentPath = "/services/ai-knowledge-base" } = Astro.props;
const brandEmail = getBrandEmail();
const CONTAINER = "mx-auto w-full max-w-[1240px] px-5 sm:px-8 lg:px-10";

const trustPoints = [
  ["Managed RAG", "Built, tuned, and operated"],
  ["Cited answers", "Every response tied to sources"],
  ["Permission aware", "Users only see approved content"],
  ["API ready", "Search and Q&A for internal apps"],
];

const sources = ["Google Drive", "SharePoint", "S3", "PostgreSQL", "Helpdesk", "CRM", "PDFs", "Docs"];

const serviceLayers = [
  {
    title: "Ingest",
    body: "Connect files, cloud folders, databases, helpdesks, and internal systems without forcing a new document workflow.",
    icon: FolderSync,
  },
  {
    title: "Index",
    body: "Parse, OCR, clean, chunk, embed, version, and index documents for hybrid search and enterprise AI search.",
    icon: FileSearch,
  },
  {
    title: "Answer",
    body: "Deliver document search, RAG Q&A, summaries, source citations, and APIs for assistants or business portals.",
    icon: Bot,
  },
  {
    title: "Govern",
    body: "Apply tenant isolation, user permissions, audit logs, deletion rules, evals, and review workflows.",
    icon: ShieldCheck,
  },
];

const workflow = [
  ["01", "Connect sources", "Drive, SharePoint, S3, DBs, PDFs, helpdesk articles"],
  ["02", "Prepare knowledge", "Parse, OCR, clean, chunk, classify, embed, version"],
  ["03", "Retrieve context", "Hybrid search, metadata filters, reranking, permissions"],
  ["04", "Generate answers", "RAG Q&A, summaries, citations, unsupported-claim limits"],
  ["05", "Operate quality", "Monitor failures, tune retrieval, update eval sets"],
];

const useCases = [
  "Internal policy and HR knowledge base",
  "Customer support knowledge assistant",
  "Contract and legal document search",
  "Sales enablement and proposal lookup",
  "Product documentation assistant",
  "Operations SOP and compliance library",
  "SharePoint AI search",
  "Google Drive AI search",
];

const packages = [
  {
    name: "Pilot",
    body: "Prove value with one source, real business questions, cited Q&A, and retrieval quality review.",
    items: ["1 source integration", "500-2,000 documents", "Search and cited Q&A"],
  },
  {
    name: "Business",
    body: "Launch a managed knowledge base for a department with dashboard, API, permissions, and tuning.",
    items: ["Multiple sources", "Permission-aware retrieval", "Monthly quality tuning"],
  },
  {
    name: "Enterprise",
    body: "Run a governed document intelligence layer across sensitive teams and production workflows.",
    items: ["Private deployment options", "SSO, RBAC, audit logs", "Custom eval benchmarks"],
  },
];

const faqs = [
  ["Is this a product or service?", "It is a managed service. Tactas AI designs, builds, deploys, and operates the AI Knowledge Base so your team is not left maintaining a fragile RAG prototype."],
  ["Can it use our current document storage?", "Yes. We can connect to Google Drive, SharePoint, S3-compatible storage, databases, helpdesks, CRMs, and internal repositories."],
  ["How do you reduce hallucinations?", "Answers are generated from retrieved source passages, include citations, and are tested with evaluation questions so weak retrieval paths can be improved."],
  ["Do you use OpenSearch or Vespa?", "Most pilots start with OpenSearch for practical hybrid search. Vespa is a good option when ranking, scale, or advanced retrieval control matters."],
];
---

<div class="min-h-screen overflow-x-hidden bg-[#050A14] text-white selection:bg-[#8B5CF6]/30">
  <div class="pointer-events-none fixed inset-0 -z-20 grid-faint opacity-[0.24] [mask-image:radial-gradient(ellipse_70%_60%_at_50%_10%,black_0%,transparent_75%)]"></div>

  <main>
    <section class="relative overflow-hidden border-b border-white/10">
      <div class="pointer-events-none absolute inset-0 z-0 bg-[linear-gradient(180deg,rgba(124,58,237,0.13)_0%,rgba(5,10,20,0)_58%)]"></div>
      <div class="pointer-events-none absolute inset-0 z-0 opacity-[0.32] [background-image:linear-gradient(to_right,rgba(255,255,255,0.055)_1px,transparent_1px),linear-gradient(to_bottom,rgba(255,255,255,0.045)_1px,transparent_1px)] [background-size:72px_72px]"></div>

      <div class={`${CONTAINER} relative z-10 grid min-h-[720px] items-center gap-14 py-16 lg:grid-cols-[0.95fr_1.05fr] lg:py-20`}>
        <div class="reveal">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#7C3AED]/35 bg-[#130B2A]/80 px-3 py-1.5">
            <Sparkles class="h-3.5 w-3.5 text-[#A78BFA]" stroke-width={1.8} />
            <span class="font-mono text-[10px] font-semibold uppercase tracking-[0.24em] text-[#C4B5FD]">
              AI Knowledge Base Service
            </span>
          </div>

          <h1 class="max-w-[12ch] text-[clamp(3rem,7vw,5.8rem)] font-extrabold leading-[0.94] tracking-[-0.045em]">
            Managed RAG for document search and cited answers.
          </h1>

          <p class="mt-7 max-w-[42rem] text-[17px] leading-relaxed text-[#C8D0DE]">
            Tactas AI builds and operates private AI Knowledge Bases that connect company documents, power enterprise AI search,
            answer questions with citations, and keep retrieval quality under active management.
          </p>

          <div class="mt-9 flex flex-col gap-3 sm:flex-row sm:items-center">
            <a
              href="#contact"
              class="group inline-flex h-12 items-center justify-center rounded-[6px] bg-[#7C3AED] px-6 text-[14px] font-semibold text-white shadow-[0_18px_48px_-24px_rgba(124,58,237,0.8)] transition hover:bg-[#8B5CF6]"
            >
              Start a pilot
              <ArrowRight class="ml-2 h-4 w-4 transition group-hover:translate-x-0.5" stroke-width={1.9} />
            </a>
            <a
              href="#service"
              class="inline-flex h-12 items-center justify-center rounded-[6px] border border-white/18 bg-white/[0.03] px-6 text-[14px] font-semibold text-white transition hover:border-[#A78BFA]/70 hover:text-[#C4B5FD]"
            >
              See managed service
            </a>
          </div>

          <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
            {trustPoints.map(([title, body]) => (
              <div class="border-l border-[#7C3AED]/50 pl-4">
                <p class="text-[14px] font-semibold text-white">{title}</p>
                <p class="mt-1 text-[12px] leading-relaxed text-[#8A93A6]">{body}</p>
              </div>
            ))}
          </div>
        </div>

        <div class="reveal" data-delay="2">
          <div class="relative mx-auto max-w-[640px]">
            <div class="absolute inset-x-8 bottom-[-18px] h-12 rounded-full bg-[#7C3AED]/18 blur-2xl"></div>
            <div class="relative overflow-hidden rounded-[12px] border border-white/12 bg-[#07101F] shadow-[0_40px_110px_-56px_rgba(0,0,0,0.95)]">
              <div class="flex h-12 items-center justify-between border-b border-white/10 bg-white/[0.035] px-4">
                <div class="flex items-center gap-2">
                  <span class="h-2.5 w-2.5 rounded-full bg-[#8B5CF6]"></span>
                  <span class="h-2.5 w-2.5 rounded-full bg-white/24"></span>
                  <span class="h-2.5 w-2.5 rounded-full bg-white/24"></span>
                </div>
                <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-[#A78BFA]">Knowledge runtime</p>
              </div>

              <div class="grid lg:grid-cols-[185px_1fr]">
                <aside class="border-b border-white/10 bg-[#080D1A] p-4 lg:border-b-0 lg:border-r">
                  <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-[#A78BFA]">Sources</p>
                  <div class="mt-4 grid gap-2">
                    {sources.map((source, index) => (
                      <div class:list={[
                        "flex items-center justify-between rounded-[6px] border px-3 py-2 text-[12px]",
                        index < 4 ? "border-[#7C3AED]/35 bg-[#160B36] text-[#EDE9FE]" : "border-white/10 bg-white/[0.025] text-[#8A93A6]",
                      ]}>
                        <span>{source}</span>
                        <span class:list={[
                          "h-1.5 w-1.5 rounded-full",
                          index < 4 ? "bg-[#A78BFA]" : "bg-white/20",
                        ]}></span>
                      </div>
                    ))}
                  </div>
                </aside>

                <div class="p-5">
                  <div class="rounded-[8px] border border-white/10 bg-[#0A1324] p-4">
                    <div class="flex items-start gap-3">
                      <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-[6px] bg-[#7C3AED] text-white">
                        <Search class="h-5 w-5" stroke-width={2} />
                      </span>
                      <div>
                        <p class="text-[14px] font-semibold text-white">What changed in the enterprise refund policy?</p>
                        <p class="mt-1 text-[12px] leading-relaxed text-[#8A93A6]">
                          Searching approved policy docs, support SOPs, and contract addendums.
                        </p>
                      </div>
                    </div>

                    <div class="mt-4 h-1.5 overflow-hidden rounded-full bg-white/10">
                      <div class="tactas-progress h-full rounded-full bg-[#8B5CF6]"></div>
                    </div>
                  </div>

                  <div class="mt-4 rounded-[8px] border border-[#7C3AED]/35 bg-[#160B36]/72 p-4">
                    <div class="flex items-center justify-between gap-4">
                      <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-[#C4B5FD]">Cited answer</p>
                      <Check class="h-4 w-4 text-[#A78BFA]" stroke-width={2.2} />
                    </div>
                    <p class="mt-3 text-[14px] leading-relaxed text-[#EDE9FE]">
                      Enterprise refunds require finance approval when the account has an active annual contract. Support can
                      offer service credit first, then route exceptions to billing.
                    </p>
                    <div class="mt-4 grid gap-2 sm:grid-cols-2">
                      {["Policy-v4.pdf p.12", "Billing-SOP.md sec.3", "Contract-addendum p.4", "Support-playbook p.9"].map((item) => (
                        <div class="flex items-center gap-2 rounded-[5px] border border-white/10 bg-[#070B16] px-3 py-2 text-[11px] text-[#C8D0DE]">
                          <FileText class="h-3.5 w-3.5 text-[#A78BFA]" stroke-width={1.8} />
                          {item}
                        </div>
                      ))}
                    </div>
                  </div>

                  <div class="mt-4 grid gap-3 sm:grid-cols-3">
                    {[
                      [Database, "Metadata"],
                      [Layers, "Hybrid index"],
                      [KeyRound, "Permissions"],
                    ].map(([Icon, label]) => (
                      <div class="rounded-[8px] border border-white/10 bg-white/[0.025] p-3">
                        <Icon class="h-4 w-4 text-[#A78BFA]" stroke-width={1.8} />
                        <p class="mt-3 text-[12px] font-semibold text-white">{label}</p>
                      </div>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="border-b border-white/10 bg-[#070B16]">
      <div class={`${CONTAINER} py-10`}>
        <div class="grid gap-3 text-center sm:grid-cols-2 lg:grid-cols-4">
          {["AI Knowledge Base", "Managed RAG Service", "Enterprise AI Search", "Private Document Q&A"].map((term) => (
            <div class="rounded-[8px] border border-white/10 bg-white/[0.025] px-4 py-4 font-mono text-[11px] uppercase tracking-[0.18em] text-[#A78BFA]">
              {term}
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="service" class="border-b border-white/10 bg-[#050A14]">
      <div class={`${CONTAINER} py-18 lg:py-24`}>
        <div class="mx-auto max-w-3xl text-center">
          <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-[#A78BFA]">Managed service</p>
          <h2 class="mt-4 text-[clamp(2rem,4vw,3.2rem)] font-bold leading-tight tracking-[-0.025em]">
            We manage the parts that make RAG work in production.
          </h2>
          <p class="mt-5 text-[16px] leading-relaxed text-[#8A93A6]">
            The value is not just vector search. It is the operating layer around documents, permissions, retrieval quality,
            source freshness, and user trust.
          </p>
        </div>

        <div class="mt-12 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
          {serviceLayers.map((item) => {
            const Icon = item.icon;
            return (
              <article class="group min-h-[250px] rounded-[8px] border border-white/10 bg-[#07101F] p-6 transition hover:border-[#7C3AED]/55 hover:bg-[#0A1324]">
                <span class="flex h-12 w-12 items-center justify-center rounded-[8px] border border-[#7C3AED]/25 bg-[#160B36] text-[#A78BFA]">
                  <Icon class="h-5 w-5" stroke-width={1.8} />
                </span>
                <h3 class="mt-7 text-[22px] font-semibold tracking-tight">{item.title}</h3>
                <p class="mt-3 text-[14px] leading-relaxed text-[#8A93A6]">{item.body}</p>
              </article>
            );
          })}
        </div>
      </div>
    </section>

    <section id="architecture" class="border-b border-white/10 bg-[#F8FAFC] text-[#0F172A]">
      <div class={`${CONTAINER} py-16 lg:py-20`}>
        <div class="mx-auto max-w-3xl text-center">
          <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-[#7C3AED]">Reference architecture</p>
          <h2 class="mt-4 text-[clamp(2rem,4vw,3.1rem)] font-bold leading-tight tracking-[-0.025em]">
            From raw documents to reliable answers.
          </h2>
        </div>

        <div class="mt-12 grid gap-4 lg:grid-cols-5">
          {workflow.map(([step, title, body], index) => (
            <article class="relative rounded-[8px] border border-[#D8E1EA] bg-white p-5 shadow-[0_20px_60px_-52px_rgba(15,23,42,0.28)]">
              {index < workflow.length - 1 ? (
                <div class="absolute -right-3 top-10 hidden h-px w-6 bg-[#7C3AED]/45 lg:block"></div>
              ) : null}
              <p class="font-mono text-[11px] text-[#7C3AED]">{step}</p>
              <h3 class="mt-5 text-[17px] font-semibold">{title}</h3>
              <p class="mt-3 text-[13px] leading-relaxed text-[#64748B]">{body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="border-b border-white/10 bg-[#050A14]">
      <div class={`${CONTAINER} grid gap-12 py-18 lg:grid-cols-[0.72fr_1.28fr] lg:py-24`}>
        <div>
          <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-[#A78BFA]">Use cases</p>
          <h2 class="mt-4 text-[clamp(2rem,4vw,3.15rem)] font-bold leading-tight tracking-[-0.025em]">
            Knowledge workflows where source-backed answers matter.
          </h2>
          <p class="mt-5 text-[16px] leading-relaxed text-[#8A93A6]">
            Start with one department or document set, prove answer quality, then expand the knowledge layer.
          </p>
        </div>

        <div class="grid gap-3 sm:grid-cols-2">
          {useCases.map((item) => (
            <div class="flex items-center gap-3 rounded-[8px] border border-white/10 bg-[#07101F] p-4">
              <BrainCircuit class="h-4.5 w-4.5 shrink-0 text-[#A78BFA]" stroke-width={1.8} />
              <p class="text-[15px] font-semibold text-[#E5E7EB]">{item}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="border-b border-white/10 bg-[#070B16]">
      <div class={`${CONTAINER} py-18 lg:py-24`}>
        <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
          <div class="max-w-3xl">
            <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-[#A78BFA]">Packages</p>
            <h2 class="mt-4 text-[clamp(2rem,4vw,3.15rem)] font-bold leading-tight tracking-[-0.025em]">
              Start narrow. Prove retrieval. Expand with confidence.
            </h2>
          </div>
          <a href="#contact" class="inline-flex h-11 items-center justify-center rounded-[6px] border border-white/18 px-4 text-[13px] font-semibold text-white transition hover:border-[#A78BFA]/70 hover:text-[#C4B5FD]">
            Discuss scope
          </a>
        </div>

        <div class="mt-10 grid gap-4 lg:grid-cols-3">
          {packages.map((plan, index) => (
            <article class:list={[
              "rounded-[8px] border p-6",
              index === 1 ? "border-[#7C3AED]/65 bg-[#130B2A]" : "border-white/10 bg-[#050A14]",
            ]}>
              <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-[#A78BFA]">{plan.name}</p>
              <p class="mt-5 min-h-[96px] text-[15px] leading-relaxed text-[#C8D0DE]">{plan.body}</p>
              <ul class="mt-6 grid gap-3 border-t border-white/10 pt-5">
                {plan.items.map((item) => (
                  <li class="flex items-start gap-2.5 text-[14px] text-[#8A93A6]">
                    <Check class="mt-0.5 h-3.5 w-3.5 shrink-0 text-[#A78BFA]" stroke-width={2.2} />
                    {item}
                  </li>
                ))}
              </ul>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="faq" class="border-b border-white/10 bg-[#050A14]">
      <div class={`${CONTAINER} grid gap-12 py-18 lg:grid-cols-[0.72fr_1.28fr] lg:py-24`}>
        <div>
          <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-[#A78BFA]">FAQ</p>
          <h2 class="mt-4 text-[clamp(2rem,4vw,3.15rem)] font-bold leading-tight tracking-[-0.025em]">
            Common questions before launching a managed RAG service.
          </h2>
        </div>

        <div class="grid rounded-[8px] border border-white/10 bg-[#07101F]">
          {faqs.map(([question, answer], index) => (
            <article class="grid gap-3 border-b border-white/10 p-6 last:border-b-0 sm:grid-cols-[76px_1fr]">
              <p class="font-mono text-[11px] text-[#A78BFA]">{String(index + 1).padStart(2, "0")}</p>
              <div>
                <h3 class="text-[20px] font-semibold tracking-tight">{question}</h3>
                <p class="mt-3 text-[15px] leading-relaxed text-[#8A93A6]">{answer}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="contact" class="bg-[#070B16]">
      <div class={`${CONTAINER} py-18 lg:py-24`}>
        <div class="grid overflow-hidden rounded-[12px] border border-[#7C3AED]/35 bg-[#0A1324] lg:grid-cols-[0.92fr_1.08fr]">
          <div class="p-7 sm:p-9 lg:p-10">
            <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-[#A78BFA]">Start a pilot</p>
            <h2 class="mt-4 text-[clamp(2rem,4vw,3.2rem)] font-bold leading-tight tracking-[-0.025em]">
              Turn one document set into a working AI Knowledge Base.
            </h2>
            <p class="mt-5 max-w-[34rem] text-[16px] leading-relaxed text-[#8A93A6]">
              Share the document sources, user groups, and questions your team needs answered with citations.
            </p>

            <div class="mt-8 flex items-center gap-3 text-[14px] text-[#C8D0DE]">
              <Mail class="h-4 w-4 text-[#A78BFA]" stroke-width={1.8} />
              <a href={`mailto:${brandEmail}`} class="border-b border-[#7C3AED]/55 pb-0.5 transition hover:border-[#A78BFA] hover:text-white">
                {brandEmail}
              </a>
            </div>
          </div>

          <form id="knowledge-inquiry-form" class="border-t border-white/10 bg-[#050A14] p-7 sm:p-9 lg:border-l lg:border-t-0">
            <div class="flex items-center justify-between gap-4 border-b border-white/10 pb-4">
              <div>
                <p class="font-mono text-[10px] uppercase tracking-[0.24em] text-[#A78BFA]">Pilot request</p>
                <h3 class="mt-2 text-[24px] font-semibold tracking-tight">What should your team ask AI?</h3>
              </div>
              <Send class="hidden h-5 w-5 text-[#A78BFA] sm:block" stroke-width={1.8} />
            </div>

            <div class="mt-5 grid gap-4 sm:grid-cols-2">
              <label class="grid gap-1.5 text-[11px] font-medium uppercase tracking-[0.16em] text-[#8A93A6]">
                First name
                <input required name="name" class="h-11 rounded-[6px] border border-white/12 bg-white/[0.035] px-3.5 text-[14px] text-white outline-none transition placeholder:text-[#5E6678] focus:border-[#8B5CF6] focus:ring-2 focus:ring-[#8B5CF6]/15" placeholder="Your name" />
              </label>
              <label class="grid gap-1.5 text-[11px] font-medium uppercase tracking-[0.16em] text-[#8A93A6]">
                Work email
                <input required type="email" name="email" class="h-11 rounded-[6px] border border-white/12 bg-white/[0.035] px-3.5 text-[14px] text-white outline-none transition placeholder:text-[#5E6678] focus:border-[#8B5CF6] focus:ring-2 focus:ring-[#8B5CF6]/15" placeholder="you@company.com" />
              </label>
            </div>

            <label class="mt-4 grid gap-1.5 text-[11px] font-medium uppercase tracking-[0.16em] text-[#8A93A6]">
              Company
              <input name="company" class="h-11 rounded-[6px] border border-white/12 bg-white/[0.035] px-3.5 text-[14px] text-white outline-none transition placeholder:text-[#5E6678] focus:border-[#8B5CF6] focus:ring-2 focus:ring-[#8B5CF6]/15" placeholder="Company name" />
            </label>

            <label class="mt-4 grid gap-1.5 text-[11px] font-medium uppercase tracking-[0.16em] text-[#8A93A6]">
              Document sources and questions
              <textarea required name="knowledge" class="min-h-32 rounded-[6px] border border-white/12 bg-white/[0.035] px-3.5 py-3 text-[14px] text-white outline-none transition placeholder:text-[#5E6678] focus:border-[#8B5CF6] focus:ring-2 focus:ring-[#8B5CF6]/15" placeholder="Example: HR policies in Drive, support articles in Zendesk, contracts in S3, questions from support and sales..."></textarea>
            </label>

            <button type="submit" class="mt-6 inline-flex h-12 w-full items-center justify-center rounded-[6px] bg-[#7C3AED] px-6 text-[14px] font-semibold text-white transition hover:bg-[#8B5CF6]">
              Request knowledge pilot
            </button>
            <p id="knowledge-form-status" class="mt-3 text-center text-[12px] text-[#8A93A6]">
              Prefer email? {brandEmail}
            </p>
          </form>
        </div>
      </div>
    </section>
  </main>
</div>

<script define:vars={{ brandEmail }} is:inline>
  const knowledgeForm = document.getElementById("knowledge-inquiry-form");
  const knowledgeStatus = document.getElementById("knowledge-form-status");
  knowledgeForm?.addEventListener("submit", (event) => {
    event.preventDefault();
    const form = new FormData(knowledgeForm);
    const company = String(form.get("company") || "").trim() || "Tactas AI";
    const subject = encodeURIComponent(`AI Knowledge Base pilot - ${company}`);
    const body = encodeURIComponent(
      [
        `Name: ${String(form.get("name") || "")}`,
        `Work email: ${String(form.get("email") || "")}`,
        `Company: ${String(form.get("company") || "")}`,
        "",
        "Document sources and questions:",
        String(form.get("knowledge") || ""),
      ].join("\n"),
    );
    if (knowledgeStatus) {
      knowledgeStatus.textContent = "Opening your email client with the pilot details.";
    }
    window.location.href = `mailto:${brandEmail}?subject=${subject}&body=${body}`;
  });
</script>
