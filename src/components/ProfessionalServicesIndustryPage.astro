---
import {
  ArrowRight,
  Bot,
  Briefcase,
  Check,
  CreditCard,
  FileText,
  Headphones,
  Mail,
  PackageCheck,
  Search,
  Send,
  ShieldCheck,
  Sparkles,
  TrendingUp,
} from "@lucide/astro";
import { getBrandEmail } from "../lib/site";

interface Props {
  siteUrl: string;
  currentPath?: string;
}

const { currentPath = "/industries/professional-services" } = Astro.props;
const brandEmail = getBrandEmail();
const CONTAINER = "mx-auto w-full max-w-[1240px] px-5 sm:px-8 lg:px-10";

const proof = [
  ["Client intake", "Collect goals, contact details, service needs, deadlines, budget, files, and context before staff review."],
  ["Document collection", "Request missing contracts, statements, IDs, briefs, screenshots, forms, and supporting materials."],
  ["Lead qualification", "Score fit, urgency, scope, value, and next steps so the right person can respond faster."],
  ["Staff handoff", "Route legal, financial, pricing, conflict, and engagement decisions to qualified humans with context."],
];

const painPoints = [
  {
    title: "New client inquiries arrive incomplete",
    body: "Teams spend time chasing context, documents, deadlines, budget, and decision-maker details before real work can begin.",
  },
  {
    title: "Follow-up depends on manual coordination",
    body: "Prospects and clients fall through the cracks when email, CRM, calendars, files, and task tools are not connected.",
  },
  {
    title: "Professional judgment must stay controlled",
    body: "Regulated advice, pricing, conflicts, scope changes, and sensitive commitments need approval instead of unchecked automation.",
  },
];

const workflows = [
  {
    title: "AI client intake automation",
    body: "Capture request details, goals, deadlines, budget, files, and missing information before a consultant or specialist reviews.",
    icon: FileText,
  },
  {
    title: "Lead qualification and routing",
    body: "Classify fit, urgency, service line, deal value, and next owner while syncing the right context to CRM.",
    icon: TrendingUp,
  },
  {
    title: "Document collection workflows",
    body: "Request, track, and organize contracts, statements, intake forms, briefs, screenshots, and supporting documents.",
    icon: PackageCheck,
  },
  {
    title: "Proposal and scope prep",
    body: "Prepare staff-ready summaries, draft scope notes, collect assumptions, and flag pricing or approval questions.",
    icon: Briefcase,
  },
  {
    title: "Client support triage",
    body: "Classify incoming requests, enrich cases, draft replies, and route urgent or sensitive issues to the right person.",
    icon: Headphones,
  },
  {
    title: "Approval and control layer",
    body: "Keep advice, pricing, conflict checks, payment exceptions, and engagement decisions behind human review.",
    icon: ShieldCheck,
  },
];

const searchIntents = [
  {
    title: "AI client intake automation",
    body: "Turn messy inquiry forms, emails, and calls into structured client profiles, required documents, and next actions.",
  },
  {
    title: "AI automation for professional services",
    body: "Automate repeatable admin work across intake, qualification, document collection, CRM updates, and follow-up.",
  },
  {
    title: "AI legal intake assistant",
    body: "Collect matter details, deadlines, documents, and conflict-check context while routing legal judgment to qualified staff.",
  },
  {
    title: "AI accounting workflow automation",
    body: "Prepare client onboarding, tax document collection, bookkeeping questions, billing follow-up, and approval-ready summaries.",
  },
  {
    title: "AI consulting workflow automation",
    body: "Qualify opportunities, collect discovery context, prepare meeting briefs, and track proposal follow-up.",
  },
  {
    title: "CRM workflow automation",
    body: "Sync intake details, conversation summaries, next steps, and owner assignments into the systems your team already uses.",
  },
];

const reviewTakeaways = [
  "Identify the highest-friction client intake or follow-up workflow",
  "Map CRM, email, calendar, document, billing, and task-management context",
  "Define what AI can prepare and what requires partner, manager, or specialist approval",
];

const exampleWorkflow = [
  ["01", "Client inquiry", "A prospect describes a business problem, deadline, budget range, and several missing details."],
  ["02", "Agent collects context", "Service line, decision maker, timeline, documents, CRM history, and preferred meeting times."],
  ["03", "Fit and risk check", "The workflow flags scope gaps, conflicts, regulated advice, pricing questions, and urgency."],
  ["04", "Staff-ready packet", "The team gets a concise summary, missing items, suggested owner, and recommended next step."],
  ["05", "Follow-up logged", "CRM updates, document requests, tasks, and next actions stay visible for review."],
];

const integrations = [
  "CRM",
  "Email",
  "Calendar",
  "Document storage",
  "E-signature",
  "Project tools",
  "Billing systems",
  "Client portals",
  "Call notes",
  "Spreadsheets",
  "Knowledge base",
  "Internal tools",
];

const beforeAfter = [
  ["Prospects send incomplete inquiries.", "AI intake collects the context, documents, and next-step details staff need."],
  ["Teams manually qualify every lead.", "Automation scores fit, urgency, service line, and routing before human review."],
  ["Documents arrive across emails and folders.", "Agents track missing files and prepare complete client packets."],
  ["Follow-up depends on memory and inbox discipline.", "CRM updates, reminders, and task creation happen inside one workflow."],
  ["Sensitive decisions are hard to audit.", "Advice, pricing, conflict, and scope approvals stay logged with ownership."],
];

const rollout = [
  {
    step: "01",
    title: "Choose the client workflow",
    body: "Start with intake, lead qualification, document collection, proposal prep, or client support triage.",
  },
  {
    step: "02",
    title: "Map rules and approvals",
    body: "Define service lines, routing rules, required fields, documents, conflicts, pricing boundaries, and approval paths.",
  },
  {
    step: "03",
    title: "Connect and test",
    body: "Run real scenarios for urgent requests, missing files, poor-fit leads, pricing questions, and sensitive commitments.",
  },
  {
    step: "04",
    title: "Launch supervised",
    body: "Go live with logs, owner assignment, human review, exception alerts, and tuning from real client interactions.",
  },
];

const faq = [
  {
    q: "Is this only for law firms or accounting firms?",
    a: "No. The same workflow patterns apply to agencies, consultancies, financial advisors, legal teams, accounting firms, implementation partners, and other B2B service teams.",
  },
  {
    q: "Can AI make legal, financial, or pricing decisions?",
    a: "Tactas AI workflows should prepare context and recommendations, not replace licensed or accountable judgment. Advice, pricing, conflict checks, and sensitive commitments can require human approval.",
  },
  {
    q: "What professional services workflow should we automate first?",
    a: "The best first workflow is usually client intake, lead qualification, document collection, proposal preparation, CRM updates, or follow-up because the work is frequent and measurable.",
  },
  {
    q: "Can this work with our existing CRM and document tools?",
    a: "Yes. Tactas AI designs around the tools your team already uses, including CRMs, email, calendars, document storage, e-signature, project tools, billing systems, and client portals.",
  },
];
---

<div class="min-h-screen overflow-x-hidden bg-[#F6F8FB] text-[#0F172A] selection:bg-[#06B6D4]/20">
  <div class="pointer-events-none fixed inset-0 -z-20 grid-faint opacity-[0.35] [mask-image:radial-gradient(ellipse_70%_55%_at_50%_15%,black_0%,transparent_75%)]"></div>
  <div class="pointer-events-none fixed inset-x-0 top-0 -z-20 h-[700px] bg-[radial-gradient(ellipse_75%_55%_at_50%_0%,rgba(34,211,238,0.10),transparent_60%)]"></div>

  <main>
    <section class="relative pb-20 pt-12 lg:pb-28 lg:pt-20">
      <div class={`${CONTAINER} relative grid items-center gap-14 lg:grid-cols-[1.02fr_1fr] lg:gap-14`}>
        <div>
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#D8E1EA] bg-white/80 px-3 py-1.5 backdrop-blur">
            <Sparkles class="h-3.5 w-3.5 text-[#0891B2]" stroke-width={1.7} />
            <span class="font-mono text-[10px] font-semibold uppercase tracking-[0.24em] text-[#c8d0de]">
              AI automation for professional services
            </span>
          </div>
          <h1 class="text-[clamp(2.45rem,6vw,5rem)] font-bold leading-[0.96] tracking-[-0.045em] text-[#0F172A]">
            AI agents for client intake, document collection, and follow-up workflows.
          </h1>
          <p class="mt-7 max-w-[41ch] text-[16px] leading-relaxed text-[#8a93a6] sm:text-[17px]">
            Tactas AI helps professional services teams automate intake, qualification, document collection, CRM updates,
            proposal prep, and client support triage with clear approval paths for sensitive decisions.
          </p>
          <div class="mt-9 flex flex-col gap-3 sm:flex-row sm:items-center">
            <a
              href="#contact"
              class="group inline-flex h-12 items-center justify-center rounded-md bg-[#22d3ee] px-6 text-[13px] font-semibold tracking-tight text-[#07090f] transition hover:bg-[#67e8f9]"
            >
              Book client task review
              <ArrowRight class="ml-2 h-4 w-4 transition group-hover:translate-x-0.5" />
            </a>
            <a
              href="#workflows"
              class="group inline-flex h-12 items-center justify-center rounded-md px-2 text-[13px] font-semibold tracking-tight text-[#c8d0de] transition hover:text-[#0F172A]"
            >
              See workflows
              <ArrowRight class="ml-2 h-3.5 w-3.5 transition group-hover:translate-x-0.5" />
            </a>
          </div>
          <p class="mt-5 max-w-[46ch] text-[13px] leading-relaxed text-[#64748B]">
            In a 30-minute review, we identify one high-friction client workflow, map your tools and approval rules,
            and show which steps AI can prepare, route, or log.
          </p>
        </div>

        <div class="relative">
          <div class="pointer-events-none absolute -inset-10 -z-10 bg-[radial-gradient(60%_60%_at_50%_40%,rgba(34,211,238,0.18),transparent_72%)] blur-3xl"></div>
          <div class="overflow-hidden rounded-2xl border border-[#D8E1EA] bg-gradient-to-b from-[#0c111c] to-[#070a12] shadow-[0_50px_120px_-60px_rgba(0,0,0,0.9),inset_0_1px_0_rgba(255,255,255,0.03)]">
            <div class="flex items-center justify-between border-b border-[#D8E1EA] px-5 py-4">
              <div class="flex items-center gap-2.5">
                <span class="flex h-2 w-2 rounded-full bg-[#34d399] pulse-dot" aria-hidden="true"></span>
                <span class="font-mono text-[10px] font-semibold uppercase tracking-[0.24em] text-[#c8d0de]">
                  client workflow
                </span>
              </div>
              <span class="font-mono text-[10px] uppercase tracking-[0.24em] text-[#64748B]">review queue</span>
            </div>

            <div class="grid gap-0 lg:grid-cols-[1fr_230px]">
              <div class="px-5 py-5 sm:px-6">
                <div class="grid gap-3 sm:grid-cols-3">
                  {[
                    ["fit", "qualified"],
                    ["scope", "drafted"],
                    ["risk", "review"],
                  ].map(([label, value]) => (
                    <div class="rounded-md border border-[#D8E1EA] bg-white px-4 py-3">
                      <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-[#64748B]">{label}</p>
                      <p class="mt-2 text-[15px] font-semibold text-[#0F172A]">{value}</p>
                    </div>
                  ))}
                </div>

                <div class="mt-5 rounded-xl border border-[#D8E1EA] bg-[#F6F8FB] p-4">
                  <div class="mb-4 flex items-center gap-2 text-[12px] text-[#8a93a6]">
                    <Bot class="h-4 w-4 text-[#0891B2]" stroke-width={1.7} />
                    intake trace
                  </div>
                  <div class="grid gap-3 font-mono text-[12px] leading-relaxed">
                    {[
                      ["intake", "prospect submits service request"],
                      ["collect", "scope, budget, deadline, files"],
                      ["score", "fit, urgency, value, owner"],
                      ["guard", "pricing and advice require approval"],
                      ["action", "CRM update + follow-up task"],
                    ].map(([tag, line], index) => (
                      <div class="grid grid-cols-[28px_72px_1fr] gap-3 text-[#c8d0de]">
                        <span class="text-[#64748B]">{String(index + 1).padStart(2, "0")}</span>
                        <span class={tag === "guard" ? "text-[#fbbf24]" : "text-[#0891B2]"}>{tag}</span>
                        <span>{line}</span>
                      </div>
                    ))}
                  </div>
                </div>

                <div class="mt-5 grid gap-3 sm:grid-cols-2">
                  <div class="rounded-md border border-[#D8E1EA] bg-white p-4">
                    <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-[#64748B]">next action</p>
                    <p class="mt-2 text-[14px] leading-relaxed text-[#0F172A]">
                      Send missing-document request and assign qualified lead to the right service owner.
                    </p>
                  </div>
                  <div class="rounded-md border border-[#D8E1EA] bg-white p-4">
                    <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-[#64748B]">guardrail</p>
                    <p class="mt-2 text-[14px] leading-relaxed text-[#0F172A]">
                      Advice, pricing, conflicts, and scope commitments require human approval.
                    </p>
                  </div>
                </div>
              </div>

              <aside class="border-t border-[#D8E1EA] px-5 py-5 lg:border-l lg:border-t-0">
                <p class="font-mono text-[10px] uppercase tracking-[0.24em] text-[#64748B]">connected tools</p>
                <div class="mt-4 grid gap-2.5">
                  {["CRM", "Email", "Calendar", "Docs", "Billing", "Tasks"].map((tool) => (
                    <div class="flex items-center justify-between rounded-md border border-[#D8E1EA] bg-white px-3 py-2.5">
                      <span class="text-[12.5px] text-[#c8d0de]">{tool}</span>
                      <Check class="h-3.5 w-3.5 text-[#34d399]" stroke-width={2.5} />
                    </div>
                  ))}
                </div>
              </aside>
            </div>
          </div>
        </div>
      </div>

      <div class={`${CONTAINER} mt-20 lg:mt-28`}>
        <div class="grid divide-y divide-[#D8E1EA] border-y border-[#D8E1EA] sm:grid-cols-2 sm:divide-x sm:divide-y-0 lg:grid-cols-4">
          {proof.map(([title, body], idx) => (
            <div class="px-5 py-7 lg:px-7">
              <span class="font-mono text-[10px] font-semibold uppercase tracking-[0.24em] text-[#64748B]">
                {String(idx + 1).padStart(2, "0")}
              </span>
              <p class="mt-3 text-[14px] font-medium text-[#0F172A]">{title}</p>
              <p class="mt-2 text-[13.5px] leading-relaxed text-[#8a93a6]">{body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="problems" class="border-y border-[#D8E1EA] bg-white py-24 lg:py-32">
      <div class={`${CONTAINER} grid gap-12 lg:grid-cols-[0.72fr_1.28fr] lg:gap-20`}>
        <div>
          <span class="font-mono text-[10px] font-semibold uppercase tracking-[0.28em] text-[#0891B2]/85">Why professional services</span>
          <h2 class="mt-4 text-[clamp(1.9rem,3.4vw,2.7rem)] font-semibold leading-[1.05] tracking-[-0.03em] text-[#0F172A]">
            Growth slows when experts spend time chasing intake details.
          </h2>
          <p class="mt-5 max-w-md text-[15px] leading-relaxed text-[#8a93a6]">
            The best AI automation opportunities are repeatable client workflows where context gathering, routing,
            follow-up, and review consume valuable specialist time.
          </p>
        </div>

        <div>
          <div class="hairline mb-8"></div>
          <ul class="grid gap-0">
            {painPoints.map((item, idx) => (
              <li class="grid gap-3 border-b border-[#D8E1EA] py-7 last:border-b-0 sm:grid-cols-[120px_1fr] sm:gap-8">
                <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.24em] text-[#64748B]">
                  Case {String(idx + 1).padStart(2, "0")}
                </span>
                <div>
                  <h3 class="text-[16px] font-medium tracking-tight text-[#0F172A]">{item.title}</h3>
                  <p class="mt-2 text-[14.5px] leading-relaxed text-[#8a93a6]">{item.body}</p>
                </div>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <section class="py-24 lg:py-32">
      <div class={CONTAINER}>
        <div class="max-w-3xl">
          <span class="font-mono text-[10px] font-semibold uppercase tracking-[0.28em] text-[#0891B2]/85">Buyer workflows</span>
          <h2 class="mt-4 text-[clamp(1.9rem,3.4vw,2.7rem)] font-semibold leading-[1.05] tracking-[-0.03em] text-[#0F172A]">
            Built around the client operations professional services teams ask for.
          </h2>
          <p class="mt-5 max-w-xl text-[15px] leading-relaxed text-[#8a93a6]">
            Tactas focuses on intake, qualification, document collection, proposal preparation, CRM updates,
            and supervised follow-up workflows.
          </p>
        </div>

        <div class="mt-12 grid border-y border-[#D8E1EA] sm:grid-cols-2 lg:grid-cols-3">
          {searchIntents.map((item, idx) => (
            <article class="group flex flex-col gap-3 border-t border-[#D8E1EA] px-0 py-7 transition duration-300 hover:bg-white/45 sm:border-t-0 sm:border-l sm:px-6 lg:first:border-l-0">
              <span class="font-mono text-[10px] font-semibold uppercase tracking-[0.22em] text-[#64748B]">
                {String(idx + 1).padStart(2, "0")}
              </span>
              <h3 class="text-[16px] font-medium tracking-tight text-[#0F172A]">{item.title}</h3>
              <p class="text-[14px] leading-relaxed text-[#8a93a6]">{item.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="workflows" class="py-24 lg:py-32">
      <div class={CONTAINER}>
        <div class="max-w-3xl">
          <span class="font-mono text-[10px] font-semibold uppercase tracking-[0.28em] text-[#0891B2]/85">Workflows</span>
          <h2 class="mt-4 text-[clamp(1.9rem,3.4vw,2.7rem)] font-semibold leading-[1.05] tracking-[-0.03em] text-[#0F172A]">
            Start with automation closest to revenue, delivery speed, and client experience.
          </h2>
          <p class="mt-5 max-w-xl text-[15px] leading-relaxed text-[#8a93a6]">
            Each AI agent is designed around your service lines, intake rules, approval boundaries, documents, and existing operating stack.
          </p>
        </div>

        <div class="mt-12 grid border-y border-[#D8E1EA] sm:grid-cols-2 lg:grid-cols-3">
          {workflows.map((item, idx) => {
            const Icon = item.icon;
            return (
              <article class="group flex flex-col gap-4 border-t border-[#D8E1EA] px-0 py-8 transition duration-300 hover:-translate-y-0.5 hover:bg-white/45 sm:border-t-0 sm:border-l sm:px-7 sm:py-9 sm:[&:nth-child(odd)]:border-l-0 lg:[&:nth-child(odd)]:border-l lg:[&:nth-child(3n+1)]:border-l-0">
                <div class="flex items-center justify-between">
                  <span class="flex h-10 w-10 items-center justify-center rounded-md border border-[#D8E1EA] bg-white text-[#0891B2] transition group-hover:border-[#06B6D4]/50">
                    <Icon class="h-4 w-4" stroke-width={1.6} />
                  </span>
                  <span class="font-mono text-[10px] uppercase tracking-[0.24em] text-[#64748B]">
                    {String(idx + 1).padStart(2, "0")}
                  </span>
                </div>
                <h3 class="text-[16px] font-medium tracking-tight text-[#0F172A]">{item.title}</h3>
                <p class="text-[14px] leading-relaxed text-[#8a93a6]">{item.body}</p>
              </article>
            );
          })}
        </div>
      </div>
    </section>

    <section id="integrations" class="border-y border-[#D8E1EA] bg-white py-24 lg:py-32">
      <div class={`${CONTAINER} grid gap-12 lg:grid-cols-[0.7fr_1.3fr] lg:gap-20`}>
        <div>
          <span class="font-mono text-[10px] font-semibold uppercase tracking-[0.28em] text-[#0891B2]/85">Integrations</span>
          <h2 class="mt-4 text-[clamp(1.9rem,3.4vw,2.7rem)] font-semibold leading-[1.05] tracking-[-0.03em] text-[#0F172A]">
            Connected to the tools that run client relationships and delivery.
          </h2>
          <p class="mt-5 max-w-md text-[15px] leading-relaxed text-[#8a93a6]">
            Tactas AI is built around your systems, not a generic chat widget. Agents can gather client context,
            prepare actions, and log every step.
          </p>
        </div>
        <div>
          <div class="grid grid-cols-2 gap-x-10 gap-y-0 sm:grid-cols-3">
            {integrations.map((item) => (
              <div class="group flex items-baseline gap-3 border-b border-[#D8E1EA] py-5 text-[14.5px] text-[#c8d0de] transition-colors duration-300 hover:border-[#2a3346] hover:text-[#0F172A]">
                <span class="h-1.5 w-1.5 shrink-0 rounded-full bg-[#34d399] transition-transform duration-300 group-hover:scale-125" aria-hidden="true"></span>
                {item}
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="py-24 lg:py-32">
      <div class={`${CONTAINER} grid gap-12 lg:grid-cols-[0.72fr_1.28fr] lg:gap-20`}>
        <div>
          <span class="font-mono text-[10px] font-semibold uppercase tracking-[0.28em] text-[#0891B2]/85">Example workflow</span>
          <h2 class="mt-4 text-[clamp(1.9rem,3.4vw,2.7rem)] font-semibold leading-[1.05] tracking-[-0.03em] text-[#0F172A]">
            Client intake automation that prepares the work before experts step in.
          </h2>
          <p class="mt-5 max-w-md text-[15px] leading-relaxed text-[#8a93a6]">
            The first professional services AI workflow should be easy to measure. Intake is often a strong starting point
            because missing context slows every downstream step.
          </p>
        </div>

        <div class="overflow-hidden rounded-2xl border border-[#D8E1EA] bg-white">
          {exampleWorkflow.map(([step, title, body]) => (
            <div class="grid gap-3 border-b border-[#D8E1EA] px-6 py-5 last:border-b-0 sm:grid-cols-[76px_0.75fr_1.25fr] sm:items-start">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.24em] text-[#0891B2]/85">{step}</p>
              <h3 class="text-[15px] font-medium tracking-tight text-[#0F172A]">{title}</h3>
              <p class="text-[14.5px] leading-relaxed text-[#8a93a6]">{body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="py-24 lg:py-32">
      <div class={CONTAINER}>
        <div class="max-w-3xl">
          <span class="font-mono text-[10px] font-semibold uppercase tracking-[0.28em] text-[#0891B2]/85">Before / after</span>
          <h2 class="mt-4 text-[clamp(1.9rem,3.4vw,2.7rem)] font-semibold leading-[1.05] tracking-[-0.03em] text-[#0F172A]">
            From scattered inquiries to controlled client workflow automation.
          </h2>
        </div>

        <div class="mt-12 overflow-hidden rounded-2xl border border-[#D8E1EA]">
          <div class="grid bg-white font-mono text-[10px] font-semibold uppercase tracking-[0.24em] text-[#64748B] sm:grid-cols-2">
            <div class="border-b border-[#D8E1EA] px-6 py-4 sm:border-b-0 sm:border-r">Before Tactas</div>
            <div class="px-6 py-4 text-[#0891B2]/85">After Tactas</div>
          </div>
          {beforeAfter.map(([before, after]) => (
            <div class="grid border-t border-[#D8E1EA] transition-colors duration-300 hover:bg-[#F6F8FB] sm:grid-cols-2">
              <div class="border-b border-[#D8E1EA] px-6 py-5 text-[14.5px] leading-relaxed text-[#8a93a6] sm:border-b-0 sm:border-r">{before}</div>
              <div class="flex items-baseline gap-3 px-6 py-5 text-[14.5px] leading-relaxed text-[#0F172A]">
                <Check class="mt-1 h-3.5 w-3.5 shrink-0 text-[#34d399]" stroke-width={2.5} />
                <span>{after}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="rollout" class="border-y border-[#D8E1EA] bg-white py-24 lg:py-32">
      <div class={CONTAINER}>
        <div class="max-w-3xl">
          <span class="font-mono text-[10px] font-semibold uppercase tracking-[0.28em] text-[#0891B2]/85">Rollout</span>
          <h2 class="mt-4 text-[clamp(1.9rem,3.4vw,2.7rem)] font-semibold leading-[1.05] tracking-[-0.03em] text-[#0F172A]">
            Launch one measurable client workflow first.
          </h2>
          <p class="mt-5 max-w-xl text-[15px] leading-relaxed text-[#8a93a6]">
            Keep the first deployment narrow enough to control, but important enough to prove value in response speed,
            document completion, CRM hygiene, or qualified pipeline.
          </p>
        </div>

        <ol class="mt-12 grid gap-0 border-t border-[#D8E1EA] lg:grid-cols-4 lg:border-t-0">
          {rollout.map((item, idx) => (
            <li class="relative border-b border-[#D8E1EA] py-7 transition duration-300 hover:bg-white/45 lg:border-b-0 lg:border-l lg:px-6 lg:py-0 lg:first:border-l-0">
              <div class="hidden h-px w-full bg-gradient-to-r from-transparent via-[#D8E1EA] to-transparent lg:block"></div>
              <div class="lg:pt-7">
                <div class="flex items-baseline gap-3">
                  <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.24em] text-[#0891B2]/85">{item.step}</span>
                  {idx < rollout.length - 1 ? <span class="hidden h-px flex-1 bg-[#D8E1EA] lg:block" aria-hidden="true"></span> : null}
                </div>
                <h3 class="mt-3 text-[16px] font-medium tracking-tight text-[#0F172A]">{item.title}</h3>
                <p class="mt-2 text-[13.5px] leading-relaxed text-[#8a93a6]">{item.body}</p>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <section class="py-24 lg:py-32">
      <div class={`${CONTAINER} grid gap-12 lg:grid-cols-[0.72fr_1.28fr] lg:gap-20`}>
        <div>
          <span class="font-mono text-[10px] font-semibold uppercase tracking-[0.28em] text-[#0891B2]/85">FAQ</span>
          <h2 class="mt-4 text-[clamp(1.9rem,3.4vw,2.7rem)] font-semibold leading-[1.05] tracking-[-0.03em] text-[#0F172A]">
            Practical questions before the first professional services AI workflow.
          </h2>
        </div>
        <div class="border-t border-[#D8E1EA]">
          {faq.map((item) => (
            <section class="border-b border-[#D8E1EA] py-6">
              <h3 class="text-[16px] font-medium tracking-tight text-[#0F172A]">{item.q}</h3>
              <p class="mt-2 text-[14.5px] leading-relaxed text-[#8a93a6]">{item.a}</p>
            </section>
          ))}
        </div>
      </div>
    </section>

    <section id="contact" class="border-t border-[#D8E1EA] bg-white py-24 lg:py-32">
      <div class={`${CONTAINER} grid gap-12 lg:grid-cols-[0.85fr_1.15fr] lg:gap-20`}>
        <div>
          <span class="font-mono text-[10px] font-semibold uppercase tracking-[0.28em] text-[#0891B2]/85">Contact</span>
          <h2 class="mt-4 text-[clamp(1.9rem,3.4vw,2.7rem)] font-semibold leading-[1.05] tracking-[-0.03em] text-[#0F172A]">
            Book a client task review.
          </h2>
          <p class="mt-5 max-w-md text-[15px] leading-relaxed text-[#8a93a6]">
            Share your service line, current systems, inquiry volume, and the client workflow you want to improve first.
            We will help define a supervised workflow with clear ownership and review rules.
          </p>
          <div class="mt-8 grid gap-4 text-[14px] text-[#c8d0de]">
            {reviewTakeaways.map((text, index) => {
              const Icon = index === 0 ? PackageCheck : index === 1 ? Search : ShieldCheck;
              return (
                <div class="flex items-start gap-3">
                  <Icon class="mt-0.5 h-4 w-4 shrink-0 text-[#0891B2]" stroke-width={1.6} />
                  <span>{text}</span>
                </div>
              );
            })}
          </div>
          <div class="mt-8 flex items-center gap-3 text-[14px] text-[#c8d0de]">
            <Mail class="h-4 w-4 text-[#0891B2]" stroke-width={1.6} />
            <a href={`mailto:${brandEmail}`} class="border-b border-[#D8E1EA] pb-0.5 transition hover:border-[#67e8f9]/60 hover:text-[#0F172A]">
              {brandEmail}
            </a>
          </div>
        </div>
        <form
          id="professional-services-inquiry-form"
          class="rounded-2xl border border-[#D8E1EA] bg-gradient-to-b from-[#0c111c] to-[#0a0e17] p-6 shadow-[0_30px_90px_-60px_rgba(0,0,0,0.9)] sm:p-7"
        >
          <div class="mb-6 flex items-center gap-2.5">
            <span class="flex h-1.5 w-1.5 rounded-full bg-[#34d399] pulse-dot" aria-hidden="true"></span>
            <span class="font-mono text-[10px] font-semibold uppercase tracking-[0.24em] text-[#c8d0de]">
              client task review
            </span>
          </div>

          <div class="grid gap-4 sm:grid-cols-2">
            <label class="grid gap-1.5 text-[11px] font-medium uppercase tracking-[0.16em] text-[#8a93a6]">
              Name
              <input required name="name" class="h-11 w-full rounded-md border border-[#D8E1EA] bg-white px-3.5 text-[14px] text-[#0F172A] outline-none transition placeholder:text-[#64748B] focus:border-[#06B6D4] focus:ring-2 focus:ring-[#06B6D4]/15" placeholder="Your name" />
            </label>
            <label class="grid gap-1.5 text-[11px] font-medium uppercase tracking-[0.16em] text-[#8a93a6]">
              Work email
              <input required type="email" name="email" class="h-11 w-full rounded-md border border-[#D8E1EA] bg-white px-3.5 text-[14px] text-[#0F172A] outline-none transition placeholder:text-[#64748B] focus:border-[#06B6D4] focus:ring-2 focus:ring-[#06B6D4]/15" placeholder="you@firm.com" />
            </label>
          </div>

          <div class="mt-4 grid gap-4 sm:grid-cols-2">
            <label class="grid gap-1.5 text-[11px] font-medium uppercase tracking-[0.16em] text-[#8a93a6]">
              Company / firm
              <input required name="company" class="h-11 w-full rounded-md border border-[#D8E1EA] bg-white px-3.5 text-[14px] text-[#0F172A] outline-none transition placeholder:text-[#64748B] focus:border-[#06B6D4] focus:ring-2 focus:ring-[#06B6D4]/15" placeholder="Firm name" />
            </label>
            <label class="grid gap-1.5 text-[11px] font-medium uppercase tracking-[0.16em] text-[#8a93a6]">
              Service type
              <input name="service" class="h-11 w-full rounded-md border border-[#D8E1EA] bg-white px-3.5 text-[14px] text-[#0F172A] outline-none transition placeholder:text-[#64748B] focus:border-[#06B6D4] focus:ring-2 focus:ring-[#06B6D4]/15" placeholder="Legal, accounting, consulting, agency..." />
            </label>
          </div>

          <label class="mt-4 grid gap-1.5 text-[11px] font-medium uppercase tracking-[0.16em] text-[#8a93a6]">
            Workflow to improve
            <textarea required name="workflow" class="min-h-28 w-full rounded-md border border-[#D8E1EA] bg-white px-3.5 py-3 text-[14px] text-[#0F172A] outline-none transition placeholder:text-[#64748B] focus:border-[#06B6D4] focus:ring-2 focus:ring-[#06B6D4]/15" placeholder="Client intake, document collection, proposal prep, lead routing, CRM updates, follow-up..."></textarea>
          </label>

          <label class="mt-4 grid gap-1.5 text-[11px] font-medium uppercase tracking-[0.16em] text-[#8a93a6]">
            Monthly inquiries / matters / client requests
            <input name="volume" class="h-11 w-full rounded-md border border-[#D8E1EA] bg-white px-3.5 text-[14px] text-[#0F172A] outline-none transition placeholder:text-[#64748B] focus:border-[#06B6D4] focus:ring-2 focus:ring-[#06B6D4]/15" placeholder="e.g. 300 inquiries / month" />
          </label>

          <button type="submit" class="group mt-6 inline-flex h-12 w-full items-center justify-center rounded-md bg-[#22d3ee] px-7 text-[13px] font-semibold tracking-tight text-[#07090f] transition hover:bg-[#67e8f9]">
            Send client workflow
            <Send class="ml-2 h-4 w-4 transition group-hover:translate-x-0.5" />
          </button>
          <p id="professional-services-form-status" class="mt-3 text-center text-[12px] text-[#64748B]">
            Prefer email? {brandEmail}
          </p>
        </form>
      </div>
    </section>
  </main>
</div>

<script define:vars={{ brandEmail }} is:inline>
  const professionalServicesForm = document.getElementById("professional-services-inquiry-form");
  const professionalServicesStatus = document.getElementById("professional-services-form-status");
  professionalServicesForm?.addEventListener("submit", (event) => {
    event.preventDefault();
    const form = new FormData(professionalServicesForm);
    const company = String(form.get("company") || "").trim() || "Professional services firm";
    const subject = encodeURIComponent(`Professional services workflow inquiry - ${company}`);
    const body = encodeURIComponent(
      [
        `Name: ${String(form.get("name") || "")}`,
        `Work email: ${String(form.get("email") || "")}`,
        `Company / firm: ${String(form.get("company") || "")}`,
        `Service type: ${String(form.get("service") || "")}`,
        "",
        "Workflow to improve:",
        String(form.get("workflow") || ""),
        "",
        "Monthly inquiries / matters / client requests:",
        String(form.get("volume") || ""),
      ].join("\n"),
    );
    if (professionalServicesStatus) {
      professionalServicesStatus.textContent = "Opening your email client with the workflow details.";
    }
    window.location.href = `mailto:${brandEmail}?subject=${subject}&body=${body}`;
  });
</script>
